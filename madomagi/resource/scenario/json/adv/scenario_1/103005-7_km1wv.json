{"story":{"group_1":[{"autoTurnLast":1,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103701,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1,"turnChangeOut":"fadeOut","turnChangeOutTime":2},{"chara":[{"eyeClose":0,"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-1"}],"nameCenter":"那由他","textCenter":"…这里是"},{"chara":[{"id":103701,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-2"}],"nameCenter":"那由他","textCenter":"（好像在哪里见过…）"},{"autoTurnLast":0.2,"chara":[{"id":103701,"pos":0}],"textClear":1},{"bgm":"bgm23_folklore02","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":802401,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-3"}],"nameRight":"太助","textRight":"你醒了"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103701,"motion":400,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-4"}],"nameLeft":"那由他","textLeft":"爸爸！"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-5"}],"nameRight":"太助","textRight":"拉比，还有大家@那由他醒了"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103701},{"effect":"fadeout","id":802401}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-6"},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"motion":0,"pos":2}],"nameLeft":"拉比","textLeft":"您的身体状况如何？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103701,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-7"}],"nameLeft":"那由他","textLeft":"诶？@并没有什么奇怪的地方哦"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103401,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-8"}],"nameRight":"旭","textRight":"那真是太好了"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-9"}],"nameRight":"旭","textRight":"因为粗暴地让你昏迷了，@所以我们都很担心"},{"chara":[{"id":103701,"motion":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-10"}],"nameLeft":"那由他","textLeft":"粗暴地…"},{"chara":[{"id":103701,"motion":400,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-11"}],"nameLeft":"那由他","textLeft":"啊！@山中小屋里的事不是梦…"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-12"}],"nameRight":"拉比","textRight":"并不是@您记忆中的事应该都是真的"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-13"}],"nameLeft":"那由他","textLeft":"那么，我被学生们@拐走并盘问的事也全都是…"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-14"}],"nameLeft":"那由他","textLeft":"那，这里又是哪里？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103501,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-15"}],"nameRight":"亚历山德拉","textRight":"大地的摇篮@是汤国温泉的一家民宿"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103701,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-16"}],"nameLeft":"那由他","textLeft":"啊，是我之前住的那家旅馆"},{"chara":[{"id":103501,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-17"}],"nameRight":"亚历山德拉","textRight":"并且，也是拉比小姐的家"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-18"}],"nameLeft":"那由他","textLeft":"哼嗯…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103701,"motion":400,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-19"}],"nameLeft":"那由他","textBg":"shout","textLeft":"[chara:103701:effect_emotion_surprise_0][se:7226_shock]诶诶诶诶诶！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103301,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-20"},{"id":103701}],"nameRight":"拉比","textRight":"让你见怪了"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-21"}],"nameLeft":"那由他","textLeft":"重点才不是那个！@怪不得饭菜的味道这么像！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-22"}],"nameLeft":"那由他","textLeft":"像这样被揭露真相之后@就越来越有实感了…"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-23"}],"nameLeft":"那由他","textLeft":"大家都对我隐瞒了很多事情@而我一直都在和空气搏斗…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103601,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-24"}],"nameRight":"丽","textRight":"啊呜呜，@对此我们很抱歉…"},{"chara":[{"id":103601,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-25"},{"id":103701,"motion":0}],"nameRight":"丽","textRight":"但是，这都是因为@教授为那由他小姐着想的父母心"},{"chara":[{"id":103601,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-26"}],"nameRight":"丽","textRight":"我们只是配合他@隐瞒了起来而已…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-27"}],"nameLeft":"那由他","textLeft":"…也就是说，以前我来这里的时候@说爸爸的预约取消了"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-28"}],"nameLeft":"那由他","textLeft":"也是骗人的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":802401,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-29"}],"nameRight":"太助","textRight":"确实是这样…"},{"chara":[{"id":103701,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-30"}],"nameLeft":"那由他","textLeft":"…………"},{"autoTurnLast":0.5,"bg":"bg_adv_21461.jpg","turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"太助","narration":"「但是，那由他应该也记得@在编写下卷的过程中@我的身体状况慢慢恶化@变得无法继续执笔了」","narrationCoverOpacity":150,"narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-31"},{"narration":"「所以