ion":0,"pos":0}]},{"autoTurnLast":0.2,"bg":"bg_adv_53011.jpg","turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"太助","narration":"「然后，我发现在这座城市里@至少在学生们之间@魔法少女是广为人知的存在」","narrationCoverOpacity":150,"narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-39"},{"narration":"「虽说并不完全，但那正是@我想要达成的目标成型的姿态」","voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-40"},{"narration":"「但是，那对魔法少女而言@却是人间地狱」","voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-41"},{"autoTurnLast":0.2,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"face":"mtn_ex_052.exp3.json","id":103701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":802401,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-7-42"}],"nameLeft":"那由他","textLeft":"体会了人间地狱的@莫非就是拉比她们吗？","turnChangeOut":"fadeOut"},{"autoTurnLast":2,"turnChangeIn":"fadeIn"}]},"version":3}