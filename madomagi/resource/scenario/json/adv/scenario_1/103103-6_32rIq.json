{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103800,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm05_event06","chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-1"}],"nameNarration":"御影","narration":"「嗯，就是桃碳说的那样」","narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-2"}],"narration":"「咪想对姐姐和七夜碳证明@就算不去实现毁灭神滨市的愿望也没关系」"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-3"}],"narration":"「所以，咪和大家一直在努力@让“友好相处大作战”成功！」"},{"autoTurnLast":0.8,"bg":"bg_adv_12041.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101800,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103800,"motion":100,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-4"}],"nameRight":"御影","textRight":"呐，姐姐@我有件事想拜托你","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":101800,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-5"}],"nameLeft":"月夜","textLeft":"是、是什么呢…"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-6"}],"nameRight":"御影","textRight":"我想让东西的大家和好，@让姐姐安心"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103800,"motion":200,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-7"}],"nameRight":"御影","textRight":"所以，希望你能来帮忙！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101800,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-8"}],"nameLeft":"月夜","textLeft":"还、还真是突然呢…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103800,"motion":400,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-9"}],"nameRight":"御影","textRight":"呐，拜托了！"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-10"}],"nameRight":"御影","textRight":"咪想把姐姐@从Meo-Magius带回来！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101800,"motion":100,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-11"}],"nameLeft":"月夜","textLeft":"…虽然不是很懂，@但把她带回来的目的是一致的…"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-12"}],"nameLeft":"月夜","textLeft":"我也有小月咲的事，@所以请和我讲讲详情吧"},{"autoTurnLast":1.5,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101800,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103800,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story06","chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-13"}],"nameLeft":"月夜","textLeft":"我明白情况了","turnChangeOut":"fadeOut"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-14"}],"nameLeft":"月夜","textLeft":"不仅累积了好几重像选举@和粗点心店的事这样的不安"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-15"}],"nameLeft":"月夜","textLeft":"御魂小姐还开始相信@自己期望的毁灭一定会实现了…"},{"chara":[{"id":101800,"motion":100,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-16"}],"nameLeft":"月夜","textLeft":"而十七夜小姐则是为了@让毁灭对未来更有意义"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-17"}],"nameLeft":"月夜","textLeft":"而试图亲自成为毁灭的当事人，@以及大众的敌人…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-18"}],"nameLeft":"月夜","textLeft":"因为她觉得那会成为@让东西的人们团结起来的契机…"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103800,"motion":400,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-19"}],"nameRight":"御影","textRight":"大概就是这样！"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":101800,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-20"}],"nameLeft":"月夜","textLeft":"嗯～…@按照小御影的说法"},{"chara":[{"id":101800,"motion":200,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-21"}],"nameLeft":"月夜","textLeft":"御魂小姐好像不知道小御影"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-22"}],"nameLeft":"月夜","textLeft":"和在明日屋欺负过你的孩子@和好的事情吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103800,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-23"}],"nameRight":"御影","textRight":"嗯，七夜碳应该也不知道"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101800,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-24"}],"nameLeft":"月夜","textLeft":"不过，@我也不知道她们改变的原因…"},{"chara":[{"id":103800,"motion":300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-25"}],"nameRight":"御影","textRight":"姐姐好像是@和自己的愿望有关系…"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-26"}],"nameRight":"御影","textRight":"但是，因为七夜碳@比姐姐更相信人类"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-27"}],"nameRight":"御影","textRight":"所以要不是有很痛苦的事情@应该不会发生那么大的变化…"},{"chara":[{"id":101800,"motion":1,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-28"}],"nameLeft":"月夜","textLeft":"…让她不再信任神滨市的人，@并感受到敌意的事情…"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-29"}],"nameLeft":"月夜","textLeft":"比如受到了西边的人的攻击，@或者受到了伤害吗…？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103800,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-30"}],"nameRight":"御影","textRight":"嗯，所以咪想做相反的事情"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-31"}],"nameLeft":"月夜","textLeft":"相反的事情指的是？"},{"chara":[{"id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-32"}],"nameRight":"御影","textRight":"咪要证明西边的人和东边的人@能友好相处，并且团结一致"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103800,"motion":200,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-33"}],"nameRight":"御影","textRight":"[chara:103800:effect_emotion_joy_0][se:7222_happy]就是「友好相处大作战」哦！！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101800,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-34"}],"nameLeft":"月夜","textLeft":"原、原来如此…"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-35"}],"nameLeft":"月夜","textLeft":"虽然能明白你的意思"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-36"}],"nameLeft":"月夜","textLeft":"但要由我们来实现@花费许多年都没能成功的事情"},{"chara":[{"id":101800,"motion":200,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-37"}],"nameLeft":"月夜","textLeft":"可是无谋中的无谋啊！"},{"chara":[{"id":103800,"motion":400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-38"}],"nameRight":"御影","textRight":"放弃可不好哦，姐姐！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-39"}],"nameRight":"御影","textRight":"直到最后都不放弃希望，一直努力@这才是咪我们魔法少女吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101800,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-40"}],"nameLeft":"月夜","textLeft":"呜…@一看到这么天真无邪的笑容…"},{"chara":[{"id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-41"},{"id":103800,"motion":0}],"nameLeft":"月夜","textLeft":"…我知道了"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101800,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-42"}],"nameLeft":"月夜","textLeft":"就让我，天音月夜@也加入你的计划吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":101800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-43"}],"nameLeft":"月夜","textLeft":"…所以，@你已经有主意了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-6-44"}],"nameRight":"御影","textRight":"咪知道的@东西两边的人都会去的地方"},{"autoTurnLast":1,"chara":[{"id":103800,"motion":100,"voiceFull":"fullvoice/section_103103/vo_full_103103-6-45"}],"nameRight":"御影","textRight":"就是明日屋了！@嘻嘻"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103800}]},{"autoTurnLast":2,"bgm":"stop","turnChangeIn":"fadeIn","voiceFullStop":"fullvoice/section_103103/vo_full_103103-6-45"}]},"version":3}