103-11-9"}],"nameLeft":"ももこ","textLeft":"也太耿直了…！"},{"bgm":"bgm05_event05","chara":[{"id":800800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-10"}],"nameCenter":"市長","surround":"stop","textCenter":"那身校服…@是大东的孩子、吧…"},{"chara":[{"id":800800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-11"}],"nameCenter":"市長","textCenter":"对不起"},{"chara":[{"id":800800,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-12"}],"nameCenter":"市長","textCenter":"你们一定因为我受了苦吧…@请原谅我…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103801,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-13"}],"nameRight":"御影","textRight":"诶、诶诶…？"},{"autoTurnLast":0.3,"chara":[{"effect":"fadeout","id":103801},{"effect":"fadeout","id":101001},{"effect":"fadeout","id":800800}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101101,"motion":200,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-14"},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100901,"motion":1,"pos":0}],"nameRight":"かえで","surround":"7202_telepathy","textRight":"呐呐，小玲奈","turnEffect":"ef_adv_02"},{"chara":[{"id":101101,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-15"}],"nameRight":"かえで","textRight":"关于Neo-Magius@干涉并搅乱了市长选举的那件事"},{"chara":[{"id":101101,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-16"}],"nameRight":"かえで","textRight":"这莫非是…"},{"chara":[{"id":100901,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-17"}],"nameLeft":"レナ","textLeft":"嗯，可能是@被施加的暗示解开了"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100901},{"effect":"fadeout","id":101101}],"surround":"stop","textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800800,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-11-18"},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103801,"motion":0,"pos":2}],"nameLeft":"市長","textLeft":"我自己也不是很懂"},{"chara":[{"id":800800,"voiceFul