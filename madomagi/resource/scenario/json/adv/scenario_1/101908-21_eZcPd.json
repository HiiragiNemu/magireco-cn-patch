    "narrationCoverOpacity": 110.0,
    "narrationEffect": "in",
    "turnChangeOut": "fadeOut"
   },
   {
    "narration": "它真正的目的是“[textRed:拯救宇宙]”@拯救这个我们生活在其中的宇宙",
    "voiceFull": "fullvoice/section_101970/vo_full_101970-1-11"
