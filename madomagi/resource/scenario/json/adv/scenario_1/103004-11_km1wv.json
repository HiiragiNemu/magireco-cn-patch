4"}],"nameLeft":"千春","textLeft":"所谓的坏事，@是因为感到痛苦才会去做的"},{"chara":[{"id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-15"}],"nameLeft":"千春","textLeft":"而痛苦@则是从悲伤和愤怒发展出来的"},{"chara":[{"eyeClose":1,"id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-16"}],"nameLeft":"千春","textLeft":"并且会让其他人也陷入痛苦"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":102602,"motion":200,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-17"}],"nameLeft":"千春","textLeft":"而阻止这一切的方法@就是温柔地去治愈他人"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102702,"lipSynch":1,"motion":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-18"}],"nameRight":"沙绪","textRight":"——！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102702,"lipSynch":1,"motion":100,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-19"}],"nameRight":"沙绪","textRight":"如果说@感到痛苦才会作恶的话"},{"chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-20"}],"nameRight":"沙绪","textRight":"那么，@这只老虎才是最痛苦的吗…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102602,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-21"}],"nameLeft":"千春","textLeft":"从最开始，@老虎小姐就在在寻求救赎哦"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-11-22"}],"nameLeft":"千春","textLeft":"所以，我会温柔地对待它@因为我相信它的心原本也是善良的"},{"autoTurnLast":0.2,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102702,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102602,"motion":1,"pos":0},{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":102502,"motion":0,"pos":1}],"deleteArmatureList":[1,2,3],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102702,"motion":300,"voiceFullAuto":"fullvo