{"story":{"group_1":[{"autoTurnLast":2,"bg":"bg_adv_21563.jpg","chara":[{"cheek":0,"face":"mtn_ex_120.exp3.json","id":101601,"motion":0,"pos":0},{"cheek":0,"eyeClose":0,"face":"mtn_ex_101.exp3.json","id":101701,"motion":300,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"bgm":"bgm24_story07","chara":[{"id":101601,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-1"}],"nameLeft":"十七夜","textLeft":"八云，@我们就去破坏公主的机关吧","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":101701,"motion":0,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-2"}],"nameRight":"御魂","textRight":"嗯，因为现在的我们@也只能做到这些了"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100301,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-3"}],"nameLeft":"鶴乃","textLeft":"你们不和我们一起来吗？"},{"chara":[{"eyeClose":0,"id":101701,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-4"}],"nameRight":"御魂","textRight":"因为我们还有其他事要解决"},{"chara":[{"cheek":0,"face":"mtn_ex_132.exp3.json","id":101601,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-5"}],"nameRight":"十七夜","textRight":"而且，现在@我们无法和由比君你们并肩行动"},{"autoTurnLast":1,"bg":"bg_adv_20258.jpg","chara":[{"cheek":0,"face":"mtn_ex_130.exp3.json","id":101601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_130.exp3.json","id":101701,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101601,"motion":300,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-6"}],"nameLeft":"十七夜","textLeft":"那个时候的感觉@果然是正确的…","turnChangeOut":"fadeOut"},{"autoTurnLast":1,"bg":"black","item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","posX":250,"posY":-60,"scale":1.5,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"十七夜","narration":"十七夜―@是啊…","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":35,"narrationLineSpace":20,"turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-7"},{"narration":"―十七夜―@就像我因为东西的事情而积累起了悲伤一样@许多人也因为这件事十分难过…","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-8"},{"narration":"―十七夜―@明明如此，我却顺从自己的悲叹@无视了其他人心怀的悲叹…","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-9"},{"autoTurnLast":1,"bg":"bg_adv_20258.jpg","chara":[{"cheek":0,"face":"mtn_ex_130.exp3.json","id":101601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_132.exp3.json","id":101701,"motion":1,"pos":2}],"item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101701,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-10"}],"nameRight":"御魂","textRight":"嗯…无论得到怎样的喜悦…@都会被悲伤覆盖…","turnChangeOut":"fadeOut"},{"autoTurnLast":1,"bg":"black","item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","posX":-240,"posY":-60,"scale":1.5,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"御影","narration":"—御影—@就算这样，给予毁灭的姐姐@看起来还是很痛苦哦？","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":10,"narrationLineSpace":20,"turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-11"},{"narration":"—御影—@那么，还是不要去痛苦的那边比较好","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-12"},{"narration":"—御影—@到那个时候再去想就可以了","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-13"},{"nameNarration":"桃子","narration":"—桃子—@是啊，到了真正要毁灭的时候@我也会和你一起拼命挣扎的","voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-14"},{"autoTurnLast":1,"bg":"bg_adv_20258.jpg","chara":[{"cheek":0,"face":"mtn_ex_130.exp3.json","id":101601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_131.exp3.json","id":101701,"motion":0,"pos":2}],"item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101701,"motion":300,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-15"}],"nameRight":"御魂","textRight":"不行…","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":101701,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-16"}],"nameRight":"御魂","textRight":"咪的话语，桃子的话语…@大家的话语都要被覆盖掉了…"},{"chara":[{"cheek":0,"face":"mtn_ex_132.exp3.json","id":101601,"motion":300,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-17"}],"nameLeft":"十七夜","textLeft":"这就是为了不被[textYellow:心魔]所囚禁，@让灵魂和悲伤融为一体的结果吗…"},{"chara":[{"cheek":0,"face":"mtn_ex_133.exp3.json","id":101601,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-18"}],"nameLeft":"十七夜","textLeft":"呵…"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_130.exp3.json","id":101601,"motion":100,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-19"}],"nameLeft":"十七夜","textLeft":"我原本就打算在阻止公主的机关时@献出自己的生命…"},{"chara":[{"id":101601,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-20"}],"nameLeft":"十七夜","textLeft":"如果能不给大家添麻烦地变成魔女@就没有任何问题了…"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_133.exp3.json","id":101601,"motion":0,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-21"}],"nameLeft":"十七夜","textLeft":"八云觉得这里比较好吧…？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_130.exp3.json","id":101701,"motion":0,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-22"}],"nameRight":"御魂","textRight":"嗯…"},{"chara":[{"id":101701,"motion":100,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-23"}],"nameRight":"御魂","textRight":"因为，这里是过去的巫被仇恨支配@变成了魔女的地方…"},{"chara":[{"id":101701,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-24"}],"nameRight":"御魂","textRight":"和同样无法从仇恨中逃离@步向死亡的我们十分相称"},{"chara":[{"id":101701,"motion":200,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-25"}],"nameRight":"御魂","textRight":"但是，必须想办法@把[textYellow:心魔]石交给她们…"},{"chara":[{"cheek":0,"face":"mtn_ex_132.exp3.json","id":101601,"motion":400,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-26"}],"nameLeft":"十七夜","textLeft":"…[textYellow:心魔]啊@在我们力尽之后"},{"chara":[{"id":101601,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-27"}],"nameLeft":"十七夜","textLeft":"能请你去环君和七海那里吗…"},{"chara":[{"cheek":0,"face":"mtn_ex_100.exp3.json","id":101601,"motion":300,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-28"}],"nameLeft":"十七夜","textLeft":"吃掉变成了魔女的我和八云也无妨"},{"chara":[{"id":101601,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-29"}],"nameLeft":"十七夜","textLeft":"自由使用留下的身体也无妨"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_132.exp3.json","id":101601,"motion":0,"voiceFullAuto":"fullvoice/section_103201/vo_full_103201-9-30"}],"nameLeft":"十七夜","textLeft":"所以，求求你@在那只白色狸猫夺走一切之前…"},{"autoTurnLast":2,"turnChangeIn":"fadeIn"}]},"version":3}