{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","bgm":"bgm01_battle05","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.4,"flashEffect":"flashWhite1","surround":"3057A06"},{"autoTurnLast":0.8,"flashEffect":"flashWhite2","surround":"3057A10"},{"autoTurnLast":0.5,"item":[{"path":"resource/scenario/img/part2_chapter11/103303_tsuyu_chizuru_in.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"whiteIn"},{"nameNarration":"露","narration":"―露―@为什么你加入了阵列…！？","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":35,"narrationLineSpace":20,"surround":"7202_telepathy","turnChangeOut":"whiteOut","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-1"},{"nameNarration":"千鹤","narration":"―千鹤―@就算装装样子也好@要是不加入会很麻烦的","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-2"},{"nameNarration":"露","narration":"―露―@我也只是象征性地站在这里@你不是真的准备战斗真是太好了…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-3"},{"narration":"―露―@不过，东边到底是什么意思…？","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-4"},{"narration":"―露―@不仅撕坏了信札@居然还潜入城内，企图暗害父亲","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-5"},{"nameNarration":"千鹤","narration":"―千鹤―@我也不知道啊…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-6"},{"narration":"―千鹤―@我也知道老爸很重视一族的羁绊@但他又不惜又把伙伴送上战场，让他们丧命","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-7"},{"narration":"―千鹤―@说实话，我觉得很矛盾…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-8"},{"narration":"―千鹤―@即便如此，老爸还是觉得@战斗比生命还重要","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-9"},{"nameNarration":"露","narration":"―露―@我的父亲也只是忧虑着水名的未来@才打算先发制人而已…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-10"},{"narration":"―露―@但是，我觉得为此而夺走@对他人来说比生命还重要的东西是错误的","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-11"},{"nameNarration":"千鹤","narration":"―千鹤―@明明好不容易才抓住了希望，得到了救赎@为什么要被老爸他们个人的想法毁掉啊…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-12"},{"narration":"―千鹤―@这也太让人难过了…","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-13"},{"autoTurnLast":0.2,"bg":"bg_adv_20751.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104500,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104600,"motion":0,"pos":2}],"narrationEffect":"out","surround":"stop","turnChangeIn":"rollInFast","turnEffect":"stop"},{"chara":[{"id":104500,"motion":300,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-14"}],"nameLeft":"露","surround":"7202_telepathy","textLeft":"对不起，千鹤","turnChangeOut":"rollOutFast","turnEffect":"ef_adv_02"},{"chara":[{"id":104500,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-15"}],"nameLeft":"露","textLeft":"我在心中的某处@还以为你背叛了自己…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104600,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-16"}],"nameRight":"千鹤","textRight":"真过分啊@怎么可能呢"},{"chara":[{"id":104500,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-17"}],"nameLeft":"露","textLeft":"也是啊…"},{"chara":[{"id":104500,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-18"}],"nameLeft":"露","textLeft":"因为一直发生不好的事，@我好像也有点疑神疑鬼了"},{"chara":[{"id":104500,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-19"}],"nameLeft":"露","textLeft":"请原谅我，千鹤"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104600,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-20"}],"nameRight":"千鹤","textRight":"我也没生气"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104600,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-21"}],"nameRight":"千鹤","textRight":"而且，我又不是水名的同伴@而是彻头彻尾的露的同伴"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104500,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-22"}],"nameLeft":"露","textLeft":"千鹤"},{"chara":[{"id":104600,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-23"}],"nameRight":"千鹤","textRight":"所以，我有个想法"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104500,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-24"}],"nameLeft":"露","textLeft":"什么？"},{"chara":[{"id":104600,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-25"}],"nameRight":"千鹤","textRight":"这次就靠我们之间的冲突@来让他们两方收兵吧"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104600,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-26"}],"nameRight":"千鹤","textRight":"如果，老爸也还是要@遵从信念，让这种事情重演的话"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104600,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-27"}],"nameRight":"千鹤","textRight":"下次，就强行让他们@服从我们两个的信念吧"},{"chara":[{"id":104500,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-28"}],"nameLeft":"露","textLeft":"也就是说…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104500,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-29"}],"nameLeft":"露","textLeft":"要背叛父亲吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104600,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-30"}],"nameRight":"千鹤","textRight":"对，东西的战神子@以一骑当千的强大为傲"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104600,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-31"}],"nameRight":"千鹤","textRight":"如果我们能够联手，@老爸他们也肯定也敌不过吧"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104500,"motion":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-32"}],"nameLeft":"露","textLeft":"也就是说，@我们要成为连结东西的楔子吧"},{"chara":[{"id":104600,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-33"}],"nameRight":"千鹤","textRight":"怎么样？"},{"chara":[{"id":104500,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-10-34"}],"nameLeft":"露","textLeft":"嗯，这主意不错"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104600,"mo