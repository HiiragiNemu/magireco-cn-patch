{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102702,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102602,"motion":0,"pos":0}],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story08","chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-1"}],"nameNarration":"沙绪","narration":"「小乌龟和小鸟遇见了@从被大雪覆盖的深山中来到这里的老虎@它的篮子里装着大家种植的蔬菜、保存起来的肉@和在温暖的鸡舍里生下来的鸡蛋」","narrationCoverOpacity":100,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-2"}],"nameNarration":"千春","narration":"「小乌龟和小鸟被惊呆了，放跑了老虎@但在那之后，老虎提出了要在镇上工作」"},{"chara":[{"id":102702,"motion":100,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-3"}],"nameNarration":"沙绪","narration":"「但是，所有动物在冬天都很闲@所以没有能给老虎做的工作」"},{"chara":[{"id":102602,"motion":200,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-4"}],"nameNarration":"千春","narration":"「渐渐地，老虎开始每天出现在镇上@一点点地偷走了镇里储存的食物」"},{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3003_act_stage.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_50016.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102502,"motion":0,"pos":1}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":102502,"lipSynch":0,"motion":300,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-5"}],"nameCenter":"静香","textCenter":"（我又偷了东西…）","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"bg":"bg_adv_19305.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102502,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":801600,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":102502,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-6"}],"nameLeft":"静香","textLeft":"怎么样，好吃吗…？","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801600,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-7"}],"nameRight":"","textRight":"嗯，谢谢姐姐@工作还顺利吗？"},{"chara":[{"id":102502,"motion":300,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-8"}],"nameLeft":"静香","textLeft":"嗯、嗯…直到春天@他们好像都会让我在那里工作"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":801600,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-9"}],"nameRight":"","textRight":"太好了"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102502,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-10"}],"nameLeft":"静香","textLeft":"是啊，大家都很温柔@真是帮大忙了"},{"autoTurnLast":0.2,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102702,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102602,"motion":0,"pos":0}],"deleteArmatureList":[1],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102702,"motion":100,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-11"}],"nameNarration":"沙绪","narration":"「但是，镇上的人们渐渐注意到@自己的食物正在减少@并终于发现了那是老虎干的好事」","narrationCoverOpacity":100,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":102602,"motion":300,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-12"}],"nameNarration":"千春","narration":"「老虎终于被抓住了@它被镇上的人严厉地惩罚了一番@遍体鳞伤，连动都动不了了」"},{"chara":[{"id":102702,"motion":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-13"}],"nameNarration":"沙绪","narration":"「在寒意尚未缓和的深冬@老虎被人们扔在了镇上@身体积满了雪，也被冻僵了」"},{"armatureList":[{"animation":["action"],"armatureId":2,"filePath":"resource/image_native/effect/story/general/3003_act_stage.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_50016.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102502,"motion":0,"pos":1}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"armatureList":[{"animation":["action"],"armatureId":3,"filePath":"resource/image_native/effect/story/general/3009_blizzard.ExportJson","zOrder":"charaFront"},{"animation":["action"],"armatureId":4,"filePath":"resource/image_native/effect/story/general/6005_blizzard.ExportJson","zOrder":"bgFront"}],"chara":[{"id":102502,"lipSynch":0,"motion":300,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-14"}],"nameCenter":"静香","textCenter":"（我会就这么死去吗…）","turnChangeOut":"fadeOut"},{"chara":[{"id":102502,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-15"}],"nameCenter":"静香","textCenter":"（那孩子还小，没办法工作…@也没办法一个人狩猎…）"},{"chara":[{"cheek":1,"eyeClose":1,"id":102502,"lipSynch":1,"tear":1,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-16"}],"nameCenter":"静香","textCenter":"对不起@我真是个没用的姐姐…"},{"autoTurnLast":0.2,"chara":[{"id":102502,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102702,"lipSynch":0,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-17"}],"nameRight":"沙绪","textRight":"…………"},{"chara":[{"eyeClose":0,"id":102502,"motion":200,"tear":1,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-18"}],"nameLeft":"静香","textLeft":"拜托了…救救我吧…"},{"chara":[{"id":102502,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-19"}],"nameLeft":"静香","textLeft":"我会道歉，不会找任何借口…@到了春天，也会好好偿还的…"},{"chara":[{"id":102502,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-20"}],"nameLeft":"静香","textLeft":"所以，请你背着我，@把我搬到暖和的地方…"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":102702,"lipSynch":1,"motion":100,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-21"}],"nameRight":"沙绪","textRight":"你嘴上是这么说，@但肯定还在盘算再次偷走食物吧"},{"chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-22"}],"nameRight":"沙绪","textRight":"虽然没有人受重伤，@但确实有人被你撞飞过"},{"autoTurnLast":3,"chara":[{"id":102702,"voiceFull":"fullvoice/section_103004/vo_full_103004-10-23"}],"enableSkipAutoTurn":1,"nameRight":"沙绪","textRight":"不知道你恢复之后会做出什么事…@我没办法相信你…"},{"chara":[{"id":102702,"motion":0}]},{"chara":[{"id":102502,"motion":300,"tear":1,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-24","voiceFullStop":"fullvoice/section_103004/vo_full_103004-10-23"}],"enableSkipAutoTurn":0,"nameLeft":"静香","textLeft":"…请不要说这种话"},{"chara":[{"id":102702,"motion":200,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-25"}],"nameRight":"沙绪","textRight":"说到底，@恶人真的有必要拯救吗…？"},{"chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-26"}],"nameRight":"沙绪","textRight":"我觉得@恶人没有必要被拯救…"},{"chara":[{"id":102702,"motion":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-27"}],"nameRight":"沙绪","textRight":"都是自作自受…"},{"chara":[{"cheek":2,"eyeClose":1,"id":102502,"tear":1,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-10-28"}],"nameLeft":"静香","textLeft":"唔…呜呜、呜…"},{"autoTurnLast":2,"bgm":"stop","deleteArmatureList":[2,3,4],"turnChangeIn":"fadeIn"}]},"version":3}