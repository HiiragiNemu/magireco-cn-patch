{"story":{"group_1":[{"autoTurnLast":0.1,"bg":"black","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":1,"bg":"bg_adv_13131.jpg","turnChangeIn":"rollInLogo_PB"},{"autoTurnLast":2.5,"turnChangeOut":"rollOutLogo_Union"},{"autoTurnLast":0.5,"bg":"bg_adv_13141.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":100101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":100401,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":100101,"motion":200,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-1"}],"nameLeft":"彩羽","textLeft":"所以，你把小莎奈的绘本@发给小静香了吗…？","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102701,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-2"}],"nameRight":"沙绪","textRight":"是的，我已经把@购入的电子书发给她了…"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":100401,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-3"}],"nameLeft":"莎奈","textLeft":"她的反应如何…？"},{"chara":[{"id":102701,"motion":300,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-4"}],"nameRight":"沙绪","textRight":"这个，还是毫无音讯…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-5"}],"nameLeft":"莎奈","textLeft":"连看都没看一眼吗…？"},{"chara":[{"id":102701,"motion":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-6"}],"nameRight":"沙绪","textRight":"不，信息已经被查看过@绘本也成功接收了"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-7"}],"nameRight":"沙绪","textRight":"但是，自那之后@就没有任何反应了…"},{"chara":[{"id":102701,"motion":100,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-8"}],"nameRight":"沙绪","textRight":"虽然试着@重新发了好几次信息…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100401,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-9"}],"nameLeft":"莎奈","textLeft":"…毕竟是业余的我画的绘本@肯定是没能打动她吧…"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-10"}],"nameLeft":"莎奈","textLeft":"内容也很烂大街@只是沙绪小姐太抬举我了…"},{"chara":[{"id":102701,"motion":200,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-11"}],"nameRight":"沙绪","textRight":"不，没有那种事"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-12"}],"nameRight":"沙绪","textRight":"只要跟我和千儿一起看，@她一定也能理解的…"},{"autoTurnLast":0.2,"chara":[{"id":100401,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100101,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-13"}],"nameLeft":"彩羽","textLeft":"那个，小莎奈的绘本@讲的是什么故事？"},{"chara":[{"id":100101,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-14"}],"nameLeft":"彩羽","textLeft":"虽然听说过这件事，@但我还没看过…"},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp3.json","id":100401,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-15"}],"nameRight":"莎奈","textRight":"那个，但实在太羞耻了…"},{"chara":[{"id":100101,"motion":100,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-16"}],"nameLeft":"彩羽","textLeft":"不是那本@以AI小姐为原型的绘本吧？"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-17"}],"nameRight":"莎奈","textRight":"嗯…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100101,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-18"}],"nameLeft":"彩羽","textLeft":"我不能看吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":100401,"motion":200,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-19"}],"nameRight":"莎奈","textRight":"不、不行！"},{"chara":[{"cheek":2,"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-20"}],"nameRight":"莎奈","textRight":"那个，实在是太羞耻了@我可能会死掉的…！"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":100101,"motion":401,"pos":0,"voiceFull":"fullvoice/section_103002/vo_full_103002-5-21"}],"nameLeft":"彩羽","textLeft":"有那么羞耻吗！？@至少告诉我一下梗概也好啊…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100101}]},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":100401,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-22","voiceFullStop":"fullvoice/section_103002/vo_full_103002-5-21"}],"nameRight":"莎奈","textRight":"…我来讲就太羞耻了，@所以让沙绪小姐来吧…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102701,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-23"},{"id":100101,"motion":0}],"nameRight":"沙绪","textRight":"诶，我来吗…？@倒是没问题…"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100101}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"id":102701,"pos":1}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102701,"pos":1,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-24"}],"nameCenter":"沙绪","textCenter":"嗯，二叶小姐的绘本呢"},{"bgm":"bgm03_story03","chara":[{"id":102701,"motion":1,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-25"}],"nameNarration":"沙绪","narration":"「简单来说，比起说是讨论善恶的故事@更像是个传达了“真正感到痛苦的人是谁”@“真正应当拯救的人是谁”这两点的故事」","narrationEffect":"in"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-26"}],"narration":"「故事是从一只不管做什么都很慢，@没有自信的小乌龟@遇见了来到村庄的白色小鸟开始的」"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-27"}],"narration":"「那只小鸟告诉了小乌龟@它身上的温柔之处@仅仅如此，小乌龟就知道了自己被他人所需要@慢慢地做起了自己力所能及的事情」"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102701,"motion":300,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-28"}],"narration":"「但是，就在这时@有一头危险的老虎突然出现@夺走了村里的食物」"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-29"}],"narration":"「然而，该说是因果报应吗@老虎被村民们狩猎，最终被抓住了」"},{"chara":[{"id":102701,"motion":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-30"}],"narration":"「老虎恳求看到了这一幕的小乌龟帮助它@但小乌龟不想帮助坏人，所以无视了它」"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102701,"motion":100,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-31"}],"narration":"「但是，小鸟却帮助了老虎@得到了帮助的老虎为至今为止的事情道歉@并发誓从今以后都会为了村庄劳动」"},{"chara":[{"eyeClose":1,"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-32"}],"narration":"「看着这副场景，@小乌龟意识到自己才是真正的坏人」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"eyeClose":0,"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-33"}],"nameCenter":"沙绪","textCenter":"就是这么一个故事"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":100101,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-34"},{"cheek":1,"face":"mtn_ex_030.exp3.json","id":100401,"motion":0,"pos":2}],"nameLeft":"彩羽","textLeft":"…我觉得是个好故事，@没什么要对我隐瞒的啊…？"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-35"}],"nameRight":"莎奈","textRight":"因、因为…"},{"chara":[{"id":100401,"motion":100,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-36"}],"nameRight":"莎奈","textRight":"小乌龟是我…老虎是红晴小姐…@小鸟则是彩羽同学…"},{"chara":[{"id":100101,"motion":401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-37"}],"nameLeft":"彩羽","textLeft":"诶，是我吗…！？"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-38"}],"nameRight":"莎奈","textRight":"是的…"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":100401,"motion":1,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-39"},{"id":100101,"motion":0}],"nameRight":"莎奈","textRight":"因为彩羽同学说，@围绕着[textYellow:心魔]石的战斗"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-40"}],"nameRight":"莎奈","textRight":"是由于大家寻求拯救的内心@而爆发的…"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-41"}],"nameRight":"莎奈","textRight":"大家虽然有种种不同，@但都怀抱着尊贵的愿望"},{"chara":[{"id":100401,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-42"}],"nameRight":"莎奈","textRight":"所以要去憎恨争斗本身而非个人@并尽可能拯救大家"},{"chara":[{"eyeClose":0,"id":100401,"motion":200,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-43"}],"nameRight":"莎奈","textRight":"所以，我想画一本@能传达这种想法的绘本…"},{"chara":[{"cheek":2,"id":100101,"motion":301,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-44"}],"nameLeft":"彩羽","textLeft":"这、这样啊@虽然很高兴…"},{"chara":[{"cheek":2,"face":"mtn_ex_041.exp3.json","id":100101,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-45"}],"nameLeft":"彩羽","textLeft":"但是，被当面说这种话@稍微有点害羞呢…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100401,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-46"}],"nameRight":"莎奈","textRight":"对不起，@果然让你不舒服了吧…"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":100101,"motion":400,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-47"}],"nameLeft":"彩羽","textLeft":"不是那样的…！@我真的很高兴哦…！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":100101,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-48"},{"cheek":1,"face":"mtn_ex_050.exp3.json","id":100401,"motion":0}],"nameLeft":"彩羽","textLeft":"因为，这就说明小莎奈"},{"chara":[{"id":100101,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-49"}],"nameLeft":"彩羽","textLeft":"像重视AI小姐一样@很重视我的想法嘛"},{"autoTurnLast":0.2,"chara":[{"id":100401,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102701,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-50"}],"nameRight":"沙绪","textRight":"如果有人愿意画以我为原型的绘本@我也会很高兴的"},{"autoTurnLast":2,"chara":[{"id":102701,"motion":100,"voiceFull":"fullvoice/section_103002/vo_full_103002-5-51"}],"enableSkipAutoTurn":1,"nameRight":"沙绪","textRight":"能表达自己的心意真是太好了呢@二叶小姐，呵呵"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102701}]},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":100401,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-52","voiceFullStop":"fullvoice/section_103002/vo_full_103002-5-51"}],"enableSkipAutoTurn":0,"nameLeft":"莎奈","textLeft":"嗯…！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102701,"motion":300,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-53"}],"nameRight":"沙绪","textRight":"之后就只能祈祷@静香会直率地接受这些内容了…"},{"chara":[{"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-54"}],"nameRight":"沙绪","textRight":"因为，无论是自己在做的事@还是自己才是需要拯救的人的事实"},{"chara":[{"eyeClose":1,"id":102701,"voiceFullAuto":"fullvoice/section_103002/vo_full_103002-5-55"}],"nameRight":"沙绪","textRight":"她好像都没有意识到"},{"autoTurnLast":2,"bgm":"stop","turnChangeIn":"fadeIn"}]},"version":3}