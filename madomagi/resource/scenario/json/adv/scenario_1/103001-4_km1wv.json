{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21742.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103201,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103101,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm23_magus02","chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-1"}],"nameRight":"美由利","textRight":"灿大人…@关于射电望远镜的作战的事","turnChangeOut":"fadeOut"},{"chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-2"}],"nameRight":"美由利","textRight":"不告诉安积和宫尾@真的好吗…"},{"chara":[{"id":103101,"motion":300,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-3"}],"nameLeft":"灿","textLeft":"对她们二人保有秘密@确实会感到难受呢…"},{"chara":[{"id":103201,"motion":100,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-4"}],"nameRight":"美由利","textRight":"是的…说实话，@美由感到很不安…"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-5"},{"id":103101,"motion":0}],"nameRight":"美由利","textRight":"美由我们是为了彼此@实现无谋的梦想的同伴"},{"chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-6"}],"nameRight":"美由利","textRight":"也是为了共同治愈心伤@而努力的同志"},{"chara":[{"id":103201,"motion":0,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-7"}],"nameRight":"美由利","textRight":"明明约定了@要扩散魔法少女至上主义"},{"chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-8"}],"nameRight":"美由利","textRight":"让美由我们受到认可@实现怀抱的愿望"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103201,"motion":300,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-9"}],"nameRight":"美由利","textRight":"她们两人却不在那里…"},{"chara":[{"eyeClose":1,"id":103101,"motion":100,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-10"}],"nameLeft":"灿","textLeft":"但“现在的姬小姐的做法”@还是不适合她们…"},{"chara":[{"eyeClose":0,"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-11"}],"nameLeft":"灿","textLeft":"向世间扩散魔法少女@本是我们的起点"},{"chara":[{"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-12"}],"nameLeft":"灿","textLeft":"而现在的起点@已经变成了从最开始就君临顶点"},{"chara":[{"id":103101,"motion":1,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-13"}],"nameLeft":"灿","textLeft":"因为变成了如此“强硬的做法”"},{"chara":[{"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-14"}],"nameLeft":"灿","textLeft":"所以如果被安积和宫尾知道了@她们一定会离开姬小姐身边的…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103201,"motion":1,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-15"}],"nameRight":"美由利","textRight":"灿大人没关系吗…？"},{"chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-16"}],"nameRight":"美由利","textRight":"就算通过姬小姐的做法@大家都会知道美由我们的事情"},{"chara":[{"id":103201,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-17"}],"nameRight":"美由利","textRight":"灿大人会被认可为神明@火祭也会残存下来"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103201,"motion":300,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-18"}],"nameRight":"美由利","textRight":"和青年会的人们的关系也会崩塌@与至今为止完全不同哦…？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103101,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-19"}],"nameLeft":"灿","textLeft":"神滨市的人变成什么样@都和我没有关系"},{"chara":[{"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-20"}],"nameLeft":"灿","textLeft":"而且，我从最开始就做好了@和青年会的关系会改变的心理准备"},{"chara":[{"cheek":0,"id":103101,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-21"},{"id":103201,"motion":0}],"nameLeft":"灿","textLeft":"而且，如果姬小姐变成@会对青年会的人们出手的恶神"},{"chara":[{"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-22"}],"nameLeft":"灿","textLeft":"我就会成为人们的盾牌@成为守护大家的善神"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103101,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-23"}],"nameLeft":"灿","textLeft":"复数的神共存的神话@要多少有多少"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-24"}],"nameLeft":"灿","textLeft":"就算火祭的神@也属于其中之一也不奇怪"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103201,"motion":200,"pos":2,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-25"}],"nameRight":"美由利","textRight":"的确的确！@日本也有很多神明！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103101,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-26"}],"nameLeft":"灿","textLeft":"所以，对于由善神和恶神两柱@来组成支配我并没有意见"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-27"}],"nameLeft":"灿","textLeft":"不过，只要姬小姐不改变@这些都是不用思考的烦恼"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103201,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-28"}],"nameRight":"美由利","textRight":"…姬小姐为什么突然@转向了过激的方向呢"},{"chara":[{"id":103101,"motion":301,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-29"}],"nameLeft":"灿","textLeft":"因为莎夏离开了，她很害怕"},{"chara":[{"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-30"}],"nameLeft":"灿","textLeft":"那个人和我们不同，@是唯一一个向姬小姐伸出了手的人"},{"chara":[{"eyeClose":1,"id":103101,"voiceFullAuto":"fullvoice/section_103001/vo_full_103001-4-31"}],"nameLeft":"灿","textLeft":"对姬小姐来说，是除了彦先生以外@唯一能够撒娇的人…"},{"autoTurnLast":1,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/part2_chapter5/102601_hime_alex_meet.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"promist"},{"turnChangeOut":"fadeOut"},{"autoTurnLast":1.5,"bg":"bg_adv_21573.jpg","chara":[{"cheek":1,"face":"mtn_ex_031.exp3.json","id":102801,"motion":0,"pos":1}],"item":[{"path":"resource/scenario/img/part2_chapter5/102601_hime_alex_meet.jpg","visible":"hide"}],"turnChangeIn":"fadeIn","turnChangeInTime":1.2,"turnEffect":"stop"},{"autoTurnLast":1.4,"nameNarration":"","narration":"[surround:7105_telphone]～～♪","narrationBg":"bla