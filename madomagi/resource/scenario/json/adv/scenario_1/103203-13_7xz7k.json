{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21186.jpg","bgm":"bgm21_system01","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":100800,"motion":0,"pos":0},{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":101200,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101200,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-1"}],"nameRight":"御园花凛","textRight":"…………","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":101200,"motion":300,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-2"}],"nameRight":"御园花凛","textRight":"这就是令大家痛苦的@东西问题的根源吗…？"},{"chara":[{"eyeClose":0,"id":100800,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-3"}],"nameLeft":"阿莉娜","textLeft":"问题从更早的时候开始就存在了@所以roots不只有这个"},{"chara":[{"cheek":0,"face":"mtn_ex_013.exp3.json","id":100800,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-4"}],"nameLeft":"阿莉娜","textLeft":"不如说，重要的是@happiness变成了sadness这一点"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104400,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-5"},{"id":101200,"motion":0}],"nameLeft":"命","textLeft":"对，小阿莉娜回答正确"},{"chara":[{"id":104400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-6"}],"nameLeft":"命","textLeft":"喜悦会化为悲伤@希望也会化为绝望"},{"chara":[{"id":104400,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-7"}],"nameLeft":"命","textLeft":"那是全世界共通的规律@而一切最后都会走向毁灭"},{"chara":[{"id":104400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-8"}],"nameLeft":"命","textLeft":"我们生活着的神滨市@也是一样吧？"},{"chara":[{"id":104400,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-9"}],"nameLeft":"命","textLeft":"有史以来，东西就在互相冲突@并试图毁灭彼此"},{"chara":[{"id":104400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-10"}],"nameLeft":"命","textLeft":"尽管露和千鹤@从那份绝望中找到了希望之光"},{"chara":[{"id":104400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-1