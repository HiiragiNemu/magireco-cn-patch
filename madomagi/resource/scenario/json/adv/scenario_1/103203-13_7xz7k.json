e/section_103203/vo_full_103203-13-23"}],"nameLeft":"阿莉娜","textLeft":"啊哈哈"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100800,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-24"}],"nameLeft":"阿莉娜","textLeft":"正是因为想得到拯救@人类才会request毁灭"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101200,"motion":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-25"}],"nameRight":"御园花凛","textRight":"诶…？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":100800,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-26"}],"nameLeft":"阿莉娜","textLeft":"Happy会化为sad@hope也会化为despair"},{"chara":[{"cheek":0,"face":"mtn_ex_013.exp3.json","id":100800,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-27"}],"nameLeft":"阿莉娜","textLeft":"就是因为忍受不了@自己那样的action"},{"chara":[{"id":100800,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-28"}],"nameLeft":"阿莉娜","textLeft":"人类才想要reset自己@comeback到进化之前"},{"chara":[{"eyeClose":1,"id":100800,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-29"}],"nameLeft":"阿莉娜","textLeft":"因为想作为生物@好好地live下去"},{"autoTurnLast":0.2,"chara":[{"id":100800,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104400,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-30"}],"nameLeft":"命","textLeft":"嗯呵呵@那种想法也很有趣呢"},{"chara":[{"eyeClose":1,"id":104400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-31"}],"nameLeft":"命","textLeft":"是吗，所有人都想毁灭一次@然后从根源重来吗"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":100800,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-32"}],"nameRight":"阿莉娜","textRight":"也就是回归原点@寻求生命的Renaissance"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101200,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-13-33"}],"nameRight":"御园花凛","textRight":"但是，我果然还是@听不懂前辈们的意思…"},{"autoTurnLast":2,"turnChangeIn