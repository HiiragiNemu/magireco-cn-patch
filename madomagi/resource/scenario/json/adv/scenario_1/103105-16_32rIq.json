{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/part2_chapter10/103105_neo_magus.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"ひめな","narration":"—姬奈—@明明大家@不可能赶到人家这里来才对…","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":10,"narrationLineSpace":20,"turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-1"},{"bgm":"bgm20_song13","nameNarration":"時雨","narration":"—时雨—@我、我也不明白…@我原本是想赶过来，和姬战斗的才对…！","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-2"},{"narration":"—时雨—@因为我知道你绝对会和射电望远镜的时候一样@让大家遭遇危险的事情…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-3"},{"narration":"—时雨—@但是，@我的身体却擅自动了起来…！","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-4"},{"nameNarration":"はぐむ","narration":"—育梦—@…我也有点能明白@小时雨…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-5"},{"narration":"—育梦—@一定是因为伤害着大家的蓝家小姐@和让Neo-Magius的大家逃走的蓝家小姐是同一个人","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-6"},{"narration":"—育梦—@而我们知道蓝家小姐温柔的一面@所以才像这样帮助了她…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-7"},{"narration":"—育梦—@虽然她扩散魔法少女至上主义是为了自己@但她也为我们努力过了吧…？","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-8"},{"nameNarration":"時雨","narration":"—时雨—@好像也是…所以我…@尽管无法原谅姬的做法，但还是很不甘心…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-9"},{"narration":"—时雨—@明明背叛了姬…@但是，我却不想让她在这里，就这样输掉…！","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-10"},{"nameNarration":"ひめな","narration":"—姬奈—@时雨儿…育梦儿…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-11"},{"nameNarration":"燦","narration":"—灿—@明明你就是为了不将安积和宫尾卷入这种计划@才故意疏远了她们","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-12"},{"narration":"—灿—@要是她们像这样跑回来@就都没意义了吧","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-13"},{"nameNarration":"ひめな","narration":"—姬奈—@教官和美由儿不也一样…！@你在说什么啊…！？","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-14"},{"nameNarration":"燦","narration":"—灿—@虽然我也是为了实现自己的目的@但是，我不想看见姬大人在此凋零","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-15"},{"nameNarration":"ミユリ","narration":"—美由利—@所以，美由也劝说了灿大人留下来","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-16"},{"narration":"—美由利—@虽、虽然确实很可怕，也不知道会怎么样…@但但、但是！","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-17"},{"narration":"—美由利—@我不想看见至今为止@作为Neo-Magius积累起来的东西就此崩塌！","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-18"},{"nameNarration":"燦","narration":"—灿—@以前的我应该会乖乖听从姬大人的指示吧@但是，我好像比自己想的还要喜欢你","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-19"},{"nameNarration":"はぐむ","narration":"—育梦—@我也是…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-20"},{"nameNarration":"時雨","narration":"—时雨—@我可能…也是这样…","voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-21"},{"autoTurnLast":1,"bg":"bg_adv_15053.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":100200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":100600,"motion":1,"pos":0}],"item":[{"path":"resource/scenario/img/part2_chapter10/103105_neo_magus.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bgm":"bgm23_magus01","chara":[{"id":100200,"motion":200,"voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-22"}],"nameRight":"やちよ","textRight":"所以，只是因为同伴增加了，@你就觉得自己能撑到直播吗…？","turnChangeOut":"fadeOut"},{"chara":[{"id":100600,"voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-23"}],"nameLeft":"みふゆ","textLeft":"再怎么说也很困难吧…"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100100,"motion":0,"pos":0}],"textClear":1},{"autoTurnLast":0.8,"chara":[{"cheek":0,"effect":"ef_adv_01","face":"mtn_ex_050.exp3.json","id":100100}],"se":"7201_detect_magic"},{"chara":[{"id":100100,"motion":401,"voiceFullAuto":"fullvoice/section_103105/vo_full_103105-16-24"}]