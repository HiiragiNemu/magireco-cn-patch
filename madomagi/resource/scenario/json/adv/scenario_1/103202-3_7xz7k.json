},{"chara":[{"cheek":0,"face":"mtn_ex_002.exp3.json","id":104101,"motion":100,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-24"}],"nameLeft":"莉薇娅","textLeft":"是啊，已经找到房子了@接下来只要收拾好行李就行了"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-25"}],"nameRight":"","textRight":"我把自己的住址写在这里了@可以的话，就联系一下吧"},{"chara":[{"id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-26"}],"nameRight":"","textRight":"我也想知道你搬去的地方"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":104101,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-27"}],"nameLeft":"莉薇娅","textLeft":"我哪天心情好了就告诉你"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-28"}],"nameRight":"","textRight":"对我来说@莉薇娅是特别的"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_002.exp3.json","id":104101,"motion":1,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-29"}],"nameLeft":"莉薇娅","textLeft":"突然怎么了，好恶心…"},{"chara":[{"id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-30"}],"nameRight":"","textRight":"因为你是我开始做这份工作之后@第一个负责的孩子"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-31"}],"nameRight":"","textRight":"抱歉，明明说这种@私人的事情也没什么用"},{"nameNarration":"莉薇娅","narration":"其实我真的很想安慰她@也想至少说些至今为止多谢了之类的话","narrationBg":"bg_adv_50071.jpg","narrationEffect":"in","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-32"},{"narration":"但是，越是体谅他人的心情@就越是不知道接下来@老师会遇到多么令人绝望的状况","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-33"},{"narration":"所以，尽量不去接近@不如说要冷淡地对待@那就是我对老师的温柔","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-34"},{"autoTurnLast":1,"bg":"black","narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"莉薇娅","narration":"在那之后，我们再也没有联系过@搬家之后，我也没有联系老师","narrationBg":"black","narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-35"},{"narration":"我每天就在便利店之类的地方打工@并用逐渐成熟的调整之力支援着魔法少女们","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-36"},{"narration":"因为不想在善人的世界里做恶人@所以，我只好既无善意也无恶意地平淡生活着@这时，我才感到@这种不伦不类的人生到底是多么枯燥无趣","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-37"},{"autoTurnLast":2,"turnChangeIn":"fadeIn"}]},"version":3}