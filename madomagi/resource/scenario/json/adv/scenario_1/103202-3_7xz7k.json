{"story":{"group_1":[{"autoTurnLast":0.01,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801400,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"chara":[{"id":801400,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-1"}],"nameCenter":"","textCenter":"人从出生的时候@就已经注定了","turnChangeOut":"fadeOut"},{"chara":[{"id":801400,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-2"}],"nameCenter":"","textCenter":"是作为善人活下去比较好@还是作为恶人活下去比较好"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801400,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-3"}],"nameCenter":"","textCenter":"恶人无法在善人中生存@善人无法在恶人中生存"},{"chara":[{"id":801400,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-4"}],"nameCenter":"","textCenter":"虽然你以前@可能也在善人中生存过"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":801400,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-5"}],"nameCenter":"","textCenter":"但你已经来到了无法回头的地方"},{"autoTurnLast":0.5,"bg":"bg_adv_50071.jpg","chara":[{"cheek":0,"face":"mtn_ex_002.exp3.json","id":104101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800600,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story07","nameNarration":"莉薇娅","narration":"但我还是回来了","narrationBg":"bg_adv_50071.jpg","narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-6"},{"narration":"明明是为了生存才变成了恶@我却再次来到了自己无法生存的世界","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-7"},{"narration":"所以，我想让自己和那个人的关系@变得更朴素、更淡漠@我不会做必要以上的事@我们在私下里也不再交往了","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-8"},{"narration":"并且，绝对不能温柔地对待他人","voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-9"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"id":800600,"voiceFullAuto":"fullvoice/section_103202/vo_full_103202-3-10"}],"nameRight":"","textRight":"嗯，恭喜你高认合格！"},{"chara":[{"id":104101,"voiceFullAuto":"fullvoice/sectio