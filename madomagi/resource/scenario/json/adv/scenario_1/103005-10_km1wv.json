03005-10-32"}],"narration":"「你不觉得，那对通过希望与绝望的相转移@维持着自身的宇宙来说@是一件很不利的事情吗？」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-33"}],"nameRight":"那由他","textRight":"虽然确实是那样…@但宇宙本身怎么会有意志呢"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-34"}],"nameLeft":"太助","textLeft":"虽然谁都回答不了这个问题@但我们人类是从宇宙中产生的"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-35"}],"nameLeft":"太助","textLeft":"就算身为母体的宇宙@拥有意志也不奇怪"},{"chara":[{"id":103701,"motion":0},{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-36"}],"nameNarration":"太助","narration":"「如果真的是那样，就像人体有免疫系统一样@宇宙或许也有自己的免疫系统」","narrationCoverOpacity":150,"narrationEffect":"in"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-37"}],"narration":"「就像我们的身体出现异常的时候@身体会在无意识下修复那些异常一样@在宇宙中发生异常的时候@或许也会发生用于修复异常的反应」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"id":103701,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-38"}],"nameRight":"那由他","textRight":"那样的话@让大家知晓魔法少女的行为"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-39"}],"nameRight":"那由他","textRight":"就是对宇宙而言的危害了吗…？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":802401,"motion":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-40"}],"nameLeft":"太助","textLeft":"很有可能…"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-41"}],"nameNarration":"太助","narration":"「没有了从魔法少女身上获得的能量@宇宙总有一天会无法继续维持存在@对宇宙来说就像生了病一样」","narrationCoverOpacity":150,"narrationEffect":"in"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-42"}],"narration":"「那样的话，对宇宙不利的我们@对宇宙而言，就像癌细胞一样@就算遭到无形之力的驱逐也并不奇怪…」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_052.exp3.json","id":103701,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-43"}],"nameRight":"那由他","textRight":"怎么这样…"},{"chara":[{"id":802401,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-44"}],"nameNarration":"太助","narration":"「那由他，要让我们存活下来@说不定必须要与@宇宙强大的“自净作用”战斗才行…」","narrationCoverOpacity":150,"narrationEffect":"in"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103701,"motion":400,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-45"}],"nameRight":"那由他","textRight":"但、但是，@那只是个假说而已！"},{"chara":[{"id":802401,"motion":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-46"}],"nameLeft":"太助","textLeft":"是啊，只是个假说"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-47"}],"nameLeft":"太助","textLeft":"能将其称为真相的时刻@或许永远不会到来…"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-48"}],"nameLeft":"太助","textLeft":"所以，我才把这件事@托付给了拉比她们"},{"chara":[{"id":103701,"motion":1,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-49"}],"nameRight":"那由他","textRight":"神滨市的战斗@是否会再次产生绝望…"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-50"}],"nameRight":"那由他","textRight":"并且是由于宇宙的意志@产生绝望…"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-51"}],"nameRight":"那由他","textRight":"一旦超过限度@“自净作用”就会开始引起不幸"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-52"}],"nameLeft":"太助","textLeft":"没错，拉比她们遭受过的不讲理的对待，可能也会在神滨市发生"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-53"}],"nameLeft":"太助","textLeft":"那个时刻@就是我们得以确信的时刻…"},{"autoTurnLast":0.2,"bgm":"stop","textClear":1},{"autoTurnLast":2,"bg":"bg_adv_50073.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":802401,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnChangeInTime":2},{"chara":[{"id":802401,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-54"}],"nameCenter":"太助","textCenter":"…………","turnChangeOut":"fadeOut","turnChangeOutTime":2},{"chara":[{"id":802401,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-55"}],"nameCenter":"太助","textCenter":"（人才是更可怕的存在…）"},{"chara":[{"id":802401,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-56"}],"nameCenter":"太助","textCenter":"（由于魔法少女的存在，@文明或许确实得到了发展…）"},{"chara":[{"id":802401,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-57"}],"nameCenter":"太助","textCenter":"（但是，@人心的构造并没有改变）"},{"chara":[{"id":802401,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-58"}],"nameCenter":"太助","textCenter":"（人的内部构造完全没有改变@仍然重复着同样的行为…）"},{"chara":[{"eyeClose":1,"id":802401,"motion":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-59"}],"nameNarration":"太助","narration":"那也就意味着@就算经过了几千几万年的时间@人类也永远无法完成精神上的进化@只有技术在不断发展向上","narrationCoverOpacity":150,"narrationEffect":"in"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-60"}],"narration":"如果不趁现在阻止发展@总有一天，不仅是魔法少女@连人类也会毁灭"},{"chara":[{"id":802401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-10-61"}],"narration":"我们人类马上就要跨入@只靠人类的精神无法完全应对的未来了…"},{"autoTurnLast":0.01},{"autoTurnLast":2,"bg":"black","narrationEffect":"out","turnChangeIn":"fadeIn","turnChangeInTime":1},{"autoTurnLast":0.1,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.1,"bg":"white","turnChangeIn":"whiteIn"},{"nameNarration":"","narration":"[textBlack:—取材记录—]@[textBlack:里见 那由他]","narrationCoverOpacity":0,"narrationEffect":"in","turnChangeOut":"whiteOut","turnChangeOutTime":0.2},{"autoTurnLast":0.1,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103701,"motion":0,"pos":2,"posX":50}],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"narrationEffect":"out","turn