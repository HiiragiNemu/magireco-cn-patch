_103205/vo_full_103205-5-128"}],"progressNarration":"[textBlack:「然后，等变成大人的时候]@[textBlack:我想再和库拉拉好好谈一次。]@[textBlack:如果能互相体谅彼此，]@[textBlack:到那个时候，我们或许就能心灵相通了」]"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103601,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-129"}],"progressNarration":"[textBlack:「到那个时候，我想再结成双人组合]@[textBlack:向大家展示最棒的杂技！」]"},{"autoTurnLast":0.01,"bg":"white","narrationEffect":"out","turnChangeIn":"whiteIn"},{"nameNarration":"","narration":"[textBlack:—取材记录—]@[textBlack:冰室 拉比]","narrationCoverOpacity":0,"narrationEffect":"in","turnChangeOut":"whiteOut","turnChangeOutTime":0.2},{"autoTurnLast":0.1,"bg":"balck","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":0,"pos":2,"posX":40}],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"narrationEffect":"out","turnChangeIn":"whiteIn"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-131"}],"nameNarration":"ラビ","narrationCoverOpacity":0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":80,"progressNarration":"[textBlack:「自己到底有没有未来。]@[textBlack:到底能不能得到救赎。]@[textBlack:居然向持续着那样的自问，]@[textBlack:并旁观着战斗经过的我们询问未来的话题，]@[textBlack:真是滑稽」]","turnChangeOut":"whiteOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":300,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-132"}],"progressNarration":"[textBlack:「…对不起，明明你在顾虑着我们提问]@[textBlack:我却说了失礼的话」]"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-133"}],"progressNarration":"[textBlack:「毕竟，这就像对被告知了只有一年生命的人]@[textBlack:询问十年后的事情一样」]"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":0,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-134"}],"progressNarration":"[textBlack:「…嗯，就算这么说，我也不是没有任何想法]@[textBlack:不如说，正是因为会思考未来的事，]@[textBlack:我们才这么痛苦」]"},{"chara":[{"id":103301,"motion":1,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-135"}],"progressNarration":"[textBlack:「我想继承母亲经营得很繁荣的旅店]@[textBlack:也想进一步宣传祖父为了我栽培的蔬菜。]@[textBlack:还有，我想在研读父亲收集的藏书同时，]@[textBlack:为了加深理解而进入大学深造…」]"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":100,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-136"}],"progressNarration":"[textBlack:「是的，梦想越是繁多，期望越是繁多]@[textBlack:时日无多的悲伤就越是会]@[textBlack:像摘胆剜心一般侵蚀着我们」]"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":0,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-137"}],"progressNarration":"[textBlack:「即便如此，仍然会紧抓住未来不放]@[textBlack:或许就是我们人类的本性吧」]"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-138"}],"progressNarration":"[textBlack:「说到底，对时间这个概念的理解]@[textBlack:就会孕育出对死亡的恐惧和对未来的羡望]@[textBlack:并引起因此而生的行动」]"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-139"}],"progressNarration":"[textBlack:「社会这种词语之所以会产生]@[textBlack:人之所以会杀人、加害于人]@[textBlack:都是因为人类理解时间这个概念]@[textBlack:并将其与焦躁的感情联系起来而产生出的」]"},{"chara":[{"id":103301,"motion":1,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-140"}],"progressNarration":"[textBlack:「正因如此，一无所有的我]@[textBlack:就算放弃一切或许也不奇怪。]@[textBlack:不做出任何行动也是很普通的」]"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-141"}],"progressNarration":"[textBlack:「但是，我在庭院里开辟了一方家庭菜园。]@[textBlack:仅仅如此，我就已经得出了答案」]"},{"chara":[{"id":103301,"motion":200,"voiceFullAuto":"fullvoice/section_103205/vo_full_103205-5-142"}],"progressNarration":"[textBlack:「我仍然想得到未来…」]"},{"autoTurnLast":2,"turnChangeIn":"fadeIn"}]},"version":3}