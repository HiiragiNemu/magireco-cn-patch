{"story":{"group_1":[{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3503_mirrors_memory.ExportJson","zOrder":"messageFront"}],"autoTurnLast":0.01,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/part2_chapter6/102704_mirror.png","posX":0,"posY":0,"scale":1,"setVisible":1}],"turnChangeIn":"fadeIn"},{"nameNarration":"命","narration":"「镜子将要映出的@是仍在战乱之中，混乱登峰造极的@几百年前发生的事情」","narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-1"},{"narration":"「当时，战争仍然在神滨这块土地上持续@身为土豪的水名氏的谋反也@是这一时期的代表性事件之一」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-2"},{"narration":"「侍奉着当时的领主的他@与苦于歉收和暴政的民众们共同起兵@和从古时起就一直被排斥的东边的贼人联手@让自己作为领主东山再起了」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-3"},{"narration":"「对东西两边来说@那简直是令人不敢置信的奇迹」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-4"},{"narration":"「但是，孕育出奇迹的主角@其实是西边的水名露和东边的千鹤@两名被称为战神子的魔法少女」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-5"},{"autoTurnLast":0.01},{"autoTurnLast":0.01,"item":[{"action":{"scaleTo":{"duration":0.2,"scale":5}},"path":"resource/scenario/img/part2_chapter6/102704_mirror.png"},{"action":{"moveTo":{"duration":0.4,"posY":0}},"path":"resource/scenario/img/adv_roll_fade.png","posX":0,"posY":1000,"scale":6,"setVisible":1,"zOrder":"messageFront"}],"narrationEffect":"out"},{"autoTurnLast":0.01,"deleteArmatureList":[1],"item":[{"path":"resource/scenario/img/part2_chapter6/102704_mirror.png","visible":"hide"}]},{"autoTurnLast":0.01,"item":[{"action":{"moveTo":{"duration":0.4,"posY":-1000}},"path":"resource/scenario/img/adv_roll_fade.png"}]},{"bgm":"stop","nameNarration":"命","narration":"「但这件事也…」","narrationEffect":"in","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-6"},{"autoTurnLast":2,"bg":"bg_adv_24012.jpg","narrationEffect":"out","turnChangeIn":"whiteIn"},{"autoTurnLast":2,"turnChangeOut":"whiteOut"},{"autoTurnLast":0.5,"bg":"bg_adv_20741