p3.json","id":104501,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-18"}],"nameLeft":"露","textLeft":"真是的，太没礼貌了"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104601,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-19"}],"nameRight":"千鹤","textRight":"哈，这不是事实吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104601,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-20"}],"nameRight":"千鹤","textRight":"…一说到他们店@米店的老头子就向我招手了"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104601,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-21"}],"nameRight":"千鹤","textRight":"我稍微过去一下"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":104601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104501,"motion":0,"pos":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-22"}],"nameCenter":"露","textCenter":"啊、等等，千鹤！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-23"}],"nameCenter":"露","textCenter":"居然这么兴奋，真是的"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104501,"lipSynch":0,"motion":300,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-24"}],"nameCenter":"露","textCenter":"…………"},{"chara":[{"id":104501,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-25"}],"nameCenter":"露","textCenter":"（不，我也和千鹤一样…）"},{"chara":[{"eyeClose":1,"id":104501,"motion":0}],"nameNarration":"","narration":"「怎么搞的@居然有个美人大小姐走在大街上」","narrationBg":"","narrationEffect":"in","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-26"},{"narration":"「从外边来的你大概不知道吧@她可是治理着水名的领主大人的女儿」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-27"},{"narration":"「哈！？那为什么如此不加防备…@这种毫无温情的世道…@搞不好会被附近的恶党拐走的」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-28"},{"narration":"「啊哈哈，那恶党大概会被反杀吧」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-29"},{"narration":"「因为她虽然是女人，却会剑术吗？」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-30"},{"narration":"「你听说过战神子吗？」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-31"},{"narration":"「两位战神子，西边的水名露和东边的千鹤@这个国家大概没有人不知道吧@毕竟她们可是和城主大人@一起构筑起和平的主角啊」","voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-32"},{"autoTurnLast":0.2,"chara":[{"id":104501,"pos":0}],"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104601,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-33"}],"nameRight":"千鹤","textRight":"给，露也吃点吧"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":104501,"lipSynch":1,"motion":400,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-34"}],"nameLeft":"露","textLeft":"[chara:104501:effect_emotion_surprise_0][se:7226_shock]——！？"},{"chara":[{"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-35"}],"nameRight":"千鹤","textRight":"好啦，别在那傻笑了，@赶紧接过去吧"},{"chara":[{"id":104501,"motion":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-36"}],"nameLeft":"露","textLeft":"烤年糕…？"},{"chara":[{"id":104601,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-37"}],"nameRight":"千鹤","textRight":"是老头子给的"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104501,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-38"}],"nameLeft":"露","textLeft":"…我说，千鹤@我们抓住的说不定就是这个"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104601,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-39"}],"nameRight":"千鹤","textRight":"不，我倒也不是@为了烤年糕而战斗的"},{"chara":[{"eyeClose":1,"id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-40"}],"nameLeft":"露","textLeft":"不，我们得到的@是人们内心的余裕"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-41"}],"nameRight":"千鹤","textRight":"嗯，这么一说@说不定确实是那样"},{"chara":[{"eyeClose":0,"id":104501,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-42"}],"nameLeft":"露","textLeft":"所以，我们再加把劲@继续努力吧"},{"chara":[{"id":104601,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-43"}],"nameRight":"千鹤","textRight":"就是要宣扬我们的存在，@保护好水名对吧？"},{"chara":[{"id":104501,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-44"}],"nameLeft":"露","textLeft":"嗯"},{"chara":[{"id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-45"}],"nameLeft":"露","textLeft":"不会有人想攻打@由两位战神子守护着的土地"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-46"}],"nameLeft":"露","textLeft":"还有就是，@如果千鹤的父亲愿意接受就好了…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104601,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-47"}],"nameRight":"千鹤","textRight":"你是说@成为你们的家臣那件事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-6-48"}],"nameRight":"千鹤","textRight":"只要能把土地作为知行地守护好@老爸估计也没有怨言吧"},{"autoTurnLast":2,"turnChangeIn":"fadeIn"}]},"version":3}