      {
        "nameNarration": "御影",
        "narration": "―御影―@笼目亲已经把书整理完了吧！？",
        "narrationAnchor": "bottom",
        "narrationCoverOpacity": 110,
        "narrationEffect": "in",
        "narrationFontSize": 30,
        "narrationLineMargin": 10,
        "narrationLineSpace": 20,
        "turnChangeOut": "fadeOut",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-14"
      },
      {
        "narration": "―御影―@还有，那由碳爸爸也在！",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-15"
      },
      {
        "narration": "―御影―@能扩散魔法少女的事了吗！？@什么时候才能扩散！？",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-16"
      },
      {
        "nameNarration": "那由他",
        "narration": "―那由他―@如果本来就能进来，@你就不用发出那么大的声音了吧",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-17"
      },
      {
        "narration": "―那由他―@话说，门锁是不是根本没派上用场啊！",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-18"
      },
      {
        "nameNarration": "拉比",
        "narration": "―拉比―@对不起，我拿过报纸之后就忘记锁门了…",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-19"
      },
      {
        "nameNarration": "那由他",
        "narration": "―那由他―@哎呀，拉比会这样还真是稀奇",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-20"
      },
      {
        "nameNarration": "拉比",
        "narration": "―拉比―@是的，似乎是主人迷糊的地方传染到我了…",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-21"
      },
      {
        "nameNarration": "那由他",
        "narration": "―那由他―@啊~原来如此，是这样啊@等等，你什么意思…！？",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-22"
      },
      {
        "nameNarration": "御影",
        "narration": "―御影―@所以，什么时候才能扩散啊！？",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-23"
      },
      {
        "nameNarration": "太助",
        "narration": "―太助―@不，现在还是太早了@毕竟还有必要进行很多次修正…",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-24"
      },
      {
        "nameNarration": "笼目",
        "narration": "―笼目―@我也必须重读一遍写下来的东西@思考要怎么整理才行…",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-25"
      },
      {
        "nameNarration": "太助",
        "narration": "―太助―@而且，就算书写好了@也不能轻易地把魔法少女的一切都告诉大家",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-26"
      },
      {
        "narration": "―太助―@因为有必要吸取至今为止的事中的教训@慢慢地按阶段进行",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-27"
      },
      {
        "nameNarration": "笼目",
        "narration": "―笼目―@那件事和我整理书的方法也有关吗？",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-28"
      },
      {
        "nameNarration": "太助",
        "narration": "―太助―@是啊",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-29"
      },
      {
        "narration": "―太助―@因为人类会抵抗既定概念被颠覆@并被植入新的概念的行为",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-30"
      },
      {
        "narration": "―太助―@所以，是种很难灵活应对变化的生物",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-31"
      },
      {
        "narration": "―太助―@所以，就像各种学问都有入门书一样@还是分成几个阶段，慢慢推出会比较好",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-32"
      },
      {
        "nameNarration": "拉比",
        "narration": "―拉比―@毕竟还刚刚站上起跑线@还是不要太着急会更好吧",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-33"
      },
      {
        "narration": "―拉比―@在这之后，教授为了回避断念的情况@而考虑的流程应该也能派上用场吧",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-34"
      },
      {
        "nameNarration": "太助",
        "narration": "―太助―@就像民俗学刚刚被设立的时候一样",
        "voiceFullAuto": "fullvoice/section_103306/vo_full_103306-2-35"
      },
      {
