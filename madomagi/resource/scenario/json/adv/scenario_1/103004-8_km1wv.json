{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":102702,"motion":1,"pos":1}],"item":[{"iPhoneXScale":1,"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story03","chara":[{"eyeClose":1,"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-1"}],"nameNarration":"沙绪","narration":"「那是在一个远离人们居住的城市的地方@在动物们生活的世界发生的故事」","narrationCoverOpacity":100,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-2"}],"narration":"「住在池塘边上的小乌龟有个烦恼@那就是自己做什么都很慢@完全帮不上任何人的忙」"},{"chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-3"}],"narration":"「既不能像小鱼一样飞快地游着泳搬运东西@也不能像小狗一样表演杂技来逗大家开心@小乌龟总是烦恼地一头扎在自己的壳里」"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102602,"motion":0,"pos":1,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-4"}],"nameNarration":"千春","narration":"「有一天，@一只从遥远的国家来旅行的小白鸟@来到了这座小镇」"},{"chara":[{"id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-5"}],"narration":"「小鸟拜托正在晒太阳的小乌龟@让自己站在它温暖的壳上休息@小乌龟也同意了」"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102602,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-6"}],"narration":"「小鸟表扬了小乌龟的壳很温暖@让小乌龟的胸口深处也变得温暖了起来」"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102602,"pos":0}]},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102702,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-7"}],"nameNarration":"沙绪","narration":"「在小乌龟不知道的地方@小鸟的事情一下子在镇里传开了@它也听说了很多不同的传闻」"},{"chara":[{"id":102602,"motion":100,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-8"}],"nameNarration":"千春","narration":"「又是帮忙取来大象也够不到的高处的东西@又是从空中帮迷路的小猫寻找家的方向@又是帮小猪宣传自家的料理@小鸟的温柔广受好评，让小乌龟无比憧憬」"},{"chara":[{"id":102702,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-9"}],"nameNarration":"沙绪","narration":"「在小鸟来小乌龟那里休息的时候@小乌龟直率地告诉了小鸟自己很憧憬它@然后，小鸟就对小乌龟说」"},{"chara":[{"eyeClose":1,"id":102602,"motion":0,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-10"}],"nameNarration":"千春","narration":"「『只是因为我什么都没有@所以才想对大家温柔一点而已』」"},{"autoTurnLast":0.2,"bg":"black","item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_yu_dairy.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"千春&沙绪","narration":"[voiceFull:fullvoice/section_103004/vo_full_103004-8-11_chiharu][voiceFull:fullvoice/section_103004/vo_full_103004-8-11_sunao]「在这个故事的另一侧@有一只可怕的老虎生活在森林里面」","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"voiceFullStop":"fullvoice/section_103004/vo_full_103004-8-11_chiharu"},{"autoTurnLast":0.01,"voiceFullStop":"fullvoice/section_103004/vo_full_103004-8-11_sunao"},{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3003_act_stage.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_19301.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102502,"motion":0,"pos":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":801000,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-12"}],"nameRight":"静香的母亲","textRight":"[chara:801000:effect_shake]咳咳、咳咳…唔…@抱歉，只让静香一个人去劳动","turnChangeOut":"fadeOut"},{"autoTurnLast":2,"chara":[{"id":102502,"voiceFull":"fullvoice/section_103004/vo_full_103004-8-13"}],"enableSkipAutoTurn":1,"nameLeft":"静香","textLeft":"毕竟妈妈生了病，这也没办法@没关系，我很有精神的"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102502,"motion":100}]},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801600,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103004/vo_full_103004-8-14","voiceFullStop":"fullvo