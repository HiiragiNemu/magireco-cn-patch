    "voiceFull": "fullvoice/section_101505/vo_full_101505-5-34",
    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-33"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 300
     }
    ],
    "textRight": ">所以，莎奈不应该@>跟我这样的传闻在一起。",
