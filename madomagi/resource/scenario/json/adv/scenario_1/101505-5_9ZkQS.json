    "chara": [
     {
      "cheek": 2,
      "face": "mtn_ex_031.exp.json",
      "id": 100401,
      "voiceFull": "fullvoice/section_101505/vo_full_101505-5-45",
      "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-44"
