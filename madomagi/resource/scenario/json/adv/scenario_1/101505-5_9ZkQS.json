    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-31"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 300
     }
    ],
    "textRight": ">我是被创造出来的人工智能，@>总有一天会消失。",
    "voiceFull": "fullvoice/section_101505/vo_full_101505-5-33",
    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-32"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 100
     }
    ],
