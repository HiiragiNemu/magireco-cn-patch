    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-45"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 300
     }
    ],
    "textRight": ">这样一来，@>你就不必在这里……",
    "voiceFull": "fullvoice/section_101505/vo_full_101505-5-47",
    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-46"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 100
     }
    ],
    "textRight": ">为玛吉斯之翼所做之事@>而感到痛苦了。",
    "voiceFull": "fullvoice/section_101505/vo_full_101505-5-48",
    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-47"
   },
   {
    "chara": [
     {
      "id": 820100,
      "motion": 100
     }
    ],
    "textRight": ">我不想看到你烦恼的模样。",
    "voiceFull": "fullvoice/section_101505/vo_full_101505-5-49",
    "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-48"
   },
   {
    "chara": [
     {
      "cheek": 2,
      "face": "mtn_ex_031.exp.json",
      "id": 100401,
      "motion": 300,
      "voiceFull": "fullvoice/section_101505/vo_full_101505-5-50",
      "voiceFullStop": "fullvoice/section_101505/vo_full_101505-5-49"
     },
     {
      "id": 820100,
      "motion": 0
     }
    ],
    "textLeft": "小爱……"
