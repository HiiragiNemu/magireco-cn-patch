005/vo_full_103005-1-29"}],"nameRight":"亚历山德拉","textRight":"愤怒也会转变为恐惧@让他们向魔法少女求救吧"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103601,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-30"}],"nameLeft":"丽","textLeft":"但这样，一个弄不好@就会让大家全部死掉的啊"},{"chara":[{"id":103501,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-31"}],"nameRight":"亚历山德拉","textRight":"但就是因为无法阻止，@所以我也决定了离开"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-32"}],"nameLeft":"拉比","textLeft":"无论我们协助哪边的行动@结局都不会改变"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-33"}],"nameRight":"旭","textRight":"是的，我们只能@注视事态是否会朝断念前进"},{"chara":[{"id":103301,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-34"}],"nameLeft":"拉比","textLeft":"然后，如果那由他@能理解我们的想法就好了…"},{"chara":[{"id":103401,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-35"}],"nameRight":"旭","textRight":"…根据时女一族的情报@带她去汤国市应该就没问题了"},{"chara":[{"id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-1-36"}],"nameRight":"旭","textRight":"最近那里又开始出现魔法少女@他们应该也在警惕了"},{"autoTurnLast":2,"bgm":"stop","surround":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"}]},"version":3}