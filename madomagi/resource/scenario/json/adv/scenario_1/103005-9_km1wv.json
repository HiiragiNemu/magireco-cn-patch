{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm23_folklore04","chara":[{"id":103301,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-1"}],"nameLeft":"拉比","textLeft":"过去，我们曾期待过周围的人","turnChangeOut":"fadeOut"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-2"}],"nameLeft":"拉比","textLeft":"我们曾以为他们会@怜悯我们背负的不幸，并同情我们"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-3"}],"nameLeft":"拉比","textLeft":"虽然不能解决任何事情，但@终将成为魔女这一背负于身的宿命"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-4"}],"nameLeft":"拉比","textLeft":"实在是令我们过于痛苦，@让我们甚至想要得到他人的慰藉…"},{"chara":[{"id":103301,"motion":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-5"}],"nameLeft":"拉比","textLeft":"但是，寻求着怜悯和慰藉的我们@得到的却是"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-6"}],"nameLeft":"拉比","textLeft":"周围的人迸发的愤怒"},{"chara":[{"id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-7"}],"nameRight":"旭","textRight":"都怪我们@汤国市的魔法少女饱受苛责"},{"chara":[{"id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-8"}],"nameRight":"旭","textRight":"精神不断受到打击的同胞们的数量@也一天天地少了下去"},{"autoTurnLast":0.2,"chara":[{"id":103401,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103501,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-9"}],"nameRight":"亚历山德拉","textRight":"感受到了危机的我们"},{"chara":[{"id":103501,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-10"}],"nameRight":"亚历山德拉","textRight":"为了帮助无关的魔法少女们，@不让魔女继续增加"},{"chara":[{"id":103501,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-9-11"}],"nameRight":"亚历山德拉","textRight":"让愤怒的矛头朝向了自己"},{"chara":[{"id":103401,"motion