{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"face":"mtn_ex_052.exp3.json","id":103701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":802401,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm23_folklore04","chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-1"}],"nameLeft":"那由他","textLeft":"体会了人间地狱的@莫非就是拉比她们吗？","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-2"}],"nameRight":"拉比","textRight":"是的@正如那由他大人所说"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-3"}],"nameRight":"拉比","textRight":"不过，我们也只能@去接受那个人间地狱…"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-4"}],"nameLeft":"那由他","textLeft":"难道说…"},{"autoTurnLast":0.8,"bg":"bg_adv_21841.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":800100,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":800100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-5"}],"nameRight":"库拉拉","textRight":"你真的什么都不知道吗","turnChangeOut":"fadeOut"},{"chara":[{"id":800100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-6"}],"nameRight":"库拉拉","textRight":"她们杀了这座城市的学生@节目组的工作人员也是…所有人…"},{"autoTurnLast":0.2,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"face":"mtn_ex_052.exp3.json","id":103701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103301,"motion":1,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-7"}],"nameLeft":"那由他","textLeft":"那些人说的都是真的吗…？","turnChangeOut":"fadeOut"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-8"}],"nameLeft":"那由他","textLeft":"说拉比你们@杀了这座城市的学生…"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-9"}],"nameRight":"拉比","textRight":"虽说并非有意，@但结果上确实是我们杀的"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"motion":1,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-10"}],"nameRight":"旭","textRight":"因为，我们想让魔法少女的事情@为世间所知"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103501,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-11"}],"nameRight":"亚历山德拉","textRight":"是的，虽然还没有得出结论@但现在的我们是这么想的"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-12"}],"nameLeft":"那由他","textLeft":"如果让世人知道魔法少女的事情，@反而会产生绝望"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-13"}],"nameLeft":"那由他","textLeft":"来这里之前，@爸爸确实是这么说的…"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-14"}],"nameLeft":"那由他","textLeft":"大家身上到底发生了什么…？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103301,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-15"}],"nameRight":"拉比","textRight":"那由他大人@为什么想扩散魔法少女的存在？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":103701,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-16"}],"nameLeft":"那由他","textLeft":"这个…@是为了拯救魔法少女"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-17"}],"nameRight":"拉比","textRight":"又要怎么拯救魔法少女呢？"},{"chara":[{"id":103701,"motion":1,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-18"}],"nameNarration":"那由他","narration":"「我们魔法少女中有很多人@是受到家庭和环境这种近在身边的社会的影响@而许下了愿望」","narrationBg":"","narrationEffect":"in"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-19"}],"narration":"「所以，如果魔法少女的存在广为人知@在签订契约之前，周围的人就可以上前阻止@虽然很困难，但或许也能制定出@不鼓励契约的社会秩序」"},{"chara":[{"id":103701,"motion":400,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-20"}],"narration":"「…但是，比起制定规则@我更希望能通过让人们变得更温柔@来拯救少女们」"},{"chara":[{"id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-21"}],"narration":"「人们的行动和发言会营造出不幸的状况和环境@少女们则是为了改变这些@才会与丘比签订契约而成为魔法少女@这样的情况应该也不在少数」"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103701,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-22"}],"narration":"「虽然这些都是照搬爸爸的理论…」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103301,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-23"}],"nameRight":"拉比","textRight":"…我也差不多"},{"chara":[{"id":103301,"motion":1,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-24"}],"nameNarration":"拉比","narration":"「在知道魔法少女会变成魔女之后@我就感到一种无以言表的空虚@我认为，那种感情是因为@没有任何人知道魔法少女才会产生的」","narrationBg":"","narrationEffect":"in"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-25"}],"narration":"「就算用“我思故我在”@来让自己的存在藉由自己终结@在社会层面上存在与否@也是要有他人的认知才能成立的」"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-26"}],"narration":"「所以，我也试图@通过让人们知晓魔法少女的存在@来为自己谋求安宁」"},{"chara":[{"id":103301,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-27"}],"narration":"「但是，那种行为带来的@却是对我们魔法少女而言的不幸@而非防止不幸的产生」"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"id":103701,"motion":100,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-28"}],"nameLeft":"那由他","textLeft":"到底发生了什么…？"},{"chara":[{"id":103301,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-29"}],"nameRight":"拉比","textRight":"最开始，我们顺利地@把魔法少女作为好人扩散了出去…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103401,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-30"}],"nameRight":"旭","textRight":"但是，不幸从我身边@开始出现了…"},{"chara":[{"id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-31"}],"nameRight":"旭","textRight":"首先，本应被守护的@我的同学被魔女杀害了…"},{"chara":[{"id":103401,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-32"}],"nameRight":"旭","textRight":"另一名同学正好也在场@我和他约定过会保护好他们两人"},{"chara":[{"id":103401,"motion":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-33"}],"nameRight":"旭","textRight":"但是，我害得其中一人死去@让另一个人仇恨起了我们"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103401},{"effect":"fadeout","id":103701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103501,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-34"},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103601,"motion":0,"pos":2}],"nameLeft":"亚历山德拉","textLeft":"而且，那时的事故@把很多人都卷了进来…"},{"chara":[{"id":103501,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-35"}],"nameLeft":"亚历山德拉","textLeft":"再加上冬天发生的雪崩@也造成了很多伤亡…"},{"chara":[{"id":103501,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-36"}],"nameLeft":"亚历山德拉","textLeft":"我们也被迫背负起了@那件事的责任"},{"chara":[{"id":103601,"motion":300,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-37"}],"nameRight":"丽","textRight":"不仅如此，魔法少女@会变成魔女的事情也暴露了"},{"chara":[{"id":103601,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-38"}],"nameRight":"丽","textRight":"于是，所有事件和灾害@都被归咎于魔法少女"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103701,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-39"}],"nameLeft":"那由他","textLeft":"那么，@抓住我的那些人的愤怒…"},{"chara":[{"id":103601,"motion":0,"voiceFullAuto":"fullvoice/section_103005/vo_full_103005-8-40"}],"nameRight":"丽","textRight":"也并非毫无根据…"},{"autoTurnLast":2,"bgm":"stop","turnChangeIn":"fadeIn"}]},"version":3}