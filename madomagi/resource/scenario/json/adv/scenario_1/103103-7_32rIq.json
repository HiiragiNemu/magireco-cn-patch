01,"motion":400,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-9"}],"nameLeft":"御影","textLeft":"就算这样我也想挑战@所以帮帮忙吧…！拜托了…！"},{"chara":[{"id":103801,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-10"}],"nameLeft":"御影","textLeft":"咪我们也不是@一开始就关系这么好吧…？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801600,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-11"}],"nameRight":"","textRight":"嗯、嗯…是啊…"},{"chara":[{"id":801600,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-12"}],"nameRight":"","textRight":"当时我们想让小咪远离明日屋…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801300,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-13"}],"nameRight":"","textRight":"我甚至还向咪扔了石头，@做了很过分的事…"},{"chara":[{"id":103801,"motion":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-14"}],"nameLeft":"御影","textLeft":"神滨市还有很多@处于相似情况的人哦"},{"autoTurnLast":0.2,"chara":[{"id":103801,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101801,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-15"}],"nameLeft":"月夜","textLeft":"…在孩子们之间"},{"chara":[{"id":101801,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-16"}],"nameLeft":"月夜","textLeft":"状况也已经让人无比痛心了呢…"},{"chara":[{"id":101801,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-17"},{"id":103801}],"nameLeft":"月夜","textLeft":"小御影…"},{"chara":[{"id":101801,"motion":100,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-18"}],"nameLeft":"月夜","textLeft":"作为西边的年长者，@请你接受我的道歉…"},{"chara":[{"id":103801,"motion":300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-19"}],"nameRight":"御影","textRight":"嗯—…@这个我也有点在意呢"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101801,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-7-20"}],"nameLeft":"月夜","textLeft":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103801,"motion":100,