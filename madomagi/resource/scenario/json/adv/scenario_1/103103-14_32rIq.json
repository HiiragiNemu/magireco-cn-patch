{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21173.jpg","turnChangeIn":"fadeIn"},{"bgm":"bgm02_anime16","nameNarration":"八千代","narration":"「说实话，关于这次见面会的内容@我的心情很复杂」","narrationCoverOpacity":0,"narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-1"},{"autoTurnLast":0.2,"bg":"black","item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_appearance.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"八千代","narration":"虽然对包括在深夜也会提供点滴治疗服务的医院@和对邻近自治体的协助请求在内的@这些属于定例会见的内容没有不满","narrationCoverOpacity":110,"narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-2"},{"narration":"但市长和反社会势力有勾结的事情@和因此辞职的决定@令我不但很震惊，还不禁感到悲伤…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-3"},{"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience1.png","posX":0,"posY":0,"visible":"appear"}],"narration":"虽然很少放到表面上来说，但在神滨市@自古以来，东西之间就存在不和@这些因素也影响到了我们这一代","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-4"},{"autoTurnLast":0.2,"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience1.png","visible":"hide"}]},{"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience2.png","posX":0,"posY":0,"visible":"appear"}],"narration":"虽说是发生了灾害的结果@但我也亲眼看见了人们逐渐凝聚为整体的姿态@因此，在市长选举的影响下再次产生鸿沟的状况@让我实在是目不忍视","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-5"},{"autoTurnLast":0.2,"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience2.png","visible":"hide"}]},{"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience3.png","posX":0,"posY":0,"visible":"appear"}],"narration":"虽然再次填平这个鸿沟很困难@但是，神滨市的学生们@如今正尝试着靠自己取回那份联系","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-6"},{"autoTurnLast":0.2,"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience3.png","visible":"hide"}]},{"item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_audience4.png","posX":0,"posY":0,"visible":"appear"}],"narration":"「创造神滨市未来的学生会议」","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-7"},{"narration":"现在，她们正在为创设这一会议进行署名活动@我也参加到了其中","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-8"},{"autoTurnLast":0.2,"bg":"bg_adv_21563.jpg","chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":103801,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"八千代","narration":"「虽然像宣传一样真的很抱歉@但如果有人愿意帮忙，还请务必进行署名@我已经不想再看到@因为东西的事情而哭泣的友人了…」","narrationBg":"bg_adv_21563.jpg","narrationEffect":"in","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-9"},{"narration":"「所以，如果能靠我们@亲手改变这种状况就太好了」","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-10"},{"autoTurnLast":0.1,"narrationEffect":"out"},{"chara":[{"id":103801,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-11"}],"nameCenter":"御影","textCenter":"你看，姐姐…"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":103801,"motion":100,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-12"}],"nameCenter":"御影","textCenter":"咪我们友好相处的未来@还好好地留存在这里哦…！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103801}],"textClear":1},{"autoTurnLast":2,"chara":[{"cheek":0,"face":"mtn_ex_032.exp3.json","id":121700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_032.exp3.json","id":121600,"motion":0,"pos":0}]},{"autoTurnLast":0.2,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_132.exp3.json","id":101601,"motion":0,"pos":0}],"se":"7205_magic_girl"},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_132.exp3.json","id":101701,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-13"}],"nameRight":"御魂","se":"7205_magic_girl","textRight":"咪…"},{"chara":[{"id":101701,"motion":300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-14"}],"nameRight":"御魂","textRight":"但是，你难道想让我@相信这种署名的数字吗…？"},{"chara":[{"id":101601,"motion":300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-15"}],"nameLeft":"十七夜","textLeft":"而且，也不知道这种事情@是否能创造出携手前行的未来…"},{"nameCenter":"十七夜的弟弟的声音","textCenter":"会的，姐姐","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-16"},{"chara":[{"cheek":0,"face":"mtn_ex_150.exp3.json","id":101601,"motion":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-17"},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":832400,"motion":0,"pos":2}],"nameLeft":"十七夜","textLeft":"——！？@[wait:1.6][chara:121600:lipSynch_1]你…为什么会在这里…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":832400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-18"}],"nameRight":"十七夜的弟弟","textRight":"我从小丽良她们大东小区的人那里@打听到了姐姐的位置"},{"chara":[{"id":832400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-19"}],"nameRight":"十七夜的弟弟","textRight":"然后，走到一半@环小姐她们又把我带到了这里"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100101,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-20"}],"nameLeft":"彩羽","textLeft":"是的，我们在路上会合@然后一起来到了这里"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100501,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-21"}],"nameRight":"菲莉希亚","textRight":"而且，我们还去西边转了一圈@所以可不只有我们几个哦!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100501},{"effect":"fadeout","id":100101}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21563.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800202,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800301,"motion":0,"pos":2}]},{"autoTurnLast":0.3,"chara":[{"effect":"fadeout","id":800301},{"effect":"fadeout","id":800202},{"effect":"fadeout","id":800101}]},{"autoTurnLast":0.1,"bg":"bg_adv_21563.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800102,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":2}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800102},{"effect":"fadeout","id":800400}]},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":101501,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-22"}],"nameLeft":"忧","textLeft":"你有话想对御魂姐姐说吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100301,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-23"}],"nameLeft":"鹤乃","textLeft":"要说就趁现在哦"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-24"}],"nameRight":"","textRight":"嗯、嗯…"},{"chara":[{"cheek":0,"face":"mtn_ex_130.exp3.json","id":101701,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-25"}],"nameLeft":"御魂","textLeft":"你是…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-26"}],"nameRight":"","textRight":"你很恨我…吧…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-27"}],"nameRight":"","textRight":"因为我以前@曾经试图把你从楼梯上推下去…"},{"chara":[{"cheek":0,"face":"mtn_ex_131.exp3.json","id":101701,"lipSynch":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-28"}],"nameLeft":"御魂","textLeft":"…………"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-29"}],"nameRight":"","textRight":"对不起…@明明一切都是我嫉妒的错"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-30"}],"nameRight":"","textRight":"你却遭受了惩罚，@从学校退学了…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-31"}],"nameRight":"","textRight":"我彻底打乱了你的人生计划…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-32"}],"nameRight":"","textRight":"虽然我不认为@自己能恢复那份歪曲…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-33"}],"nameRight":"","textRight":"但是，拜托你了…"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-34"}],"nameRight":"","textRight":"为了阻止同样的不幸再次发生@我会尽全力活下去的"},{"chara":[{"id":800300,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-35"}],"nameRight":"","textRight":"所以请让我帮帮你吧…@就算是为了大家的未来…"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101701},{"effect":"fadeout","id":800300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":832400,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-36"},{"cheek":0,"face":"mtn_ex_132.exp3.json","id":101601,"motion":0,"pos":0}],"nameRight":"十七夜的弟弟","textRight":"是啊…@虽然不知道姐姐想做什么"},{"chara":[{"id":832400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-37"}],"nameRight":"十七夜的弟弟","textRight":"但是，请你不要独自背负一切@并且自暴自弃"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":832400,"motion":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-38"}],"nameRight":"十七夜的弟弟","textRight":"虽然姐姐很难得到理解@但我会努力支撑你来弥补这部分的"},{"chara":[{"id":832400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-39"}],"nameRight":"十七夜的弟弟","textRight":"姐姐和御魂小姐@一起改变东西关系的尝试"},{"chara":[{"id":832400,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-40"}],"nameRight":"十七夜的弟弟","textRight":"从今往后我们也会一起努力的@所以，请你不要独自背负一切"},{"autoTurnLast":1.5,"bgm":"stop","chara":[{"id":101601,"lipSynch":0,"voiceFull":"fullvoice/section_103103/vo_full_103103-14-41"}],"enableSkipAutoTurn":1,"nameLeft":"十七夜","surround":"7003_wind","textLeft":"…………唉…"},{"chara":[{"eyeClose":1,"id":101601,"lipSynch":1,"motion":300}]},{"chara":[{"eyeClose":0,"id":101601,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-42","voiceFullStop":"fullvoice/section_103103/vo_full_103103-14-41"}],"enableSkipAutoTurn":0,"nameLeft":"十七夜","textLeft":"我…我…@有可能确实太笨拙了…"},{"chara":[{"cheek":0,"face":"mtn_ex_133.exp3.json","id":101701,"motion":300,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-43"}],"nameRight":"御魂","textRight":"只要行动的人一变，@情况居然就会发生这么大变化…"},{"chara":[{"id":101601,"motion":0,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-44"}],"nameLeft":"十七夜","textLeft":"是啊…"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100101,"motion":200,"pos":2,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-45"}],"nameRight":"彩羽","textRight":"…观鸟小姐@在留下的视频里说过"},{"chara":[{"id":100101,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-46"}],"nameRight":"彩羽","textRight":"她很羡慕十七夜小姐和御魂小姐"},{"chara":[{"id":100101,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-47"}],"nameRight":"彩羽","textRight":"因为你们能够享受@平等而公平的大东"},{"chara":[{"eyeClose":1,"id":100101,"voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-48"}],"nameRight":"彩羽","textRight":"而这恰恰就是她盼望到@甚至不惜加入Magius的东西"},{"autoTurnLast":0.2,"bg":"black","item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","posX":250,"posY":-60,"scale":1.5,"visible":"appear"}],"surround":"stop","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story15","nameNarration":"十七夜","narration":"―十七夜―@是啊…","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":35,"narrationLineSpace":20,"turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-49"},{"narration":"―十七夜―@就像我因为东西的事情而积累起了悲伤一样@许多人也因为这件事十分难过…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-50"},{"narration":"―十七夜―@明明如此，我却顺从自己的悲叹@无视了其他人心怀的悲叹…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-51"},{"narration":"―十七夜―@这个悲叹的[textYellow:心魔]一定也明白这些吧@包括观鸟君和牧野君的悲叹在内…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-52"},{"narration":"―十七夜―@我看似纵观神滨市的全局@却忽略了离自己最近的人们的悲伤","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-53"},{"narration":"―十七夜―@这和自暴自弃没有任何区别…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-54"},{"narration":"―十七夜―@那么，我说不定已经@一只脚踏入了放弃的境地","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-55"},{"narration":"―十七夜―@但现在我已经明白了@没有必要放弃","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-56"},{"narration":"―十七夜―@今后，我会借助周围的人的力量@努力构筑出没有悲叹的未来","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-57"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","posX":-240,"posY":-60,"scale":1.5,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"御魂","narration":"—御魂—@我的愿望乘载着毁灭的使命@到底会去往何方呢…","narrationAnchor":"bottom","narrationCoverOpacity":110,"narrationEffect":"in","narrationFontSize":30,"narrationLineMargin":10,"narrationLineSpace":20,"turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-58"},{"narration":"—御魂—@这样下去，越是拖延毁灭的瞬间@愿望或许就越是会为了实现而增强力量","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-59"},{"narration":"—御魂—@并给予这个世界@超越神滨市规模的毁灭…","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-60"},{"narration":"—御魂—@镜之魔女的膨大@说不定就是我的愿望造成的哦…？","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-61"},{"nameNarration":"御影","narration":"—御影—@就算这样，给予毁灭的姐姐@看起来还是很痛苦哦？","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-62"},{"narration":"—御影—@那么，还是不要去痛苦的那边比较好","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-63"},{"narration":"—御影—@到那个时候再去想就可以了","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-64"},{"nameNarration":"桃子","narration":"—桃子—@是啊，到了真正要毁灭的时候@我也会和你一起拼命挣扎的","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-65"},{"narration":"—桃子—@没有主动去毁灭的必要@还是主动地去阻止毁灭吧，调整师","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-66"},{"nameNarration":"御魂","narration":"—御魂—@就算我的愿望会杀掉桃子@你也不会恨我吗…？","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-67"},{"nameNarration":"桃子","narration":"—桃子—@我都说过了会和你一起挣扎吧","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-68"},{"narration":"—桃子—@如果就算这样也会毁灭@那么，我会毫无怨言地和你一起毁灭的","voiceFullAuto":"fullvoice/section_103103/vo_full_103103-14-69"},{"autoTurnLast":2,"bgm":"stop","item":[{"path":"resource/scenario/img/part2_chapter10/103103_kanagi_mitama_settle.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"}]},"version":3}