    "chara": [
     {
      "eyeClose": 1,
      "id": 110300,
      "voiceFull": "fullvoice/section_101716/vo_full_101716-2-10",
      "voiceFullStop": "fullvoice/section_101716/vo_full_101716-2-9"
     }
