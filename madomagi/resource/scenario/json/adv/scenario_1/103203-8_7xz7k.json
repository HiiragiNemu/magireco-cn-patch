{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_19301.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":832200,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":104601,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-1"}],"nameRight":"千鹤","textRight":"我会通过露说服她的父亲","turnChangeOut":"fadeOut"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-2"}],"nameLeft":"千鹤的父亲","textBg":"shout","textLeft":"够了，你别插手！"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-3"}],"nameLeft":"千鹤的父亲","textLeft":"我已经撕烂了水名的信札@对面应该也不会善罢甘休"},{"chara":[{"id":104601,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-4"}],"nameRight":"千鹤","textRight":"就算这样！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-5"}],"nameRight":"千鹤","textRight":"我也知道@你们和水名的人关系一直不好"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104601,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-6"}],"nameRight":"千鹤","textRight":"但是，正因如此…！"},{"chara":[{"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-7"}],"nameRight":"千鹤","textRight":"我们才应该欢迎@东西成功联手的现在吧…！"},{"chara":[{"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-8"}],"nameRight":"千鹤","textRight":"不用葬送关系亲密的同伴"},{"chara":[{"id":104601,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-9"}],"nameRight":"千鹤","textRight":"也可以互相吐露直到变成@老头子和老太婆为止的梦想！"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-10"}],"nameLeft":"千鹤的父亲","textLeft":"你太幼稚了，千鹤"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-11"}],"nameLeft":"千鹤的父亲","textLeft":"世界上有很多@比生命更珍贵的东西"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-12"}],"nameLeft":"千鹤的父亲","textLeft":"为了生命@而狩猎其他生命可是常识"},{"chara":[{"id":832200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-13"}],"nameLeft":"千鹤的父亲","textLeft":"不管对动物还是对人@我们都一直是这么做的吧"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104601,"motion":300,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-14"}],"nameRight":"千鹤","textRight":"别把人和动物混为一谈啊…"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104601,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-15"}],"nameRight":"千鹤","textRight":"我要保护现在的奇迹和露@老爸就别急着出风头了"},{"autoTurnLast":2,"bg":"bg_adv_20258.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story07","chara":[{"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-16"}],"nameRight":"千鹤","textRight":"我们撕坏的那封信札…","turnChangeOut":"fadeOut"},{"chara":[{"id":104501,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-17"}],"nameLeft":"露","textLeft":"这件事已经收场了@你们没有斩杀使者真是太好了"},{"chara":[{"id":104601,"motion":300,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-18"}],"nameRight":"千鹤","textRight":"真的很抱歉…"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104501,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-19"}],"nameLeft":"露","textLeft":"…关于东边的情况，@我也对家臣嘱咐过几次"},{"chara":[{"id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-20"}],"nameLeft":"露","textLeft":"但虽说是战神子，@让他们理解我果然还是很困难"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-21"},{"id":104601,"motion":0}],"nameLeft":"露","textLeft":"但是，因为歉收和战争的影响，@我们的国家非常疲敝"},{"chara":[{"id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-22"}],"nameLeft":"露","textLeft":"希望致力于恢复国力的家臣占多数@真是帮大忙了"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104501,"motion":300,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-23"}],"nameLeft":"露","textLeft":"虽说如此，因为这件事结下的怨恨@应该还是很难消除"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-24"}],"nameLeft":"露","textLeft":"而且，越是和父亲关系深厚的人@就越容易盯上千鹤你们"},{"chara":[{"id":104501,"motion":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-25"}],"nameLeft":"露","textLeft":"所以，现在的状况@仍然不容大意…"},{"chara":[{"id":104601,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-26"}],"nameRight":"千鹤","textRight":"就算这样也没关系@没有发生战斗真是太好了…"},{"chara":[{"id":104501,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-27"}],"nameLeft":"露","textLeft":"你的父亲@到现在还没有息怒吗…？"},{"chara":[{"eyeClose":1,"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-28"}],"nameRight":"千鹤","textRight":"他说只要有半点小动作，@就要让这里血流成河…"},{"chara":[{"id":104501,"motion":200,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-29"}],"nameLeft":"露","textLeft":"果然，话语的压力@比我父亲还要强呢…"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":104601,"motion":100,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-30"}],"nameRight":"千鹤","textRight":"但是，说明会重新决定待遇之后@他就冷静一点了"},{"chara":[{"id":104601,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-31"}],"nameRight":"千鹤","textRight":"老爸的耐心姑且还能管到@下一封信札送到为止"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104501,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-32"}],"nameLeft":"露","textLeft":"那么，希望他@务必忍耐到那个时候"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104501,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-33"}],"nameLeft":"露","textLeft":"虽然父亲总是生气@说女人不要插手政事"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":104501,"motion":1,"voiceFullAuto":"fullvoice/section_103203/vo_full_103203-8-34"}],"