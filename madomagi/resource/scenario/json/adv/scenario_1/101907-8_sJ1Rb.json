    "voiceFull": "fullvoice/section_101942/vo_full_101942-3-9",
    "voiceFullStop": "fullvoice/section_101942/vo_full_101942-3-8"
   },
   {
    "narration": "她们想杀掉魔法少女本该保护的人们",
    "voiceFull": "fullvoice/section_101942/vo_full_101942-3-10",
    "voiceFullStop": "fullvoice/section_101942/vo_full_101942-3-9"
   },
   {
