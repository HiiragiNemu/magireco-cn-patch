{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100300,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0,"mouthOpen":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_11091.jpg","bgm":"bgm03_story02","chara":[{"id":100900,"motion":1}],"nameLeft":"鹤乃","nameRight":"玲奈","textRight":"玲奈在网上曾经看到过……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"mouthOpen":0}],"textLeft":"什么什么！？"},{"chara":[{"cheek":0,"id":100900,"mouthOpen":0}],"textRight":"神滨有一个@能一针见血地提出建议的人。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"桃子","textLeft":"建议？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"枫","textLeft":"烦恼咨询……吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"mouthOpen":0}],"textRight":"没错！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"mouthOpen":0}],"textRight":"而且，@听说那个人还开了一家咨询所。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"桃子","textLeft":"也就是说……"},{"chara":[{"cheek":0,"id":100900,"motion":201,"mouthOpen":0}],"textRight":"去问问那个人吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"motion":400,"mouthOpen":0,"pos":0}],"nameLeft":"鹤乃","textLeft":"什么嘛！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":0,"mouthOpen":0}],"textRight":"没办法呀！@玲奈和大家又给不了什么建议！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"桃子","textRight":"不过，这也算是个好办法吧？@能听到别人提的客观意见。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"mouthOpen":0}],"textRight":"或许能成为改变的契机哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100300,"motion":0,"mouthOpen":0}],"nameLeft":"鹤乃","textLeft":"是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"枫","textRight":"有可能哦……@我也觉得这是个好主意。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"玲奈","textLeft":"对吧！？@[chara:100900:effect_emotion_joy_0][se:7222_happy]对吧！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"桃子","textRight":"鹤乃，你觉得呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100300,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"鹤乃","textLeft":"唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100300,"motion":300,"mouthOpen":0}],"textLeft":"确实……去了或许会有收获……@也能转换一下心情……"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100300,"mouthOpen":0}],"textLeft":"去看看吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"玲奈","textRight":"好！@就这么决定了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"mouthOpen":0}],"textRight":"玲奈查到地址后，@会发信息给你的！"},{"chara":[{"cheek":0,"id":100300,"motion":0,"mouthOpen":0}],"textLeft":"嗯，谢谢……@那我今天就先回去了……拜拜。"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":100300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"桃子","textRight":"嗯，辛苦了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"枫","textRight":"再见！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"玲奈","textRight":"玲奈很快就发给你！"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":0,"mouthOpen":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100900,"motion":300}],"nameLeft":"玲奈","textLeft":"呼！@终于解放了……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp