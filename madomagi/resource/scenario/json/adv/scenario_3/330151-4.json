":303001}],"textLeft":"欢迎你们下次再来店里玩哦！"},{"chara":[{"id":303001,"motion":1}],"textLeft":"给，这是购物卡！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301301,"motion":100,"pos":2}],"nameRight":"伊吹丽良","textRight":"好的！"},{"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":301401,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"桑水清佳","textRight":"…………"},{"chara":[{"id":301401,"lipSynch":1}],"nameRight":"桑水清佳","textRight":"好、好的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":400,"pos":0}],"nameLeft":"春名木乃美","textLeft":"[chara:303001:effect_emotion_surprise_0][se:7226_shock]第一次听到你说话呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301301,"motion":200,"pos":2}],"nameRight":"伊吹丽良","textRight":"她好像拼尽全力了呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301501,"motion":200,"pos":2}],"nameRight":"相野未都","textRight":"我一定会来的！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303001,"motion":1,"pos":0}],"nameLeft":"春名木乃美","textLeft":"等你们哦！"},{"nameNarration":"相野未都","narration":"在「绽放」帮忙的事@就这样顺利结束了！","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"不过，在这个时候，我呢……@想到了一个好点子！"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":4.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301501,"motion":1,"pos":1,"voice":"vo_char_3015_00_03","textHome":"只要每天能欢笑，那就是幸福了吧！啊哈！"}],"nameCenter":"相野未都","textCenter":"只要每天都能欢笑，@就会很幸福了呢！啊哈！","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"id":301501,"motion":400}]},{"chara":[{"id":301501}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}