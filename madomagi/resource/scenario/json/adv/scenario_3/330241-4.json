{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_12071.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":300902,"lipSynch":0}],"nameCenter":"胡桃爱香","surround":"7001_birdsong","textCenter":"（纺已经有五天没来了……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":300902,"lipSynch":0}],"nameCenter":"胡桃爱香","textCenter":"（她以前明明天天都会来这里……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":1,"pos":2,"soulGem":0}],"nameRight":"若菜纺","textRight":"爱香！","turnEffect":"stop"},{"chara":[{"id":300902,"lipSynch":0,"motion":300}],"nameCenter":"胡桃爱香","textCenter":"（是不是我之前说得太过分了……）","turnEffect":"thinking"},{"chara":[{"id":300902,"lipSynch":0}],"nameCenter":"胡桃爱香","textCenter":"（难道她已经@吃腻我做的饭菜了吗……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302401,"motion":400,"mouthOpen":1}],"nameRight":"若菜纺","surround":"stop","textBg":"shout","textRight":"爱香！！","turnEffect":"stop"},{"bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"lipSynch":1,"motion":400,"pos":0},{"id":302401,"mouthOpen":0}],"nameLeft":"胡桃爱香","textLeft":"哇！是、是你啊？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"motion":0,"pos":2}],"nameRight":"若菜纺","textRight":"你怎么在发呆啊？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"不好意思……我刚才在想事情。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":100,"pos":2}],"nameRight":"若菜纺","textRight":"不说这个了，@爱香，麻烦来一份便当！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":100,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"来，请拿好。@这刚好是最后一个。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"说起来，你居然会来买我的便当……"},{"chara":[{"id":300902,"motion":0}],"nameLeft":"胡桃爱香","textLeft":"真罕见啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":1,"pos":2}],"nameRight":"若菜纺","textRight":"其实我以前就很想买你的特制便当。"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"可等我吃完妈妈做的便当后，@爱香的便当也差不多卖完了。"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"所以我今天就速战速决，@一吃完就过来买啦。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":400,"pos":2}],"nameRight":"若菜纺","textRight":"那我就不客气啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":400,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"等等，你别站着吃啊！@我们去找个地方坐下来吧。"},{"autoTurnLast":1.0,"bg":"bg_adv_12081.jpg","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":0,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":302401,"motion":100}],"nameRight":"若菜纺","textRight":"[chara:302401:effect_emotion_joy_0][se:7222_happy]嗯～爱香做的饭菜@就算冷掉了也好好吃哦！","turnChangeOut":"fadeOut"},{"chara":[{"id":300902,"lipSynch":0,"motion":200}],"nameLeft":"胡桃爱香","textLeft":"（她还是吃得那么香啊……）","turnEffect":"thinking"},{"chara":[{"eyeClose":1,"id":300902,"lipSynch":0}],"nameLeft":"胡桃爱香","textLeft":"（看来她没有吃腻我做的饭菜……@太好了。）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0,"pos":2}],"nameRight":"若菜纺","textRight":"爱香，怎么了？@我脸上有什么东西吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":1,"motion":0}],"nameLeft":"胡桃爱香","textLeft":"有啊……"},{"chara":[{"id":300902}],"nameLeft":"胡桃爱香","textLeft":"你脸上不仅有米粒和鸡蛋，@还有番茄酱和土豆沙拉……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":100,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"等等，@便当里的菜你全都往脸上沾了个遍啊！"},{"chara":[{"id":300902}],"nameLeft":"胡桃爱香","textLeft":"你到底是怎么做到的？！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":1,"pos":2}],"nameRight":"若菜纺","textRight":"嘿嘿，我好久没吃爱香做的饭了嘛，@太好吃了就不小心沾上了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"lipSynch":0,"motion":0}],"nameLeft":"胡桃爱香","textLeft":"（纺真的吃得津津有味啊……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":0,"motion":300}],"nameLeft":"胡桃爱香","textLeft":"（不管怎么说……）"},{"chara":[{"id":300902,"lipSynch":0}],"nameLeft":"胡桃爱香","textLeft":"（看她吃得这么高兴，@其实我也很开心……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":400,"pos":2}],"nameRight":"若菜纺","textRight":"我吃饱啦！真的好好吃呀！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0,"pos":2}],"nameRight":"若菜纺","textRight":"咦，你怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"lipSynch":1,"motion":400}],"nameLeft":"胡桃爱香","textLeft":"没、没什么！"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":302401,"motion":100}],"nameRight":"若菜纺","textRight":"呼～"},{"chara":[{"eyeClose":0,"id":302401}],"nameRight":"若菜纺","textRight":"要是我今天没吃到爱香的便当……"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"那我肯定会一蹶不振的！"},{"chara":[{"id":300902,"motion":1}],"nameLeft":"胡桃爱香","textLeft":"那你放学之后来我店里不就好了……"},{"chara":[{"id":302401,"motion":0}],"nameRight":"若菜纺","textRight":"我也想来啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302401,"motion":200,"pos":2}],"nameRight":"若菜纺","textRight":"这可是个艰难的抉择！"},{"chara":[{"id":300902,"motion":100}],"nameLeft":"胡桃爱香","textLeft":"到底是怎么回事？"},{"chara":[{"id":302401,"motion":400}],"nameRight":"若菜纺","textRight":"你看这个！"},{"chara":[{"id":300902}],"nameLeft":"胡桃爱香","textLeft":"唔，那是因为……"},{"chara":[{"id":300902,"motion":200}],"nameLeft":"胡桃爱香","textLeft":"这是你经常投稿的点评网站吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":100,"pos":2}],"nameRight":"若菜纺","textRight":"嗯，我最近听取了莉爱学姐的建议。"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"正在努力练习写点评，@在网站上发了不少东西哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":200,"pos":2}],"nameRight":"若菜纺","textRight":"这就是『纺的升级大作战』！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"阿见学姐又给你灌输了@什么奇怪的知识吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"pos":2}],"nameRight":"若菜纺","textRight":"才不奇怪啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":1,"pos":2}],"nameRight":"若菜纺","textRight":"我准备去点评各式各样的店铺@来提高自己的水平。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"pos":2}],"nameRight":"若菜纺","textRight":"然后成为有名的评论家！"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"我希望能靠我的一句点评，@就能让Walnuts变得门庭若市！"},{"chara":[{"id":300902,"motion":200}],"nameLeft":"胡桃爱香","textLeft":"这还是挺困难的吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":200,"pos":2}],"nameRight":"若菜纺","textRight":"只要努力就一定会实现的啦！"},{"chara":[{"id":302401}],"nameRight":"若菜纺","textRight":"而且我最近也越来越擅长写点评了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":400,"pos":2}],"nameRight":"若菜纺","textRight":"你看！我还涨了一些粉丝呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":0,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"还真是……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":0,"pos":2}],"nameRight":"若菜纺","textRight":"只要继续努力，我就肯定能帮上忙。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":100,"pos":2}],"nameRight":"若菜纺","textRight":"你就等着我的好消息吧！"},{"autoTurnLast":0.1,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"motion":0,"pos":1,"soulGem":0,"voice":"vo_char_3024_00_03","textHome":"美味的饭店却要惨遭倒闭什么的…我绝不允许@！"}],"nameCenter":"若菜纺","textCenter":"我绝不会让这么好的店倒闭！","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302401,"motion":200}]},{"chara":[{"id":302401}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}