{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_21161.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":800300}],"nameRight":"濑奈命","textRight":"我叫濑奈命。","turnChangeOut":"fadeOut"},{"chara":[{"id":800300}],"textRight":"我勉强算是个魔法少女，@你应该……也是吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":0}],"nameLeft":"更纱帆奈","textLeft":"是、是的……"},{"chara":[{"id":800300}],"textRight":"哇～我第一次见到别的魔法少女！"},{"chara":[{"id":800300}],"textRight":"除了我果然还有别的魔法少女呢！"},{"chara":[{"id":301800,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800300}],"textRight":"…………@[chara:800300:lipSynch_0][wait:1.0][chara:800300:lipSynch_1]请问……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800}],"textLeft":"什、什么？"},{"chara":[{"id":800300}],"textRight":"能告诉我你叫什么吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"id":301800,"motion":300}],"textLeft":"……更纱帆奈。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300}],"textRight":"诶？你叫帆奈吗！？"},{"chara":[{"id":301800}],"textLeft":"是、是啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300}],"textRight":"哇，我们的名字很像呢！@你叫帆奈，我叫濑奈！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":0}],"textLeft":"啊？"},{"chara":[{"id":800300}],"textRight":"请多指教！@我可以叫你“帆奈”吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800}],"textLeft":"……随你便。"},{"chara":[{"id":800300}],"textRight":"你叫我“命”就好！"},{"chara":[{"id":301800,"lipSynch":0,"motion":1}],"textLeft":"…………"},{"chara":[{"id":301800}],"textLeft":"……濑奈。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300}],"textRight":"啊，你要叫我姓吗！？"},{"chara":[{"id":301800}],"textLeft":"不行吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300}],"textRight":"没、没有！完全OK哦！"},{"nameNarration":"更纱帆奈","narration":"濑奈这之后说想跟我组队作战@她说单打独斗不太放心","narrationBg":"black","narrationEffect":"in"},{"narration":"我接受了她的提案@说实话，我这边的情况也挺棘手的……"},{"narration":"直截了当地说@我当时决定利用濑奈减轻战斗负担！啊哈！"},{"narration":"总之，我和濑奈就这样组成了搭档"},{"narration":"我最初的转机是成为魔法少女……"},{"narration":"而下一个转机便是与濑奈的相遇吧～"},{"autoTurnFirst":5.2,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_03","textHome":"……哈哈……已经无所谓了，@真的……各方各面……"}],"nameCenter":"更纱帆奈","narrationEffect":"out","textCenter":"哈哈……都无所谓，@什么都无所谓了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301800}]},{"chara":[{"id":301800}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}