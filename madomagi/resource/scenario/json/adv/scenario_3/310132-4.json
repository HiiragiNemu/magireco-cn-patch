{"story":{"group_1":[{"bg":"black","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":1}],"nameCenter":"龙城明日香","textCenter":"我之所以担心堂兄阁下……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101301,"motion":100,"mouthOpen":0}],"textCenter":"是因为他或许会因此当不了警察！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"mouthOpen":0}],"textCenter":"就是这样……"},{"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"mouthOpen":0,"pos":2}],"nameLeft":"龙城明日香","nameRight":"菲莉希亚","textRight":"嗯？@为什么？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"id":100501,"motion":100,"mouthOpen":0}],"textRight":"啊！担心他因为父亲的问题，@所以不去参加考试……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"mouthOpen":0}],"textRight":"咦？@但他不是说了会参加吗？"},{"chara":[{"cheek":0,"id":101301,"mouthOpen":0}],"textLeft":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"mouthOpen":0}],"textRight":"担心他无心学习……@会考不上？"},{"chara":[{"cheek":0,"id":101301,"motion":300,"mouthOpen":0}],"textLeft":"堂兄阁下各方面都很优秀，@只要参加考试就一定能过……"},{"chara":[{"cheek":0,"id":100501,"motion":1,"mouthOpen":0}],"textRight":"嗯？@那又是为什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"然后明日香就……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101301,"motion":100,"mouthOpen":1}],"textLeft":"啊啊！@我明明说了自己来的！"},{"chara":[{"cheek":0,"id":300401,"mouthOpen":0}],"textRight":"我怕堂兄父亲犯下的罪，@可能会让他无法当上警察。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"哦……@这样啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300401,"motion":200,"mouthOpen":0}],"textRight":"不对不对！@才不会发生这种事！"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":300401,"mouthOpen":0}],"textRight":"现在哪还有让@子女去替父母承担罪责的啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401,"motion":1,"mouthOpen":0,"tear":0}],"textRight":"虽然有舆论的压力……"},{"chara":[{"cheek":0,"id":300401,"mouthOpen":0}],"textRight":"总之，你堂兄不会因为自己父亲@犯下的过错当不上警察啦……"},{"chara":[{"cheek":0,"id":100501,"motion":400,"mouthOpen":1}],"textLeft":"啊！@[chara:100501:effect_emotion_surprise_0][se:7226_shock]是这样吗！「[textRed:明日香的臆想]」！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":200,"mouthOpen":0}],"textRight":"对，就是这样！@只是她自己这样认为的！"},{"chara":[{"cheek":0,"id":300401,"mouthOpen":0}],"textRight":"就在明日香烦恼、纠结的时候，@就遇见了……"},{"bg":"black","chara":[{"id":810000,"motion":0,"pos":0,"posX":-50}],"nameLeft":"丘比","textLeft":"嗨，龙城明日香。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"bg":"bg_adv_21141.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"mouthOpen":0,"pos":2}],"nameLeft":"龙城明日香","nameRight":"菲莉希亚","textRight":"所以明日香许的愿望是？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":300,"mouthOpen":0}],"textLeft":"让我的堂兄当上警察。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401,"motion":1,"mouthOpen":0,"pos":0}],"nameLeft":"美凪纱纱罗","textLeft":"明日香就是因此当上@魔法少女的。"},{"chara":[{"cheek":0,"id":300401,"motion":100,"mouthOpen":0}],"textLeft":"就因为自己的臆想？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100501,"motion":100,"mouthOpen":0}],"textRight":"哈～@原来是这样啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"龙城明日香","textLeft":"但是！堂兄有可能真的@因为那件事当不上警察！"},{"chara":[{"id":101301,"motion":200,"mouthOpen":0}],"textLeft":"所以说！@无所谓啦！就结果而言！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"嗯，这件事本身@是还好啦。"},{"chara":[{"cheek":0,"id":300401,"motion":200,"mouthOpen":0}],"textRight":"但真没想到，@契机居然是自己的臆想……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100501,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"菲莉希亚","textRight":"哈哈哈！@明日香真是太冒失了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"lipSynch":0,"motion":0,"mouthOpen":0}],"textLeft":"…………"},{"chara":[{"cheek":2,"id":101301,"lipSynch":1,"mouthOpen":1,"tear":1}],"textLeft":"我、我要自杀！"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401,"motion":200,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"啊，好了好了，@快停下吧？"},{"chara":[{"id":101301,"motion":300,"mouthOpen":0}],"textLeft":"呜呜呜……"},{"chara":[{"cheek":0,"id":300401,"motion":1,"mouthOpen":0}],"textRight":"好了，说了这么多题外话……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401,"mouthOpen":0}],"textRight":"我们真正要讨论的是其他事情吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":1,"mouthOpen":0,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"嗯？是要说什么来着？"},{"chara":[{"cheek":0,"id":300401,"motion":200,"mouthOpen":0}],"textRight":"明日香想不起来的情报！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100501,"motion":100,"mouthOpen":0}],"textLeft":"哦，对，@就是这个！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"龙城明日香","textLeft":"关于这件事，@就交给我吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101301,"motion":200,"mouthOpen":0}],"textLeft":"我想出对策了！"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":101301,"motion":300,"pos":1,"voice":"vo_char_1013_00_04","textHome":"虽然很不想用这招……但没有办法了！"}],"nameCenter":"龙城明日香","textCenter":"我本不想使用这个手段，@但是……没别的选择了！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":101301,"motion":0}]},{"chara":[{"id":101301}]},{"autoTurnLast":2.0,"turnCh