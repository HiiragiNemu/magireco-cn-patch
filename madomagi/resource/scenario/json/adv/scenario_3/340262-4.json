{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_20231.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"nameNarration":"","narration":"＜神圣罗马帝国＞","narrationCoverOpacity":50.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"＜龙骑士团据点＞"},{"autoTurnLast":0.01,"bg":"bg_adv_20121.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0,"pos":0}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story06","chara":[{"id":831100}],"nameRight":"佩蕾奈尔·弗拉梅尔","textRight":"怎么样？","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":1}],"nameLeft":"爱丽莎·瑟尔斯加","textLeft":"暂时没事。"},{"chara":[{"id":402601}],"textLeft":"母亲大人……@不，芭芭拉皇妃她没事。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":200}],"textLeft":"我亲眼确认了情况，@并要求加强警备。"},{"chara":[{"id":831100}],"textRight":"骑士团里也没什么不对劲的地方。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100}],"textRight":"所以幕后黑手的目的是@爱丽莎小姐的性命？"},{"chara":[{"id":831100}],"textRight":"丘卜，你怎么看？"},{"autoTurnLast":0.01,"turnChangeIn":"rollInFast"},{"autoTurnLast":1.3,"turnChangeOut":"rollOutFast"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":831100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":402601,"motion":0,"pos":0}],"turnChangeIn":"rollInFast"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":831100}],"textRight":"[chara:831100:effect_emotion_surprise_0][se:7226_shock]咦？","turnChangeOut":"rollOutFast"},{"chara":[{"id":831100}],"textRight":"丘卜它去哪了？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402601,"motion":100}],"textLeft":"大概是被我吓跑了吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100}],"textRight":"难办了呢。"},{"chara":[{"id":831100}],"textRight":"接下来可能会需要@用到丘卜的智慧……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":1}],"textLeft":"哼！"},{"textLeft":"我可没打算要借助它的智慧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402601,"motion":300}],"textLeft":"比起这个，@我现在更担心龙骑团。"},{"chara":[{"id":831100}],"textRight":"嗯。"},{"chara":[{"id":831100}],"textRight":"就像是捅了马蜂窝一样@闹得不可开交呢。"},{"autoTurnLast":0.01,"bg":"bg_adv_20103.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":830300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":830400,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_050.exp.json","id":830500,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":830300,"mouthOpen":1}],"nameNarration":"","narration":"「这是真的吗！」","narrationCoverOpacity":150.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":830400,"mouthOpen":1},{"id":830300,"mouthOpen":0}],"narration":"「万万没想到皇帝陛下之剑——@龙骑士团里」"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":830500,"mouthOpen":1},{"id":830400,"mouthOpen":0}],"narration":"「竟然会有叛徒……」"},{"autoTurnLast":0.01,"bg":"bg_adv_20121.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0,"pos":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100}],"textRight":"既然已经找到伪造的信件@这个确凿的证据……","turnChangeOut":"fadeOut"},{"chara":[{"id":831100}],"textRight":"那就说明叛徒要不就是@把信件带进来的宫廷的人……"},{"chara":[{"id":831100}],"textRight":"要不就是骑士团内部的人。"},{"chara":[{"eyeClose":1,"id":402601}],"textLeft":"现在唯一值得信任的@沃尔爷爷不在……"},{"chara":[{"eyeClose":0,"id":402601,"motion":200}],"textLeft":"看来只能由我们自己来找出犯人。"},{"chara":[{"id":831100}],"textRight":"爱丽莎小姐，你打算做什么？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402601,"motion":300}],"textLeft":"我想想……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0}],"textLeft":"把嫌疑人聚起来……"},{"chara":[{"id":402601}],"textLeft":"然后开始查问吧。"},{"autoTurnFirst":2.7,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402601,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_4026_00_04","textHome":"真是怎么看都很可疑的家伙。"}],"nameCenter":"爱丽莎·瑟尔斯加","textCenter":"感觉都很可疑呢。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":1.8,"chara":[{"eyeClose":1,"id":402601}]},{"chara":[{"id":402601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}