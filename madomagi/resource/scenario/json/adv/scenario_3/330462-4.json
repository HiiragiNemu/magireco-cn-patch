{"story":{"group_1":[{"autoTurnLast":0.1,"bg":"bg_adv_21025.jpg","bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800302,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800302}],"nameCenter":"","textCenter":"你光看镇上的评价和大人们的态度@就能明白了吧？","turnChangeOut":"fadeOut"},{"chara":[{"id":800302}],"textCenter":"只要你是大东人，@别人就不会信你啊！"},{"nameNarration":"观鸟令","narration":"观鸟我受不了这些话，转身就跑走了@之后我跑进了@空荡荡的化学社活动室","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"autoTurnLast":2.0,"bg":"bg_adv_21023.jpg","chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":304601,"motion":0,"pos":1,"tear":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":304601,"lipSynch":0}],"nameCenter":"观鸟令","textCenter":"…………","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"pos":1}],"nameNarration":"","narration":"喀嚓","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"id":300301}],"nameCenter":"都雏乃","narrationEffect":"out","textCenter":"嗯？@有谁在吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"lipSynch":0,"motion":400}],"textCenter":"！？"},{"chara":[{"id":300301}],"textCenter":"你是……令！？@你躲在角落里干什……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200}],"textCenter":"你是在等拍摄时机吗！？@我今天可不会失败哦！"},{"autoTurnLast":0.2,"chara":[{"id":300301,"pos":2}],"textClear":1},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":304601,"lipSynch":0,"motion":1,"pos":0}],"nameLeft":"观鸟令","nameRight":"都雏乃","textLeft":"（雏乃来了……@怎么办……我也没那个力气动了……）","turnEffect":"thinking"},{"chara":[{"id":300301,"lipSynch":0}],"textRight":"…………[wait:0.8][chara:300301:motion_0][chara:300301:cheek_0][chara:300301:face_mtn_ex_030.exp.json][chara:300301:lipSynch_1]怎么了？@感觉你今天没什么精神啊。","turnEffect":"stop"},{"chara":[{"id":304601}],"textLeft":"没什么……"},{"chara":[{"id":300301,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textRight":"你要是不介意的话，@可以跟我说说哦。"},{"chara":[{"id":304601,"motion":200}],"textLeft":"我就算说了……@你也不会懂的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":1}],"textRight":"或许是吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textRight":"不过，既然我们都是魔法少女，@那我可能会比其他人要了解你一点。"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":304601,"motion":0}],"textLeft":"诶？魔法少女？"},{"chara":[{"id":300301,"motion":0}],"textRight":"你是第一次遇见其他魔法少女吗？"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":304601}],"textLeft":"嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"nameNarration":"观鸟令","narration":"我是第一次遇到魔法少女@或许也是出于这个原因","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"观鸟我才会跟雏乃说了各种各样的事@包括我许下的愿望@以及身为大东人遭到的歧视"},{"chara":[{"id":304601}],"narrationEffect":"out","textLeft":"然后我就逃了出来……"},{"chara":[{"id":300301,"motion":300}],"textRight":"这样啊。"},{"chara":[{"id":304601,"motion":1}],"textLeft":"我问你啊，你有庆幸自己成为@魔法少女的时候吗？"},{"chara":[{"id":300301,"motion":0}],"textRight":"有哦。"},{"chara":[{"id":304601}],"textLeft":"那你有没有想过如果@自己没成为魔法少女就好了呢？"},{"chara":[{"id":300301}],"textRight":"有哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":1}],"textRight":"我好歹当了这么久的魔法少女，@也经历了不少事嘛。"},{"chara":[{"id":300301}],"textRight":"经历过好事，自然也碰见过坏事啊。"},{"chara":[{"eyeClose":1,"id":304601}],"textLeft":"那你不会觉得……痛苦吗？"},{"chara":[{"eyeClose":0,"id":304601,"motion":200}],"textLeft":"在你觉得庆幸之后就遇上了烦心事，@你不觉得痛苦吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"我会觉得痛苦啊，@也有过痛苦到想要逃离的时候。"},{"chara":[{"id":300301,"motion":300}],"textRight":"尤其是……遇上了无能为力的事……"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":304601,"motion":0}],"textLeft":"无能为力的事？@[chara:304601:lipSynch_0][wait:0.8][chara:304601:cheek_2][chara:304601:face_mtn_ex_030.exp.json][chara:304601:lipSynch_1]那是什么事？"},{"chara":[{"eyeClose":1,"id":300301,"lipSynch":0}],"textRight":"…………"},{"chara":[{"eyeClose":0,"id":300301,"motion":0}],"textRight":"我不太想回忆过去，不过……@跟你说这些也能解决你的烦恼……"},{"nameNarration":"观鸟令","narration":"雏乃喃喃自语般地低声讲了起来@从她口中我得知了@当时在魔女稀少的神滨东西两边@发生的领地之争以及事情的原委","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"id":304601,"motion":1}],"narrationEffect":"out","textLeft":"在魔法少女的世界里@中央区深受蔑视……"},{"chara":[{"id":300301,"motion":1}],"textRight":"与其说是蔑视，不如说是……@别人认为中央区没有后盾。"},{"chara":[{"id":300301}],"textRight":"甚至有人认为，@比起寻找为数不多的魔女，"},{"chara":[{"id":300301}],"textRight":"不如从没有后盾的弱小魔法少女手中@抢走悲叹之种，这样更容易存活。"},{"chara":[{"id":304601,"motion":0}],"textLeft":"那种做法不好吧？"},{"chara":[{"id":300301,"motion":300}],"textRight":"是啊……"},{"chara":[{"id":300301}],"textRight":"但在当时，@所有人都为了生存而拼尽了全力。"},{"chara":[{"id":304601}],"textLeft":"你觉得是无可奈何的吗？"},{"chara":[{"id":304601,"motion":200}],"textLeft":"你觉得她们被欺凌@也是没办法的事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200}],"textRight":"我可不这么想！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"textRight":"我现在也希望那时@能得到更强的力量……"},{"chara":[{"id":300301}],"textRight":"那样的话……@应该就能做到更多事了吧。"},{"chara":[{"eyeClose":1,"id":304601,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":0}],"textRight":"只不过，这世上并不只有@“对错”这一个衡量标准。"},{"chara":[{"id":300301}],"textRight":"有时光靠“正确”做事是行不通的。"},{"chara":[{"id":304601,"lipSynch":0,"motion":300}],"textLeft":"…………@[wait:1.5][chara:304601:eyeClose_0][chara:304601:lipSynch_1]好难啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":1}],"textRight":"是啊，很难。@比复杂的化学式麻烦多了。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301}],"textRight":"可我们也只能去面对。"},{"chara":[{"id":300301}],"textRight":"自己好好想想，@然后找到让自己满意的答案吧。"},{"chara":[{"id":304601,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"我说这些可不是让你@现在就马上去做点什么哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textRight":"在得出结论前@多花点时间想想也好。"},{"chara":[{"id":304601}],"textLeft":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200}],"textRight":"不过，不能因为事情难办@就让别人替你做决定啊。"},{"chara":[{"id":300301}],"textRight":"你可以听取别人的意见，@但要保证做决定的人是你自己。"},{"bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304601}],"textLeft":"自己决定……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0}],"textRight":"是啊，毕竟人生也好，靠契约得到的@能力也好，都是你自己的东西嘛。"},{"chara":[{"eyeClose":1,"id":304601,"lipSynch":0,"motion":300}],"textLeft":"（人生和能力……都是我自己的……@[wait:0.8][chara:304601:eyeClose_1][chara:304601:cheek_2][chara:304601:face_mtn_ex_030.exp.json]对……没错……嗯。）","turnEffect":"thinking"},{"bgm":"bgm03_story18","chara":[{"eyeClose":0,"id":304601,"motion":0}],"textLeft":"我要自己思考……想怎么做……","turnEffect":"stop"},{"chara":[{"id":304601,"lipSynch":0}],"textLeft":"…………[wait:0.8][chara:304601:lipSynch_1]我明白。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300}],"textRight":"对了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0}],"textRight":"你因为大东人的身份而烦恼，@那就去见见和泉十七夜吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":304601,"motion":1}],"textLeft":"和泉……十七夜？"},{"chara":[{"id":300301}],"textRight":"她就像是东边魔法少女们的领袖。"},{"chara":[{"id":300301}],"textRight":"她一定会认真听你倾诉的。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":304601}],"textLeft":"我去见见她……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300301,"motion":100}],"textRight":"好！"},{"chara":[{"id":300301}],"textRight":"那你今天就早点回家，@吃饭洗澡睡觉吧。"},{"chara":[{"id":300301}],"textRight":"累的时候就该这么做。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":304601,"motion":100}],"textLeft":"哈哈，你说这些干嘛啦。@你这么娇小，说话却像个老妈子。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200}],"textBg":"shout","textRight":"“娇小”这两个字是多余的！"},{"nameNarration":"观鸟令","narration":"我跟雏乃谈了心","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"与十七夜见了面"},{"narration":"观鸟我该如何使用通过许愿获得的力量@该如何接受自己大东人的身份@我好好思考了这些问题"},{"autoTurnLast":2.0,"bg":"bg_adv_17051.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304601,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"thinking"},{"chara":[{"id":304601,"lipSynch":0}],"nameCenter":"观鸟令","textCenter":"（我既没法像雏乃一样坚强，）","turnChangeOut":"fadeOut"},{"chara":[{"id":304601,"lipSynch":0}],"textCenter":"（也没法像十七夜一样率真，）"},{"chara":[{"id":304601,"lipSynch":0}],"textCenter":"（所以我只能以我的方式继续前进。）"},{"chara":[{"id":304601,"lipSynch":0}],"textCenter":"（大东人生来便遭受不公待遇，）"},{"chara":[{"id":304601,"lipSynch":0,"motion":200}],"textCenter":"（而我与丘比相遇，获得了奇迹。）"},{"chara":[{"id":304601,"lipSynch":0}],"textCenter":"（就当这两件事已经抵消了吧。）"},{"chara":[{"eyeClose":1,"id":304601,"lipSynch":0}],"textCenter":"（因为……我……@观鸟我要……）"},{"chara":[{"eyeClose":0,"id":304601,"motion":400,"mouthOpen":1}],"textBg":"shout","textCenter":"我要用许愿得到的力量@去告诉人们真相！","turnEffect":"stop"},{"chara":[{"id":304601,"motion":1,"mouthOpen":0}],"textCenter":"这与善恶无关，"},{"chara":[{"id":304601}],"textCenter":"我只想拍下真相，传递真相。"},{"chara":[{"id":304601,"motion":200}],"textCenter":"我不管外人的闲言碎语。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601}],"textCenter":"我要传递真相，无论它是好是坏。"},{"chara":[{"id":304601,"motion":400}],"textBg":"shout","textCenter":"我要为此使用许愿获得的力量！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304601,"mouthOpen":1}],"textBg":"shout","textCenter":"无论多么细微的事实，@都要用相机拍下来传达给所有人！"},{"nameNarration":"观鸟令","narration":"我下定决心之后……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"成立了八卦社……@准确地说，是新闻社"},{"autoTurnLast":0.5,"bg":"bg_adv_21025.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":304601,"motion":200}],"textCenter":"好！","turnChangeOut":"fadeOut"},{"nameNarration":"观鸟令","narration":"这也让观鸟我下了新的决心","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"bgm":"stop","narration":"那时我还对之后将迎来的绝望……@也就是魔法少女的真相一无所知","narrationBg":"black"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":2.2,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304601,"motion":200,"pos":1,"voice":"vo_char_3046_00_04","textHome":"一定要掌握证据，这就是我的信条。"}],"nameCenter":"观鸟令","textCenter":"我一定要掌握证据@这就是观鸟我的信条","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601}]},{"chara":[{"id":304601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}