{"story":{"group_1":[{"bg":"bg_adv_21143.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":0}],"nameLeft":"美国织莉子","textRight":"——！！@魔法少女！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100},{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":2}],"nameRight":"？？？","textLeft":"……！"},{"bgm":"bgm01_anime05","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（出现了……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0,"motion":200}],"textLeft":"（你和@佐仓杏子一样……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100},{"effect":"fadeout","id":300700,"lipSynch":0}],"textLeft":"（也是出现在我的预知梦中的@魔法少女之一……）"},{"bg":"bg_adv_20023.jpg","chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":200,"pos":2}],"nameLeft":"杏子","nameRight":"？？？","textLeft":"雫？@为什么……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0}],"textRight":"由麻她！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textLeft":"诶！？@[chara:200601:motion_400]由麻！？"},{"bg":"bg_adv_21143.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"美国织莉子","textLeft":"（我们贵重的棋子——）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（千岁由麻的@救世主，佐仓杏子……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（就让你来担任@救世主的向导吧。）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":300},{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":2}],"nameRight":"？？？","textLeft":"哎呀，幸会。@你是这座城市的魔法少女吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"嗯……@你不是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":0}],"textLeft":"嗯，我的领地@是别的城市。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"那你也是来神滨……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":0}],"textLeft":"我“也”？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"最近有很多……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300}],"textRight":"像你这样……@从外地来的魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"lipSynch":0}],"textLeft":"（——！！@[chara:400100:cheek_0:face_mtn_ex_020.exp.json]果然……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（不止是见泷原……@各地的魔法少女都聚集到了神滨？）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100}],"textLeft":"是这样吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700,"motion":0}],"textRight":"？@你……[chara:300700:cheek_0:face_mtn_ex_000.exp.json]不也是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"魔女都聚集到了神滨……@大家都是来这里狩猎魔女的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（“魔女聚集”！？）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100}],"textLeft":"魔女聚集？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"正好最近……@大量魔女都聚集到了神滨……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（魔女和魔法少女@都聚集到了这座城市？）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"lipSynch":0}],"textLeft":"（果然，神滨……@发生了什么异常现象……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100}],"textLeft":"是这样啊……","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100}],"textLeft":"谢谢你告诉我这些。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":300}],"textLeft":"既然这样，@我就必须绷紧神经了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"你不知道魔女聚集的事吗？@那又是为什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"如果不是为了狩猎魔女……@为什么要来这座城市？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":0}],"textLeft":"我是为了找一个魔法少女，@来到这座城市的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":200}],"textLeft":"不过……来到这里之后，@我就跟丢了……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"是……@什么样的魔法少女？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300}],"textLeft":"是个年纪很小的魔法少女。@她的名字叫做由麻……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":101}],"textRight":"“由麻”……"},{"bg":"bg_adv_13043.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200600,"motion":0,"pos":1}],"nameCenter":"杏子","textCenter":"我答应过她@晚饭前就会回去……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200600}],"textCenter":"希望由麻她@不要嚎啕大哭啊……"},{"bg":"bg_adv_21143.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":0,"pos":0}],"nameLeft":"美国织莉子","nameRight":"？？？","textRight":"是佐仓认识的人？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100}],"textLeft":"“佐仓”？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"我在一个熟人那里@听过这个名字……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100}],"textLeft":"你是说……@佐仓……杏子？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}],"textRight":"你认识@佐仓吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300}],"textLeft":"由麻她，经常提起@一位杏子小姐。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100}],"textRight":"那么，果然……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":0}],"textLeft":"你见过@佐仓吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":300}],"textRight":"还是跟佐仓@说一声比较好……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":200}],"textLeft":"是啊……@在这座魔女聚集的城市……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300}],"textLeft":"要是真迷路了，@那可是很危险的……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0}],"textRight":"那么……@我这就去告诉佐仓……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0}],"textLeft":"好的，我继续@在城市里找找！"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_04","textHome":"竟然把自己投身于危险之中。人的想法真是@不可思议。"}],"nameCenter":"美国织莉子","textCenter":"竟然自己主动迈入险境。@人的情感真的很不可思议呢。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":200}]},{"chara":[{"id":400100}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}