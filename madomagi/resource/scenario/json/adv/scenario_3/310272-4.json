{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21081.jpg","bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":810000,"motion":0,"pos":2,"posX":40,"posY":80}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":102701}],"nameLeft":"沙绪","textLeft":"你怎么……会说话……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":200}],"textLeft":"而且你还说可以解决我的烦恼……"},{"chara":[{"id":810000}],"nameRight":"丘比","textRight":"如果你愿意成为魔法少……@啊，这个地方不这么称呼……"},{"chara":[{"id":810000}],"textRight":"如果你愿意成为巫，@我可以实现你的愿望。"},{"chara":[{"id":102701,"motion":1}],"textLeft":"如果我许愿消除父母的烦恼呢？"},{"chara":[{"id":810000}],"textRight":"那我当然也会帮你实现。"},{"chara":[{"id":810000}],"textRight":"只是我想知道，@你具体想消除什么烦恼？"},{"textRight":"据我所知，人类有很多种烦恼。"},{"textRight":"最后说不定得不到你想要的结果。"},{"chara":[{"id":102701}],"textLeft":"我只是想让爸爸和妈妈@变回以前的样子。"},{"chara":[{"id":102701,"motion":300}],"textLeft":"为此必须消除他们现在的烦恼。"},{"chara":[{"eyeClose":1,"id":102701}],"textLeft":"而那个烦恼，一定和我有关……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102701,"motion":0}],"textLeft":"所以，拜托你了。"},{"textLeft":"消除我父母现在烦恼着的、@和我有关的烦心事！"},{"nameNarration":"沙绪","narration":"于是我许了愿，成了巫","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","textClear":1},{"narration":"得知我成为巫后@父母非常吃惊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":2}],"narration":"他们总算接受了现状……@然后终于变回了@我从前最喜欢的爸爸和妈妈"},{"chara":[{"id":800700}],"nameRight":"沙绪的父亲","narrationEffect":"out","textRight":"那我出门了，@今天会晚点回来……"},{"chara":[{"id":800700}],"textRight":"你一个人能看家吗？"},{"chara":[{"id":102701,"motion":200}],"textLeft":"当然啦，你太担心了。"},{"chara":[{"id":800700}],"textRight":"也是……抱歉抱歉。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"那我们走了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102701,"motion":0}],"textLeft":"没错！"},{"nameNarration":"沙绪","narration":"我最喜欢的父母和@平稳的生活都恢复了原状","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","textClear":1},{"narration":"我的愿望实现了……"},{"bg":"bg_adv_21083.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"narration":"本该是这样的"},{"chara":[{"id":800600,"lipSynch":0}],"narrationEffect":"out","textRight":"……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800700},{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":100,"pos":1}],"nameCenter":"沙绪","textCenter":"爸爸，妈妈？"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":1,"pos":0}],"nameLeft":"沙绪的父亲","textLeft":"啊……是沙绪啊……"},{"chara":[{"id":102701}],"nameRight":"沙绪","textRight":"你们还没睡吗？"},{"chara":[{"id":800700}],"textLeft":"是啊……@我和你妈有要事要谈。"},{"chara":[{"id":102701}],"textRight":"这样啊……"},{"narration":"不知何时起@他们又开始苦恼了","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"narration":"然后，我得知了其中的原因","narrationBg":"bg_adv_narration.jpg"},{"chara":[{"id":800600}],"nameRight":"沙绪的母亲","narrationEffect":"out","textRight":"一想到女儿要和恶鬼战斗，@我就担心得不行……"},{"chara":[{"id":800700}],"nameLeft":"沙绪的父亲","textLeft":"嗯……我也是。@早知会变成这样……"},{"narration":"当时我就想@我不该许愿的……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"autoTurnLast":2.0,"bg":"bg_adv_50012.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story07","chara":[{"id":102701}],"nameRight":"沙绪","textRight":"那之后，@我得知了时女的规矩。","turnChangeOut":"fadeOut"},{"chara":[{"id":102701}],"textRight":"也得知了我父母曾祈祷@不要让我成为巫。"},{"chara":[{"id":102501,"motion":200}],"nameLeft":"静香","textLeft":"所以他们才问你那多次……"},{"chara":[{"id":102501}],"textLeft":"『有没有烦恼』……"},{"chara":[{"id":102501}],"textLeft":"因为你不知道时女，@怕你擅自许了愿。"},{"chara":[{"id":102701,"motion":200}],"textRight":"但我还是许愿了。"},{"chara":[{"id":102701}],"textRight":"通过许愿，@我父母的确不再害怕我会成为巫。"},{"chara":[{"id":102701}],"textRight":"我和父母之间的关系也暂时恢复了。"},{"chara":[{"id":102701,"motion":300}],"textRight":"但从结果上来讲，@我父母又开始烦恼了。"},{"chara":[{"id":102701}],"textRight":"全都怪我许了愿。"},{"chara":[{"id":102701}],"textRight":"从那以后，我父母对我的态度@便称得上是过度保护了。"},{"chara":[{"id":102701,"motion":0}],"textRight":"他们和以前不同，不再藏着掖着，@而是直白地表现对我的担心。"},{"chara":[{"id":102701}],"textRight":"一旦我要做什么，@或者要去哪里……"},{"chara":[{"id":102701}],"textRight":"都会被他们事无巨细地@盘问去见谁、要去哪里。"},{"chara":[{"id":102701,"motion":1}],"textRight":"他们肯定非常担心我@会不会又搞砸了什么。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":1,"pos":0}],"nameLeft":"千春","textLeft":"别这么说啦……"},{"chara":[{"id":102601}],"textLeft":"他么说不定也只是考虑到@过去发生过的事……"},{"chara":[{"id":102601}],"textLeft":"为了以防万一，@才总是问你。"},{"chara":[{"id":102601,"motion":200}],"textLeft":"毕竟他们也让你来物产展帮忙了啊？"},{"chara":[{"id":102701}],"textRight":"但他们还是要来亲自看看啊？"},{"chara":[{"id":102601,"motion":300}],"textLeft":"唔……那倒也是……"},{"chara":[{"id":102701,"motion":100}],"textRight":"其实，我也想像静香说的那样，@好好跟他们谈谈。"},{"chara":[{"id":102701}],"textRight":"告诉他们我没问题，@不用他们过来……"},{"chara":[{"id":102701,"motion":0}],"textRight":"但就算我说了，@他们恐怕也听不进去。"},{"chara":[{"id":102701}],"textRight":"去神滨的事也一样……"},{"chara":[{"id":102701}],"textRight":"如果他们知道了，@肯定会更加担心我。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102501,"motion":100,"pos":0}],"nameLeft":"静香","textLeft":"那你打算怎么办？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701}],"textRight":"咦？"},{"chara":[{"id":102501}],"textLeft":"你应该也明白吧？@这样下去不行。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"lipSynch":0,"motion":1}],"textRight":"……"},{"chara":[{"id":102501,"motion":0}],"textLeft":"虽说发生过那种事……"},{"chara":[{"id":102501}],"textLeft":"但你难道要一直怕父母担心，"},{"chara":[{"id":102501}],"textLeft":"以至于不敢告诉他们@自己要去神滨，最后只剩下愧疚吗？"},{"chara":[{"id":102701,"motion":100}],"textRight":"但是……究竟要怎么办……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501}],"textLeft":"只能赢取你父母的信任了，@除此之外没有别的办法。"},{"bgm":"bgm03_story09","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501}],"textLeft":"所以，我们在明天的物产展上@必须好好表现。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501}],"textLeft":"要让你父母看看沙绪的……@或者说是我们的出色表现……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100}],"textLeft":"好让他们放心！"},{"autoTurnFirst":3.6,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0,"pos":1,"voice":"vo_char_1027_00_04","textHome":"和我许了类似的愿望的人是有的吧…？"}],"nameCenter":"沙绪","textCenter":"也有人和我许了一样的愿望吧？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"id":102701,"motion":200}]},{"chara":[{"id":102701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}