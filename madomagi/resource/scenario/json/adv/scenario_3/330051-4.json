{"story":{"group_1":[{"bg":"bg_adv_21441.jpg","bgm":"bgm03_story06","chara":[{"id":810000,"pos":0,"posX":-50},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":2}],"nameLeft":"丘比","nameRight":"志伸晶","textLeft":"常盘七香所说的@都是真的。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":810100}],"textLeft":"她拥有@找出自己复仇对象的力量。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801}],"textRight":"既然丘比都这么说，@那就没错了吧……"},{"chara":[{"cheek":1,"face":"mtn_ex_022.exp.json","id":301101,"motion":400,"pos":2}],"nameRight":"夏目佳子","textRight":"是呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0,"pos":2}],"nameRight":"纯美雨","textRight":"然后呢？"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300501,"motion":1,"pos":0}],"nameLeft":"常盘七香","textLeft":"我复仇的对象……@[chara:300501:cheek_-1:face_mtn_ex_020.exp.json]果然就是魔女。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":2}],"nameRight":"志伸晶","textRight":"那么，背叛你家的@得意门生也是……"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300501,"motion":0}],"textLeft":"那个人只不过是@被魔女操控了。"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301201,"motion":0,"pos":2}],"nameRight":"纯美雨","textRight":"[textRed:「魔女之吻」]……"},{"chara":[{"cheek":-1,"id":300501,"motion":100}],"textLeft":"没错……"},{"chara":[{"cheek":-1,"id":300501,"motion":1}],"textLeft":"而我@所追寻的魔女……"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501,"motion":0}],"textLeft":"就是……@将我们联系在一起的魔女。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301201}],"textRight":"……!?"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801,"motion":200,"pos":2}],"nameRight":"志伸晶","textRight":"诶！@那我们遇到的时候也是？"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501,"motion":1}],"textLeft":"没错。@当时我正在追踪目标。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301101,"motion":1,"pos":2}],"nameRight":"夏目佳子","textRight":"与收购土地有关的，@果然也是……"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501}],"textLeft":"应该就是她。"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301201,"motion":300,"pos":2}],"nameRight":"纯美雨","textRight":"魔女……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301101,"motion":400,"mouthOpen":1,"pos":2}],"nameRight":"夏目佳子","textRight":"但、但是！@那是什么样的魔女？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301101}],"textRight":"与我们所有人相关……@[chara:301101:motion_300]这样的魔女究竟是？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":300,"pos":2}],"nameRight":"志伸晶","textRight":"确实……@我有点想象不到啊……"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300501,"motion":100}],"textLeft":"我现在就@向大家说明这件事……"},{"autoTurnFirst":3.0,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501,"motion":0,"pos":1,"voice":"vo_char_3005_00_03","textHome":"「宿命」……我将会背负它。"}],"nameCenter":"常盘七香","textCenter":"「宿命」……@我将它背负至今。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.5,"chara":[{"id":300501,"motion":300}]},{"chara":[{"id":300501}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}