{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_11063.jpg","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story19","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700,"motion":1,"pos":1}],"nameCenter":"御魂","textCenter":"纱纱罗、明日香，@欢迎光临～","turnChangeOut":"fadeOut"},{"chara":[{"id":111700,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300401,"motion":400,"pos":2}],"nameLeft":"御魂","nameRight":"美凪纱纱罗","textRight":"[chara:300401:effect_emotion_surprise_0][se:7226_shock]哇！@御魂！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101301,"motion":0,"pos":2}],"nameRight":"龙城明日香","textRight":"哎呀！@[chara:101301:lipSynch_0][wait:1.0][chara:101301:motion_200][chara:101301:cheek_0][chara:101301:face_mtn_ex_010.exp.json][chara:101301:lipSynch_1]你实在是太美了！"},{"chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":111700,"motion":400}],"textLeft":"讨厌啦，明日香真是的！@居然说人家是公主……"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":300401,"motion":100,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"不不，她可没这么说啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"纱纱罗你们是来做调整的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401,"motion":1}],"textRight":"啊，不是哦。"},{"chara":[{"id":300401}],"textRight":"我们担心御魂，@所以来看看她。"},{"chara":[{"id":300401,"motion":200}],"textRight":"不过……她看起来没问题呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101301,"motion":100,"pos":2}],"nameRight":"龙城明日香","textRight":"是的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":111700,"motion":0,"pos":0}],"nameLeft":"御魂","textLeft":"你们是特地来看我的呀……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101301,"motion":0}],"textRight":"这不算什么大事。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101301,"motion":200}],"textRight":"能欣赏到这么华丽的新年装饰……@我真是深受感动！"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401,"motion":1,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"你要是不嫌弃的话，请尝尝这个。"},{"chara":[{"id":300401}],"textRight":"我想你今天可能也会很忙，@就买了点熟食过来。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":200,"pos":0}],"nameLeft":"桃子","textLeft":"啊，我们也有带东西来！@[chara:101001:lipSynch_0][wait:1.0][chara:101001:cheek_0][chara:101001:face_mtn_ex_030.exp.json][chara:101001:lipSynch_1]不过只是些布丁果冻之类的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":0,"mouthOpen":1,"pos":2}],"nameRight":"彩羽","textRight":"啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":400,"mouthOpen":0}],"textRight":"那我们一起来做吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":111700,"motion":400,"pos":0}],"nameLeft":"御魂","textLeft":"做什么？"},{"chara":[{"id":100101,"motion":200}],"textRight":"除了和服之外，@我们还有一件想做的事……"},{"chara":[{"id":111700,"motion":0}],"textLeft":"想做的事？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":200,"pos":2}],"nameRight":"鹤乃","textRight":"当当当！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100501,"motion":200,"pos":2}],"nameRight":"菲莉希亚","textRight":"就是这个！"},{"chara":[{"id":111700,"motion":300}],"textLeft":"这是……做手卷寿司的东西？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100401,"motion":200,"pos":2}],"nameRight":"莎奈","textRight":"是的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":100,"pos":2}],"nameRight":"彩羽","textRight":"现在吃跨年荞麦面还太早，@所以就想先做手卷寿司。"},{"chara":[{"cheek":-1,"face":"mtn_ex_014.exp.json","id":100201,"motion":1,"pos":2}],"nameRight":"八千代","textRight":"我们带了很多食材过来，@可以做自己喜欢的寿司吃哦。"},{"chara":[{"cheek":1,"id":111700,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":111700,"motion":300}],"textLeft":"我真的……很高兴！"},{"chara":[{"eyeClose":1,"id":111700,"lipSynch":0}],"textLeft":"（她们为我考虑得这么周到……）","turnEffect":"thinking"},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111700,"motion":100}],"textLeft":"[chara:111700:effect_emotion_joy_0][se:7222_happy]谢谢你们！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100101,"motion":401,"pos":2}],"nameRight":"彩羽","textRight":"不用客气！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":100,"pos":2}],"nameRight":"鹤乃","textRight":"你一直都在帮我们，@我们才要谢谢你呢！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":111700,"lipSynch":0,"motion":0}],"textLeft":"（她们为我做了这么多……）","turnEffect":"thinking"},{"chara":[{"eyeClose":1,"id":111700,"lipSynch":0}],"textLeft":"（我真的好幸福……）"},{"autoTurnLast":2.0,"bg":"bg_adv_11063.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story02","chara":[{"id":101301,"motion":300}],"nameLeft":"美凪纱纱罗","nameRight":"龙城明日香","textRight":"开心的时光总是过得很快呢……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401}],"textLeft":"是啊……"},{"chara":[{"id":300401,"motion":200}],"textLeft":"时候也不早了，@我们差不多该回去了吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101301,"motion":0}],"textRight":"也对！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101301,"motion":100}],"textRight":"御魂，@今年真是受了你许多照顾。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":1}],"textLeft":"提前祝你新年快乐！"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":300401},{"effect":"fadeout","id":101301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100901,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101101,"motion":100,"pos":2}],"nameCenter":"玲奈","nameLeft":"桃子","nameRight":"枫","textRight":"感谢招待！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101101}],"textRight":"明年也请多多指教！"},{"chara":[{"id":100901,"motion":200}],"textCenter":"那就明年见啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101001,"motion":100}],"textLeft":"说是这么说，其实很快就会再见的……"},{"chara":[{"c