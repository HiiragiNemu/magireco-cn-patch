{"story":{"group_1":[{"autoTurnLast":0.01,"bgm":"bgm01_anime02","turnChangeIn":"fadeIn"},{"nameNarration":"南津凉子","narration":"时隔多年@我去给爸妈扫墓","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"我心中暗暗期待，去扫过墓后@是不是就能得到答案了呢"},{"narration":"我也不抱希望地想着，如果已故的@妈妈能从墓中回应我就好了"},{"narration":"说起来……@我几乎不记得妈妈的声音了……"},{"autoTurnLast":0.01,"bg":"bg_adv_13131.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":305801}],"nameCenter":"南津凉子","textCenter":"妈妈，你听我说。","turnChangeOut":"fadeOut"},{"chara":[{"id":305801}],"textCenter":"大家都说妈妈是英雄哦。"},{"chara":[{"id":305801}],"textCenter":"妈妈真的是个英雄吗？"},{"chara":[{"id":305801}],"textCenter":"妈妈也觉得自己是个英雄吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801}],"textCenter":"你死得像个英雄吗？@你死前感到满足了吗？"},{"chara":[{"eyeClose":1,"id":305801}],"textCenter":"还是说，@你就像那个掉到河里的女孩一样……"},{"chara":[{"id":305801,"lipSynch":0}],"textCenter":"……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305801}],"textCenter":"不可能有回答呢……"},{"chara":[{"id":305801,"motion":1}],"textCenter":"要是能听到……就好了。"},{"chara":[{"id":305801}],"textCenter":"哪里有这么好的事啊。"},{"autoTurnLast":0.2,"chara":[{"id":305801,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"nameRight":"凉子的爷爷","textRight":"是凉子啊……@真难得……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305801,"lipSynch":0,"motion":400}],"nameLeft":"南津凉子","textLeft":"！@[wait:1.0][chara:305801:lipSynch_1]爷爷……"},{"chara":[{"id":801500}],"textRight":"你有什么事要问你母亲吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":0}],"textLeft":"嗯……"},{"chara":[{"id":801500}],"textRight":"不论原因为何，@你终究是肯来扫墓了啊。"},{"chara":[{"id":801500}],"textRight":"我们一起参拜吧。"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":801500}],"textRight":"说起来，还没正式向你道谢。","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":305801,"motion":100}],"textLeft":"是指什么事情？"},{"chara":[{"id":801500}],"textRight":"水德寺的事。"},{"chara":[{"id":801500}],"textRight":"是你救了水德寺吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305801,"lipSynch":0,"motion":400}],"textLeft":"咦？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":300}],"textLeft":"这都被你发现了。"},{"chara":[{"id":801500}],"textRight":"因为实在是太巧了……@我一开始就怀疑是巫女的力量。"},{"chara":[{"id":801500}],"textRight":"但没想到会是自己的孙女。"},{"autoTurnLast":0.01,"turnChangeIn":"fadeIn"},{"nameNarration":"南津凉子","narration":"正如爷爷所说@我许愿救了水德寺@成了魔法少女","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"当时水德寺和那一带的土地@被丑恶的官员和政治家肆意玩弄@被逼得面临拆迁"},{"narration":"我家……净安寺也焦头烂额@我不太清楚详情@但多少也察觉到了"},{"narration":"那时丘比出现了@于是我许了愿"},{"narration":"希望……将意图拆迁水德寺的@那群人的丑闻公之于众"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":305801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":801500}],"textRight":"虽然很不讲道理，@但从制度上来说他们占理。","turnChangeOut":"fadeOut"},{"chara":[{"id":801500}],"textRight":"所以水德寺才被逼得走投无路。"},{"chara":[{"id":305801}],"textLeft":"就在那时……@幕后黑手的丑闻忽然被揭露了。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":100}],"textLeft":"嗯，确实很不自然呢。"},{"chara":[{"id":801500}],"textRight":"你为什么救了水德寺？"},{"chara":[{"id":801500}],"textRight":"对你来说，水德寺@只不过是亲戚的寺庙而已吧。"},{"chara":[{"id":801500}],"textRight":"现在虽然成了神滨的据点，@但当时你只去过几次而已。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801500}],"textRight":"但你却为此用掉了一生一次的愿望，@还为此背负上战斗的使命。"},{"chara":[{"id":801500}],"textRight":"这可不是轻易就能做到的……@你为什么这么做？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":305801,"motion":1}],"textLeft":"你问我我也说不清啊……"},{"autoTurnLast":0.01,"turnChangeIn":"fadeIn"},{"nameNarration":"南津凉子","narration":"眼前正有人因恶行而陷入不幸@如果只有我能阻止@那我肯定会去阻止的吧？","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"当时的我@别无选择"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":305801,"motion":200}],"textLeft":"只是单纯不想让他们得逞……","turnChangeOut":"fadeOut"},{"chara":[{"id":801500}],"textRight":"仅此而已？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801}],"textLeft":"我也不清楚……"},{"chara":[{"id":305801,"motion":300}],"textLeft":"说不定……我只是怒上心头。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801500}],"textRight":"怒上心头？"},{"autoTurnLast":0.01,"turnChangeIn":"fadeIn"},{"nameNarration":"南津凉子","narration":"那些人硬要开发水德寺的周边@但在媒体报道里@却被当成推动了经济发展的英雄","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"或许@他们的行为的确有益于大多数人"},{"narration":"但同时也有很多人承受了损失……"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":305801}],"textLeft":"所以我许愿将他们的丑闻公之于众。","turnChangeOut":"fadeOut"},{"chara":[{"id":801500}],"textRight":"你就这么想严惩他们吗？"},{"chara":[{"id":305801}],"textLeft":"嗯……"},{"chara":[{"eyeClose":1,"id":305801}],"textLeft":"表面被人当做英雄，@但背地里却让别人受尽委屈。"},{"chara":[{"id":305801}],"textLeft":"我无法原谅这种成年人。"},{"autoTurnLast":0.01,"bgm":"stop","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story12","nameNarration":"南津凉子","narration":"这件事……@让我想起了我妈妈","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"妈妈身为英雄，可能救了许多人@但同时，我的童年却过得很辛苦"},{"narration":"得知水德寺的麻烦时@我可能联想到了自己的遭遇"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":801500,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"……","turnChangeOut":"fadeOut"},{"chara":[{"id":801500}],"textRight":"原来是这样啊……@我终于明白了。"},{"chara":[{"id":801500}],"textRight":"跟我来。"},{"chara":[{"id":801500},{"cheek":0,"face":"mtn_ex_050.exp.json","id":305801}],"textRight":"我有些事想告诉你。"},{"chara":[{"id":801500}],"textRight":"你有权知道你的母亲的死因……"},{"chara":[{"id":801500}],"textRight":"或者说，她是怎么活着的……"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":100,"pos":1,"voice":"vo_char_3058_00_04","textHome":"ここ…なーんかあンだよなぁ"}],"nameCenter":"南津凉子","textCenter":"这里……果然藏着些什么啊。","turnChangeOut":"fadeOut"},{"chara":[{"id":305801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}