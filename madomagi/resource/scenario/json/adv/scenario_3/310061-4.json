{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21161.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":100601,"motion":1}],"nameCenter":"美冬","textCenter":"灯花跟音梦想分配人手@去保护[textBlue:传闻]，","turnChangeOut":"fadeOut"},{"chara":[{"id":100601}],"textCenter":"优先保证把感情能量拿到手。"},{"chara":[{"id":100601}],"textCenter":"而阿莉娜想让更多魔法少女知道晓@魔女化的事情，"},{"chara":[{"id":100601}],"textCenter":"这样能促使魔女化身出现，@以此来获得能量。"},{"chara":[{"id":100601}],"textCenter":"同时培育强大的魔女，@以此加强防御……"},{"chara":[{"id":100601,"motion":100}],"textCenter":"是这样吧？"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101401,"motion":100,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100801,"motion":0,"pos":2}],"nameCenter":"音梦","nameLeft":"灯花","nameRight":"阿莉娜","textCenter":"差不多吧。"},{"chara":[{"id":100701,"motion":1}],"textLeft":"是这样。"},{"chara":[{"id":100801,"motion":200}],"textRight":"没错。"},{"autoTurnLast":0.01,"chara":[{"effect":"fadeout","id":100701},{"effect":"fadeout","id":101401},{"effect":"fadeout","id":100801}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100601,"motion":200,"pos":1}],"nameCenter":"美冬","textCenter":"被牵扯进来的那些羽翼@现在都很不安。"},{"chara":[{"id":100601}],"textCenter":"你们应该是让她们安心的人，@怎么反倒让她们不安了？"},{"chara":[{"id":100601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100801,"motion":0,"pos":2}],"nameLeft":"美冬","textLeft":"首先是阿莉娜。"},{"chara":[{"id":100601,"motion":100}],"textLeft":"俗话说……@鱼与熊掌不可兼得。"},{"chara":[{"id":100601}],"textLeft":"你不能这么贪心。"},{"chara":[{"id":100801,"lipSynch":0,"motion":300}],"nameRight":"阿莉娜","textRight":"…………"},{"chara":[{"id":100601,"motion":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100701,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101401,"motion":0,"pos":2}],"nameCenter":"灯花","nameRight":"音梦","textLeft":"另外……灯花跟音梦。"},{"chara":[{"id":100601,"motion":1}],"textLeft":"我明白，@用[textBlue:传闻]来获得能量很重要。"},{"chara":[{"id":100601}],"textLeft":"但你们刚才也太意气用事了。"},{"chara":[{"id":100701,"motion":300}],"textCenter":"才没这回事……"},{"chara":[{"id":101401,"motion":200}],"textRight":"才没有。"},{"chara":[{"id":100601,"motion":0}],"textLeft":"我平时都很理性的……"},{"chara":[{"id":100601}],"textLeft":"但一牵扯到[textBlue:传闻]，@我就会比较激动。"},{"chara":[{"id":100601,"motion":200}],"textLeft":"你们站在领导人的立场上，@要多注意。"},{"chara":[{"id":100701,"lipSynch":0,"motion":0}],"textCenter":"…………"},{"chara":[{"id":101401,"lipSynch":0,"motion":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"motion":1}],"textLeft":"不过，你们的主张都没有错。"},{"chara":[{"id":100601}],"textLeft":"我个人的意见是……"},{"chara":[{"id":100601}],"textLeft":"按平时的效率来制造[textBlue:传闻]就好。"},{"chara":[{"id":100601}],"textLeft":"它们与魔女不同，@不是人尽皆知的东西。"},{"chara":[{"id":100601}],"textLeft":"至今为止，@非恶性的[textBlue:传闻]都没有被消灭过。"},{"chara":[{"id":100601,"motion":100}],"textLeft":"增加人手这方面也一样，@只要能提高回收能量的效率就好。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100701}],"textCenter":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401}],"textRight":"我会考虑的。"},{"chara":[{"id":100601,"motion":1},{"effect":"fadeout","id":100701},{"cheek":0,"face":"mtn_ex_000.exp.json","id":100801,"motion":0,"pos":2}],"textLeft":"接下来就是魔女了。"},{"chara":[{"id":100601}],"textLeft":"为了培养夏娃，@必须要获得一定数量的悲叹之种。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":300}],"textLeft":"但把魔女化告诉所有魔法少女的话，@会不会太坏心眼了些？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601}],"textLeft":"像是在给她们制造不必要的绝望。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":100}],"textLeft":"只让已经知道了魔女化的人@成为同伴——"},{"chara":[{"id":100601}],"textLeft":"这样做不行吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100801,"motion":100}],"nameRight":"阿莉娜","textRight":"阿莉娜觉得啊，@只要能在绝望下释放魔女化身就行了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100801}],"textRight":"不过这次看在美冬的份上，@我可以让步。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1}],"textLeft":"非常感谢。@那你们两位觉得呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":100,"pos":1},{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401,"motion":0,"pos":2}],"textCenter":"也对，美冬的话很有道理。"},{"chara":[{"id":101401,"motion":100}],"nameRight":"音梦","textRight":"是我刚才太幼稚了，@我没有异议。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100601}],"textLeft":"非常感谢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":100}],"textLeft":"那接下来@就由我来跟羽翼她们说明吧。"},{"autoTurnLast":1.0,"bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp.json","id":100601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story08","chara":[{"id":100601}],"nameCenter":"美冬","textCenter":"呼……","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":100601,"lipSynch":0,"motion":100}],"textCenter":"（总算解决了一桩事……）","turnEffect":"thinking"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（这3个人问题就在于@都很固执己见……）"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100601,"lipSynch":0}],"textCenter":"（如果没有我这样的人来调解……@那她们可能会从内部开始瓦解……）"},{"chara":[{"id":100601,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"motion":1,"pos":2}],"nameLeft":"美冬","nameRight":"月夜","textRight":"辛苦你了，向羽翼们解释了这么多。","turnEffect":"stop"},{"chara":[{"id":101801}],"textRight":"方便的话还请收下这个。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":0}],"textLeft":"悲叹之种？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":300}],"textRight":"你的灵魂宝石看起来很浑浊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601}],"textLeft":"啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":0,"motion":300}],"textLeft":"（因为我现在真的很苦恼@要不要回到小八身边呢……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":0}],"textRight":"美冬？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1}],"textLeft":"我收下了，谢谢。"},{"autoTurnLast":1.0,"chara":[{"effect":"ef_adv_09","id":100601}],"se":"7210_souljem_01","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":100}],"textRight":"真是抱歉，@在你不舒服的时候打扰你了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801}],"textRight":"请好好休息，@我先失陪了……"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":101801}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":0,"motion":100}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100601,"lipSynch":0}],"textLeft":"（我把月夜卷进了@玛吉斯之翼的计划之中…）","turnEffect":"thinking"},{"chara":[{"id":100601,"motion":1,"pos":1}],"nameNarration":"美冬","narration":"还有许多羽翼也当了很久的魔法少女@她们都是相信我才加入玛吉斯之翼的。","narrationBg":"black","narrationEffect":"in","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601}],"nameCenter":"美冬","narrationEffect":"out","textCenter":"事到如今，@我已经没法逃离这里了吧……"},{"nameNarration":"美冬","narration":"如果连我也离开了@肯定会有人觉得自己被背叛了@再一次陷入绝望……","narrationBg":"black","narrationEffect":"in"},{"narration":"羽翼们的承受能力本来就不是很强……@所以……她们可能承受不了"},{"chara":[{"id":100601,"lipSynch":0,"motion":300}],"narrationEffect":"out","textCenter":"[wait:1.5][chara:100601:lipSynch_1]唉……"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100601}],"textCenter":"我……没办法回到小八身边……"},{"autoTurnFirst":5.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100601,"motion":100,"pos":1,"voice":"vo_char_1006_00_03","textHome":"我已经背负了太多，@无法离开玛吉斯之翼了……"}],"nameCenter":"美冬","textCenter":"我背负了太多，@没办法离开玛吉斯之翼了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100601}]},{"chara":[{"id":100601}]},{"autoTurnLast":0.01,"turnChangeIn":"fadeIn"}]},"version":3}