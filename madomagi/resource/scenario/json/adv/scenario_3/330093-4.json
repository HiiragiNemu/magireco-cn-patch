{"story":{"group_1":[{"bg":"bg_adv_12071.jpg","bgm":"bgm03_story09","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":400,"pos":0}],"nameLeft":"胡桃爱香","surround":"7001_birdsong","textLeft":"爱香特制便当！@仅剩一份！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":1}],"textLeft":"给，多谢惠顾！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902}],"textLeft":"好！@售罄了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":100,"mouthOpen":1}],"textLeft":"明天还请大家@继续光顾！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800200,"motion":0,"pos":0}],"nameLeft":"","textLeft":"诶～@今天没买到……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800300,"motion":0,"pos":2}],"textRight":"我们@明天早点来吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100401,"motion":400,"mouthOpen":1,"pos":2},{"effect":"fadeout","id":800200}],"nameRight":"莎奈","textRight":"啊！@胡桃！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":100,"pos":0}],"nameLeft":"胡桃爱香","textLeft":"可惜，只差一点点～@已经卖完了。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100401,"motion":0,"mouthOpen":0}],"textRight":"今后！@你会……继续卖便当啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":1}],"textLeft":"你怎么说得事不关己啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902}],"textLeft":"这全都是……@因为你吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":100401,"motion":400}],"textRight":"诶！@[chara:100401:cheek_1:face_mtn_ex_030.exp.json]我、我……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":0}],"textLeft":"生意依旧很兴盛……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902}],"textLeft":"我太忙了，@还没来得及吃午饭呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":300}],"textLeft":"那么，现在我要拿出@给自己留的一份……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":200}],"textLeft":"咦？@这里竟然还有一份……"},{"cha