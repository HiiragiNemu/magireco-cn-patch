{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_21441.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102601,"lipSynch":0,"motion":400}],"nameLeft":"千春","textLeft":"[chara:102601:effect_emotion_surprise_0][se:7226_shock]？！","turnChangeOut":"fadeOut"},{"chara":[{"id":102601,"lipSynch":1,"motion":0}],"textLeft":"原来是这样啊……@我明白了……"},{"chara":[{"id":102501,"motion":0}],"nameRight":"静香","textRight":"咦？明白什么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":0}],"textLeft":"我……我啊……"},{"bgm":"bgm03_story07","chara":[{"id":102601,"motion":300}],"textLeft":"谁的忙也没帮上……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":200}],"textRight":"才没这回事……@怎么突然这么说？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":2}],"nameRight":"沙绪","textRight":"小千一直都在为了我们@超级拼命地努力。"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":102601}],"textLeft":"嗯……我努力了……@虽然努力了……"},{"chara":[{"eyeClose":1,"id":102601}],"textLeft":"但还是没帮上忙……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":1,"pos":2}],"nameRight":"静香","textRight":"唔……@你为什么会这么想？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":0}],"textLeft":"我本来还以为@我们村落什么也没有……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":102601}],"textLeft":"但实际上这里风景很好，@东西也好吃……"},{"chara":[{"eyeClose":1,"id":102601}],"textLeft":"村落里的人们又温柔，@你们还有很厉害的特技……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":300}],"textRight":"算不上特技啦……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":100}],"textLeft":"没那回事，@这些都是这里的亮点。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":0}],"textLeft":"可我却没有拿得出手的特长……"},{"chara":[{"eyeClose":1,"id":102601,"motion":300}],"textLeft":"只有我什么都不会……@帮不上大家的忙……"},{"autoTurnLast":0.2,"chara":[{"id":102501,"pos":1}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":100},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":2}],"nameCenter":"静香","textCenter":"小千，不是这样的。"},{"chara":[{"id":102701}],"nameRight":"沙绪","textRight":"小千也帮了我们很多啊。"},{"chara":[{"eyeClose":1,"id":102601,"lipSynch":0}],"textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501}],"textCenter":"小千……"},{"bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":200,"mouthOpen":1}],"textBg":"shout","textLeft":"不行！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"lipSynch":0,"motion":400},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":400},{"id":102601,"mouthOpen":0}],"nameCenter":"静香＆沙绪","textCenter":"[chara:102501:effect_emotion_surprise_0][chara:102701:effect_emotion_surprise_0][se:7226_shock]？！"},{"bgm":"bgm03_story09","chara":[{"id":102601}],"textBg":"shout","textLeft":"我才不会止步于此！"},{"chara":[{"id":102601}],"textLeft":"我也要成为很厉害的英雄，@帮上大家！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102601,"motion":0}],"textLeft":"我现在的确什么也不会……[chara:102601:lipSynch_0][wait:0.8][chara:102601:cheek_1][chara:102601:face_mtn_ex_020.exp.json][chara:102601:lipSynch_1]@但我总有一天要学会很厉害的特技！"},{"chara":[{"cheek":1,"id":102601,"motion":100}],"textBg":"shout","textLeft":"所以我不会放弃！@在属于我的传说开始之前！"},{"chara":[{"id":102501,"motion":0}],"nameCenter":"静香","textCenter":"啊……@嗯……是呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":1}],"textRight":"太好了，只是我们瞎操心。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501}],"textCenter":"嗯。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501}],"textClear":1},{"chara":[{"eyeClose":1,"id":102701,"motion":100}],"textRight":"好了，我吃饱了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":0}],"textLeft":"咦？@沙绪，你这就吃好了？"},{"chara":[{"eyeClose":0,"id":102701,"motion":200}],"textRight":"是的，@我稍微有点事要出门……"},{"chara":[{"id":102701}],"textRight":"大概三十分钟左右就会回来。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":0}],"nameLeft":"静香","textLeft":"啊，和平常一样？"},{"chara":[{"id":102701,"motion":0}],"textRight":"是的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":200,"pos":0}],"nameLeft":"千春","textLeft":"咦？@什么什么，要去做什么？！"},{"chara":[{"id":102701,"motion":1}],"textRight":"我去看看村里上了年纪的人@饭后有没有按时服药。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102701}],"textRight":"我想尽量提醒他们一声。"},{"chara":[{"id":102601,"motion":0,"mouthOpen":1}],"textLeft":"不是吧……"},{"chara":[{"id":102601,"lipSynch":0,"mouthOpen":0}],"textLeft":"（沙绪她……）","turnEffect":"thinking"},{"chara":[{"id":102601,"lipSynch":0}],"textLeft":"（真是爷爷奶奶辈的@英雄啊……）"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":102601,"lipSynch":1,"motion":300}],"textLeft":"唔……","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300}],"textRight":"毕竟我也只能做到这点事了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100,"pos":0}],"nameLeft":"静香","textLeft":"沙绪，这很了不起。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":100}],"textRight":"谢谢你这么说，@那我先走了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102501}],"textLeft":"嗯，路上小心。"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":102701}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501}]},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":0,"pos":1}],"nameCenter":"千春","textCenter":"唉……沙绪的温柔@真是国宝级的……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":102601,"motion":300}],"textCenter":"如果我是将军，@一定要让全国人民知道她的好……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102601}],"textCenter":"啊……"},{"chara":[{"cheek":1,"id":102601,"motion":200,"mouthOpen":1}],"textBg":"shout","textCenter":"就是这个啊！"},{"autoTurnLast":0.2,"chara":[{"id":102601,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":400,"pos":2}],"nameRight":"静香","textRight":"[chara:102501:effect_emotion_surprise_0][se:7226_shock]哇？！什么？！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102601,"motion":100,"mouthOpen":0}],"nameLeft":"千春","textLeft":"就是这个，就是这个啊！@静香！"},{"autoTurnFirst":5.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":300,"pos":1,"voice":"vo_char_1026_00_04","textHome":"或许沙绪比起我要更像英雄一些……"}],"nameCenter":"千春","textCenter":"沙绪可能比我还像个英雄……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":102601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}