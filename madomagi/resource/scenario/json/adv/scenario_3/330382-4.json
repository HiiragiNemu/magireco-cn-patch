{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21481.jpg","bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":303801,"motion":0,"pos":0,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800900}],"nameRight":"","textRight":"这样啊……","turnChangeOut":"fadeOut"},{"chara":[{"id":303801,"lipSynch":0}],"nameLeft":"古町美仓","textLeft":"（唔……好紧张啊。）","turnEffect":"thinking"},{"chara":[{"id":303801,"lipSynch":0}],"textLeft":"（没想到市立大学的教授@真的联系上我了。）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"嗯，你的考据写得很好。","turnEffect":"stop"},{"chara":[{"id":800900}],"textRight":"而且对文献的研究也很透彻。"},{"chara":[{"id":800900}],"textRight":"真没想到这是高中生写的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textRight":"只是……"},{"bgm":"stop","nameNarration":"","narration":"（紧张）","narrationBg":"","narrationEffect":"in"},{"bgm":"bgm03_story08","chara":[{"id":800900}],"narrationEffect":"out","textRight":"你的考据有两个非常致命的问题。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801}],"textLeft":"您请说……"},{"chara":[{"id":800900}],"textRight":"一个是在江户时代发现的埴轮碎片。"},{"chara":[{"id":800900}],"textRight":"这份记载几乎无人知晓，@连我也很吃惊。"},{"chara":[{"id":800900}],"textRight":"但是关于这块碎片的由来……"},{"chara":[{"id":800900}],"textRight":"可以说是已经得出结论了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303801,"motion":1}],"textLeft":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"你知道这附近有很多小型的古墓吧。"},{"chara":[{"id":303801,"motion":101}],"textLeft":"是的……"},{"chara":[{"id":800900}],"textRight":"根据出土位置来看，@这个碎片很可能来自这些小古坟。"},{"chara":[{"id":800900}],"textRight":"另外一点……"},{"chara":[{"id":800900}],"textRight":"如果这座山是古墓，@那它的形状就很有问题了。"},{"chara":[{"id":303801,"motion":0}],"textLeft":"形状？"},{"chara":[{"id":800900,"motion":0}],"textRight":"嗯。"},{"chara":[{"id":800900}],"textRight":"如果这座圆顶山是一座古墓，@那它就应该属于「圆坟」这一类。"},{"chara":[{"id":800900}],"textRight":"如此一来，@这就会是一座相当巨大的圆坟。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textRight":"但这片区域里的大型古墓@全都是「前方后圆坟」……"},{"chara":[{"id":800900}],"textRight":"也就是所谓的锁孔型古墓。"},{"chara":[{"id":800900}],"textRight":"而且这座古墓也不太可能@和其他古墓处于不同时代……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801,"motion":1}],"textLeft":"也就是说……如果它真是古墓，@那就是属于极其特殊的一种？"},{"chara":[{"id":800900}],"textRight":"是的。"},{"chara":[{"id":800900}],"textRight":"如果不能合理说明这一点，@那就很难推翻现有的定论。"},{"chara":[{"id":800900}],"textRight":"毕竟这附近有很多小型古墓，@如果这座古墓的规模没那么大……"},{"chara":[{"id":800900}],"textRight":"那你的论点也会更有说服力吧。"},{"chara":[{"id":303801,"lipSynch":0,"motion":300}],"textLeft":"（是我太天真了……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"但你这份考据真的很不错。"},{"chara":[{"id":800900}],"textRight":"今后也继续加油吧，@你一定能成为一名优秀的研究员。"},{"chara":[{"eyeClose":1,"id":303801,"lipSynch":0,"motion":0}],"textLeft":"……[wait:1.0][chara:303801:lipSynch_1]谢谢您的夸奖。"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303801,"motion":1,"pos":1,"soulGem":0,"voice":"vo_char_3038_00_04","textHome":"这是…非常珍贵的一手史料！"}],"nameCenter":"古町美仓","textCenter":"这是很重要的第一手史料啊！","turnChangeOut":"fadeOut"},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801}]},{"chara":[{"id":303801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}