{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_19081.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100601}],"nameLeft":"美冬","textLeft":"说起来……","turnChangeOut":"fadeOut"},{"chara":[{"id":100601}],"textLeft":"七濑你不惜成为魔法少女@也要实现的愿望又是什么呢？"},{"chara":[{"id":100601,"motion":1}],"textLeft":"我记得从中学开始@你就一直是学生会成员……"},{"chara":[{"id":100601}],"textLeft":"而且你在水名也是有名的大小姐吧。"},{"chara":[{"eyeClose":1,"id":301701}],"nameRight":"七濑幸佳","textRight":"是的……我的家境的确还不错。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":100,"pos":2}],"nameRight":"月咲","textRight":"在月夜上的那所学校里，@学生都是大小姐吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100601,"motion":100}],"textLeft":"那里是有不少大小姐，但七濑在其中@也属于出类拔萃的那一类呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301701,"motion":200,"pos":2}],"nameRight":"七濑幸佳","textRight":"可我也只能算是那一类里的@「垫底」人物！"},{"chara":[{"id":301701,"motion":0}],"textRight":"明槻学姐才是真正的大小姐啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"motion":1}],"textLeft":"七濑，你的父母都是大人物，@你的成绩都很靠前吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301701,"motion":300}],"textRight":"靠前是靠前，但我的名次@在靠前的那一批里是属于靠后的。"},{"chara":[{"id":301701}],"textRight":"要说我在班里最过人的一项……@可能就是我头发的长度了吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":200,"pos":0}],"nameLeft":"月咲","textLeft":"啊……仔细一看你的头发真的好长啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":1}],"textRight":"每个人都这样……毕竟我不受人瞩目，@没给大家留下什么印象。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"motion":300,"pos":0}],"nameLeft":"美冬","textLeft":"你也不用这么谦虚呀……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101901,"motion":100,"pos":2}],"nameRight":"月咲","textRight":"是啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901}],"textRight":"其实你比自己想的还要优秀，@更像一个大小姐哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":1}],"textLeft":"我也是这么想的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301701,"motion":1,"pos":2}],"nameRight":"七濑幸佳","textRight":"因为我一直以来都受到了@很多人的关照……"},{"chara":[{"id":301701}],"textRight":"我这么说是有些生在福中不知福……@但我有一天发现——"},{"chara":[{"eyeClose":1,"id":301701}],"textRight":"一直以来我从没靠过自己……"},{"chara":[{"id":301701}],"textRight":"从来都是走在我父母铺好的路上。"},{"chara":[{"id":301701,"motion":300}],"textRight":"我逐渐察觉自己这样@不算是「活着」……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":0}],"textRight":"就在那时，我遇见了它。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"motion":0}],"textLeft":"你是说丘比吗？"},{"bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301701,"motion":300}],"textRight":"不，我是说推币机。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"pos":0}],"nameLeft":"月咲","textLeft":"推币机？"},{"autoTurnLast":0.01,"bg":"bg_adv_21031.jpg","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301701,"motion":200,"pos":1,"soulGem":0}],"narrationCoverOpacity":40.0,"narrationEffect":"in","turnChangeIn":"fadeIn"},{"bgm":"bgm01_anime25","chara":[{"id":301701}],"nameNarration":"七濑幸佳","narration":"只有将自己置身于这个@成败在此一举的游戏之中时@我才会忘记无聊的日常生活","narrationBg":"","turnChangeOut":"fadeOut","turnEffect":"sepiaFrame"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301701,"motion":300}],"narration":"所以我就迷上在放学后@到游戏厅里玩推币机了"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/33017_yukika_story/memoria_1402.jpg","posX":0,"posY":0,"visible":"appear"}]},{"nameNarration":"七濑幸佳","narration":"―幸佳―@我偷偷买了赌场套装回家@每天晚上都会呆呆地盯着它看……","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_19081.jpg","chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":300,"pos":2,"soulGem":1},{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":1,"pos":0}],"item":[{"path":"resource/scenario/img/33017_yukika_story/memoria_1402.jpg","visible":"hide"}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":100601}],"nameLeft":"美冬","narrationEffect":"out","textLeft":"你这是在逃避现实啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301701,"motion":100}],"nameRight":"七濑幸佳","textRight":"没错。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901,"motion":1,"pos":0}],"nameLeft":"月咲","textLeft":"你拼命脱离正轨也只是做了这些……@还真是大小姐的作风啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301701,"motion":1}],"textRight":"是、是吗？"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/51071_tower_yukika/memoria_1404.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"nameNarration":"七濑幸佳","narration":"―幸佳―@有一天，一只奖品玩偶@突然来找我搭话","narrationAnchor":"bottom","narrationCoverOpacity":40.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_21031.jpg","chara":[{"id":810000,"pos":1,"posY":80}],"item":[{"path":"resource/scenario/img/51071_tower_yukika/memoria_1404.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"丘比","narration":"「和我签订契约，成为魔法少女吧！」","narrationBg":"","narrationCoverOpacity":40.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_19081.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":300,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":301701,"motion":300,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story20","chara":[{"id":100601}],"nameLeft":"美冬","narrationEffect":"out","textLeft":"你好像……","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":100601}],"textLeft":"把丘比错认成奖品玩偶了吧。"},{"chara":[{"eyeClose":1,"id":301701}],"textRight":"是的……我当时都以为自己疯了。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301701,"motion":200}],"textRight":"可我眼前的确有一个不可思议的生物。"},{"chara":[{"id":301701}],"textRight":"我以为自己是在做清醒梦，@就向它许下了愿望。"},{"chara":[{"id":301701,"motion":100}],"textRight":"这个愿望有点丢人，@可这说到底是一场梦。"},{"chara":[{"id":301701}],"textRight":"所以我觉得许这个愿应该也没事吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":1,"pos":0}],"nameLeft":"月咲","textLeft":"你许的什么愿望？"},{"chara":[{"face":"mtn_ex_000.exp.json","id":810100,"motion":100,"pos":1}],"nameCenter":"小丘比","textCenter":"么啾？"},{"chara":[{"cheek":2,"face":"mtn_ex_040.exp.json","id":301701,"motion":0}],"textRight":"呜……一想起来了还是觉得好丢人啊。"},{"autoTurnLast":0.3,"bg":"bg_adv_21031.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301701,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"chara":[{"id":301701,"motion":300}],"nameCenter":"七濑幸佳","textCenter":"我不想继续走在父母设计好的路上了。","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":301701}],"textCenter":"我不想过这种无趣的幸福日子。"},{"chara":[{"eyeClose":0,"id":301701,"motion":400}],"textCenter":"我想要的……"},{"chara":[{"cheek":2,"id":301701,"motion":100}],"textBg":"shout","textCenter":"是「活着的感觉」！"},{"autoTurnLast":0.01,"bg":"bg_adv_19081.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"pos":0},{"cheek":2,"face":"mtn_ex_030.exp.json","id":301701,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm01_anime02","chara":[{"id":101901}],"nameLeft":"月咲","textLeft":"这也没什么丢人的吧？","turnChangeOut":"fadeOut"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":301701,"motion":300}],"nameRight":"七濑幸佳","textRight":"大家闺秀的妄想被人看了个精光，@真是太丢人了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"motion":100,"pos":0}],"nameLeft":"美冬","textLeft":"我大概能明白你的感受……@那你的愿望实现了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301701,"motion":200}],"nameRight":"七濑幸佳","textRight":"是的。自从那之后……"},{"chara":[{"id":301701}],"textRight":"我就经常会被卷入各种麻烦事里去！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101901,"motion":1,"pos":0}],"nameLeft":"月咲","textLeft":"也就是说，你的人生确实@没许愿前那么无聊了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301701,"motion":1}],"textRight":"是的。"},{"chara":[{"id":301701}],"textRight":"我现在根本就是没了退路，@陷入了别无选择的境地。"},{"chara":[{"id":301701}],"textRight":"时常被卷入混乱的事态……"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":301701,"motion":400}],"textRight":"还差一点丢了性命，@好不容易才能死里逃生。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":0,"motion":1,"pos":0}],"nameLeft":"美冬","textLeft":"……"},{"chara":[{"id":100601}],"textLeft":"你以成为魔法少女为代价——"},{"chara":[{"eyeClose":0,"id":100601}],"textLeft":"换来的却是与死亡相伴的生活吗。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301701,"motion":0}],"textRight":"是啊……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301701,"motion":300}],"textRight":"可我每次碰上千钧一发的情况时……"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301701}],"textRight":"也会觉得……[chara:301701:lipSynch_0][wait:0.8][chara:301701:lipSynch_1]@挺刺激的？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":400,"pos":0}],"nameLeft":"月咲","textLeft":"啊？"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":101901},{"effect":"fadeout","id":301701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"motion":0,"pos":0}],"nameLeft":"美冬","surround":"7202_telepathy","textLeft":"她有点吓人啊……","turnEffect":"ef_adv_02"},{"chara":[{"cheek":0,"id":101901,"motion":100}],"nameRight":"月咲","textRight":"嗯，是有点独特呢。"},{"autoTurnLast":0.3,"chara":[{"effect":"fadeout","id":101901}],"surround":"stop","textClear":1,"turnEffect":"stop"},{"autoTurnLast":0.5,"chara":[{"face":"mtn_ex_000.exp.json","id":810100,"motion":0,"pos":1,"posX":0,"posY":0},{"cheek":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":0,"pos":2}]},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":300}],"textLeft":"那今天七濑被卷进的麻烦事——"},{"chara":[{"id":100601}],"textLeft":"就是这只小丘比了吧？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301701,"motion":300}],"nameRight":"七濑幸佳","textRight":"我觉得是这样的……"},{"chara":[{"id":810100,"motion":100}],"nameCenter":"小丘比","textCenter":"么啾？"},{"autoTurnFirst":3.0,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301701,"motion":0,"pos":1,"voice":"vo_char_3017_00_04","textHome":"签订了契约，这样好吗？"}],"nameCenter":"七濑幸佳","textCenter":"我不小心签订了契约……@这是正确的吗？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301701,"motion":300}]},{"chara":[{"id":200200}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}