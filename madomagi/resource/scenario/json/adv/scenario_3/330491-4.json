{"story":{"group_1":[{"bg":"black","bgm":"stop","nameNarration":"加奈惠","narration":"…………","narrationBg":"black","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"嗯？"},{"narration":"嗯～"},{"narration":"…………"},{"narration":"诶！？"},{"autoTurnLast":1.0,"bg":"bg_adv_21203.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":304901,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"chara":[{"eyeClose":0,"id":304901,"lipSynch":0}],"nameCenter":"加奈惠","textCenter":"…………","turnChangeOut":"fadeOut","turnChangeOutTime":1.0},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304901,"lipSynch":0}],"textCenter":"（这、这里是！？）"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801800,"motion":0,"pos":0},{"id":304901,"pos":2}],"nameLeft":"八千代的祖母","nameRight":"加奈惠","textLeft":"啊，你醒了啊？@你看起来很困啊。"},{"chara":[{"id":304901,"motion":400}],"textRight":"[chara:304901:effect_emotion_surprise_0][se:7226_shock]唔！"},{"chara":[{"id":304901,"lipSynch":0}],"textRight":"（这、这是谁！？）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":100,"pos":0}],"nameLeft":"八千代","textLeft":"离家出走太过劳累，@睡眠不足了吧。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304901,"motion":200}],"textRight":"你、你是……"},{"chara":[{"id":304901,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304901,"lipSynch":0,"motion":0}],"textRight":"（等等？）","turnEffect":"thinking"},{"chara":[{"id":304901,"lipSynch":0}],"textRight":"（离家出走？）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801800,"motion":0,"pos":0}],"nameLeft":"八千代的祖母","textLeft":"你的家人不担心你吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":304901,"motion":0}],"nameNarration":"加奈惠","narration":"之后我才知道，@这个人是八千代的奶奶。","narrationBg":"bg_adv_21203.jpg","narrationEffect":"in"},{"narration":"我跟十七夜战斗时受了伤，@耗费了魔力使我晕倒了@据说那之后，我被抬回了八千代的家"},{"chara":[{"id":100204,"motion":1}],"nameLeft":"八千代","nameRight":"加奈惠","narrationEffect":"out","surround":"7202_telepathy","textLeft":"我说……","turnEffect":"ef_adv_02"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304901,"motion":400}],"textRight":"咦！？"},{"chara":[{"id":100204}],"textLeft":"这些话不能让祖母听见……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304901,"motion":1}],"textRight":"什么？"},{"chara":[{"id":100204,"motion":100}],"textLeft":"收下吧，@这些悲叹之种。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304901}],"textRight":"悲叹之种？@是谁给的？"},{"chara":[{"id":100204,"motion":200}],"textLeft":"那个叫十七夜的人。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304901,"motion":0}],"textRight":"她居然会？"},{"chara":[{"id":100204,"motion":1}],"textLeft":"她貌似是想道歉吧。"},{"chara":[{"id":100204}],"textLeft":"应该是稍微冷静下来了。"},{"chara":[{"id":100204,"motion":300}],"textLeft":"毕竟那件事@对她来说很严肃。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204}],"textLeft":"所以才会追你追到那里……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304901,"lipSynch":0}],"textRight":"…………"},{"chara":[{"id":100204,"motion":301}],"textLeft":"唉，她是有些不知变通……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":304901,"lipSynch":0}],"textRight":"…………"},{"chara":[{"id":304901,"motion":200}],"textRight":"她那才不叫“有些”，@是“非常”才对！"},{"chara":[{"effect":"fadeout","id":100204},{"effect":"fadeout","id":304901}],"nameNarration":"加奈惠","narration":"把我送到这里来时@她们跟八千代的奶奶解释说@『她是离家出走了的朋友』","narrationBg":"bg_adv_21203.jpg","narrationEffect":"in","surround":"stop","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801800,"motion":0,"pos":1}],"narration":"要圆这个谎也很辛苦……@我原本就不擅长和人交流，@还要应付连珠炮似的提问，@一开始几乎什么也答不上来@不过总算是混过去了"},{"narration":"然后我发现了不可思议的事@一般遇到这种事，我都会板着脸@别人也会因此害怕我"},{"narration":"可是，我发现……"},{"chara":[{"id":801800}],"nameCenter":"八千代的祖母","narrationEffect":"out","textCenter":"你肚子饿了吧？@来，吃个橘子吧。"},{"nameNarration":"加奈惠","narration":"面对这个人的慈祥微笑时，@我自然而然地就放松了下来……","narrationBg":"bg_adv_21203.jpg","narrationEffect":"in"},{"autoTurnLast":0.01,"bgm":"stop","narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.4,"bg":"bg_adv_narration.jpg","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304901,"motion":0,"pos":1,"voice":"vo_char_3049_00_03","textHome":"甘苦参半……总感觉……很怀念……"}],"nameCenter":"加奈惠","textCenter":"好温暖……好心酸……@好久没体会过……这种感觉了……","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":304901,"motion":300}]},{"chara":[{"id":304901}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}