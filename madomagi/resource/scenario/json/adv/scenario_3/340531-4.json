{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_21181.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":405201,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":405101,"motion":300}],"nameLeft":"高町奈叶","textLeft":"这下就剩下三个疾风啦～","turnChangeOut":"fadeOut"},{"chara":[{"id":405201,"motion":300}],"nameRight":"菲特·泰斯特罗莎·哈拉温","textRight":"总感觉是在试探别人一样，@真过意不去……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405301,"motion":0,"pos":0}],"nameLeft":"八神疾风？","textLeft":"我不在意的啦～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405301,"motion":100}],"textLeft":"说不定我们全都是复制体哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405101,"motion":400,"pos":2}],"nameRight":"高町 なのは","textRight":"别……别说这么吓人的话！"},{"autoTurnLast":0.1,"chara":[{"effect":"fadeout","id":405101},{"effect":"fadeout","id":405301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":300,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101101,"motion":0,"pos":2}],"nameLeft":"桃子","textLeft":"她们都没争着说自己是真的疾风，"},{"chara":[{"id":101001}],"textLeft":"所以就更难分清了啊～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101101,"motion":100}],"nameRight":"枫","textRight":"疾风连复制体都很老实呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901,"motion":0,"pos":2}],"nameRight":"玲奈","textRight":"……可一旦暴露自己是假的，@她终究是会攻击我们的呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101001,"motion":1}],"textLeft":"毕竟是魔女的手下嘛。"},{"chara":[{"id":100901,"motion":100}],"textRight":"……你们还有别的检验方法吗？"},{"chara":[{"id":100901}],"textRight":"比如只有真的疾风@擅长做的事之类的？"},{"autoTurnLast":0.1,"chara":[{"effect":"fadeout","id":100901},{"effect":"fadeout","id":101001}],"textClear":1},{"item":[{"path":"resource/scenario/img/51063_singleraid_nanoha/memoria_1365.png","posX":0,"posY":0,"visible":"appear"}],"nameCenter":"琳芙斯II","textCenter":"说到她擅长的事情……@那就是做饭！"},{"textCenter":"我也是吃疾风的饭长大的！"},{"autoTurnLast":0.1,"item":[{"path":"resource/scenario/img/51063_singleraid_nanoha/memoria_1365.png","visible":"hide"}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101101,"motion":1,"pos":2}],"textLeft":"长大的……"},{"chara":[{"id":101101}],"nameRight":"かえで","textRight":"做饭啊……"},{"chara":[{"id":101101}],"textRight":"让她们在这里做饭，@然后靠味道分辨真假？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":100}],"textLeft":"说什么呢，再怎么说@这里也是魔女的结界啊？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405301,"motion":300,"pos":0}],"nameLeft":"八神 はやて？","textLeft":"这里不可能有厨房跟食材吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300400,"motion":200,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"啊……可我在早上"},{"chara":[{"id":300400}],"textRight":"有看到调整专家@搬进了大量厨房用具和食材。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405201,"motion":100,"pos":0}],"nameLeft":"フェイト·Ｔ·ハラオウン","textLeft":"咦……为什么啊？"},{"autoTurnLast":0.5,"bg":"bg_adv_21182.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story16","chara":[{"id":101700,"motion":100}],"nameCenter":"御魂","textCenter":"[chara:101700:effect_emotion_joy_0][se:7222_happy]今天就特别给各位露一手，@尝尝我亲手做的菜吧～","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":101700}],"textCenter":"你们就好好期待@午休时间吧～"},{"autoTurnLast":0.5,"bg":"bg_adv_21181.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp.json","id":101001,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":100901,"motion":400}],"nameRight":"レナ","textRight":"糟了！","turnChangeOut":"fadeOut"},{"chara":[{"id":101001,"motion":200}],"nameLeft":"ももこ","textLeft":"是啊，必须要阻止她！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405301,"motion":0,"pos":0}],"nameLeft":"八神 はやて？","textLeft":"你、你们是要阻止她做菜吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101001,"motion":1,"pos":2}],"nameRight":"ももこ","textRight":"是啊！"},{"chara":[{"id":101001}],"textRight":"她要是做菜给别人吃……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":200,"pos":2}],"nameRight":"レナ","textRight":"……会出人命的啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405301,"motion":400}],"textLeft":"[chara:405301:effect_emotion_surprise_0][se:7226_shock]出……出人命！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405201,"motion":100,"pos":0}],"nameLeft":"フェイト·Ｔ·ハラオウン","textLeft":"为什么会这么说？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":300,"pos":2}],"nameRight":"ももこ","textRight":"这……@也不是我们要抹黑调整专家，"},{"chara":[{"eyeClose":1,"id":101001}],"textRight":"可她做出来的东西都是毁灭性的。"},{"chara":[{"id":405201,"motion":300}],"textLeft":"是、是吗……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101001,"motion":0}],"textRight":"所以说……@[chara:101001:lipSynch_0][wait:0.8][chara:101001:cheek_0][chara:101001:motion_200][chara:101001:lipSynch_1]我们必须全力阻止调整专家！"},{"autoTurnLast":0.1,"chara":[{"effect":"fadeout","id":101001},{"effect":"fadeout","id":405201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":405301,"live2dName":"live2d_2","motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":405301,"live2dName":"live2d_1","motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_020.exp.json","id":405301,"live2dName":"live2d_0","motion":0,"pos":2}],"nameLeft":"八神 はやて？","textLeft":"好、好的！"},{"chara":[{"id":405301,"live2dName":"live2d_0","motion":100},{"id":405301,"live2dName":"live2d_1","motion":200}],"nameRight":"八神 はやて？","textRight":"我们走！"},{"autoTurnFirst":2.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405301,"motion":0,"pos":1,"voice":"vo_char_4053_00_03","textHome":"八神疾风，会努力的！"}],"nameCenter":"八神疾风","textCenter":"我八神疾风会加油的！","turnChangeIn":"fadeIn","turnChangeOut":"fa