{"story":{"group_1":[{"autoTurnLast":0.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_17023.jpg","bgm":"bgm03_story06","chara":[{"id":101601,"motion":1}],"nameLeft":"御魂","nameRight":"十七夜","textRight":"那时我实在是大吃一惊。","turnChangeOut":"fadeOut"},{"chara":[{"id":101601}],"textRight":"因为等我回过神，@八云已经变成魔法少女了。"},{"chara":[{"id":101702,"motion":300}],"textLeft":"不过我没想到@自己居然连使魔都攻击不了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101702}],"textLeft":"呵呵。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":200}],"textRight":"事到如今可以一笑而过了，@但我真的是吓破了胆。"},{"chara":[{"id":101601}],"textRight":"可能因为@一开始恨意很强。"},{"chara":[{"id":101601}],"textRight":"所以你的灵魂宝石@变污浊的速度也非常快。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":0}],"textLeft":"说真的，十七夜你能帮助我，@真是救了我一命。"},{"chara":[{"id":101601,"motion":300}],"textRight":"但是在当时的神滨之中，@魔女的数量也有限。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601}],"textRight":"说实话，@我还以为八云你撑不住了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":200}],"textLeft":"当时我也曾打算@在这片土地埋下憎恶。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101702}],"textLeft":"然后就这样死去呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":1}],"textRight":"嘛，不过，@有了那次奇迹一般的邂逅……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":0}],"textLeft":"嗯……"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/memoria_1200.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"御魂","narration":"她说想要生存下去的话就要听她的","narrationBg":"narration","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"那个人教会了我如何为大家进行调整@如何帮助与我有着@相似遭遇的人活下去……"},{"narration":"如果那时老师没有出现@我大概已经死去了吧……"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":1,"pos":2}],"item":[{"path":"resource/scenario/img/31017_mitama_story/memoria_1200.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bg":"bg_adv_17023.jpg","chara":[{"id":101702,"lipSynch":0}],"nameLeft":"御魂","textLeft":"…………","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101702,"lipSynch":1,"motion":300}],"textLeft":"啊，对不起。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702}],"textLeft":"拉你倾听我讲述回忆了。"},{"chara":[{"id":101601,"motion":100}],"nameRight":"十七夜","textRight":"不要紧。"},{"chara":[{"id":101601}],"textRight":"我感觉自己也回顾了@自己的初衷。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0}],"textRight":"就像八云当初@想要毁灭这个城市一样。"},{"chara":[{"id":101601}],"textRight":"我也认为必须消灭历史。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":400}],"textRight":"因为两者很相似，@所以我再次振奋起了精神。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101702,"motion":0}],"textLeft":"那就好。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0}],"textRight":"那么，我告辞了。@明天学校见。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"motion":200}],"textLeft":"我明天不去哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601}],"textRight":"是吗，也别太逞强了哦。"},{"autoTurnLast":0.1,"chara":[{"effect":"fadeout","id":101601}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101702,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"御魂","textCenter":"…………"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/memoria_1199.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm05_event06","nameNarration":"御魂","narration":"我是八云御魂，出身于大东区@就读于大东学院，水灵灵的17岁@出勤天数勉强及格，但考试分数非常完美@就是这样一个女孩子","narrationBg":"narration","narrationCoverOpacity":80.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/memoria_1198.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"御魂","narration":"我以前就读于水名女子学园@在当地是一位知名的才色兼备的女孩@但是因为某件事情而回到了大东学院","narrationBg":"narration","narrationCoverOpacity":80.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/memoria_1200.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"御魂","narration":"水名和大东对我来说都是黑历史@是一道隐藏于深渊之中的深刻伤痕@它给予了我足够浓厚的恨意@令我许愿毁灭这个城市","narrationBg":"narration","narrationCoverOpacity":80.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"…………"},{"narration":"但是……"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/31017_puellamag.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"御魂","narration":"我着手进行调整工作后，@读取到大家的记忆","narrationBg":"narration","narrationCoverOpacity":80.0,"narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"感觉自己那颗因愤怒与憎恶@而冰冻的心灵渐渐融化了"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31017_mitama_story/31017_puellamag.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":0,"pos":2}],"narration":"毕竟","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"bg":"bg_adv_11061.jpg","chara":[{"id":101000,"motion":200}],"nameLeft":"御魂","nameRight":"桃子","narrationEffect":"out","textRight":"喂，调整专家，@听说使魔又出现了？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":0}],"textLeft":"毕竟大家很温柔嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000}],"textRight":"嗯？"},{"chara":[{"id":101700,"motion":100}],"textLeft":"没什么～"},{"autoTurnFirst":2.0,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_05","textHome":"拥有这个力量，我就能活下去了。"}],"nameCenter":"御魂","textCenter":"即使感到后悔，@我也无法逃避自己的愿望。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":6.0,"chara":[{"id":101700,"motion":300}]},{"chara":[{"id":101700}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}