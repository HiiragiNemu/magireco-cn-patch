{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_18041.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":801300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303601}],"nameLeft":"由贵真里爱","textLeft":"小慎，你经常来这边玩吗？","turnChangeOut":"fadeOut"},{"chara":[{"id":801300}],"nameRight":"","textRight":"也没有……"},{"chara":[{"id":303601}],"nameLeft":"由贵真里爱","textLeft":"这样啊。"},{"chara":[{"id":303601,"motion":1}],"nameLeft":"由贵真里爱","textLeft":"那姐姐来跟你说说好多好玩的地方吧。"},{"chara":[{"id":303601}],"nameLeft":"由贵真里爱","textLeft":"小慎你可要好好记住……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":100,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"以后要介绍给你妈妈，@带她一起玩哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801300,"pos":2}],"nameRight":"","textRight":"嗯，我知道了。"},{"chara":[{"id":801300}],"nameRight":"","textRight":"我要是能跟妈妈一起去就好了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801300,"pos":2}],"nameRight":"","textRight":"毕竟我妈妈比其他人的妈妈都要忙……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"lipSynch":0,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"……"},{"chara":[{"id":303601,"lipSynch":0,"motion":0}],"nameLeft":"由贵真里爱","textLeft":"（是啊……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"id":303601,"lipSynch":0,"motion":300,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"（和其他孩子相比，@他当然会觉得寂寞了。）"},{"chara":[{"id":303601,"lipSynch":0}],"nameLeft":"由贵真里爱","textLeft":"（我也有过同样的经历啊……）"},{"autoTurnLast":0.5,"bg":"bg_adv_21142.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801201,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801600,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story02","chara":[{"id":801201}],"nameRight":"","textRight":"咦？！","turnChangeOut":"fadeOut","turnEffect":"sepiaFrame"},{"chara":[{"id":801201}],"nameRight":"","textRight":"原来真里爱的爸爸@在那座大楼里工作吗？！"},{"chara"