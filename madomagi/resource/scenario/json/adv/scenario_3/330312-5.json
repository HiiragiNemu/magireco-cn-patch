{"story":{"group_1":[{"bg":"bg_adv_14051.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"pos":2}],"nameLeft":"绫野梨花","nameRight":"都雏乃","textLeft":"不光是现在……@将来也一样……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303101}],"textLeft":"我很清楚，如果不依赖魔法……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303101,"motion":300}],"textLeft":"我实现恋情的可能性@就会一直是０％。"},{"nameNarration":"绫野梨花","narration":"即使我喜欢的人@和恋人分手@重回单身……","narrationBg":"bg_adv_18043.jpg","narrationEffect":"in"},{"narration":"那也轮不到我@肯定会有其他人插队"},{"narration":"等到我都变成老太婆@也不可能轮得到我"},{"narration":"即使我撑着伞在雨里等@我喜欢的人也不会走进我的伞下","surround":"7004_rain"},{"narration":"我……"},{"narration":"就只能眼睁睁看着@喜欢的人走进别人伞下@和别人肩并肩一起回家……"},{"narration":"不管我怎么等……@对方也不可能会出现在我的身旁","surround":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301},{"cheek":0,"face":"mtn_ex_030.exp.json","id":303101,"motion":0}],"nameLeft":"绫野梨花","nameRight":"都雏乃","narrationEffect":"out","textRight":"怎么会……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"textRight":"为什么你@把话说得这么死啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101}],"textLeft":"因为，我喜欢的人，@是女孩子啊。"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300301}],"textRight":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":200}],"textLeft":"我喜欢的人，@是女孩子。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"所以，@我的赢面才是０％啊。"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300301,"motion":400}],"textRight":"是吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"你会觉得我恶心吗？"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300301}],"textRight":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"身为女生却喜欢同性，@你会觉得我恶心吧。"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"为什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":200}],"textLeft":"诶？@因为，这很奇怪啊。[chara:303101:cheek_0:face_mtn_ex_011.exp.json]"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"一般来说，女生@应该喜欢男生才对吧？"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300301}],"textRight":"不一般就是怪异吗？"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300301}],"textRight":"不一般……就很恶心吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303101,"lipSynch":0}],"textLeft":"…………"},{"bg":"bg_adv_21221.jpg","chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":303101,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":800400,"motion":0,"pos":2}],"nameLeft":"绫野梨花","textLeft":"不一般就很好笑吗？@不一般就很奇怪哦？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"bg":"bg_adv_14051.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"pos":2},{"cheek":1,"face":"mtn_ex_050.exp.json","id":303101,"motion":0,"pos":0}],"nameLeft":"绫野梨花","nameRight":"都雏乃","textRight":"不一般又怎样。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"因为这种事觉得别人怪异的人，@自己才是最怪异的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300}],"textRight":"你说的，我不太懂。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"再说了，@到底什么叫做“一般”？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textRight":"对吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303101,"motion":300}],"textLeft":"嗯……嗯……@是啊……[chara:303101:cheek_1:face_mtn_ex_010.exp.json]"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"哈哈……@感觉好好笑……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301}],"textRight":"诶？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"我一直觉得，@这件事我对谁都说不出口……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"结果在都学姐面前，@我却轻轻松松说出来了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":400}],"textRight":"哈哈，这是为什么呢？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101,"motion":300}],"textLeft":"是啊……@为什么呢……[chara:303101:cheek_1:face_mtn_ex_030.exp.json]"},{"autoTurnFirst":2.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101,"motion":201,"pos":1,"voice":"vo_char_3031_00_04","textHome":"个子虽小，心胸却很宽广啊——"}],"nameCenter":"绫野梨花","textCenter":"学姐你个子小小的，@胸襟却很广阔啊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303101}]},{"autoTurnFirst":0.5,"chara":[{"id":303101,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}]},{"chara":[{"id":303101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":2}