{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_46104.jpg","turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.5,"bg":"bg_adv_20033.jpg","bgChangeEffect":"exitWitchSpace","se":"7209_gate_close"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":200,"pos":1}],"nameCenter":"音梦","surround":"7009_night_townbuzz","textCenter":"呼……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":715001,"motion":200,"pos":2},{"id":101400,"pos":0}],"nameRight":"黑翼","textRight":"辛苦了。"},{"chara":[{"eyeClose":0,"id":101400,"motion":0}],"nameLeft":"音梦","textLeft":"嗯，对手比预想的要棘手。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":715002,"motion":0,"pos":2}],"textRight":"幸好你能平安回来。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400}],"textLeft":"你们也很努力。"},{"chara":[{"id":101400,"motion":100}],"textLeft":"所以作为奖励，@这个就给你们吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":715001,"motion":300,"pos":2}],"textRight":"我们都没能打倒魔女，@真的可以收下悲叹之种吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":715002,"motion":0,"pos":2}],"textRight":"是啊，@实在是无言以对……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0}],"textLeft":"别太谦虚，@我还觉得这点补偿太少了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":715002}],"textRight":"为什么？"},{"chara":[{"id":101400,"motion":300}],"surround":"stop","textLeft":"因为你们失去了队长。"},{"bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":715002,"lipSynch":0,"motion":400}],"textRight":"！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":715001,"lipSynch":0,"motion":0,"pos":2}],"textRight":"……[wait:1.0][chara:715001:lipSynch_1]咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":715001,"motion":300}],"textRight":"不是吧，你在骗人吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0}],"textLeft":"从结界里出来的@只有我一个人不是吗。"},{"chara":[{"id":715001,"motion":0}],"textRight":"不会吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":715002,"motion":300,"pos":2}],"textRight":"你骗人……"},{"autoTurnLast":1.5,"bg":"bg_adv_20023.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101401,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101401,"lipSynch":0}],"textCenter":"…………","turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"bg":"bg_adv_19111.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":715100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":715100,"motion":200}],"nameRight":"白翼","textRight":"我坚信只要保护[textBlue:传闻]、捕获魔女，@我们就能得到解放。","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":715100,"motion":300}],"textRight":"自我加入玛吉斯之翼起，"},{"chara":[{"id":715100}],"textRight":"这份信念就未曾改变。"},{"chara":[{"id":715100,"motion":0}],"textRight":"今后也请让我继续为组织出力！@以后还请多多指教！"},{"nameNarration":"音梦","narration":"今天，一位白翼消逝了","narrationBg":"black","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnLast":1.0,"bg":"bg_adv_20023.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800500,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"不好，补习迟到了！","turnChangeOut":"fadeOut"},{"chara":[{"id":800500}],"nameRight":"","textRight":"这下铁定要被老师骂了！"},{"nameNarration":"音梦","narration":"但是谁也不知道她的牺牲","narrationBg":"black","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"毕竟这个世界的构造就是如此"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":801100}],"textLeft":"呼，事故发生的时候，@我真以为自己要去见阎王了。","turnChangeOut