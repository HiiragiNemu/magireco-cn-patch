{"story":{"group_1":[{"bg":"bg_adv_21221.jpg","chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701,"lipSynch":0,"motion":300,"pos":2}],"nameLeft":"常盘七香","nameRight":"游佐叶月","textRight":"…………","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":302701}],"textRight":"这……"},{"bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701,"motion":0}],"textRight":"我没有故意设计啦~！"},{"chara":[{"id":300501,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300501,"motion":300}],"textLeft":"是吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701}],"textRight":"只不过……"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300501,"motion":0}],"textLeft":"只不过？"},{"chara":[{"id":302701,"motion":1}],"textRight":"木叶她……@性格有点内向……"},{"chara":[{"id":302701}],"textRight":"不太擅长交际……@虽然现在已经比之前好一点了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701,"motion":100}],"textRight":"这次的事让她@稍微打开了心扉……"},{"chara":[{"id":300501,"motion":1}],"textLeft":"为什么？"},{"chara":[{"id":302701,"motion":1}],"textRight":"她是第一次和我们三人以外的人@一起战斗"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701}],"textRight":"第二次商讨之后@她还絮絮叨叨地跟我说"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302701,"motion":200}],"textRight":"『还是我们三个人一起比较好』、@『不能中止这个决定吗』之类的话"},{"chara":[{"id":300501,"motion":100}],"textLeft":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701,"motion":0}],"textRight":"不过，在上次和魔女战斗之后，@木叶就有些改变了……"},{"chara":[{"id":302701}],"textRight":"和七香你们一起聊天，@并且一起战斗……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701,"motion":1}],"textRight":"怎么说呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701}],"textRight":"我觉得她还……@挺开心的~"},{"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300501,"motion":0}],"textLeft":"挺开心的……是吗"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701,"motion":0}],"textRight":"木叶不太会把自己的想法@写在脸上……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701}],"textRight":"但我总觉得@她好像很开心"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300501,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"id":302701}],"textRight":"和神滨的魔法少女团结起来，@对我们来说也是好事……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701}],"textRight":"我是这样想的"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701,"motion":100}],"textRight":"所以……@结果皆大欢喜呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701,"motion":0}],"textRight":"这就是我的想法~"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":1}],"textLeft":"这样啊……！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300501}],"textLeft":"那就好！@今后也请多关照！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701,"motion":1}],"textRight":"我才要请你多多关照！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":100}],"textLeft":"[chara:300501:effect_emotion_joy_0][se:7222_happy]嗯！@[chara:300501:lipSynch_0][wait:0.8][chara:300501:cheek_0][chara:300501:face_mtn_ex_011.exp.json][chara:300501:lipSynch_1]呵呵……！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701}],"textRight":"啊哈哈……！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302701,"lipSynch":0,"motion":0}],"textRight":"（这个人虽然笑着，@但眼里却没有笑意呢……）","turnEffect":"thinking"},{"bgm":"bgm01_anime05","nameNarration":"游佐叶月","narration":"[textRed:常盘七香]果然是个棘手的人物……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"narration":"不过，也是个很有趣的人……！"},{"narration":"今后也要继续和其他魔法少女接触"},{"narration":"这次的集会就到此结束了……"},{"nameNarration":"","narration":"<以上为游佐叶月的日记摘录＞"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":2.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302701,"motion":1,"pos":1,"voice":"vo_char_3027_00_05","textHome":"魔女已经打倒了，希望一切都能顺利吧～"}],"nameCenter":"游佐叶月","textCenter":"嗯，反正魔女也打倒了，@但愿万事大吉~","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302701,"motion":200}]},{"chara":[{"id":302701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}