{"story":{"group_1":[{"bg":"bg_adv_20031.jpg","bgm":"bgm03_story09","nameNarration":"圆","narration":"元旦当天……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"lipSynch":0,"motion":1,"pos":1}],"nameCenter":"圆","nameLeft":"圆","nameRight":"焰","narrationEffect":"out","textCenter":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":210000,"lipSynch":0}],"textCenter":"（结果，还是在店里@让别人帮我穿好和服……）"},{"textRight":"鹿、鹿目同学——！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}],"textCenter":"啊，焰"},{"autoTurnLast":0.2,"chara":[{"id":210000,"pos":0}]},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200350,"motion":300,"pos":2}],"textRight":"对、对不起！@我来晚了……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":201}],"textLeft":"没关系，不要紧哦，@还没到约好的时间。"},{"chara":[{"id":200350}],"textRight":"太、太好了……"},{"chara":[{"id":200350,"lipSynch":0,"motion":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100}],"textLeft":"怎么了？"},{"chara":[{"id":200350}],"textRight":"那个，鹿目同学@是让店里帮忙穿的吗？"},{"chara":[{"id":210000,"motion":0}],"textLeft":"嗯，我还是害怕@自己会穿走样。"},{"chara":[{"id":210000}],"textLeft":"焰呢？"},{"chara":[{"id":200350,"motion":1}],"textRight":"其实我也是……"},{"chara":[{"id":200350}],"textRight":"和服教室虽然很有趣，@却没能派上用场呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":300}],"textLeft":"不，不会啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000}],"textLeft":"沙耶香说了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":0}],"textLeft":"会留下回忆。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200350,"motion":100}],"textRight":"嗯！是啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000}],"textLeft":"得重新向@沙耶香道谢才行呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":210000}],"textLeft":"啊……！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200350,"motion":0}],"textRight":"怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100}],"textLeft":"沙耶香之前说@想看新年参拜的照片！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000}],"textLeft":"我们得多拍点照片！！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200350,"motion":100}],"textRight":"嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":0}],"textLeft":"那么，@焰……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200350,"motion":0}],"textRight":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":1}],"textLeft":"新年快乐！@今年也请多多指教！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200350}],"textRight":"啊……"},{"chara":[{"eyeClose":1,"id":200350,"motion":100}],"textRight":"新年快乐，@今年也请多多指教。"},{"chara":[{"id":210000,"motion":0}],"textLeft":"嘿嘿。"},{"chara":[{"eyeClose":0,"id":200350}],"textRight":"嘻嘻嘻。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":201}],"textLeft":"那我们走吧，小焰。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}],"textLeft":"我们得去水名神社@抽神签呢！"},{"chara":[{"id":200350,"motion":1}],"textRight":"嗯……！"},{"autoTurnFirst":3.6,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_05","textHome":"要是大家都能过个幸福的年就好了呢。"}],"nameCenter":"圆","textCenter":"我最开心的事情，@就是大家都能迎来幸福的新年。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]},{},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}