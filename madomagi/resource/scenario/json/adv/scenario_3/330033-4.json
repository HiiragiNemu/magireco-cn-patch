{"story":{"group_1":[{"bg":"bg_adv_21025.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":200,"mouthOpen":0,"pos":2}],"nameLeft":"都雏乃","nameRight":"木崎衣美里","textRight":"但是，那个魔女@究竟是什么呢？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"mouthOpen":0}],"textLeft":"什么意思？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textRight":"因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"mouthOpen":0}],"textRight":"连灵魂宝石都没有反应，@她就突然出现了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textLeft":"哦哦……小学里的魔女啊……@的确如此。"},{"chara":[{"cheek":0,"id":300301,"motion":300,"mouthOpen":0}],"textLeft":"如果只有衣美里这样，@可能是你忽略了反应……"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textLeft":"但是我也在场，@我想应该不是……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"motion":300,"mouthOpen":1}],"textRight":"喂——！@若无其事地说我的坏话！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textLeft":"哈哈，开玩笑啦。"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textLeft":"不过，作为魔法少女，@必须时刻保持警惕……"},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textRight":"哎呀……@不过话说回来！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"mouthOpen":0}],"textLeft":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textRight":"我好高兴啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textRight":"嘟～前辈为我而哭了呢。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":0}],"textLeft":"笨蛋！[chara:300301:effect_emotion_angry_0][se:7219_strain]@我没有哭！！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":100,"mouthOpen":0}],"textRight":"不对不对，@我记得很清楚哦？"},{"chara":[{"cheek":0,"id":300601,"mouthOpen":0}],"textRight":"我已经把那一幕记录在……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0,"tear":0}],"textRight":"“回忆相册@嘟～之页”里面了！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300301,"motion":300,"mouthOpen":0}],"textLeft":"别制造这种令人恶心的相册！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textRight":"但是，真的像@第一次见面的时候那样。"},{"chara":[{"cheek":0,"id":300601,"mouthOpen":0}],"textRight":"你再一次@赶来救我了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textRight":"我果然@非常佩服嘟～前辈！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textRight":"你不但救了我……"},{"chara":[{"cheek":0,"id":300601,"mouthOpen":0}],"textRight":"还一个人@打败了魔女！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textLeft":"什么“佩服”啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"mouthOpen":0}],"textLeft":"明明还是一如既往地@瞧不起我。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textRight":"我真的很佩服嘟～前辈嘛。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300301,"mouthOpen":0}],"textLeft":"说什么呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textRight":"我一心想让嘟～前辈依赖我，@甚至不顾性命地乱来。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"mouthOpen":0}],"textRight":"对我来说，@嘟～前辈是一个伟大的人哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textLeft":"衣美…………"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":100,"mouthOpen":0}],"textRight":"虽然身体是迷你的！"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":300301,"mouthOpen":0}],"textLeft":"你……！[chara:300301:effect_emotion_angry_0][se:7219_strain]"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":1}],"textLeft":"你、[chara:300301:effect_emotion_angry_1][se:7218_anger]你这家伙！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":1}],"textRight":"呀哈哈！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textRight":"嘟～前辈@果然好可爱——！"},{"chara":[{"cheek":1,"id":300301,"motion":300,"mouthOpen":0}],"textLeft":"闭嘴！放开我！！"},{"chara":[{"cheek":0,"id":300601,"motion":0,"mouthOpen":0}],"textRight":"蹭脸之刑～"},{"chara":[{"cheek":1,"id":300301,"motion":200,"mouthOpen":1}],"textLeft":"唔呃！@住手、快住手！！"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"pos":1,"voice":"vo_char_3003_00_05","textHome":"真是的，突然说这么奇怪的话。@是不是有点太得意忘形了……"}],"nameCenter":"都雏乃","textCenter":"真是的，突然说些奇怪的话，@让人都不知道该做出什么反应了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"id":300301,"motion":400}]},{"chara":[{"id":300301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}