bgm01_anime07","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301901,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"motion":0,"pos":2}],"surround":"7102_townbuzz","textLeft":"哎呀！@[chara:301901:effect_emotion_joy_0][se:7222_happy]今天也笑爆了！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901}],"textLeft":"Needle Roller的相声表演@果然是最棒的！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"lipSynch":0,"motion":300}],"textRight":"（“Needle Roller”原来是……@搞笑组合啊。）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901}],"textLeft":"哎呀！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":0}],"textLeft":"筋田的那个吐槽，@比喻太形象啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301901,"motion":200}],"textLeft":"绕车道第三圈的三文鱼！@[chara:301901:cheek_0:face_mtn_ex_010.exp.json]哈哈！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301901,"motion":0}],"textLeft":"真是@精准狙击我的笑点！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300701,"lipSynch":0,"motion":0}],"surround":"stop","textRight":"（太过精准了，@我没get到……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":100}],"textLeft":"是吧！@你不是也这么觉得！"},{"chara":[{"cheek":0,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300701,"motion":401}],"se":"7226_shock","textRight":"诶！@啊、嗯……[chara:300701:cheek_0:face_mtn_ex_030.exp.json]那个……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301901,"motion":0}],"textLeft":"咦！@有那么不好笑吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301901,"motion":300}],"textLeft":"说起来，@你确实没怎么笑……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"motion":100}],"textRight":"啊！@不、不是啊，但是！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300701,"lipSynch":0,"motion":300}],"textRight":"（不能辜负她的好意……@就算是撒谎也要夸一下……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301901,"motion":1}],"textLeft":"嗯～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":0}],"textLeft":"可能你和其他人的笑点@不太一样吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"lipSynch":0,"motion":0}],"textRight":"（诶……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"lipSynch":0}],"textRight":"（但是当时……@只有你一个人在笑啊……）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301901}],"textLeft":"算了，不用在意！@[chara:301901:cheek_0:face_mtn_ex_010.exp.json]每个人的笑点都不一样嘛！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701}],"textRight":"谢……谢谢……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"lipSynch":0,"motion":101}],"textRight":"（既然她都这么说了，@那就这样吧……）"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901}],"textLeft":"总有一天你会……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301901}],"textLeft":"啊……名字。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"motion":0}],"textRight":"诶？"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":200}],"textLeft":"我们都@忘记自我介绍了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300701,"motion":300}],"textRight":"啊……@对了……的确忘记了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":100}],"textLeft":"我叫毬子亚弥华！@你呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300701,"motion":0}],"textRight":"嗯，@我叫保澄雫。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301901,"motion":0}],"textLeft":"保澄雫！@[chara:301901:cheek_0:face_mtn_ex_011.exp.json]嗯！请多关照！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300701}],"textRight":"嗯，请多关照。"},{"autoTurnFirst":5.5,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301901,"motion":300,"pos":1,"voice":"vo_char_3019_00_03","textHome":"嗯……虽然笑点和我想的不一样……@但是个好孩子呢！"}],"nameCenter":"毬子亚弥华","textCenter":"嗯……虽然我们笑点不合拍……@但你是个好女孩！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[