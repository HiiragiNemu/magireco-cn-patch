{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","item":[{"path":"resource/scenario/img/33042_meguru_story/memoria_1473.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story19","nameNarration":"枇枇木巡","narration":"这样啊～","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":60.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"narration":"感谢笔名「向梦想骑行！」的朋友@鼓起勇气向我们寻求帮助！"},{"narration":"我也每天都在为梦想而努力@所以我也很理解你哦～"},{"narration":"「向梦想骑行！」的梦想是自行车竞赛选手@我的梦想是世界知名主持人@让我们一起全力以赴吧！"},{"narration":"哎呀，差不多到说再见的时间了！"},{"narration":"这周我们也收到了很多粉丝的来信！@非常感谢各位！"},{"narration":"粉丝来信甚至多到介绍不过来@巡选手真是无比感激无比感动！"},{"narration":"今后也请大家多多支持！"},{"narration":"那么今天的早间新闻就到这里！@以上便是枇枇木巡为您带来的播报！"},{"narration":"我们下周再见吧！"},{"autoTurnLast":0.01,"bg":"bg_adv_21021.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201,"motion":0,"pos":1}],"item":[{"path":"resource/scenario/img/33042_meguru_story/memoria_1473.jpg","posX":0,"posY":0,"visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":304201}],"nameCenter":"枇枇木巡","textCenter":"[chara:304201:effect_emotion_joy_0][se:7222_happy]呼～","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":304201,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":2}],"nameRight":"","textRight":"枇枇木，辛苦了！@今天的节目也很精彩哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":100}],"nameLeft":"枇枇木巡","textLeft":"啊，学姐！谢谢夸奖！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":2}],"textRight":"广播社既招揽到了新社员，@还推出了新的节目。"},{"chara":[{"id":800100}],"textRight":"哎呀～广播社能有今天的成绩，@都是多才多艺枇枇木的功劳啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201,"motion":300}],"textLeft":"学姐你过奖啦～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":2}],"textRight":"那下周也拜托你咯。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":200}],"textLeft":"好的！学姐辛苦啦！"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":800200}],"textClear":1},{"chara":[{"id":304201,"lipSynch":0,"motion":0,"pos":1}],"textCenter":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":300}],"textCenter":"啊～这周的星期三也结束了……"},{"chara":[{"eyeClose":1,"id":304201,"lipSynch":0}],"textCenter":"（已经等不及下一周的轮值日了～）"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304201,"lipSynch":0,"motion":0}],"textCenter":"（啊，差不多该考虑@下个月的节目主题了！）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"lipSynch":0}],"textCenter":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201,"lipSynch":1,"motion":100}],"textCenter":"嘿嘿……"},{"nameRight":"丘比的声音","textRight":"看来进展很顺利嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304201,"motion":400}],"textCenter":"[chara:304201:effect_emotion_surprise_0][se:7226_shock]哇？！"},{"autoTurnLast":0.2,"chara":[{"id":304201,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":0},{"id":810000,"motion":0,"pos":2,"posX":40,"posY":0}],"textLeft":"原来是丘比啊……@真是吓我一跳～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":1}],"textLeft":"不过我通往知名主持人的道路@的确顺利得叫人害怕啊～"},{"chara":[{"eyeClose":1,"id":304201}],"textLeft":"唉……真想快点成为知名主持人啊！"},{"chara":[{"id":810000}],"nameRight":"丘比","textRight":"你为什么这么想成为知名主持人呢？"},{"bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":0}],"textLeft":"这是因为……"},{"chara":[{"id":304201,"motion":300}],"textLeft":"其实我以前没有任何长处……"},{"autoTurnLast":0.2,"bg":"bg_adv_21025.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story03","chara":[{"id":304201}],"nameNarration":"枇枇木巡","narration":"「我一直都很憧憬艺人、运动员、@科学家和艺术家……为此我也@尝试过努力学习和运动，@可都没有结果，名次也都全是垫底……」","narrationCoverOpacity":150.0,"narrationEffect":"in","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"bg":"black","bgChangeEffect":"fade","chara":[{"eyeClose":1,"id":304201,"motion":300}],"narration":"「我根本不能成为优秀的人……」"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304201,"motion":0}],"narration":"「所以我想，至少要离他们近一些……@于是我决定成为知名主持人@这样就能采访全世界的名人了！」"},{"bg":"bg_adv_21341.jpg","bgChangeEffect":"fade","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":1}],"narration":"「可不论我每天练习多久的对谈@也在学校里被提名过活动主持候选人@可我并没有主持的天赋@总是紧张得说不出话，控不了场……」"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201}],"narration":"「于是我决定在高中加入广播社@继续锻炼自己的主持能力@成为一名知名主持人！」"},{"autoTurnLast":0.5,"bg":"bg_adv_21021.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":1,"pos":0},{"id":810000,"motion":0,"pos":2,"posX":40,"posY":0}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":304201}],"textLeft":"不过我现在已经跟丘比许了愿，@所以一定能成为知名主持人的。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201}],"textLeft":"如果一切顺利，@说不定我还能碰上超级明星呢！"},{"chara":[{"id":810000}],"textRight":"或许吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304201,"motion":0}],"textLeft":"啊，但是我有个更简单的方法哦！"},{"chara":[{"id":810000}],"textRight":"是什么呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":200}],"textLeft":"只要再和丘比许愿就可以了呀！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201}],"textLeft":"丘比，你能让我现在就见到名人吗？！"},{"bgm":"stop","chara":[{"id":810000}],"textRight":"巡……"},{"chara":[{"id":810000}],"textRight":"我一开始就说过，@我只能实现你的一个愿望。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304201,"lipSynch":0}],"textLeft":"……"},{"bgm":"bgm03_story20","chara":[{"id":304201,"motion":400,"mouthOpen":1}],"textBg":"shout","textLeft":"难以置信！！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"mouthOpen":0}],"textLeft":"巡选手因大受打击而陷入消沉……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":100}],"textLeft":"开玩笑的！那就没办法啦！"},{"chara":[{"eyeClose":1,"id":304201}],"textLeft":"我以后一定能和名人对谈……"},{"chara":[{"eyeClose":0,"id":304201,"motion":200}],"textLeft":"直到那一天来临之前……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201}],"textLeft":"我的名言一定会响彻全世界的！"},{"autoTurnLast":0.1,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304201,"motion":200,"pos":1,"voice":"vo_char_3042_00_05","textHome":"响彻于心，巡游世界！我是枇枇木巡！"}],"nameCenter":"枇枇木巡","textCenter":"打动人心，巡游世界！@我就是枇枇木巡！","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304201}]},{"chara":[{"id":304201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}