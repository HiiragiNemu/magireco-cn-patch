{"story":{"group_1":[{"autoTurnLast":0.2,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":302001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_19061.jpg","bgm":"bgm01_anime03","chara":[{"id":302001,"lipSynch":0}],"nameLeft":"真尾日美香","nameRight":"粟根心","textLeft":"（对我来说，心她……@真的是……）","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302001,"lipSynch":0}],"textLeft":"（像姐姐一样呢）"},{"chara":[{"id":302001,"lipSynch":0}],"textLeft":"（虽然我觉得很难为情……@没有对本人说过）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":100}],"textRight":"怎么了？@笑眯眯的？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":302001,"motion":400}],"textLeft":"诶？啊，没事。@[chara:302001:lipSynch_0][wait:0.8][chara:302001:cheek_0][chara:302001:face_mtn_ex_030.exp.json][chara:302001:lipSynch_1]我只是想到……"},{"chara":[{"id":302001}],"textLeft":"如果那天没有遇到你，@我会是什么样子……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301601}],"textRight":"唔……你问我也……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302001,"motion":100}],"textLeft":"啊哈哈，是啊。@谁也不知道呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302001}],"textLeft":"说起来，@后来发生的事……"},{"chara":[{"id":302001}],"textLeft":"我有对你说过吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":0}],"textRight":"你这么一说，好像是没有……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":801300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":801200,"motion":0,"pos":0}],"nameCenter":"日美香的声音","nameRight":"日美香的弟弟","textRight":"啊啊！@姐姐你们又偷懒！","turnChangeIn":"rollInFast","turnChangeOut":"rollOutFast"},{"textBg":"shout","textCenter":"我们也有在摘花哦！@看！！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801200,"motion":0}],"nameLeft":"日美香的妹妹","textLeft":"诶诶……！@我的更多哦——！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301601,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":302001,"motion":0,"pos":0}],"nameLeft":"真尾日美香","nameRight":"粟根心","textRight":"不过，现在一看，@就知道你们已经和好啦。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302001,"motion":1}],"textLeft":"对！@虽然……发生了许多争执。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302001}],"textLeft":"「我很高兴你有这份心，@但其实我都知道」"},{"chara":[{"id":302001}],"textLeft":"爸爸是这样说的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302001,"motion":400}],"textLeft":"因为钱的问题，@家庭破碎！！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":400}],"textRight":"[chara:301601:effect_emotion_surprise_0][se:7226_shock]诶！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302001,"motion":0}],"textLeft":"……在这之前，@丘比出现了。"},{"chara":[{"id":302001}],"textLeft":"我让它治好了爸爸的病……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302001,"motion":100}],"textLeft":"虽然发生了很多事……@但我现在生活得很开心！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301601,"motion":0}],"textRight":"这样啊！@嗯，太好了。"},{"autoTurnLast":1.0,"bgm":"stop","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302801,"lipSynch":0,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":801200,"motion":0,"pos":0}],"nameLeft":"日美香的妹妹","nameRight":"三栗菖蒲","textRight":"…………","turnChangeOut":"fadeOut"},{"chara":[{"id":302801}],"textRight":"找不到蓝色的花……"},{"chara":[{"id":801200}],"textLeft":"但、但是……@白色的花有这么多！"},{"chara":[{"id":302801,"motion":300}],"textRight":"嗯……"},{"chara":[{"id":302801}],"textRight":"但是，我还是想要蓝色的花……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801300,"motion":0,"pos":0}],"nameLeft":"日美香的弟弟","textLeft":"再、再找找？@怎么样！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301601,"motion":0,"pos":0}],"nameLeft":"粟根心","textLeft":"嗯……"},{"chara":[{"id":301601}],"textLeft":"再找下去太阳就要下山了，@会有危险的。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":302001,"lipSynch":0,"motion":1,"pos":0}],"n