{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_23091.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":200552,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"叮咚——","narrationBg":"bg_adv_23091.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"开门"},{"chara":[{"id":200552}],"nameLeft":"麻美","nameRight":"渚","narrationEffect":"out","textLeft":"小渚？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200552}],"textLeft":"哎呀，佐仓也在呀？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":400,"pos":2}],"nameRight":"杏子","textRight":"嗯，她们还没来？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200552,"motion":1}],"textLeft":"这会儿还没到呢，@可派对马上就要开始了……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200652,"motion":300}],"textRight":"原来我们是第一个到的啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":270000,"motion":300,"pos":0}],"nameLeft":"渚","textLeft":"白着急了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":100}],"nameRight":"杏子","textRight":"给，这是礼物。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200552,"motion":300,"pos":0}],"nameLeft":"麻美","textLeft":"这是“Sugar plum”的@巧克力蛋糕？"},{"chara":[{"id":200652,"motion":0}],"textRight":"没错，我买了所有人的份，@你先放进冰箱里吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200552,"motion":0}],"textLeft":"佐仓，谢谢你。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200552,"motion":100}],"textLeft":"看来这会是一场美好的巧克力派对呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000,"motion":0,"pos":0}],"nameLeft":"渚","nameRight":"杏子","textLeft":"啊……"},{"chara":[{"id":270000,"motion":1}],"textLeft":"原来一开始杏子说的自己有事……"},{"autoTurnLast":0.01,"bg":"bg_adv_21221.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200652,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":270000,"motion":400}],"textLeft":"杏子！你怎么在这儿？！","turnChangeOut":"fadeOut"},{"chara":[{"id":200652,"motion":100}],"textRight":"嗯……我有点事要办。"},{"autoTurnLast":0.01,"bg":"bg_adv_23091.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":200652,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":0}],"textLeft":"是要去给大家买礼物啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":400}],"textRight":"我也给你买了哦。"},{"chara":[{"id":200652}],"textRight":"要是事先知道蛋糕是从哪里买的@就不好玩了吧。"},{"chara":[{"id":270000}],"textLeft":"所以才没有告诉我啊。"},{"chara":[{"id":270000,"motion":1}],"textLeft":"其实我也准备了特别的礼物……"},{"chara":[{"id":270000}],"textLeft":"不过我还买了另外的伴手礼@准备送给大家。"},{"autoTurnLast":0.2,"chara":[{"id":270000,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200552,"motion":0,"pos":0}],"nameLeft":"麻美","textLeft":"哎呀，是什么呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":270000,"motion":200}],"item":[{"path":"resource/scenario/img/51087_tower_nagisa2/51087_medal_chocolate.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"nameRight":"渚","textRight":"就是今天的战利品——@粉色奖章巧克力。"},{"chara":[{"id":200552,"motion":200}],"textLeft":"哎呀，真可爱！"},{"autoTurnLast":0.2,"chara":[{"id":270000,"pos":0}],"item":[{"path":"resource/scenario/img/51087_tower_nagisa2/51087_medal_chocolate.png","visible":"hide"}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200652,"motion":400,"pos":2}],"nameRight":"杏子","textRight":"奖章巧克力？@你不是买来给自己吃的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":270000,"motion":100,"pos":0}],"nameLeft":"渚","textLeft":"我已经留好自己那份了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200652,"motion":0}],"textRight":"我就知道……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":200}],"textLeft":"明天才要开始真正的战斗呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":100}],"textRight":"你是说狩猎巧克力吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200552,"motion":0,"pos":0}],"nameLeft":"麻美","textLeft":"狩猎巧克力？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":100,"pos":2}],"nameRight":"渚","textRight":"我和杏子结成了联盟。"},{"chara":[{"eyeClose":1,"id":270000,"motion":300}],"textRight":"今天虽然有了不少收获……"},{"chara":[{"id":270000}],"textRight":"但明天和后天——"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":270000,"motion":200}],"textRight":"才是促销巧克力争夺战的高潮！"},{"chara":[{"id":200552,"motion":1}],"textLeft":"我是没听懂你们在说什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200552,"motion":100}],"textLeft":"可看到你们这么要好的样子，@我也很开心。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":270000,"motion":1}],"textRight":"嗯！"},{"autoTurnLast":0.01,"bgm":"stop","turnChangeIn":"fadeIn"},{"bg":"white","nameNarration":"渚","narration":"[textBlack:今天虽然忙碌@但我们还是在麻美的房间里@举办了巧克力派对，愉快度过了这一天]","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":100.0,"turnChangeOut":"fadeOut"},{"narration":"[textBlack:完]"},{"autoTurnLast":3.0,"bg":"bg_adv_21041.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":810200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900,"motion":0,"pos":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"“Pink·Tapir”直销店","narrationBg":"bg_adv_21041.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"bgm":"bgm01_anime07","chara":[{"id":810200}],"nameLeft":"","nameRight":"早乙女老师","narrationEffect":"out","textRight":"你好。"},{"chara":[{"id":800900}],"textLeft":"欢迎光临，让您久等了。"},{"chara":[{"id":800900}],"textLeft":"这是您的粉色奖章巧克力。"},{"chara":[{"id":800900}],"textLeft":"感谢您每年都来购买我们的商品。"},{"chara":[{"id":810200}],"textRight":"我去车站前的分店打听了一下，@店员就告诉我……"},{"chara":[{"id":810200}],"textRight":"从今年起@奖章巧克力改在这家店里销售了。"},{"chara":[{"id":800900}],"textLeft":"感谢您的光临。"},{"chara":[{"id":800900}],"textLeft":"听说您一直在医院里举办慈善活动？"},{"chara":[{"id":810200}],"textRight":"是的。"},{"chara":[{"id":810200}],"textRight":"一开始我是被朋友叫来帮忙的，@可我看到孩子们高兴的样子……"},{"chara":[{"id":810200}],"textRight":"就忍不住每年都来参加了……"},{"chara":[{"id":800900}],"textLeft":"这真是一件好事啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900}],"textLeft":"啊，不好意思……耽误了您的时间。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textLeft":"您接下来还要去布置活动现场吗？"},{"chara":[{"id":810200}],"textRight":"是的，我之后就准备去医院。"},{"chara":[{"id":810200}],"textRight":"必须要赶在被孩子们发现之前，@在医院里藏好巧克力！"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"id":270000,"motion":300,"voice":"vo_char_2700_00_05","textHome":"撕开包装纸的瞬间，真是欲罢不能的说……"}],"nameCenter":"渚","textCenter":"拆开包装纸的瞬间真叫人激动啊……","turnChangeOut":"fadeOut"},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":270000,"motion":100}]},{"chara":[{"id":270000}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}