{"story":{"group_1":[{"bg":"bg_adv_21061.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403401,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":403301,"motion":0,"pos":0}],"nameLeft":"成见亚里纱","nameRight":"诗音千里","textRight":"呵呵……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":403401}],"textRight":"不管怎么说，@那三个人看上去关系很好呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403401,"motion":1}],"textRight":"就像平时的我们一样。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403301,"motion":1}],"textLeft":"诶，是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403401}],"textRight":"嗯。@不过……我们是四人组呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403401,"motion":200}],"textRight":"『再磨蹭就扔下你不管了！』"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403401}],"textRight":"总觉得像是@亚里纱会说的话呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403301,"motion":100}],"textLeft":"我说啊……"},{"chara":[{"id":403301}],"textLeft":"你觉得我这个人@是什么性格啊？"},{"chara":[{"id":403401,"motion":300}],"textRight":"嗯，我想想哦……"},{"chara":[{"id":403401,"motion":1}],"textRight":"虽然有点笨拙，@却比任何人都关心朋友！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":403301,"lipSynch":0,"motion":400}],"textLeft":"[chara:403301:effect_emotion_surprise_0][se:7226_shock]——！？"},{"chara":[{"id":403401}],"textRight":"真的要扔下对方不管的话，@肯定不会那么说吧？"},{"chara":[{"id":403401}],"textRight":"我觉得如果和我走散了，@亚里纱也会一直等我的。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":403301,"motion":200}],"textLeft":"你、你在说什么啊！@我才没有那么体贴！"},{"chara":[{"id":403401,"motion":200}],"textRight":"你看，又这么说！"},{"chara":[{"id":403401}],"textRight":"你这种不够坦率的性格@就是笨拙啊！"},{"chara":[{"id":403401,"motion":100}],"textRight":"但是，没关系哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403401}],"textRight":"刚认识你的时候，我不是说过吗？@现在开始也为时未晚。"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":403301,"lipSynch":0,"motion":300}],"textLeft":"…………"},{"nameNarration":"成见亚里纱","narration":"没错，就是这个笑容","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"拯救了孤独的我"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403301,"motion":1,"pos":1,"voice":"vo_char_4033_00_03","textHome":"千里真是的……@又让我想起了那个时候的事情……"}],"nameCenter":"成见亚里纱","textCenter":"千里你真是的……@让我想起了那时候的事情……","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403301,"motion":300}]},{"chara":[{"id":403301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}