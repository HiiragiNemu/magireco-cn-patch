0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":401301,"motion":0,"pos":2}],"textLeft":"嗯……？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401201,"motion":400}],"textLeft":"薰！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100,"mouthOpen":1}],"nameRight":"牧薰","textRight":"海香！"},{"nameNarration":"御崎海香","narration":"但追踪魔女的策略成功了。@我成功见到了薰……！","narrationBg":"bg_adv_21151.jpg","narrationEffect":"in"},{"narration":"可是……和美没有跟薰在一起……"},{"narration":"还没来得及感受重逢的喜悦，@我和薰又开始寻找和美"},{"narration":"中途，我们和佳子一行人汇合，@然后向她们道了谢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":0,"pos":2}],"nameLeft":"夏目佳子","nameRight":"纯美雨","narrationEffect":"out","textLeft":"我们也会一起寻找和美的！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":200}],"textRight":"如果发生了什么事，@就互相知会一声吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":100,"pos":0}],"nameLeft":"志伸晶","textLeft":"肯定很快就能找到人的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401201,"motion":0,"pos":2}],"nameRight":"御崎海香","textRight":"各位……@真的太感谢了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401201,"motion":100}],"textRight":"也代我向七香问好……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":1,"pos":0}],"nameLeft":"夏目佳子","textLeft":"好的！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101}],"textLeft":"然后，那个……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":401201,"motion":0}],"textRight":"嗯？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301101,"motion":100}],"textLeft":"下次，可以给我签名吗……？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":401201}],"textRight":"哎？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301101,"motion":400}],"textLeft":"不好意思！@我不该提出这么厚脸皮的要求！"},{"chara":[{"cheek":1,"face":"mtn_ex_022.exp.json","id":301101}],"textLeft":"可是，我好想要一份签名，@作为我们相识的纪念……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"那个……@我从佳子那里听说了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":200}],"textLeft":"可、可以也给我一份吗？@对不起！我是个庸俗的追星族……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":200,"pos":0}],"nameLeft":"纯美雨","textLeft":"我也想要签名……！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301101,"motion":300,"pos":0}],"nameLeft":"夏目佳子","textLeft":"然后……可以的话……@再加上七香的份……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":401201,"motion":1}],"textRight":"呵呵……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":401201,"motion":100}],"textRight":"小事一桩！"},{"nameNarration":"御崎海香","narration":"就这样，@我们出发寻找和美……","narrationBg":"bg_adv_21151.jpg","narrationEffect":"in"},{"narration":"寻找我的……"},{"narration":"另一个同伴！"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":1.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401201,"motion":400,"pos":1,"voice":"vo_char_4012_00_05","textHome":"快一点……要赶在那个魔女带来@更大的灾难之前！"}],"nameCenter":"御崎海香","textCenter":"必须抓紧时间……趁那个魔女@还没造成更大的灾害！","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"id":401201,"motion":1}]},{"chara":[{"id":401201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}