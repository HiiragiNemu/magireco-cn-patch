{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21083.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800700}],"nameLeft":"星罗的父亲","textLeft":"都出了这种事，@你还是想成为电影导演吗？　","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":303901,"lipSynch":0}],"nameRight":"三穗野星罗","textRight":"……"},{"bgm":"bgm03_story03","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901}],"textRight":"嗯！当然了！"},{"chara":[{"id":303901}],"textRight":"因为……"},{"chara":[{"id":303901,"motion":100}],"textRight":"爸爸你不是说我和他的审美很相似吗。"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……"},{"chara":[{"id":303901,"motion":0}],"textRight":"所以我一定要证明——"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901}],"textRight":"乔伊导演的审美是毋庸置疑的！"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"motion":1}],"textRight":"啊，可我的电影拍得还很马虎吧……"},{"chara":[{"id":303901}],"textRight":"刚才你也挑了很多毛病出来……"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……[wait:1.0][chara:800700:cheek_0][chara:800700:face_mtn_ex_030.exp.json][chara:800700:lipSynch_1]嗯，你的电影还有很多不足之处。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700}],"textLeft":"但是爸爸提出来的@全都是技术相关的问题……"},{"chara":[{"id":800700}],"textLeft":"只要你好好学习……"},{"chara":[{"id":800700}],"textLeft":"你就能熟练掌握这些技术。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700}],"textLeft":"所以你还得继续努力。"},{"bgm":"stop","chara":[{"id":303901,"motion":300}],"textRight":"嗯……"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"……[wait:1.0][chara:303901:cheek_0][chara:303901:face_mtn_ex_050.exp.json][chara:303901:lipSynch_1]咦？"},{"bgm":"bgm03_story09","chara":[{"id":303901}],"textRight":"你的意思是……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":0}],"nameLeft":"星罗的母亲","textLeft":"也就是说，你要进一步学习@对拍电影有帮助的技术。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0}],"textRight":"爸爸！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700,"motion":0,"pos":0}],"nameLeft":"星罗的父亲","textLeft":"我只有一个要求。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700}],"textLeft":"你不能模仿我哥哥那「可悲的」一面。"},{"chara":[{"id":303901,"motion":100}],"textRight":"嗯！"},{"autoTurnLast":1.5,"bg":"bg_adv_21026.jpg","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnChangeInTime":1.5,"turnEffect":"stop"},{"chara":[{"id":303901}],"nameRight":"三穗野星罗","textRight":"于是我就得到了父母的允许，@就读了设计专业。","turnChangeOut":"fadeOut","turnChangeOutTime":1.5},{"chara":[{"id":303801}],"nameLeft":"古町美仓","textLeft":"这样啊……"},{"chara":[{"id":303801}],"textLeft":"所以你才没有向丘比许愿，@希望自己能获得更好的审美啊。"},{"chara":[{"id":303901,"motion":100}],"textRight":"是的。"},{"chara":[{"id":303901}],"textRight":"我要靠我自己的审美来一决胜负。"},{"chara":[{"id":303801,"motion":1}],"textLeft":"所以才会许愿想要拍摄预算啊。"},{"chara":[{"id":303901,"motion":0}],"textRight":"是的！因为我明白了一个道理——"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"motion":300}],"textRight":"为了追求梦想，@运气和金钱都是必不可缺的……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":0}],"nameLeft":"吉良手鞠","textLeft":"既然你有如此强烈的愿望。"},{"chara":[{"id":304001}],"textLeft":"那你和丘比的相遇应该是必然吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"motion":1}],"textRight":"这也不好说呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303901,"motion":0}],"textRight":"其实我当时以为它是外星生物，@所以就特别兴奋……"},{"chara":[{"eyeClose":1,"id":303901,"motion":300}],"textRight":"可能就没想那么多吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801,"motion":101,"pos":0}],"nameLeft":"古町美仓","textLeft":"你当时该好好考虑一下吧……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0}],"textRight":"不过我也觉得这样就足够了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":0}],"nameLeft":"吉良手鞠","textLeft":"为什么呢？"},{"chara":[{"id":303901}],"textRight":"因为我成为魔法少女之后，@认识了两位温柔的学姐。"},{"chara":[{"id":303901,"motion":100}],"textRight":"而且还成立了历史研究社@这个待着特别开心的社团！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":100}],"textLeft":"说得也是啊……"},{"chara":[{"id":304001}],"textLeft":"或许只有这个历史研究社@能让你尽情地拍摄电影了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801,"motion":100,"pos":2}],"nameRight":"古町美仓","textRight":"你会这么想也挺奇怪的吧……"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":1,"pos":1,"voice":"vo_char_3039_00_05","textHome":"别看我这样，其实我一直都很感谢前辈们的"}],"nameCenter":"三穗野星罗","textCenter":"其实我很感谢两位学姐哦。","turnChangeOut":"fadeOut"},{"chara":[{"id":303901}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}