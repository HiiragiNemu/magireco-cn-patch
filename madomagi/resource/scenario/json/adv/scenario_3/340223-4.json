{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_20073.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402201,"motion":0,"pos":0},{"id":810000,"pos":2,"posX":40}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.01,"turnChangeOut":"fadeOut"},{"chara":[{"id":402201}],"nameLeft":"莉兹·霍克伍德","textLeft":"这里是……"},{"chara":[{"id":810000}],"nameRight":"丘卜","textRight":"应该是原来的森林。"},{"chara":[{"id":402201,"motion":1}],"textLeft":"由于解开了魔女的结界……"},{"chara":[{"id":402201}],"textLeft":"和栋雷米村一模一样的幻象@也消失不见了吧。"},{"chara":[{"id":810000}],"textRight":"看来是的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402101,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"塔鲁特","textRight":"…………"},{"chara":[{"face":"mtn_ex_050.exp.json","id":402101,"motion":400}],"nameRight":"塔鲁特","textRight":"咦……莉兹？@天使大人也在！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402201,"motion":100}],"textLeft":"塔鲁特……@你醒过来了！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":402201}],"textLeft":"没事吧！？@有没有觉得哪里不舒服？"},{"chara":[{"cheek":0,"id":402101,"motion":100}],"textRight":"那个……啊，没事！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402101}],"textRight":"我完全没问题！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402201,"motion":0}],"textLeft":"太好了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402101,"mouthOpen":1}],"textRight":"[chara:402101:effect_emotion_surprise_0][se:7226_shock]啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402201,"motion":100}],"textLeft":"怎么了？"},{"chara":[{"id":402101,"motion":0,"mouthOpen":0}],"textRight":"我好像听到@远处传来了声音？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402201,"motion":0}],"textLeft":"是人的声音？"},{"nameNarration":"梅丽莎·德·维尼奥勒","narration":"「……塔鲁特、莉兹！」","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"「听见的话就回应我！」"},{"chara":[{"cheek":0,"id":402201,"motion":200}],"nameLeft":"莉兹·霍克伍德","narrationEffect":"out","textLeft":"是梅丽莎的声音啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402101,"motion":100}],"nameRight":"塔鲁特","textRight":"她来找我们了呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402201,"motion":1}],"textLeft":"真让人吃惊……@没想到她真的能找到！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402201}],"textLeft":"我们在这里哦，梅丽莎！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402101,"motion":201}],"textRight":"我们都平安无事！"},{"autoTurnLast":1.0,"bg":"bg_adv_20102.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":402101,"motion":0,"pos":2}],"textClear":1,"turnChangeIn":"fadeIn"},{"autoTurnLast":0.01,"turnChangeOut":"fadeOut"},{"bgm":"bgm03_story05","chara":[{"id":402301}],"nameLeft":"梅丽莎·德·维尼奥勒","textLeft":"被魔女的结界困住了？"},{"chara":[{"id":402301}],"textLeft":"真的好危险啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402301,"motion":300,"pos":0}],"textLeft":"能平安逃出来@真是太好了！"},{"chara":[{"id":402101}],"textRight":"你不用担心！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402101,"motion":1}],"textRight":"莉兹与天使大人@都和我在一起啊！"},{"chara":[{"id":810000,"pos":2,"posX":40}],"nameRight":"丘卜","textRight":"哎呀，那个敌人可不好对付。"},{"chara":[{"id":810000}],"textRight":"只是因为莉兹以前@碰巧和那个魔女战斗过……"},{"chara":[{"id":810000}],"textRight":"才勉强找到方法打败她！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402201,"lipSynch":0,"motion":100,"pos":0}],"nameLeft":"莉兹·霍克伍德","textLeft":"（碰巧？@不对，这并不是什么巧合。）","turnEffect":"thinking"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（彩羽和八千代也因为遇到了之前@曾经战斗过的魔女而十分惊讶。）"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（在这个世界……也就是@她们所说的“梦之法国”里……）"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（敌人都是从@我们过去的经历中诞生的。）"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402201,"motion":1,"pos":0}],"textLeft":"对了……塔鲁特，@你一直都昏迷不醒。","turnEffect":"stop"},{"chara":[{"id":402201}],"textLeft":"你记得多少事情？"},{"chara":[{"id":402201}],"textLeft":"还记得……@和栋雷米村一模一样的景色吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402101,"motion":1,"pos":2}],"nameRight":"塔鲁特","textRight":"嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402101,"pos":2}],"textRight":"在去确认凯瑟琳墓碑之前的事情，@我都记得很清楚。"},{"chara":[{"id":402101}],"textRight":"在那之后……@直到我醒过来……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402101,"motion":100,"pos":2}],"textRight":"我都只有一些很让人怀念的……@朦朦胧胧的记忆！"},{"chara":[{"id":402201,"motion":300}],"textLeft":"真是服了你了。"},{"chara":[{"cheek":1,"id":402101}],"textRight":"[chara:402101:effect_emotion_joy_0][se:7222_happy]诶嘿嘿……"},{"chara":[{"id":810000,"pos":0,"posX":-50}],"nameLeft":"丘卜","textLeft":"明明和莉兹同时受到了攻击，@但精神上却没有受到伤害……"},{"chara":[{"id":810000}],"textLeft":"塔鲁特是没有@“后悔”这种感情吗？"},{"chara":[{"face":"mtn_ex_030.exp.json","id":402101,"motion":300}],"textRight":"后悔……是吗？"},{"chara":[{"id":810000}],"textLeft":"嗯，就是你们人类对于@悲伤的事情流露出的普遍情感。"},{"chara":[{"id":402101}],"textRight":"悲伤的回忆倒是有。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402101,"motion":1}],"textRight":"但是，我不会后悔。"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/51015_singleraid_tart/memoria_1172.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"塔鲁特","narration":"―塔鲁特―@我向凯瑟琳发过誓","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":35.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"chara":[{"id":402101}],"narration":"―塔鲁特―@我一定要拯救这个国家，为此……"},{"autoTurnLast":0.1,"bg":"bg_adv_20102.jpg","bgEffect":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402201,"motion":0,"pos":0},{"id":810000,"pos":2,"posX":40}],"item":[{"path":"resource/scenario/img/51015_singleraid_tart/memoria_1172.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":402201,"lipSynch":0,"motion":100}],"nameLeft":"莉兹·霍克伍德","textLeft":"…………","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（并不是塔鲁特@欠缺“后悔”这种感情……）"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（而是因为她意志坚定，@负面感情无法趁虚而入。）"},{"chara":[{"id":402201,"lipSynch":0}],"textLeft":"（应该是这样吧。）"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402201,"motion":1}],"textLeft":"塔鲁特。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402101,"motion":400,"pos":2}],"nameRight":"塔鲁特","textRight":"[chara:402101:effect_emotion_surprise_0][se:7226_shock]嗯？"},{"chara":[{"eyeClose":1,"id":402201}],"textLeft":"一定是因为这样……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402201}],"textLeft":"你才是最后的希望之光啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402101,"motion":100}],"textRight":"嗯！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402101,"motion":200}],"textRight":"[chara:402101:effect_emotion_surprise_0][se:7226_shock]呃，诶诶？@什、什么意思啊？"},{"chara":[{"cheek":1,"id":402201,"motion":100}],"textLeft":"呵呵呵……"},{"autoTurnFirst":2.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":402201,"motion":100,"pos":1,"voice":"vo_char_4022_00_05","textHome":"塔鲁特就是我的……我们的希望之光。"}],"nameCenter":"莉兹·霍克伍德","textCenter":"塔鲁特……是我们的希望之光。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":402201}]},{"chara":[{"id":402201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}