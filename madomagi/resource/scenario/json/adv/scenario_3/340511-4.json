ht":"奈叶。","turnEffect":"stop"},{"chara":[{"id":405101,"motion":0}],"textLeft":"嗯，怎么了？"},{"chara":[{"id":100101}],"textRight":"我稍微有点明白了。"},{"chara":[{"id":100101}],"textRight":"对于你们来说，魔法的力量……"},{"chara":[{"id":100101,"lipSynch":0}],"textRight":"（没错，@那不是实现愿望的代价……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100101,"motion":100}],"textRight":"是为了“实现”愿望而存在的力量吧！","turnEffect":"stop"},{"chara":[{"id":405101}],"textLeft":"咦……啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405101,"motion":100}],"textLeft":"[chara:405101:effect_emotion_joy_0][se:7222_happy]嗯！@是这样的！"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_03","textHome":"为了保护重要的东西……我们的魔法，一定是@为了这个目的！"}],"nameCenter":"高町 なのは","textCenter":"为了守护珍爱的事物……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.0,"chara":[{"id":405101,"motion":100}],"textCenter":"我们的魔法，@一定是为了这些才存在的！"},{"chara":[{"id":405101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}