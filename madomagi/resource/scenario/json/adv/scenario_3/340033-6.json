{"story":{"group_1":[{"bg":"bg_adv_11093.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100300,"motion":300,"pos":2},{"cheek":1,"face":"mtn_ex_011.exp.json","id":400300,"motion":200,"pos":0}],"nameLeft":"我得向你们道谢。@[chara:200601:face_mtn_ex_000.exp.json:cheek_0]谢了。","nameRight":"鹤乃","surround":"7003_wind","textRight":"没事！@她还有气。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0,"pos":2}],"nameRight":"八千代","textRight":"……！@[chara:100200:lipSynch_0][freeze:1.2][chara:100200:lipSynch_1][chara:100200:cheek_0:face_mtn_ex_021.exp.json]这样啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":100200}],"textRight":"赶快对她@使用悲叹之种吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100,"motion":0,"pos":0}],"nameLeft":"彩羽","textLeft":"好！"},{"bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":301}],"surround":"stop","textRight":"真令人吃惊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":0}],"textRight":"居然有这么幼小的@魔法少女……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}],"textLeft":"是啊……@她还这么小……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"motion":0,"pos":2}],"nameRight":"鹤乃","textRight":"看起来也就@小学一二年级的样子。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":400300,"motion":200,"pos":0}],"nameLeft":"千岁由麻","textLeft":"杏……@子……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300}],"textRight":"？@她好像在说什么……"},{"chara":[{"cheek":1,"id":400300}],"textLeft":"杏……@杏子……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":0,"pos":0}],"nameLeft":"彩羽","textLeft":"“杏子”？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0,"pos":2}],"nameRight":"八千代","textRight":"她说的“杏子”……@该不会……[chara:100200:lipSynch_0][freeze:1.2][chara:100200:lipSynch_1][chara:100200:cheek_0:face_mtn_ex_010.exp.json]是指佐仓吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100300,"motion":0,"pos":2}],"nameRight":"鹤乃","textRight":"“佐仓”？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":201,"pos":2}],"nameRight":"八千代","textRight":"哎呀，就是之前见过一次的……"},{"chara":[{"effect":"fadeout","id":100200}],"nameRight":"","se":"7107_arrivalone","textRight":"由麻！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":400,"pos":2}],"nameRight":"杏子","textRight":"啊，怎么是你们！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":200,"pos":0}],"nameLeft":"八千代","textLeft":"果然是你啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":0}],"textRight":"“果然”？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}],"textLeft":"你……“果然”@认识这个孩子啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textRight":"你怎么知道的？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}],"textLeft":"她一直在迷迷糊糊地@喊着『杏子』、『杏子』，"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}],"textLeft":"一直@在喊你的名字。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0},{"cheek":1,"face":"mtn_ex_011.exp.json","id":400300,"motion":200,"pos":0}],"nameLeft":"千岁由麻","textRight":"…………@（由麻……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":0,"pos":0}],"nameLeft":"彩羽","textLeft":"对不起……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":301}],"textLeft":"我们赶来的时候，@她就已经是现在这样了……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":200,"mouthOpen":1}],"textRight":"现在哪样！？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100300,"motion":101,"pos":0}],"nameLeft":"鹤乃","textLeft":"没事的！她虽然受伤了，@[chara:100300:cheek_0:face_mtn_ex_050.exp.json]但不会有事的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":300}],"textRight":"什么嘛……@吓我一跳……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100,"motion":200,"pos":0}],"nameLeft":"彩羽","textLeft":"对、对不起……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textRight":"不用道歉啦。@你们不是救了她吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601}],"textRight":"我该向你们道谢。@[chara:200601:cheek_0:face_mtn_ex_000.exp.json]谢了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":400}],"textRight":"我欠你们@一份人情。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":0}],"nameLeft":"八千代","textLeft":"别往心里去。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}],"textLeft":"我们@也不图这个。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100300,"motion":0,"pos":0}],"nameLeft":"鹤乃","textLeft":"嗯嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textRight":"抱歉啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":300}],"textRight":"话说回来……@神滨到底是什么情况啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":100}],"textRight":"我才来神滨一天，@就碰上这么多破事了。"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":100200,"motion":301,"pos":0}],"nameLeft":"八千代","textLeft":"确实……现在，@神滨发生了某种异常现象……"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":100200}],"textLeft":"不过……我们还不清楚@原因是什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":200}],"textLeft":"怪事是最近几个月@开始发生的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}],"textLeft":"我虽然@从出生就一直住在神滨……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}],"textLeft":"但以前，@也从未见过这种事……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textRight":"就连熟悉神滨的魔法少女@也束手无策吗……"},{"bg":"bg_adv_20033.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0,"motion":100,"pos":0},{"cheek":1,"face":"mtn_ex_011.exp.json","id":400301,"motion":200,"pos":2}],"nameLeft":"杏子","nameRight":"千岁由麻","textLeft":"（我还是第一次@背由麻……）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0}],"textLeft":"（她好轻啊……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0,"motion":0}],"textLeft":"（我一直叫她@小鬼、小鬼……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0}],"textLeft":"（她还真的只是@一个小孩子呢……）"},{"chara":[{"cheek":1,"id":400301,"motion":100}],"textRight":"嗯……@嗯、唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":100}],"textLeft":"别乱动。@背上很痒啊。"},{"bgm":"stop","chara":[{"cheek":1,"id":400301}],"textRight":"嗯……杏……子……@杏……子……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textLeft":"……！"},{"chara":[{"cheek":1,"id":400301,"motion":200}],"textRight":"杏子……你没事吧？@有没有……哪里疼？"},{"chara":[{"cheek":1,"id":400301}],"textRight":"由麻……@要保护……杏子……"},{"bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0,"motion":300}],"textLeft":"（又说这种话……）@[chara:200601:lipSynch_1]我没事的啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0,"motion":0}],"textLeft":"（明明就是个小鬼，@别想着要保护我啊。）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0}],"textLeft":"（小孩子就要有小孩子的样子，@乖乖地被人保护啊。）"},{"bg":"bg_adv_20023.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1}],"nameCenter":"保澄雫","textCenter":"是个穿白衣的……@魔法少女……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"bg":"bg_adv_11093.jpg","chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":100200,"motion":301,"pos":1}],"nameCenter":"八千代","textCenter":"确实……现在，@神滨发生了某种异常现象……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"bg":"bg_adv_20033.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"lipSynch":0,"motion":100,"pos":0},{"cheek":1,"face":"mtn_ex_011.exp.json","id":400301,"motion":200,"pos":2}],"nameLeft":"杏子","nameRight":"千岁由麻","textLeft":"（不管以后发生什么事……）@[chara:200601:lipSynch_1]我都一定会[chara:200601:cheek_0:face_mtn_ex_021.exp.json]保护你的。","turnChangeIn":"fadeIn","turnChangeOut"