{"story":{"group_1":[{"bg":"bg_adv_21142.jpg","bgm":"bgm03_story03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"motion":0,"pos":2}],"nameNarration":"五十铃怜","narration":"在此之前@我在这个世上只看到了悲伤","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"可是，这个世界上@的确也有闪闪发光的事物……"},{"narration":"而这@是“魔法少女”@是我的同伴们告诉我的"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":302501,"motion":0}],"nameRight":"五十铃怜","narrationEffect":"out","textRight":"我……@不会死……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0},{"cheek":1,"face":"mtn_ex_001.exp.json","id":302501,"motion":0}],"narration":"我直直地凝视着@大家送给我的礼物、送给我的希望","narrationBg":"bg_adv_21142.jpg","narrationEffect":"in"},{"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":302501,"motion":1}],"nameLeft":"绫野梨花","nameRight":"五十铃怜","narrationEffect":"out","textRight":"我要……活下去……嗯……@我要活下去……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101,"lipSynch":0}],"textLeft":"……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":1}],"textLeft":"嗯……@太好了。"},{"bg":"bg_adv_14022.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp.json","id":302501,"motion":0,"pos":2}],"nameLeft":"绫野梨花","nameRight":"五十铃怜","textLeft":"那么， @我走这边。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303101}],"textLeft":"路上小心哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302501,"motion":100}],"textRight":"啊！@[chara:302501:lipSynch_0][wait:1.0][chara:302501:cheek_0][chara:302501:face_mtn_ex_030.exp.json][chara:302501:lipSynch_1]嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501,"motion":0}],"nameNarration":"五十铃怜","narration":"在分别之前……@最后……@无论如何……@有句话我一定要说……@我很想告诉她……","narrationBg":"bg_adv_14022.jpg","narrationEffect":"in"},{"narration":"说出来吧，用我的语言，@我的声音！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501,"motion":200}],"nameLeft":"绫野梨花","nameRight":"五十铃怜","narrationEffect":"out","textRight":"那个！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"lipSynch":0,"motion":0}],"textLeft":"？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302501,"motion":100}],"textRight":"谢谢你……@梨花……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101,"lipSynch":0}],"textLeft":"……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":1}],"textLeft":"没什么，@不用谢。"},{"bg":"bg_adv_11022.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"lipSynch":0,"motion":1,"pos":1}],"nameCenter":"五十铃怜","textCenter":"（好美的……晚霞……）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"nameNarration":"五十铃怜","narration":"真的好久没有觉得@晚霞是如此美丽了","narrationBg":"bg_adv_11022.jpg","narrationEffect":"in"},{"narration":"只要拥有大家给我的希望@我就能发现@许许多多@未知的@这个世界上的美好事物"},{"bg":"bg_adv_11081.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"motion":1,"pos":1}],"nameCenter":"五十铃怜","narrationEffect":"out","textCenter":"那个……@我，那时……","turnChangeIn":"fadeIn","turnChangeInTime":1.0,"turnChangeOut":"fadeOut","turnChangeOutTime":1.0},{"nameNarration":"五十铃怜","narration":"假如有一天，我能@将那天没能说出口的话坦白道出","narrationBg":"bg_adv_11081.jpg","narrationEffect":"in"},{"narration":"只要她能露出那日的笑容@只要有她在身边@我就一定能活下去"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":4.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302501,"motion":1,"pos":1,"voice":"vo_char_3025_00_05","textHome":"感觉……真的好久没看过……@这么美丽的夕阳了。"}],"nameCenter":"五十铃怜","textCenter":"真的好久……没有觉得@晚霞是如此美丽了。","turnChangeOut":"fadeOut"},{"autoTurnFirst":2.5,"chara":[{"id":302501,"motion":100}]},{"chara":[{"id":302501}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}