1}],"textLeft":"但实际上，并不是……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":0}],"textRight":"小千……"},{"chara":[{"id":102601,"motion":300}],"textLeft":"其实出了很多问题……@全靠大家帮忙……"},{"chara":[{"id":102601}],"textLeft":"所以看起来才会很顺利……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"千春的母亲","textRight":"小千，你能注意到这点@就很厉害了哦。"},{"chara":[{"id":102601,"motion":0}],"textLeft":"唔……"},{"chara":[{"id":102601,"motion":1}],"textLeft":"我还以为……@这次肯定帮上大家的忙了。"},{"chara":[{"eyeClose":1,"id":102601}],"textLeft":"结果又是我自以为是……"},{"bgm":"stop","chara":[{"id":800600}],"textRight":"没这回事。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600}],"textRight":"我们村子说不定有救了，@而创造契机的那个人……"},{"bgm":"bgm03_story18","chara":[{"id":800600}],"textRight":"毫无疑问，就是你啊。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":0}],"textLeft":"妈妈！"},{"chara":[{"cheek":1,"id":102601,"motion":200}],"textLeft":"那我不就成了……@拯救这个村子的英雄？！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textRight":"不，还没到这份上呢。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":102601,"motion":300}],"textLeft":"唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600}],"textRight":"你要多多学习，@成为一个见多识广的人。"},{"chara":[{"id":800600}],"textRight":"然后反过来帮那些帮过你的人。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":1}],"textLeft":"哇……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textRight":"这才是你想成为的英雄吧？"},{"chara":[{"id":102601}],"textLeft":"唔……我会加油的……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102601},{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900,"motion":0,"pos":2}],"nameLeft":"","textLeft":"只要能靠旅游业维持村落日常运转……"},{"chara":[{"id":800700}],"textLeft":"就不用去外面找新工作了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_01