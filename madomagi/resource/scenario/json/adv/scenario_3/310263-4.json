{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_50012.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":1,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story03","chara":[{"id":801000}],"nameRight":"千春的姑妈","textRight":"感谢你们今天邀请我们过来。","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":801000}],"textRight":"我们体验到了很多东西，@过得非常开心。"},{"chara":[{"id":102701}],"nameLeft":"沙绪","textLeft":"欢迎下次再来玩。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100,"pos":2}],"nameRight":"静香","textRight":"下次也得请各位泡泡温泉呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":400,"pos":0}],"nameLeft":"千春","textLeft":"咦？@这里有温泉啊？！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":0}],"textRight":"小千……你不知道吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"nameRight":"千春的表兄弟","textRight":"温泉啊！我今天就想泡了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300,"pos":0}],"nameLeft":"沙绪","textLeft":"啊……这稍微有点……@那边还没准备好……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":2}],"nameRight":"千春的姑父","textRight":"哈哈，@那下次再来玩吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"千春","textLeft":"？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"lipSynch":1}],"nameRight":"千春的表兄弟","textLeft":"请问……你们以后还会过来玩吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"textRight":"嗯，当然了！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102601,"motion":100}],"textLeft":"[chara:102601:effect_emotion_joy_0][se:7222_happy]太好了！"},{"autoTurnLast":1.0,"bg":"bg_adv_21443.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":102601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":1,"pos