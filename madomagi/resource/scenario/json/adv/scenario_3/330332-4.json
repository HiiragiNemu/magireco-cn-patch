{"story":{"group_1":[{"bg":"bg_adv_18054.jpg","bgm":"bgm01_anime03","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303300,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100,"motion":0,"pos":2}],"nameNarration":"史乃沙优希","narration":"演唱会在热烈的气氛中落下帷幕@沙优希见到了至今为止@从未看见过的景象！","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":801100}],"nameLeft":"史乃沙优希","nameRight":"","narrationEffect":"out","textRight":"演唱会真的很棒！"},{"chara":[{"id":801100}],"textRight":"我还想跟你一起分享感动，@请你今后继续加油！"},{"chara":[{"id":303300,"motion":100}],"textLeft":"谢、谢谢你！"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":801100},{"id":303300,"motion":0}],"textClear":1},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":100901,"motion":201,"pos":2,"soulGem":0}],"nameRight":"玲奈","textRight":"你、你、你好！@我、我是你的粉丝！"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100901,"motion":100}],"textRight":"“试刀☆Princess”@很、很好听！"},{"chara":[{"id":303300,"lipSynch":0}],"textLeft":"（这个女孩子跟我差不多大！）","turnEffect":"thinking"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303300,"motion":300}],"textLeft":"沙优希也非常开心，@感谢你今天能到场支持！","turnEffect":"stop"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":100901},{"id":303300,"motion":1}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"nameRight":"","textRight":"我听说沙优沙优喜欢刀，@所以我也对刀产生兴趣了！"},{"chara":[{"id":800500}],"textRight":"希望以后能在自由发言之类的环节上@听你聊聊日本刀！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303300,"motion":400}],"textLeft":"竟、竟然会！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303300}],"textLeft":"听你这么说，@沙优希真的好开心啊！"},{"bg":"bg_adv_21481.jpg","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301,"motion":1,"pos":1}],"nameNarration":"史乃沙优希","narration":"而且……@握手会也为沙优希带来了力量！","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"沙优希之后的几天一直都在傻笑@现在都还有人拿这事开玩笑呢……"},{"chara":[{"id":303301,"lipSynch":0}],"nameCenter":"史乃沙优希","narrationEffect":"out","textCenter":"（没想到气氛会那么热烈啊～）","turnEffect":"thinking"},{"chara":[{"id":303301,"lipSynch":0,"motion":300}],"textCenter":"（演唱会……@真叫人开心！）"},{"autoTurnLast":0.2,"chara":[{"id":303301,"pos":0}],"textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"nameLeft":"史乃沙优希","nameRight":"沙优希的经纪人","textRight":"你笑眯眯地在想什么呀？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303301,"motion":400}],"textLeft":"[chara:303301:effect_emotion_surprise_0][se:7226_shock]啊！经纪人小姐……"},{"chara":[{"id":801000}],"textRight":"来，给你。"},{"chara":[{"id":801000}],"textRight":"我发了你在演唱会上的照片，@反响很热烈哦。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303301,"motion":1}],"nameNarration":"","narration":"沙优沙优太可爱了！@想被她斩！","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","narrationHAlignment":"left","narrationPosX":180.0},{"narration":"她在演唱会上的表现比视频上的还好，@我超开心的！"},{"narration":"一起分享感动真是太棒了！@我还想再去她的演唱会。"},{"narration":"感觉为她加油能得回应，@她下一场演唱会是什么时候啊？"},{"chara":[{"id":801000}],"narrationEffect":"out","textRight":"真替你高兴。"},{"chara":[{"id":303301}],"textLeft":"谢谢！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301,"motion":0}],"textLeft":"经纪人小姐，谢谢你！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000}],"textRight":"怎么谢起我来了？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303301,"motion":100}],"textLeft":"是经纪人小姐向我搭了话，"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301}],"textLeft":"沙优希才有机会像这样@和粉丝们一起分享感动～"},{"chara":[{"id":303301,"motion":300}],"textLeft":"所以，@真的非常感谢你～"},{"chara":[{"id":801000,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"不用谢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303301,"lipSynch":0,"motion":0}],"textLeft":"（虽然跟想象的不太一样……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303301,"lipSynch":0}],"textLeft":"（但沙优希的愿望@确实好好地实现了。）"},{"nameNarration":"史乃沙优希","narration":"就这样，沙优希明白@自己的愿望实现了～","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303301,"motion":300,"pos":1,"voice":"vo_char_3033_00_04","textHome":"气氛这么热烈……诶嘿嘿，好开心~"}],"nameCenter":"史乃沙优希","textCenter":"当时的氛围居然这么好……@呵呵，总觉得好开心啊～","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301}]},{"autoTurnFirst":3.0,"chara":[{"id":303301,"motion":100}]},{"chara":[{"id":303301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}