{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21031.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"掉下","narrationEffect":"in","turnChangeOut":"fadeOut"},{"bgm":"bgm01_anime03","chara":[{"id":101101,"motion":400}],"nameRight":"枫","narrationEffect":"out","textRight":"哇……抓到了！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101101,"motion":200}],"textRight":"好厉害啊，小玲奈！@只用三次就抓上来了！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":201}],"nameLeft":"玲奈","textLeft":"那当然了！你是在小看我吗？！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401,"motion":0,"pos":2}],"nameRight":"智珠兰华","textRight":"你提的意见还挺不错嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"lipSynch":0,"motion":0}],"textLeft":"唔！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100901,"lipSynch":1,"motion":100}],"textLeft":"你终于明白我的实力了吗。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304401,"motion":1}],"textRight":"那我今天就回去了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":400}],"textLeft":"什么？你给我站住！"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304401,"motion":300}],"textRight":"我可是很忙的啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901}],"textLeft":"可我们还没分出胜负啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304401,"motion":0}],"textRight":"好好好，下次再来吧。"},{"autoTurnLast":0.2,"chara":[{"id":304401,"pos":1},{"id":100901,"motion":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":1,"pos":2}],"nameRight":"桃子","textRight":"总觉得你们关系很不错呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304401,"motion":200,"mouthOpen":1},{"cheek":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":201,"mouthOpen":1}],"nameCenter":"玲奈＆兰华","textBg":"shout","textCenter":"谁要和这家伙关系好啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101001,"pos":2},{"id":304401,"mouthOpen":0},{"id":100901,"mouthOpen":0}],"textRight":"哈哈哈！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":200},{"id":304401,"motion":0,"pos":0}],"textRight":"我叫十咎桃子，你呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401}],"nameLeft":"智珠兰华","textLeft":"咦？"},{"chara":[{"id":304401,"lipSynch":0}],"textLeft":"……[wait:1.2][chara:304401:cheek_0][chara:304401:motion_300][chara:304401:lipSynch_1]我叫……智珠兰华。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101001,"motion":100}],"textRight":"那就请多指教啦，小兰华！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401,"lipSynch":0,"motion":0}],"textLeft":"[chara:304401:effect_emotion_surprise_0][se:7226_shock]？！"},{"bgm":"bgm23_promised04","chara":[{"id":304401,"lipSynch":0}],"textLeft":"（仔细看这家伙……@居然戴着戒指？！）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101101,"motion":200,"pos":2}],"nameRight":"枫","textRight":"我叫秋野枫！","turnEffect":"stop"},{"chara":[{"id":101101,"motion":0}],"textRight":"小玲奈也来做个自我介绍吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100901,"motion":0,"pos":0}],"nameLeft":"玲奈","textLeft":"唔……@[chara:100901:lipSynch_0][wait:1.0][chara:100901:lipSynch_1]我、我叫水波玲奈……"},{"chara":[{"eyeClose":1,"id":100901,"motion":300}],"textLeft":"请多、多……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401,"motion":0,"pos":2}],"nameRight":"智珠兰华","textRight":"请多？"},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":200}],"textLeft":"多为遇见我而感到荣幸吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304401,"motion":100}],"textRight":"我不要。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100901,"motion":201}],"textLeft":"[chara:100901:effect_emotion_angry_0][se:7219_strain]可恶……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304401,"lipSynch":0}],"textRight":"（这两个人都戴着戒指……）","turnEffect":"thinking"},{"autoTurnLast":0.2,"chara":[{"id":304401,"motion":0,"pos":0}],"textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":1,"pos":2}],"nameRight":"桃子","textRight":"咦……"},{"chara":[{"id":101001}],"textRight":"小兰华，你是魔法少女吗？"},{"chara":[{"id":304401,"lipSynch":0}],"nameLeft":"智珠兰华","textLeft":"（啧，被发现了吗……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401,"lipSynch":1,"motion":1}],"textLeft":"啊……是的，你们也是吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":200}],"textRight":"是啊，我们都是魔法少女。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":300,"pos":2}],"nameRight":"枫","textRight":"啊……我完全没有注意……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100901,"motion":400,"pos":0}],"nameLeft":"玲奈","textLeft":"我、我可是早就注意到了！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100901},{"effect":"fadeout","id":101101}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101001,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp.json","id":304401,"motion":0,"pos":0}],"nameRight":"桃子","textRight":"可是小兰花你参加了@之前魔法少女的集会了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001}],"textRight":"我总感觉没有见过到过你……"},{"chara":[{"eyeClose":1,"id":304401,"lipSynch":0}],"nameLeft":"智珠兰华","textLeft":"（随便糊弄一下吧……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304401,"lipSynch":1,"motion":100}],"textLeft":"啊……我是在我老家当上魔法少女的。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001}],"textLeft":"我最近才搬到神滨来的，@所以还不太了解这里。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":200}],"textRight":"原来是这样啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101001}],"textRight":"你有什么问题就跟我们商量吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100901,"motion":100,"pos":0}],"nameLeft":"玲奈","textLeft":"没错，桃子她特别爱多管闲事，@什么事都会来帮忙的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":300}],"textRight":"我是很爱多管闲事，@可你能不能再说好听一点呢……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100901,"motion":200}],"textLeft":"哼。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":1},{"cheek":0,"face":"mtn_ex_050.exp.json","id":304401,"motion":0,"pos":0}],"textRight":"你随时都可以来找我们。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304401,"lipSynch":0,"motion":1}],"nameLeft":"智珠兰华","textLeft":"（哼，机会终于来了……）","turnEffect":"thinking"},{"chara":[{"id":304401,"lipSynch":0}],"textLeft":"（那就让我多打听一下……）"},{"chara":[{"id":304401,"lipSynch":0}],"textLeft":"（有关神滨和@自动净化系统的事吧……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304401,"lipSynch":1,"motion":300}],"textLeft":"我还有很多不明白的事情，@所以感觉特别不安。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304401,"motion":0}],"textLeft":"今后也请你们多关照了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101101,"motion":100,"pos":2}],"nameRight":"枫","textRight":"嗯！请多关照～"},{"autoTurnLast":0.2,"chara":[{"id":304401,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100901,"motion":200,"pos":0}],"nameLeft":"玲奈","textLeft":"既然我替你解决烦恼，@那你就要和我再比试一次跳舞游戏。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100901}],"textLeft":"下次就别再让我了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304401,"motion":200}],"nameRight":"智珠兰华","textRight":"呵……好啊，@下次就用双倍得分来定胜负吧。"},{"autoTurnLast":0.1,"bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnFirst":4.6,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304401,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3044_00_03","textHome":"你是无法击败我的，还没搞明白吗？"}],"nameCenter":"智珠兰华","textCenter":"你还不明白吗？你是赢不过我的。","turnChangeOut":"fadeOut"},{"chara":[{"id":304401}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}