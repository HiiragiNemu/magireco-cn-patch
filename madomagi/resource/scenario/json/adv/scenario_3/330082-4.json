{"story":{"group_1":[{"bg":"bg_adv_47104.jpg","bgEffect":"shakeSmall","bgm":"bgm01_anime10","chara":[{"effect":"shake","id":7104,"name":"sprite_0","pos":0}],"flashEffect":"flashRed1","textLeft":"≠繧［］[se:6057_hit_strike_06_s]貞ヨ蝨＊溷慍！？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300800,"motion":300,"pos":2}],"nameRight":"志伸晶","textRight":"[name:sprite_0:effect_fadeout]呼……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300800,"motion":0}],"textRight":"这就是……@魔法少女的力量……"},{"nameNarration":"志伸晶","narration":"只要眼前有遇到困难的人，@我就不愿对他们置之不理。","narrationBg":"bg_adv_47104.jpg","narrationEffect":"in"},{"narration":"所以@我才成为了魔法少女……"},{"narration":"总之，我击败了@那里所有的使魔"},{"narration":"如我所愿，被囚禁的人们@也重获自由，回到了原来的世界"},{"bg":"bg_adv_13051.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","narrationEffect":"out","textRight":"啊，志伸学姐！@早上好！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"啊，嗯。@[chara:300801:cheek_0:face_mtn_ex_010.exp.json]早上好！"},{"chara":[{"effect":"fadeout","id":300801},{"effect":"fadeout","id":800300}],"narration":"或许是我的愿望@导致的副作用……","narrationBg":"bg_adv_21025.jpg","narrationEffect":"in"},{"narration":"被魔女抓去的人们@都失去了事发前后的记忆"},{"narration":"不仅如此@失踪的事实也不复存在"},{"bg":"bg_adv_13061.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","narrationEffect":"out","textLeft":"这一切的消失，@也算是救了他们吧？"},{"chara":[{"id":810000,"motion":0,"pos":2,"posX":40}],"nameRight":"丘比","textRight":"或许吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":300}],"textLeft":"我真的@成为魔法少女了啊……"},{"chara":[{"id":810000,"motion":0}],"textRight":"是啊，@你成为魔法少女了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0}],"textLeft":"那么，抓走大家的魔女@还仍然逍遥法外是吧……"},{"chara":[{"id":810000,"motion":0}],"textRight":"你打倒的@是使魔。"},{"chara":[{"id":810000,"motion":0}],"textRight":"用魔女之吻操纵人们的魔女@应该还在别处。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":300}],"textLeft":"是吗……@那果然……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300801,"motion":200}],"textLeft":"还是得打倒她！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0}],"textLeft":"这就是魔法少女……@该做的事情吧？"},{"chara":[{"id":810000,"motion":0}],"textRight":"并且，@这也是你的命运。"},{"autoTurnLast":0.1,"bg":"white","turnChangeIn":"fadeIn"},{"narration":"就这样，我选择@以魔法少女的身份生活","narrationBg":"narration","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"许多人因为魔女散布的@灾厄而痛苦不堪……"},{"narration":"「见义不为，无勇也」"},{"narration":"我比以前更能感受到@这句话的重量……"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300801,"motion":200,"pos":1,"voice":"vo_char_3008_00_04","textHome":"真是的！那家伙到底想要干什么！"}],"nameCenter":"志伸晶","narrationEffect":"out","textCenter":"真是的！@那家伙到底打算做什么啊！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":300801}]},{"autoTurnFirst":2.5,"chara":[{"id":300801,"motion":0}]},{"chara":[{"id":300801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}