{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21262.jpg","bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100201,"motion":200}],"nameLeft":"八千代","nameRight":"忧","textLeft":"……这样，是那个男的@撞上来的对吧。","turnChangeOut":"fadeOut"},{"chara":[{"id":101501}],"textRight":"是的，然后樱子好像生气了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201}],"textLeft":"撞上来的人的确有错……"},{"chara":[{"id":100201}],"textLeft":"但这做的还是太过了。"},{"chara":[{"id":101501,"motion":300}],"textRight":"对不起，我给大家添麻烦了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201,"motion":300}],"textLeft":"不是忧的错，@毕竟是我提议外出的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201}],"textLeft":"不过我担心的事果然发生了呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101501,"motion":100}],"textRight":"担心？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100201,"motion":100}],"textLeft":"没什么，说教就交给彩羽吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201}],"textLeft":"反正她也听不进我的话吧。"},{"chara":[{"id":101501}],"textRight":"诶？是这样吗？"},{"chara":[{"id":100201,"motion":0}],"textLeft":"你没发现吗？"},{"chara":[{"id":100201}],"textLeft":"她只愿意听你和彩羽说的话哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201,"motion":301}],"textLeft":"她只想保护你们四个人，@所以对其他人并不怎么关心……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0}],"textRight":"这样啊……"},{"autoTurnLast":0.5,"bg":"bg_adv_21202.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":304302,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100101}],"nameLeft":"彩羽","nameRight":"万年樱的传闻","textLeft":"樱子，你能保护忧，我很开心。","turnChangeOut":"fadeOut"},{"chara":[{"id":100101}],"textLeft":"但我觉得暴力是不可取的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304302,"motion":300}],"t