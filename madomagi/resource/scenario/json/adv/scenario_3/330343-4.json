{"story":{"group_1":[{"autoTurnLast":1.4,"bg":"bg_adv_21152.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"pos":2}],"turnChangeIn":"fadeIn"},{"nameLeft":"惠萌花","textLeft":"你说得不对……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301},{"id":300301,"motion":0}],"textLeft":"其实我并不是一个人……"},{"chara":[{"id":303401,"motion":300}],"textLeft":"如果我一直都是一个人……@那我现在早就……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":0,"pos":2},{"id":303401,"pos":0}],"nameRight":"纯美雨","textRight":"你怎么了？脸色很差哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"pos":2}],"nameRight":"都雏乃","textRight":"抱歉，是发生了什么事吗？@你不用强迫自己说出来的……"},{"chara":[{"id":303401,"motion":1}],"nameLeft":"惠萌花","textLeft":"不，其实我一直都没有@和任何人提过……"},{"chara":[{"eyeClose":1,"id":303401}],"textLeft":"请你们听我说……"},{"nameNarration":"惠萌花","narration":"那是我刚成为魔法少女时的事","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"有一天学校附近出现了魔女@我当时陷入了苦战"},{"narration":"就在那时，她出现了"},{"narration":"她和我是一个学校的魔法少女"},{"chara":[{"id":303401,"motion":0,"pos":1},{"effect":"fadeout","id":300301}],"narration":"就在千钧一发之际@她飒爽地出现在了我的面前……@瞬间消灭了那个强大的魔女……"},{"nameCenter":"惠萌花","narrationEffect":"out","textCenter":"多亏了她，我才能活到现在……"},{"chara":[{"id":303401,"motion":300}],"textCenter":"但她现在没来上学了……"},{"chara":[{"eyeClose":1,"id":303401}],"textCenter":"她肯定是死在了魔女的手下……"},{"autoTurnLast":0.2,"chara":[{"id":303401,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":0,"pos":2}],"nameRight":"纯美雨","textRight":"原来是这样啊……@可你也没必要自责……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":200}],"nameLeft":"惠萌花","textLeft":"当时她觉得我「碍事」。"},{"textLeft":"我惹她生气，@还害得她的心情也变差了。"},{"chara":[{"id":303401,"motion":1}],"textLeft":"如果我能做得更好……"},{"textLeft":"也许就能和她成为伙伴了。"},{"chara":[{"id":303401}],"t