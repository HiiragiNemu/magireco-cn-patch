{"story":{"group_1":[{"bg":"bg_adv_21142.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"pos":2}],"nameRight":"都雏乃","textRight":"这样好吗？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0,"pos":0}],"nameLeft":"绫野梨花","textLeft":"这样就好。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303101,"motion":200}],"textLeft":"可喜可贺！@结局很圆满！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"从最开始，@一切就都是命中注定。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"电影里不也是吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"公主和王子不论经历怎样的艰难险阻，@最后也一定会喜结良缘。"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":303101,"motion":300}],"textLeft":"我@不是王子，也不是公主……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":400}],"textRight":"梨花……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"我应该是那种角色吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303101,"motion":200}],"textLeft":"帮公主换上礼服的@魔法师？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300301,"motion":300}],"textRight":"梨花！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":300}],"textLeft":"好好笑……真的好好笑啊……[chara:303101:cheek_1]"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303101}],"textLeft":"我竟然跑去当喜欢的人的……@爱神丘比特……[chara:303101:tear_1]"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"tear":1}],"textRight":"梨花[chara:300301:lipSynch_0]……"},{"chara":[{"cheek":1,"id":303101,"motion":0}],"textLeft":"为什么……@为什么……学姐你要哭呢？"},{"chara":[{"cheek":2,"id":303101}],"textLeft":"笑啊……@你笑啊……"},{"chara":[{"cheek":2,"id":303101}],"textLeft":"你笑我傻啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"tear":1}],"textRight":"我笑不出来……@更不会笑你！[chara:300301:cheek_1:face_mtn_ex_020.exp.json:tear_1]"},{"chara":[{"cheek":1,"id":300301,"motion":0}],"textRight":"你那么认真地喜欢她……@那么认真地在烦恼……"},{"chara":[{"cheek":1,"id":300301}],"textRight":"谁会@笑话你啊！"},{"chara":[{"cheek":2,"id":303101}],"textLeft":"呜，呜……"},{"chara":[{"cheek":2,"id":303101,"motion":100,"mouthOpen":1}],"textLeft":"呜、呜哇啊啊啊啊啊啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300301,"tear":1}],"textRight":"你已经很努力了……"},{"bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303101,"motion":300,"pos":0,"tear":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"pos":2}],"nameLeft":"绫野梨花","nameRight":"都雏乃","textLeft":"呜呜、呜……@对不起，学姐……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"id":303101}],"textLeft":"我把你的校服@都弄脏了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"textRight":"啊，没关系啦……"},{"chara":[{"cheek":1,"id":303101,"motion":0}],"textLeft":"呜、呜呜～"},{"bgm":"bgm03_story09","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303101,"motion":100,"mouthOpen":1}],"textLeft":"哇～我最喜欢学姐了！"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":300301,"motion":400}],"textRight":"哈！？@咦！不对，等一下！"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":300301}],"textRight":"喜、喜、喜欢？我说你啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303101}],"textLeft":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101,"motion":0}],"textLeft":"啊，不是啦。@不是ｌｏｖｅ，是ｌｉｋｅ。"},{"chara":[{"cheek":2,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300301,"motion":0}],"se":"7226_shock","textRight":"哈！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303101}],"textLeft":"因为，@学姐不是我喜欢的类型嘛。"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":300301,"motion":400}],"textRight":"喂！@我说你啊！[chara:300301:cheek_2:face_mtn_ex_020.exp.json:motion_200:effect_emotion_angry_0][se:7219_strain]喂！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"噗，呵呵！@啊哈哈！[chara:303101:cheek_1:face_mtn_ex_011.exp.json:motion_201]"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"lipSynch":0,"motion":0}],"textRight":"（她终于找回笑容了……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"啊，对了对了！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textRight":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101}],"textLeft":"学姐，我可以叫你@“嘟学姐”吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301}],"textRight":"啊，好啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":1}],"textLeft":"因为，衣美里也说了，@喊“都学姐”很拗口嘛！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300}],"textRight":"你们怎么……@对我的名字挑三拣四的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303101,"motion":0}],"textLeft":"衣美里是叫你“嘟～前辈”@对吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303101}],"textLeft":"那我就叫你“嘟学姐”，@只有我能这么叫！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"textRight":"啊？@你还自作主张地定起规则来了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":400}],"textRight":"哎，随便吧。@随便你怎么叫。[chara:300301:cheek_0:face_mtn_ex_000.exp.json]"},{"chara":[{"cheek":0,"id":303101,"motion":100}],"textLeft":"耶！"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101,"motion":1,"pos":1,"voice":"vo_char_3031_00_05","textHome":"多亏了学姐才能笑着结束这件事。谢谢你@陪着我，学姐！"}],"nameCenter":"绫野梨花","textCenter":"多亏学姐，事情才能圆满收场。@谢谢你陪我哦，学姐。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303101,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303101}]},{"autoTurnFirst":2.5,"chara":[{"id":303101,"motion":0}]},{"chara":[{"id":303101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}