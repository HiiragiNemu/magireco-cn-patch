{"story":{"group_1":[{"bg":"bg_adv_19221.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"motion":0,"pos":0}],"nameRight":"胡桃爱香","textRight":"给你，这是今天的谢礼。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":300902,"motion":100}],"textRight":"学姐最喜欢的蛋包饭。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301001,"motion":400,"pos":0}],"nameLeft":"阿见莉爱","textLeft":"我可以吃吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"（即使撇开因为她是我“学妹”@而产生的偏袒心理）","turnEffect":"thinking"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（我也觉得胡桃做的蛋包饭@是最美味的）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（至少……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301001,"lipSynch":0}],"textLeft":"（在我至今为止吃过的蛋包饭中，@绝对是排名第一的）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"（而成为魔法少女之前的我）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301001,"motion":100}],"textLeft":"鸡蛋入口即化，@还是非常美味呢。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"（并不像这份蛋包饭一样……）","turnEffect":"thinking"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（并不是一个有潜力@争得世界第一宝座的少女）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（不过，虽然我@许愿成为美少女……）"},{"chara":[{"id":301001,"lipSynch":0,"motion":300}],"textLeft":"（可以前也并不是那种@会被所有人疏远的丑女）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301001,"lipSynch":0}],"textLeft":"（我想想，@要打比方的话……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"motion":1}],"textLeft":"你看，斜对面也有@一家西餐厅吧？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":1}],"textRight":"诶？@啊……你说花生西餐厅吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301001}],"textLeft":"对，就是那里！花生！@那里……"},{"chara":[{"id":301001}],"textLeft":"不是也自称招牌菜品是@蛋包饭吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"motion":0}],"textLeft":"胡桃，@你觉得那里的蛋包饭怎么样？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300}],"textRight":"你问我怎么样……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300902,"motion":400}],"textRight":"就是普通啊，@很普通，超级普通。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301001,"lipSynch":0,"motion":400}],"textLeft":"[chara:301001:effect_emotion_surprise_0][se:7226_shock]——！？"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（深受冲击——！！）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0,"motion":300}],"textLeft":"（“普通”……“普通”……@没错，[textRed:“普通”]）"},{"nameNarration":"阿见莉爱","narration":"过去的我，打个比方，@就像花生西餐厅的蛋包饭……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"narration":"味道、气味、口感……@还有“外表”！"},{"narration":"平凡而寻常，@与[textRed:“第一”]没有丝毫关系。@就像[textRed:“普通”]的蛋包饭"},{"chara":[{"id":301001,"lipSynch":0}],"narrationEffect":"out","textLeft":"（这就是过去的我）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300902,"motion":1}],"textRight":"肯定是没有进行过足够的钻研。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":300902,"motion":100}],"textRight":"只有经过不懈努力之后，@才能烹饪出美味的西餐！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"（这可不一定哦？）","turnEffect":"thinking"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（不管它是花生@还是腰果）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（那家店的大叔@肯定也付出了许多努力）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0}],"textLeft":"（我曾经也是……）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（为了脱离“普通”，@而进行美发、化妆）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（付出了@非同寻常的努力）"},{"chara":[{"eyeClose":1,"id":301001,"lipSynch":0,"motion":300}],"textLeft":"（可是仍然未能获得@“第一”）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（有些事情不论多么努力@都是无法成功的）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":400}],"textRight":"[chara:300902:effect_emotion_surprise_0][se:7226_shock]唔哇哇！@又来了！？","turnEffect":"stop"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301001,"motion":0}],"textLeft":"诶？"},{"chara":[{"id":300902}],"textRight":"学姐的小跟班！@好像在店门外等你呢……！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":0}],"textRight":"真是的，@美女也很辛苦啊……"},{"chara":[{"id":300902}],"textRight":"诶，不过毕竟@从小就一直是这样的。"},{"chara":[{"id":300902,"motion":1}],"textRight":"学姐自己可能早就习惯了吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301001,"motion":100}],"textLeft":"诶？……啊、嗯！@是！对啊……！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"（是的，@就连胡桃也……）","turnEffect":"thinking"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（并不知道我通过许愿@获得了重生）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（我在这方面@是不会有纰漏的……）"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（任何人都不知道@我以前是个土妹子）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"lipSynch":0}],"textLeft":"（毕竟@这就是我的愿望啊）"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301001,"motion":400,"pos":1}],"textCenter":"诶？你问这是什么意思？","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301001}],"nameCenter":"阿见莉爱","textCenter":"我说，@你到底有认真听我讲话吗？"},{"chara":[{"id":301001}],"textCenter":"来，倒带！@重新回想一下！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"motion":0,"pos":0}],"nameNarration":"阿见莉爱","narration":"『请让我……变成天生的美少女吧！！』","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"bg":"bg_adv_19221.jpg","narration":"『请让我……变成[textRed:“天生”]的美少女吧！！』"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"lipSynch":0}],"nameLeft":"阿见莉爱","narrationEffect":"out","textLeft":"（就是这样。@我通过许愿……）","turnEffect":"thinking"},{"chara":[{"id":301001,"lipSynch":0}],"textLeft":"（变成了@“天生美丽的少女”）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301001,"lipSynch":0,"motion":0}],"textLeft":"鸡蛋的生熟度……@真是恰到好处。","turnEffect":"stop"},{"nameNarration":"阿见莉爱","narration":"这份愿望让我变得@完全有机会成为“第一”了","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"我不会对这份美貌感到骄傲自满……@我要努力成为“第一”的美女，@甚至不惜进行极为勉强锻炼，@饿得晕倒在路边……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"motion":1}],"narrationEffect":"out","textLeft":"谢谢款待！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":400}],"nameRight":"胡桃爱香","textRight":"[chara:300902:effect_emotion_surprise_0][se:7226_shock]居然已经吃完了……！？"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301001,"motion":0,"pos":1,"voice":"vo_char_3010_00_03","textHome":"就连过去都重新书写了……@真是完美的愿望！"}],"nameCenter":"阿见莉爱","textCenter":"连往事都能够改写……！@这个愿望真是太完美了！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":301001,"motion":400}]},{"chara":[{"id":301001}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}