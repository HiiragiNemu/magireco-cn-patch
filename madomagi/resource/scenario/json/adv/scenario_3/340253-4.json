{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_20231.jpg","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"＜1429年5月＞","narrationBg":"","narrationCoverOpacity":50.0,"narrationEffect":"in","turnChangeOut":"fadeOut","turnEffect":"sepiaFrame"},{"narration":"＜联合英军方＞"},{"autoTurnLast":0.01,"bg":"bg_adv_20103.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402500,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnLast":4.0,"enableSkipAutoTurn":1,"nameNarration":"","narration":"[surround:7010_bell]咚……@咚……","narrationBg":"bg_adv_20103.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"bgm":"bgm05_event05","chara":[{"eyeClose":0,"id":402500,"lipSynch":0}],"enableSkipAutoTurn":0,"nameLeft":"可鲁波","narrationEffect":"out","surround":"stop","textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}],"nameRight":"米诺","textRight":"你醒了啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":400}],"nameCenter":"拉皮努","textCenter":"可鲁波！@太好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200}],"textLeft":"你们怎么在这里！@我说了不能离我太近……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":300}],"textRight":"我们很担心你，@现在已经没空顾虑了。"},{"chara":[{"id":402700,"motion":300}],"textCenter":"我们还以为你再也醒不过来了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402500,"motion":0}],"textLeft":"拉皮努姐姐，米诺，@抱歉让你们担心了。"},{"chara":[{"id":402500,"motion":300}],"textLeft":"看来……我输了。"},{"chara":[{"id":402500}],"textLeft":"我没能打倒她……"},{"chara":[{"id":402500}],"textLeft":"但大教会的钟声响了，@“圣女”从梦中醒来了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0}],"textCenter":"之后会怎么样呢？"},{"chara":[{"id":402400,"motion":1}],"textRight":"所有人都会渐渐忘记@和这个诅咒有关的事情。"},{"chara":[{"id":402400}],"textRight":"人们也会渐渐忘记这几天的骚乱……"},{"chara":[{"id":402400}],"textRight":"一切都会被自动改写成@合乎逻辑的形式……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0}],"textLeft":"我们也不例外吗？"},{"chara":[{"id":402400,"motion":0}],"textRight":"嗯，当然了。"},{"chara":[{"id":402400,"lipSynch":0,"motion":300}],"textRight":"（其实只有身为施法者的我@是个例外……）","turnEffect":"thinking"},{"chara":[{"id":402500,"motion":300}],"textLeft":"嗯，也就是说……","turnEffect":"stop"},{"chara":[{"id":402500}],"textLeft":"接下来，"},{"chara":[{"id":402500}],"textLeft":"我们就要和那个黑色的和圣女大人@「初次」见面了？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}],"textRight":"正是如此。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}],"textLeft":"那还真是让人期待。"},{"chara":[{"id":402500}],"textLeft":"忘记一切后，@我们又能厮杀一次。"},{"chara":[{"id":402400,"motion":300}],"textRight":"围绕着奥尔良的战争@也渐入佳境了。"},{"chara":[{"id":402400}],"textRight":"可鲁波姐姐的愿望肯定@很快就能实现了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":300}],"textCenter":"但是，@我们接下来该怎么办呢？"},{"chara":[{"id":402700}],"textCenter":"在米诺看到的未来里……@我们会输的吧！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}],"textRight":"放心吧，@我会立刻开始下一步计划。"},{"chara":[{"id":402400}],"textRight":"阻挠我们计划的人……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}],"textRight":"就请她「消失」吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402500,"lipSynch":0,"motion":0}],"textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100}],"textCenter":"虽然我不太懂……但就是说我们三人@之后会一起行动吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":300}],"textRight":"是啊……"},{"chara":[{"id":402400}],"textRight":"至少光凭我一人恐怕有些吃力。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402500,"motion":300}],"textLeft":"我们一起行动的话，@我的能力就有些碍事了。"},{"chara":[{"id":402500}],"textLeft":"干脆把它封印了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":1}],"textCenter":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402400,"motion":0}],"textRight":"也就是说……让侍女「许愿」……"},{"chara":[{"id":402400}],"textRight":"消除自身让他人承担魔力消耗的能力？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0}],"textLeft":"嗯。"},{"chara":[{"id":402500}],"textLeft":"老实讲，就算用这个能力赢了@也没什么意思。"},{"chara":[{"id":402500,"motion":1}],"textLeft":"如果获得了新的能力作为替代，@说不定还能帮上你们。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402500}],"textLeft":"不过，有潜质的侍女@又要因此减少了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":200}],"textLeft":"怎么样，有一试的价值吧？"},{"chara":[{"id":402700,"motion":400}],"textCenter":"米诺，试试嘛！@可以和可鲁波一起战斗哦！"},{"chara":[{"id":402500}],"textLeft":"嗯，在战斗的同时@还可以保护你们俩。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"lipSynch":0,"motion":200}],"textRight":"……@……"},{"chara":[{"id":402400,"motion":300}],"textRight":"我想想……"},{"chara":[{"id":402400}],"textRight":"如果……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0},{"id":402500,"motion":0}],"textCenter":"如果？"},{"chara":[{"id":402400,"lipSynch":0}],"textRight":"（这并非为了我们姐妹三人……@而是……）","turnEffect":"thinking"},{"chara":[{"id":402400,"lipSynch":1}],"textRight":"不违背「那位大人」的意志的话……","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402500,"lipSynch":0}],"textLeft":"（米诺？）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}],"textRight":"不说这个了，@可鲁波姐姐……","turnEffect":"stop"},{"chara":[{"id":402400}],"textRight":"你今天一定很累了吧。"},{"chara":[{"id":402400}],"textRight":"关于改变未来的下一步计划"},{"chara":[{"id":402400}],"textRight":"就等到明天再讲吧……"},{"chara":[{"id":402400,"motion":100}],"textRight":"今晚我们三人就悠闲地泡个澡吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400}],"textCenter":"去哪里泡？"},{"chara":[{"id":402400,"motion":1}],"textRight":"我都已经安排好了。"},{"chara":[{"id":402700,"motion":100}],"textCenter":"[chara:402700:effect_emotion_joy_0][se:7222_happy]太好了！"},{"autoTurnLast":1.5,"bg":"bg_adv_20083.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402501,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":402701,"motion":1,"pos":1},{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402401,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402501}],"textLeft":"你真是个能干的妹妹。","turnChangeOut":"fadeOut","turnChangeOutTime":0.6},{"chara":[{"id":402501,"motion":100}],"textLeft":"身为姐姐，我为你感到骄傲哦。"},{"chara":[{"eyeClose":1,"id":402401,"motion":100}],"textRight":"呵呵……"},{"chara":[{"eyeClose":0,"id":402401}],"textRight":"毕竟和可鲁波姐姐约好了啊。"},{"autoTurnFirst":2.6,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402501,"motion":0,"pos":1,"voice":"vo_char_4025_00_05","textHome":"约好了一起去沐浴，@就等我回来后……"}],"nameCenter":"可鲁波","textCenter":"泡澡的约定，就等我回来之后@再实现吧……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"id":402501,"motion":300}]},{"chara":[{"id":402501}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}