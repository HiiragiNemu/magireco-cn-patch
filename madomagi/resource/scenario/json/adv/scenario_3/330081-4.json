{"story":{"group_1":[{"bg":"bg_adv_21142.jpg","bgm":"bgm03_story09","chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":300801,"motion":200,"pos":0,"soulGem":0},{"cheek":2,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"nameLeft":"志伸晶","textLeft":"不不……等一下！@你说……喜欢我！？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":800300}],"textRight":"是的！@我喜欢你，志伸学姐！"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":800300,"mouthOpen":1}],"textRight":"请和我交往吧！"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":300801,"motion":400}],"textLeft":"诶……交往……@和我吗？诶诶？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801,"motion":0}],"textLeft":"啊，等一下……@难道今天你拜托我……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":800300}],"textRight":"啊……@[chara:800300:cheek_1:face_mtn_ex_030.exp.json]呃……其实……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":800300}],"textRight":"那是骗你的……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801}],"textLeft":"我就猜是这样！@[chara:300801:cheek_1:face_mtn_ex_030.exp.json:motion_300:effect_emotion_sad_0][se:7224_fall_into]真是的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0}],"textLeft":"不过，太好了。@你没遇上什么麻烦事啊。"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":800300,"mouthOpen":1}],"textRight":"对、对不起！@我就是想找个借口……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801}],"textLeft":"不，没关系。@倒不如说，还好没事。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":800300}],"textRight":"那么……那个……@你愿意吗……"},{"chara":[{"cheek":0,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300801,"motion":400}],"se":"7226_shock","textLeft":"啊，@对了……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":300}],"textLeft":"啊……那什么……@我……并不是喜欢同性……[chara:300801:cheek_1]"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300801,"motion":200,"mouthOpen":1}],"textLeft":"对、对不起！@我不能和你交往……"},{"chara":[{"