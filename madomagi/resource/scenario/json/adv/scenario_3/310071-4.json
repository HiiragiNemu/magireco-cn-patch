{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_21012.jpg","chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100702,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100702,"lipSynch":0}],"nameCenter":"灯花","textCenter":"……………","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"eyeClose":1,"id":100702,"lipSynch":1,"motion":300}],"textCenter":"呜……已经受够了……"},{"bgm":"bgm03_story03","chara":[{"id":100702,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000,"motion":0,"pos":2}],"nameNarration":"","narration":"～想哭时就大哭一场@痛苦时就大喊宣泄@不需要忍耐～","narrationEffect":"in"},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100702,"motion":0}],"narration":"～即使你身处无人的黑暗之地@我也要轻拥着你@慢慢地带你走向光明～"},{"narration":"～一整天的辛苦终将得到回报@将以春色点缀一切～"},{"narration":"～所以请安心睡去@一起享受百年的幸福吧～"},{"autoTurnLast":0.5,"bg":"bg_adv_21072.jpg","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":100701}],"nameRight":"灯花","textRight":"这首歌结束了吗？","turnChangeOut":"fadeOut"},{"chara":[{"id":100601}],"nameLeft":"美冬","textLeft":"嗯……"},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100601,"motion":100}],"textLeft":"这是什么歌？"},{"chara":[{"id":100701,"motion":100}],"textRight":"是我在医院里病痛缠身的时候，@护士姐姐唱给我听的。"},{"chara":[{"id":100701}],"textRight":"我想美冬现在应该也很难受，@所以就用这首歌做了个实验～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100701,"motion":400}],"textRight":"感觉好点了吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100601,"motion":1}],"textLeft":"嗯，好点了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":0}],"textRight":"嘿嘿，毕竟生病可难受了～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":100}],"textRight":"你要快点好起来哦。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100601,"motion":200}],"textLeft":"嗯，我会的。"},{"chara":[{"id":100601}],"textLeft":"把你和音梦还有阿莉娜放在一边不管@我也不放心。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100701,"motion":200}],"textRight":"哼～@别把我们当小孩子看待了。"},{"chara":[{"id":100701}],"textRight":"小孩子能让你通过无线电@直接听到声音吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100601,"lipSynch":0,"motion":400}],"textLeft":"[chara:100601:effect_emotion_surprise_0][se:7226_shock]！？"},{"chara":[{"id":100601,"lipSynch":1}],"textLeft":"无线电……原来如此……@所以我才能听到刚才的歌……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":400}],"textRight":"你明白了？"},{"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":100601,"motion":100}],"textLeft":"看来你们是打算用这个技术@来招募成员吧？"},{"chara":[{"id":100701,"motion":200}],"textRight":"嗯，没错！"},{"chara":[{"id":100701}],"textRight":"下次我们还打算加上视觉效果，"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100701}],"textRight":"这样魔法少女们就都能看到了。"},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100601,"motion":300}],"textLeft":"可以做到吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100701,"motion":400}],"textRight":"你可别小看天才哦。"},{"chara":[{"id":100701}],"textRight":"只要用你刚才听到歌声的那个频率@应该就能成功了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":0},{"id":100601,"motion":1}],"textRight":"魔女、使魔、结界，@都只有魔法少女才能看见，对吧？"},{"chara":[{"id":100701,"motion":100}],"textRight":"因为只有魔法少女"},{"chara":[{"id":100701}],"textRight":"才能把这些频率的波长@识别成光线和声音。"},{"chara":[{"id":100701,"motion":201}],"textRight":"总而言之！"},{"chara":[{"id":100701}],"textRight":"我为了让魔法少女看到投影，"},{"chara":[{"id":100701,"motion":1}],"textRight":"结合这个原理灵活运用了射电望远镜。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100601,"motion":100}],"textLeft":"把信息发送到很远的地方，@让深陷痛苦的魔法少女来到神滨……"},{"chara":[{"id":100601}],"textLeft":"真是出乎我意料。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100601}],"textLeft":"不愧是灯花，好厉害呀。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100701,"motion":400}],"textRight":"真的吗！？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100601,"motion":400}],"textLeft":"嗯，真的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":201}],"textRight":"我聪明吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100701}],"textRight":"嘿嘿嘿。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100601,"motion":100}],"textLeft":"我也不能因为感冒继续在这躺着了。"},{"chara":[{"id":100601}],"textLeft":"你们再等我一会儿，@我明天就会好起来了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100701,"motion":100}],"textRight":"你可不要逞强哦？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100601}],"textLeft":"嗯。"},{"autoTurnFirst":2.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100701,"motion":400,"pos":1,"voice":"vo_char_1007_00_03","textHome":"这样就完美了！能集合多少人喵？"}],"nameCenter":"灯花","textCenter":"这下所有准备工作都完成了！@不知道能招揽到多少人呢～","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701}]},{"chara":[{"id":100701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}