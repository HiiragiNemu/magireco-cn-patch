{"story":{"group_1":[{"bg":"bg_adv_12061.jpg","bgm":"bgm01_battle04","chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300800,"motion":200,"mouthOpen":1,"pos":0}],"flashEffect":"flashWhite2","nameLeft":"志伸晶","textBg":"shout","textLeft":"喝，[se:4061_landing_jump5]呀！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300500,"motion":200,"mouthOpen":1,"pos":2}],"flashEffect":"flashWhite2","nameRight":"常盘七香","textRight":"哈！[se:4061_landing_jump5]"},{"bgEffect":"shakeSmall","chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300800,"motion":100,"mouthOpen":1}],"flashEffect":"flashWhite2","se":"6059_hit_strike_06_h","textBg":"shout","textLeft":"吃我这招！"},{"bgEffect":"shakeSmall","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300500,"motion":400}],"flashEffect":"flashWhite2","se":"6106_hit_slash_03_h","textRight":"呃！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300800,"motion":200,"mouthOpen":1}],"flashEffect":"flashWhite2","se":"4061_landing_jump5","textLeft":"还没结束！"},{"bgm":"stop","chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300500,"motion":200,"mouthOpen":1}],"textRight":"到此为止！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300800}],"textLeft":"诶？"},{"chara":[{"cheek":-1,"effect":"ef_adv_05","face":"mtn_ex_030.exp.json","id":300501,"motion":0,"pos":2}],"se":"7205_magic_girl","textRight":"到此为止了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300800,"motion":0}],"textLeft":"呃……"},{"chara":[{"cheek":0,"effect":"emotion_sad_0","face":"mtn_ex_030.exp.json","id":300800,"motion":400,"mouthOpen":1}],"se":"7224_fall_into","textLeft":"啊？"},{"bgm":"bgm03_story06","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300800,"motion":200,"mouthOpen":1}],"textLeft":"不，不不不！@我们还没决出胜负呢！"},{"chara":[{"cheek":-1,"id":300501}],"textRight":"已经够了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"我了解你的实力了。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300800,"motion":0}],"textLeft":"实力……@[chara:300800:cheek_1:face_mtn_ex_030.exp.json]等一下，这到底……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"不好意思，@我故意说得那么难听。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"我想知道@你究竟有多认真。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300501,"motion":300}],"textRight":"现在我充分感受到了。@所以……到此为止。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300800}],"textLeft":"想知道我有多认真……@为、为什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501,"motion":0}],"textRight":"因为我第一次和你相遇时，@你倒在地上。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501,"motion":100}],"textRight":"所以我不知道@你是强是弱……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300501,"motion":0}],"textRight":"不过，这样就没问题了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"足够与我联手了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300800}],"textLeft":"联手？@怎么说？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"就是合作。@也就是说，[chara:300501:motion_300]组一个队伍！[chara:300501:cheek_0:face_mtn_ex_010.exp.json]"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300800}],"textLeft":"你是说……@一起战斗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":200}],"textRight":"没错。@齐心协力对抗魔女。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501,"motion":0}],"textRight":"凭借一己之力与多数敌人战斗，@力量肯定是有限的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501}],"textRight":"所以我想集结魔法少女们的力量，@一起进行战斗。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300800,"motion":300}],"textLeft":"嗯、嗯～@你说得很对……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300800,"motion":0}],"textLeft":"不过，@你突然让我和你组队……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501}],"textRight":"那不如这样吧……"},{"bgm":"bgm03_story13","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300501,"motion":300}],"textRight":"晶，@我遇到困难了！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300501}],"textRight":"我没办法@独自和魔女战斗！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300501,"motion":200}],"textRight":"我很伤脑筋！@真的很伤脑筋！"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300800,"motion":400,"mouthOpen":1}],"se":"7226_shock","textLeft":"诶诶？@这、这么突然！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300501,"motion":0}],"textRight":"我听说了……"},{"chara":[{"cheek":0,"id":300501,"motion":300,"mouthOpen":1}],"textRight":"晶，你不会对遇到困难的人@置之不理吧！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300800,"mouthOpen":1}],"textLeft":"哇……"},{"chara":[{"cheek":1,"effect":"emotion_sad_0","face":"mtn_ex_030.exp.json","id":300800,"motion":200,"mouthOpen":1}],"se":"7224_fall_into","textLeft":"你这样，@太、太狡猾了吧！"},{"bgm":"bgm03_story06","chara":[{"effect":"fadeout","id":300800},{"effect":"fadeout","id":300501}],"nameNarration":"志伸晶","narration":"在发生了很多事情后@演变成了现在这样……","narrationBg":"bg_adv_21142.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"bg":"bg_adv_21142.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":100,"pos":0}],"nameLeft":"志伸晶","narrationEffect":"out","surround":"7007_evening_townbuzz","textLeft":"给，这是@你落下的拐杖哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900,"motion":0,"pos":2}],"nameRight":"","textRight":"哦哦！谢谢你！@晶！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0}],"textLeft":"路上小心！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"帮大忙了！@再见！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"mouthOpen":1}],"textLeft":"[chara:800900:effect_fadeout]再见！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":300}],"textLeft":"好！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":200,"pos":2}],"nameRight":"美凪纱纱罗","surround":"stop","textRight":"辛苦啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0}],"textLeft":"谢谢你，纱纱罗，你也辛苦啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":0}],"textRight":"不客气！@只是碰巧帮忙而已！"},{"narration":"她叫美凪纱纱罗，也是魔法少女","narrationBg":"bg_adv_21142.jpg","narrationEffect":"in"},{"narration":"和七香组队后@我遇到了许多魔法少女"},{"narration":"并且这个交际圈@还在不断扩大"},{"narration":"神滨到底@有多少魔法少女呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801},{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401}],"nameLeft":"志伸晶","nameRight":"美凪纱纱罗","narrationEffect":"out","textLeft":"那我先走了，@有人找我。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401}],"textRight":"是七香吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801}],"textLeft":"对！@七香说有事要跟我说。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801}],"textLeft":"好像是神滨的不动产情况……@[chara:300801:cheek_0:face_mtn_ex_030.exp.json]虽然我也不太清楚啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401,"motion":200}],"textRight":"不动产？@怎么了？要开始做生意了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801}],"textLeft":"不，这个嘛……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"lipSynch":0,"motion":300}],"textLeft":"（说不定就是这样……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0}],"textLeft":"总、总之，@我去一趟哦。[chara:300801:cheek_0:face_mtn_ex_010.exp.json]"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":0}],"textRight":"嗯，@拜拜！"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":200}],"textLeft":"[chara:300401:effect_fadeout]拜拜！[freeze:0.5][chara:300801:effect_fadeout]"},{"narration":"七香她总是@注视着我们不会去看的地方@思考我们不会去想的事……","narrationBg":"bg_adv_21172.jpg","narrationEffect":"in"},{"narration":"但这就是我和七香@相遇的故事"},{"narration":"之后的事@就改天再说吧……"},{"autoTurnLast":0.01,"narrationEffect":"out"},{"autoTurnFirst":1.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":1,"voice":"vo_char_3008_00_05","textHome":"咦……难道我被七香耍了？"}],"nameCenter":"志伸晶","textCenter":"咦……总觉得……@我好像被七香耍得团团转？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"id":300801,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"id":300801,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801}]},{"chara":[{"id":300801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}