{"story":{"group_1":[{"bg":"bg_adv_21072.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":0,"pos":2}],"nameLeft":"春名木乃美","nameRight":"杏子","textRight":"来，躺好。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":100,"pos":0}],"textLeft":"谢谢你，@已经不太痛了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":1}],"textRight":"那就好。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"给，这是你刚才搬的花，@我放在这里了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":0}],"textLeft":"啊……！连花都……@[chara:303001:lipSynch_0][wait:0.8][chara:303001:cheek_0][chara:303001:face_mtn_ex_030.exp.json][chara:303001:lipSynch_1][chara:303001:effect_emotion_sad_0][se:7224_fall_into]真的很抱歉……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textRight":"好啦，那我要走了。 "},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":400}],"textLeft":"啊……@请等一下！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001}],"textLeft":"那个……@让我答谢你吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textRight":"答谢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":0}],"textLeft":"嗯，@把花送给你……"},{"chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":200601,"motion":400}],"textRight":"[chara:200601:effect_emotion_surprise_0][se:7226_shock]啊！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":100}],"textLeft":"请让我为佐仓……@做一束花吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303001}],"textLeft":"或者……@花冠！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":200}],"textRight":"啊，我不要！@绝对不要！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":400}],"textLeft":"怎么这样……@我只是想表达一点心意！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":1}],"textRight":"我对花没有兴趣。 "},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"我要吃的，我喜欢吃的，@我这个人是务实派。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303001,"motion":1}],"textLeft":"但是……我现在能答谢你的……@只有花……"},{"chara":[{"cheek":0,"id":303001}],"textLeft":"所以……@我希望你务必收下……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textRight":"就算你这么说……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":0}],"textLeft":"“杏子”的“杏”，@不是“杏”这个字吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001}],"textLeft":"杏花很漂亮……@而且佐仓又是个温柔的人……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303001,"motion":301}],"textLeft":"我想让你@也喜欢上花……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":300}],"textRight":"[chara:200601:effect_emotion_sad_0][se:7224_fall_into]唉，@我收下你就满意了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303001,"motion":0}],"textLeft":"请一定@让我把花送给你。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":100}],"textRight":"好吧，@那就收吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":1}],"textLeft":"[chara:303001:effect_emotion_joy_0][se:7222_happy]太好啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0,"pos":2}],"textLeft":"做好啦！@这个给你……请收下！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"这是什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303001,"motion":0}],"textLeft":"这是石竹花。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001}],"textLeft":"我觉得最适合佐仓了，@你觉得怎么样？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":1}],"textRight":"嗯，还不错吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303001,"motion":100}],"textLeft":"在头发上插一朵，@一定很可爱！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":200601,"motion":200,"mouthOpen":1}],"textRight":"[chara:200601:effect_emotion_angry_0][se:7219_strain]我绝对不会那样做！"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":303001,"motion":0}],"textLeft":"明明很可爱啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200601,"motion":100}],"textRight":"哈哈哈，再见啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303001,"motion":100}],"textLeft":"好的！真的……@非常感谢！"},{"bg":"bg_adv_11042.jpg","chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":200601,"motion":0,"pos":1},{"effect":"fadeout","id":303001}],"nameNarration":"杏子","narration":"离开木乃美的房间之后……","narrationBg":"bg_adv_11042.jpg","narrationEffect":"in"},{"narration":"我不由自主地@把石竹花插在头发上"},{"chara":[{"cheek":2,"face":"mtn_ex_021.exp.json","id":200601,"motion":200,"mouthOpen":1}],"nameCenter":"杏子","narrationEffect":"out","textCenter":"[chara:200601:effect_emotion_angry_1][se:7218_anger]果然不适合我！"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":1,"pos":1,"voice":"vo_char_2006_00_05","textHome":"竟然送我花……呵呵。@我真是遇到了可爱的魔女啊。"}],"nameCenter":"杏子","textCenter":"用花当做礼物……呵呵，@遇到了一位可爱的魔女啊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200601}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":100}]},{"chara":[{"id":200601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}