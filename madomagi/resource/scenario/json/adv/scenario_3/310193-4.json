{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_16111.jpg","bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700,"motion":200,"pos":2}],"nameCenter":"月咲","nameLeft":"","nameRight":"月咲的父亲","textRight":"喂，月咲，@赶紧给他们也准备好饭菜。","turnChangeOut":"fadeOut","turnEffect":"blackPromist"},{"chara":[{"id":101901,"lipSynch":0},{"effect":"fadeout","id":800700}],"textCenter":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100,"motion":0,"pos":0}],"textLeft":"月咲，不好意思啊，@弄得这么脏。"},{"chara":[{"id":101901},{"effect":"fadeout","id":801100}],"textCenter":"别这样啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":300,"pos":2}],"textRight":"我也知道钱很紧，@你就想办法凑凑吧。"},{"chara":[{"id":101901},{"effect":"fadeout","id":800700}],"textCenter":"肯定不行啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801100,"motion":400,"pos":0}],"textLeft":"诶，抱歉，那是紧急存粮？@我肚子很饿，所以就吃掉了。"},{"chara":[{"id":101901},{"effect":"fadeout","id":801100}],"textCenter":"别开玩笑了……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700,"motion":200,"pos":2}],"textRight":"工匠工房的女人……"},{"chara":[{"cheek":2,"face":"mtn_ex_021.exp.json","id":101901,"motion":200},{"effect":"fadeout","id":800700}],"textBg":"shout","textCenter":"闭嘴！"},{"chara":[{"id":101901,"tear":1}],"textCenter":"我已经受够了……"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":101901,"motion":100,"tear":1}],"textCenter":"谁来救救我，救救我！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":200,"pos":0,"soulGem":0},{"id":101901,"pos":2}],"nameLeft":"月夜","nameRight":"月咲","textLeft":"月咲！"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101901,"tear":1}],"textRight":"月夜……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"motion":0}],"textLeft":"来，抓住我的手！"},{"chara":[{"id":101901,"motion":0}],"textRight":"嗯…………"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"motion":0,"pos":0,"soulGem":0},{"cheek":1,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"whiteIn","turnEffect":"stop"},{"bg":"bg_adv_12051.jpg","bgm":"bgm03_story05","textLeft":"你没事吧，@月咲？","turnChangeOut":"whiteOut","turnEffect":"promist"},{"chara":[{"id":101901,"lipSynch":0}],"textRight":"…………"},{"chara":[{"id":101801}],"textLeft":"月咲？"},{"chara":[{"id":101801}],"textLeft":"已经没事了，@[chara:101801:lipSynch_0][wait:1.0][chara:101801:motion_1][chara:101801:lipSynch_1]我松手了哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"lipSynch":0,"motion":1}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901}],"textRight":"好怀念……"},{"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"月咲","textCenter":"咦，啊……是梦？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"nameNarration":"","narration":"「她说自己第一次负责接生的孩子@就是你们俩」","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"「因为你们两个一生下来@就马上握住了彼此的手，@所以她有印象……」"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901}],"narrationEffect":"out","textCenter":"是谁……"},{"chara":[{"id":101901}],"textCenter":"这是……真的？"},{"nameNarration":"","narration":"「我一出生，@就握住了月咲的手……」","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":100}],"narrationEffect":"out","textCenter":"这个声音……是月夜……"},{"bgm":"bgm04_movie44","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901}],"textCenter":"这样啊……"},{"chara":[{"id":101901}],"textCenter":"肯定是这样啊，月夜……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101901,"motion":0}],"textCenter":"我呢，在梦中……@握着月夜的手……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901}],"textCenter":"感到非常放心……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"lipSynch":0}],"textCenter":"（抱歉啊，月夜……）"},{"chara":[{"id":101901,"lipSynch":0}],"textCenter":"（因为那么无聊的事@就发火……）"},{"chara":[{"id":101901,"lipSynch":0}],"textCenter":"（过去的我们……@明明接受了彼此……）"},{"chara":[{"id":101901,"lipSynch":0,"motion":300}],"textCenter":"（而现在明明也是，一旦无法接受彼此，@就感到无法活下去）"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"tear":1}],"textCenter":"啊啊，我……"},{"chara":[{"id":101901}],"textCenter":"想要回到开始……"},{"bg":"bg_adv_21012.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"lipSynch":0,"motion":300,"pos":2,"soulGem":0}],"nameLeft":"月夜","nameRight":"月咲","textRight":"…………","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":0,"pos":0,"soulGem":0}]},{"chara":[{"id":101901,"motion":0}],"textRight":"月夜……"},{"chara":[{"id":101801}],"textLeft":"月咲……"},{"chara":[{"id":101901}],"textRight":"你大概……已经听到了。"},{"chara":[{"eyeClose":1,"id":101901}],"textRight":"我们确实是双胞胎。"},{"chara":[{"id":101801,"motion":1}],"textLeft":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101901}],"textRight":"诶，月夜，@我们将一切都舍弃吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101801}],"textLeft":"诶……"},{"chara":[{"id":101901}],"textRight":"将出身和教育全部舍弃。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101901}],"textRight":"让一切归零，@重新成为彼此的支撑吧。"},{"chara":[{"id":101901,"motion":1}],"textRight":"如果不这样的话，@我们一定会被大人们击溃的。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":0}],"textLeft":"嗯……@我也是这样想的。"},{"chara":[{"eyeClose":1,"id":101801}],"textLeft":"我想回到在神社@得到名字之前。"},{"chara":[{"id":101801}],"textLeft":"从刚出生、还紧握彼此的手的@崭新的自己开始。"},{"chara":[{"id":101801}],"textLeft":"重新再来……"},{"chara":[{"eyeClose":0,"id":101801,"lipSynch":0,"motion":1}],"textLeft":"（之所以能与她聊得最投缘，@之所以现在内心能如此平静）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"lipSynch":0}],"textLeft":"（肯定是