tion":100}],"textLeft":"没错。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":100801,"motion":0,"pos":2}],"nameLeft":"美冬","nameRight":"阿莉娜","textLeft":"回来的时候@真是吓了一跳……"},{"chara":[{"id":100801,"motion":100}],"textRight":"哼，@是这样吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100801}],"textRight":"我回去了…………"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101801,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":400,"pos":2}],"nameLeft":"月夜","nameRight":"月咲","textLeft":"[chara:101801:effect_emotion_surprise_0][chara:101901:effect_emotion_surprise_0][se:7226_shock]你觉得不满意吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0}],"textRight":"请原谅我们@让传闻被打倒了！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100801,"motion":300,"pos":1},{"effect":"fadeout","id":101801},{"effect":"fadeout","id":101901}],"nameCenter":"阿莉娜","textCenter":"我不会做什么的。"},{"chara":[{"id":100801}],"textCenter":"只是听到了不错的故事，@所以涌现出了创作欲望。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100801,"motion":0}],"textCenter":"再见啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":100,"pos":2},{"effect":"fadeout","id":100801}],"textRight":"唉……太好了"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801}],"textLeft":"是啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1,"pos":1},{"effect":"fadeout","id":101801},{"effect":"fadeout","id":101901}],"nameCenter":"美冬","textCenter":"那么，@我们也回去吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901,"motion":1,"pos":2},{"effect":"fadeout","id":100601}],"textRight":"好的。"},{"chara":[{"id":101801}],"textLeft":"啊，月咲。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101901}],"textRight":"怎么？"},{"c