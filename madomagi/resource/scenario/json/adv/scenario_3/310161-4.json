{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_17112.jpg","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":0,"pos":2}],"nameLeft":"十七夜的父亲","nameRight":"十七夜","textRight":"我回来了。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900,"motion":0,"pos":0}],"textLeft":"欢迎回来，十七夜。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800800,"motion":0,"pos":0}],"nameLeft":"十七夜的母亲","textLeft":"你回来啦～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800800}],"textLeft":"我还在做晚饭，@你稍微等一会儿哦。"},{"chara":[{"id":101601,"motion":200}],"textRight":"不，我也来一起帮忙。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101601}],"textRight":"唔，@妈妈，我有点事想问你……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800800}],"textLeft":"什么呀？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":100}],"textRight":"电饭锅里的米饭@好像没在煮……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800800}],"textLeft":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800800}],"textLeft":"哎呀，我以为摁过开关了，@原来没有摁呀。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":300}],"textRight":"人偶尔是会犯糊涂的。"},{"autoTurnLast":0.02,"chara":[{"id":101601,"pos":0}]},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"nameLeft":"十七夜","nameRight":"十七夜的弟弟","textBg":"shout","textRight":"我回来了！@饿死了！饭做好没啊！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":0}],"textLeft":"欢迎回来。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":200}],"textLeft":"晚饭还没做好。"},{"chara":[{"id":101601}],"textLeft":"菜马上就能做好，@饭这就开煮了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800500}],"textRight":"[chara:800500:effect_emotion_surprise_0][se:7226_shock]现、现在才开煮啊！？"},{"chara":[{"id":101601,"motion":100}],"textLeft":"啊，你应该是饿了，@不过还是稍微忍忍吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800500}],"textRight":"行吧，真没办法……"},{"chara":[{"id":101601,"motion":1}],"textLeft":"我来帮妈妈做菜，@你摆一下餐具吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500}],"textRight":"好！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900,"motion":0,"pos":0}],"nameLeft":"十七夜的父亲","textLeft":"啊——好疼……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800500}],"textRight":"爸爸，你腿疼吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"嗯……有点……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500}],"textRight":"我来给你按摩，你坐下。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"麻烦你了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"我要是没有受伤，"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"你们就能轻松一些了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":100,"pos":2}],"nameRight":"十七夜","textRight":"不要在意这些。"},{"chara":[{"id":101601}],"textRight":"我们是一家人，@当然要互相帮助，互相扶持了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800500,"motion":0,"pos":2}],"nameRight":"十七夜的弟弟","textRight":"没错，爸爸！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"谢谢……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900}],"textLeft":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"你的手受伤了啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800500}],"textRight":"啊，你说这个……"},{"bgm":"bgm03_story06","chara":[{"id":800500}],"textRight":"这是……刚才被@西边的家伙挑衅来着……"},{"chara":[{"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"你动手了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800500}],"textRight":"没有！@虽然很火大，但是我无视他们了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800500}],"textRight":"可我还是很生气……@就对着墙壁……"},{"chara":[{"id":800900}],"textLeft":"拿东西撒气是不行的。"},{"chara":[{"id":800500}],"textRight":"对不起……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textLeft":"不过……你能忍下来很好。"},{"chara":[{"id":800500}],"textRight":"爸爸……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800900},{"effect":"fadeout","id":800500}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"十七夜","textCenter":"…………"},{"autoTurnLast":1.0,"bg":"bg_adv_17112.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101601}],"textCenter":"好了……","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":101601,"lipSynch":0}],"textCenter":"…………"},{"autoTurnLast":1.0,"bg":"bg_adv_15081.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101602,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901}],"nameRight":"月咲","textRight":"昨天在水名……@[chara:101901:lipSynch_0][wait:2.0][chara:101901:lipSynch_1]月夜她……","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"autoTurnLast":0.01,"bg":"bg_adv_17112.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"eyeClose":0,"id":101601,"lipSynch":0,"motion":300}],"textCenter":"（月咲她没事吧……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101601,"lipSynch":0}],"textCenter":"（或许她和月夜之间@发生了些什么？）"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"lipSynch":0}],"textCenter":"…………","turnEffect":"stop"},{"chara":[{"id":101601,"lipSynch":0,"motion":0}],"textCenter":"（有些担心月咲啊。）"},{"autoTurnLast":0.01,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101601,"motion":200}],"nameRight":"十七夜","textRight":"这恐怕是因为整个神滨的@魔女都变多了，而且也变强了。","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":101901,"motion":400}],"nameLeft":"月咲","textLeft":"[chara:101901:effect_emotion_surprise_0][se:7226_shock]咦！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":0}],"textRight":"至少在东部区域@确实是这样的。"},{"autoTurnLast":0.01,"bg":"bg_adv_17112.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101601,"lipSynch":0,"motion":200}],"textCenter":"（而且我也很担心@其他的魔法少女……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":101601,"lipSynch":0}],"textCenter":"（还是尽快@告诉她们比较好……）"},{"autoTurnFirst":4.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":200,"pos":1,"voice":"vo_char_1016_00_03","textHome":"我很少和他人这样说话，请你用心听。"}],"nameCenter":"十七夜","textCenter":"我很少和别人说这些话，@好好听我说。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601}]},{"chara":[{"id":101601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}