{"skipTransitionList":[],"story":{"group_1":[{"bg":"bg_adv_21012.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":1,"pos":1,"soulGem":0}],"nameCenter":"月夜","textCenter":"咦，这里是……@医院吗……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101901,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"rollInFast"},{"chara":[{"id":101901,"lipSynch":0}],"nameCenter":"月咲","textCenter":"…………","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101801,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"月夜","textCenter":"哎，月……咲？","turnChangeIn":"rollInFast","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1,"pos":2},{"id":101801,"pos":0,"soulGem":0}],"nameLeft":"月夜","nameRight":"美冬","textRight":"太好了，你终于醒了。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":100}],"textLeft":"美冬……@我是怎么了……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601}],"textRight":"医生说你可能是压力太大了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":0}],"textLeft":"是……吗……"},{"chara":[{"id":101801,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"id":100601}],"textRight":"你之前说的那个二重身。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100601,"motion":0}],"textRight":"原来是你的双胞胎妹妹啊。"},{"chara":[{"id":100601}],"textRight":"没想到你们两姐妹同时倒下了。"},{"chara":[{"id":101801,"motion":300}],"textLeft":"那是你的错觉……"},{"chara":[{"id":101801}],"textLeft":"我们只是名字和外貌相似而已。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":200}],"textRight":"不，你们确实是双胞胎。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":0}],"textLeft":"你为什么会知道。"},{"chara":[{"id":100601,"motion":0}],"textRight":"刚才那个儿科的医生@还记得你们两个的事哦。"},{"chara":[{"id":101801}],"textLeft":"医生？"},{"chara":[{"id":100601}],"textRight":"没错……"},{"chara":[{"id":100601,"motion":1}],"textRight":"她说自己第一次负责接生的孩子@就是你们俩。"},{"nameNarration":"美冬","narration":"因为你们两个一生下来@就马上握住了彼此的手，@所以她有印象……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"motion":300}],"narrationEffect":"out","textRight":"当她听说从其他医生那里@听说月夜改了姓后。"},{"chara":[{"id":100601}],"textRight":"好像就一直很担心。"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":1}],"textLeft":"是……吗……"},{"nameNarration":"月夜","narration":"我一出生，@就握住了月咲的手……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"bgm":"bgm04_movie44","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"lipSynch":0}],"narrationEffect":"out","textLeft":"（我曾经接受过……@一出生就接受了月咲）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"lipSynch":0}],"textLeft":"（可我却……）"},{"chara":[{"id":101801,"lipSynch":0}],"textLeft":"（因为一些无聊的事，@自己生闷气……）"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"lipSynch":0}],"textLeft":"（我要舍弃一切会阻碍的东西）"},{"chara":[{"id":101801,"lipSynch":0}],"textLeft":"（成为一个崭新的自己，@和她重新开始……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":0}],"textRight":"我去打个电话。","turnEffect":"stop"},{"autoTurnLast":0.01,"chara":[{"effect":"fadeout","id":100601}]},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"lipSynch":0,"motion":300}],"nameLeft":"月夜","nameRight":"月咲","textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":2,"soulGem":0}],"textRight":"月夜……"},{"chara":[{"id":101801,"motion":0}],"textLeft":"月咲……"},{"chara":[{"id":101901}],"textRight":"你大概……已经听到了。"},{"chara":[{"eyeClose":1,"id":101901}],"textRight":"我们确实是双胞胎。"},{"chara":[{"id":101801,"motion":1}],"textLeft":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101901}],"textRight":"哎，月夜，@我们将一切都舍弃吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101801}],"textLeft":"哎……"},{"chara":[{"id":101901}],"textRight":"将出身和教育全部舍弃。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101901}],"textRight":"让一切归零，@重新成为彼此的支撑吧。"},{"chara":[{"id":101901,"motion":1}],"textRight":"如果不这样的话，@我们一定会被大人们击溃的。"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":0}],"textLeft":"嗯……@我也是这样想的。"},{"chara":[{"eyeClose":1,"id":101801}],"textLeft":"我想回到在神社@得到名字之前。"},{"chara":[{"id":101801}],"textLeft":"从刚出生还紧握彼此的手的@崭新的自己开始。"},{"chara":[{"id":101801}],"textLeft":"重新再来……"},{"chara":[{"eyeClose":0,"id":101801,"lipSynch":0,"motion":1}],"textLeft":"（之所以能与她聊得最投缘，@之所以现在内心能如此平静）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"lipSynch":0}],"textLeft":"（肯定是因为我们是这世上@独一无二的双胞胎……）"},{"chara":[{"id":101901,"motion":100}],"textRight":"那你愿意@再一次当我的姐姐吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101801,"motion":100}],"textLeft":"是的……"},{"chara":[{"id":101801}],"textLeft":"那你愿意@再一次当我的妹妹吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901,"motion":1}],"textRight":"嗯……"},{"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":300,"pos":1}],"nameCenter":"月夜的母亲","textCenter":"只要有爱，就能跨越出身与家教，@这只是幻想而已……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"bg":"bg_adv_21012.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101801,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":2,"soulGem":0}],"nameLeft":"月夜","nameRight":"月咲","textLeft":"但是，无论如何起誓……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":101801}],"textLeft":"或许某一天，@我们又会讨厌彼此。"},{"chara":[{"id":101801,"motion":300}],"textLeft":"到那时……"},{"chara":[{"id":101901,"motion":300}],"textRight":"我的心或许会无法忍受……"},{"bgm":"stop","nameNarration":"月夜","narration":"正当母亲的话在我心中盘旋时，@它出现了","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"id":810000,"motion":0,"pos":1,"posX":0,"posY":80}],"nameCenter":"丘比","narrationEffect":