{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_46105.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":0,"pos":2},{"id":6105,"name":"sprite_0","pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101000}],"nameRight":"桃子","textRight":"是时候结束了！","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":101000,"motion":200,"mouthOpen":1}],"textBg":"shout","textRight":"[se:6101_hit_slash_01_vh][name:sprite_0:effect_7001_attack02]喝呀！！"},{"autoTurnLast":0.5,"bgEffect":"shakeLarge","chara":[{"effect":"7003_damage02","id":6105,"name":"sprite_0","pos":0}],"se":"6100_hit_slash_01_s","textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101000},{"effect":"fadeout","id":6105,"name":"sprite_0"}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"pos":1}],"nameCenter":"枇枇木巡","textCenter":"巡选手的最佳救世主使出了奋力一击！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"mouthOpen":1}],"textBg":"shout","textCenter":"胜负已定！！"},{"autoTurnLast":1.5,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304201,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story02","chara":[{"eyeClose":1,"id":304201,"lipSynch":0}],"textCenter":"（当时幸好桃子出面来救我……）","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":304201,"lipSynch":0}],"textCenter":"（她不仅替我打倒了魔女。）"},{"chara":[{"id":304201,"lipSynch":0,"motion":100}],"textCenter":"（还带我来到了调整专家的店里……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"lipSynch":0}],"textCenter":"（不过我也不太清楚@调整专家是干什么的就是了……）"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":304201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":0}],"nameRight":"桃子","textRight":"呼～解救了巡是件好事……"},{"chara":[{"id":101001}],"textRight":"可当时真是太惊险了……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":300}],"nameLeft":"御魂","textLeft":"怎么惊险了？"},{"chara":[{"id":101001,"motion":0}],"textRight":"我有好几次都给了魔女致命一击。"},{"chara":[{"id":101001,"motion":300}],"textRight":"但不是被躲开就是被硬抗了下来……"},{"chara":[{"id":101001}],"textRight":"本以为已经打倒，@对方却又顽强地站了起来……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200}],"textLeft":"那是连你这么老练的人@也觉得棘手的魔女啊……"},{"chara":[{"id":101001,"motion":1}],"textRight":"她倒并不厉害……"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101001}],"textRight":"但是在巡的解说之下，@我就像是跟她来了一场摔跤似的。"},{"autoTurnLast":0.2,"chara":[{"id":101001,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":300,"pos":2}],"nameRight":"枇枇木巡","textRight":"如果我能更厉害一些……"},{"chara":[{"id":304201}],"textRight":"就不会给桃子添这么多麻烦了吧……"},{"chara":[{"cheek":1,"eyeClose":1,"id":304201,"motion":100,"tear":1}],"textRight":"唔……巡选手会好好反省的！"},{"chara":[{"id":101001,"motion":100}],"nameLeft":"桃子","textLeft":"没关系，你别在意。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101001,"motion":0}],"textLeft":"虽说战斗过程惊险……"},{"chara":[{"id":101001}],"textLeft":"但是多亏了巡的解说，@我也有了不少干劲。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101001,"motion":200}],"textLeft":"最后还获得了戏剧性的胜利，@感觉真的很过瘾。"},{"chara":[{"cheek":0,"eyeClose":0,"id":304201,"motion":0,"tear":0}],"textRight":"谢、谢谢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1,"pos":0}],"nameLeft":"御魂","textLeft":"巡你很擅长直播解说吗？"},{"chara":[{"id":304201,"motion":300}],"textRight":"也不能说是擅长……@这都是因为我和丘比许了愿。"},{"chara":[{"id":304201}],"textRight":"希望我能成为知名主持人。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}],"textLeft":"原来是这样啊。"},{"chara":[{"id":304201,"motion":1}],"textRight":"我的直播技术的确有所长进，@可我并不觉得自己成了知名主持人。"},{"chara":[{"id":304201}],"textRight":"为了实现梦想而加入的@广播社现在也面临解散……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304201,"motion":400},{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0}],"textRight":"难道说……我被丘比给骗了吗？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304201}],"textRight":"而且它还让我狩猎魔女，@这明明和我的梦想无关啊……"},{"chara":[{"cheek":1,"eyeClose":1,"id":304201,"motion":100,"tear":1}],"textBg":"shout","textRight":"呜呜，怎么办啊！@巡选手究竟会迎来怎样的结局？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":300,"pos":0}],"nameLeft":"桃子","textLeft":"巡，你冷静一点……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":0}],"nameLeft":"御魂","textLeft":"没错。"},{"chara":[{"id":101700}],"textLeft":"毕竟你刚成为魔法少女。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":200}],"textLeft":"现在也只是暂时没有看到成效。"},{"chara":[{"cheek":0,"eyeClose":0,"id":304201,"motion":200,"tear":0}],"textRight":"那我该怎么才能知道结果如何呢！"},{"chara":[{"id":304201}],"textRight":"我要怎么才能成为知名主持人呢？！"},{"chara":[{"eyeClose":1,"id":304201,"motion":300}],"textRight":"唉……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300}],"textLeft":"唔，我想想……"},{"chara":[{"id":101700}],"textLeft":"我也是刚刚成为调整专家，@店里的客人也不是很多。"},{"chara":[{"id":101700}],"textLeft":"我现在也不太宽裕……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}],"textLeft":"作为来店的回礼，@我能拜托你一件事吗？"},{"chara":[{"eyeClose":0,"id":304201,"motion":0}],"textRight":"拜托我？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}],"textLeft":"没错。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}],"textLeft":"毕竟你是桃子带过来的客人嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101001,"motion":100,"pos":2}],"nameRight":"桃子","textRight":"你在说什么啊……怪恶心的……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}],"textLeft":"呵呵。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300},{"cheek":0,"face":"mtn_ex_050.exp.json","id":304201,"motion":0,"pos":2}],"textLeft":"巡，你要来试试当主持人吗？"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304201,"motion":300,"pos":1,"voice":"vo_char_3042_00_03","textHome":"就算拼命努力也完全没有结果，而且我的心理@条件也还是很弱啊。"}],"nameCenter":"枇枇木巡","textCenter":"可是我努力了也没有成果，@而且还特别容易受打击。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":304201}]},{"chara":[{"id":304201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}