{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_20031.jpg","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story19","chara":[{"id":801000}],"nameRight":"姐姐","textRight":"理子，好久不见！你还好吗？","turnChangeOut":"fadeOut"},{"chara":[{"id":303501,"motion":200}],"nameLeft":"千秋理子","textLeft":"好久不见！"},{"chara":[{"id":303501}],"textLeft":"姐姐看起来这么有精神，我好开心！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":0}],"nameLeft":"理子的母亲","textLeft":"你好——"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000}],"textRight":"阿姨！@您也来了啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600}],"textLeft":"我是陪理子来的啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textLeft":"而且，@你爸爸也拜托我来看看你的近况。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":801000}],"textRight":"真是的！@爸爸总是多管闲事……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000}],"textRight":"对不起，给您添麻烦了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303501,"motion":400,"pos":0}],"nameLeft":"千秋理子","textLeft":"那、那个！姐姐！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000}],"textRight":"嗯？怎么啦？"},{"chara":[{"id":303501,"motion":0}],"textLeft":"你的病好了吗？"},{"chara":[{"id":801000}],"textRight":"病？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"啊，不是啦，@我不是因为生病才住院的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000}],"textRight":"抱歉啦，让你担心了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303501,"motion":100}],"textLeft":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"快请进吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"理子的母亲","textRight":"打扰了。"},{"chara":[{"id":303501}],"textLeft":"打、打扰了……"},{"autoTurnLast":0.5,"bg":"bg_adv_21081.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":801100,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":801100}],"nameRight":"","textRight":"你好呀，理子。","turnChangeOut":"rollOutFast"},{"chara":[{"id":303501,"motion":400}],"textLeft":"你、你好！"},{"chara":[{"id":303501,"lipSynch":0}],"textLeft":"（这是姐姐的丈夫！）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"nameRight":"姐姐","textRight":"理子，我想跟你介绍一个人。"},{"chara":[{"id":303501,"lipSynch":0,"motion":100}],"textLeft":"诶？介绍？"},{"chara":[{"id":801100}],"textRight":"来，过来这边。"},{"chara":[{"id":303501,"motion":0}],"textLeft":"好、好的……"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":303501,"lipSynch":0}],"textLeft":"…………","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303501,"lipSynch":1,"motion":200}],"textLeft":"[chara:303501:effect_emotion_surprise_0][se:7226_shock]是姐姐的……小宝宝！？"},{"chara":[{"id":801000}],"textRight":"对。"},{"chara":[{"id":801000}],"textRight":"我是要生小宝宝才住院的。"},{"chara":[{"id":303501,"motion":0}],"textLeft":"这样啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303501,"motion":400}],"textLeft":"啊，恭、恭喜你！@姐姐！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"呵呵，谢谢。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303501,"motion":1}],"textLeft":"[chara:303501:effect_emotion_joy_0][se:7222_happy]长得好像姐姐！@好可爱……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100,"motion":0,"pos":0}],"nameLeft":"","textLeft":"你一直说，"},{"chara":[{"id":303501}],"textLeft":"孩子生下来之后要介绍给理子呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"嗯，因为理子是我的好妹妹嘛。"},{"autoTurnLast":0.01,"bgm":"stop","chara":[{"effect":"fadeout","id":801000},{"effect":"fadeout","id":801100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303501,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"千秋理子","textCenter":"…………"},{"bgm":"bgm05_event10","chara":[{"cheek":1,"id":303501,"lipSynch":0}],"textCenter":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303501,"lipSynch":0,"motion":200}],"textCenter":"（太好了……）"},{"chara":[{"id":303501,"lipSynch":0}],"textCenter":"（姐姐……@看上去很幸福……）"},{"nameNarration":"千秋理子","narration":"「早知道就不许愿让姐姐的婚姻@得到所有人认可了……」","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"我已经不会这么想了"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303501,"motion":0,"pos":0}],"narration":"因为姐姐看上去是如此幸福"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000,"motion":0,"pos":2}],"narration":"还好我向丘比许了愿……"},{"chara":[{"id":801000}],"narrationEffect":"out","textRight":"看，理子姐姐来看你了哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303501,"motion":400,"mouthOpen":1}],"nameLeft":"千秋理子","textLeft":"诶？"},{"chara":[{"cheek":1,"id":303501,"lipSynch":0,"mouthOpen":0}],"textLeft":"（我是……理子姐姐！）"},{"chara":[{"id":801000},{"id":303501,"motion":0}],"textRight":"我有事要拜托理子姐姐哦。"},{"chara":[{"id":801000}],"textRight":"今后请和这个孩子@好好相处吧？"},{"chara":[{"id":303501,"lipSynch":1}],"textLeft":"好好……相处？"},{"nameNarration":"千秋理子","narration":"虽然我们之间没有血缘关系@可我是打从心底喜欢姐姐","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303501}],"narration":"我也能成为@这个小宝宝的好姐姐吗……"},{"chara":[{"id":303501}],"narrationEffect":"out","textLeft":"我也想变成姐姐这样……"},{"chara":[{"eyeClose":1,"id":303501,"motion":300}],"nameNarration":"千秋理子","narration":"姐姐会陪我一起玩@在我寂寞时陪着我、跟我谈心@我也想像姐姐对我那样@对这个孩子","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"到时候@我想给这个孩子吃好多好多@我亲手做的千秋屋便当"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000}],"narrationEffect":"out","textRight":"理子？"},{"chara":[{"cheek":1,"eyeClose":0,"id":303501,"motion":200}],"textLeft":"姐姐，@我想和小宝宝好好相处！"},{"chara":[{"id":303501}],"textLeft":"我们一定能好好相处的！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"呵呵，谢谢你，理子。@我就知道你会这么说。"},{"nameNarration":"千秋理子","narration":"等我回了家@我就让爸爸妈妈@教我做便当","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303501,"motion":0}],"narration":"因为我想早点让姐姐和小宝宝@吃到好吃的便当……"},{"chara":[{"cheek":0,"id":801000}],"narrationEffect":"out","textRight":"理子，你去和小宝宝说说话吧。"},{"chara":[{"id":801000}],"textRight":"他还没睁眼，但能听见声音哦。"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/33035_riko_story/memoria_1266.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"千秋理子","narration":"―理子―@呃……小宝宝，初次见面。@我叫千秋理子。","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":20.0,"narrationLineSpace":15.0,"turnChangeOut":"fadeOut"},{"narration":"―理子―@请多关照哦？"},{"narration":"―理子―@……"},{"narration":"―理子―@你、你就叫我……@理子姐姐吧。"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/33035_riko_story/memoria_1266.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"千秋理子","narration":"我希望将来有一天@能成为这个孩子引以为傲的姐姐","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"我要好好锻炼做菜的手艺@要学着独立、学会坚强@我想变得温柔，我想帮助他人"},{"narration":"因为那就是我「理想中的姐姐」"},{"autoTurnLast":1.0,"bg":"bg_adv_20032.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":303501,"motion":400}],"textLeft":"打扰了！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600,"motion":0,"pos":0}],"nameLeft":"理子的母亲","textLeft":"我会跟你爸爸说@你过得很好的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000}],"nameRight":"姐姐","textRight":"啊哈哈……@真不好意思，拜托您了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"我很感谢你们能来。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000},{"cheek":0,"face":"mtn_ex_010.exp.json","id":303501,"motion":0,"pos":0}],"textRight":"理子，下次再来玩哦。@我随时都欢迎你。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303501,"motion":200}],"nameLeft":"千秋理子","textLeft":"嗯！@姐姐，下次见啦。"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303501,"motion":0,"pos":1,"voice":"vo_char_3035_00_05","textHome":"下次，我一定会成为值得骄傲的姐姐！！"}],"textCenter":"今后我一定要成为一名@令人骄傲的姐姐！！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303501,"motion":200}]},{"chara":[{"id":303501}]},{"autoTurnLast":2.0,"bgm":"stop","turnChangeIn":"fadeIn"}]},"version":3}