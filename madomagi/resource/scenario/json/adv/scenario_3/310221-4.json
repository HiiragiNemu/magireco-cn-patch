{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21021.jpg","bgm":"bgm05_event08","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":102201,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800900}],"nameLeft":"顾问","textLeft":"你说想退出网棒球社团？","turnChangeOut":"fadeOut"},{"chara":[{"id":102201}],"nameRight":"光","textRight":"是的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"textLeft":"你是……认真的吗？"},{"chara":[{"id":102201,"motion":200}],"textRight":"我是认真的！"},{"chara":[{"id":800900}],"textLeft":"这样啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800900}],"textLeft":"你再好好想一想。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":0}],"textRight":"咦？"},{"chara":[{"id":800900}],"textLeft":"你明白的吧？"},{"chara":[{"id":800900}],"textLeft":"虽然最近状态不佳，@但你对我们社团来说不可或缺。"},{"chara":[{"id":800900}],"textLeft":"就这么轻易说要退部，@让人很不好办啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102201,"motion":1}],"textRight":"但、但是……"},{"chara":[{"id":800900}],"textLeft":"首先，你想退出的理由是什么？"},{"chara":[{"id":102201}],"textRight":"那个……该怎么说呢……"},{"chara":[{"id":102201,"motion":300}],"textRight":"我实在做不到真正投入网棒球……"},{"chara":[{"id":800900}],"textLeft":"那你能投入到什么事情中去？"},{"chara":[{"id":102201,"motion":0}],"textRight":"我也不知道……"},{"chara":[{"id":800900}],"textLeft":"我说煌里啊，@好歹我也算是个教师。"},{"chara":[{"id":800900}],"textLeft":"到现在这么多年，@也见过不少形形色色的学生。"},{"chara":[{"id":800900}],"textLeft":"一个人有多认真多投入，@我能看得出来。"},{"chara":[{"id":800900}],"textLeft":"所以我很清楚你对网棒球@并没有做到全心投入。"},{"chara":[{"id":800900}],"textLeft":"但我第一次看你打球的时候……"},{"chara":[{"id":800900}],"textLeft":"至少能感觉到你是快乐的。"},{"chara":[{"id":102201,"lipSynch":0}],"textRight":"……"},{"chara":[{"id":800900}],"textLeft":"一次也好，@你试着全心投入一次怎么样？"},{"chara":[{"id":800900}],"textLeft":"能做到的话，我就同意让你退出。"},{"chara":[{"id":102201,"motion":200}],"textRight":"为、为什么？"},{"chara":[{"id":800900}],"textLeft":"虽然我不想这么说……"},{"chara":[{"id":800900}],"textLeft":"没法在一件事上@全心投入的家伙……"},{"chara":[{"id":800900}],"textLeft":"去做任何别的事@也只可能是个半吊子。"},{"chara":[{"id":800900}],"textLeft":"所以我希望你能体验一次@彻底投入的感觉……"},{"chara":[{"cheek":1,"id":102201,"motion":300,"tear":1}],"textRight":"做不到……我做不到的……"},{"chara":[{"id":102201,"motion":200}],"textRight":"我到现在一次都没能全心投入过！"},{"chara":[{"id":102201}],"textRight":"不管自己多么想要认真起来@都没能做到！！"},{"chara":[{"id":800900}],"textLeft":"煌里……"},{"chara":[{"id":800900}],"textLeft":"你现在退出社团@也解决不了任何问题。"},{"chara":[{"id":800900}],"textLeft":"只有那个没能坚持网棒球的半吊子@会一直陪着你。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":102201,"lipSynch":0,"motion":0,"tear":1}],"textRight":"唔？！"},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102201,"motion":200,"tear":1}],"textRight":"这种事我当然明白！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900}],"textLeft":"喂、喂！@煌里！！"},{"autoTurnLast":0.01,"bg":"bg_adv_21021.jpg","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102201,"motion":1,"pos":1,"tear":1}],"turnChangeIn":"rollInFast"},{"chara":[{"id":102201}],"nameCenter":"光","textCenter":"呼……呼……","turnChangeOut":"rollOutFast"},{"chara":[{"eyeClose":1,"id":102201,"lipSynch":0}],"textCenter":"（根本没人可以依靠……）"},{"chara":[{"id":102201,"lipSynch":0}],"textCenter":"（现在我谁都不想见……）"},{"chara":[{"eyeClose":0,"id":102201,"lipSynch":0}],"textCenter":"（这里的话应该能独处……）"},{"autoTurnLast":0.01,"bg":"bg_adv_21025.jpg","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102201,"motion":1,"pos":1,"tear":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102201,"mouthOpen":1}],"textCenter":"呼……呼……呼……","turnChangeOut":"fadeOut"},{"chara":[{"id":102201,"lipSynch":0,"mouthOpen":0}],"textCenter":"（我心里最清楚……@顾问说得一点都没错。）"},{"chara":[{"id":102201,"lipSynch":0,"motion":300}],"textCenter":"（但办不到的事就是办不到啊。）"},{"chara":[{"id":102201,"lipSynch":0}],"textCenter":"（那个叫丘比的东西@结果也没能实现我的愿望。）"},{"chara":[{"id":102201,"lipSynch":0}],"textCenter":"（连退出社团都实现不了……）"},{"chara":[{"eyeClose":1,"id":102201}],"textCenter":"为什么就没人@能理解我的心情……"},{"bgm":"stop","chara":[{"id":102103}],"nameRight":"？？？","textRight":"不被任何人理解，@真是可悲啊。"},{"autoTurnLast":0.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":400,"pos":0}],"textClear":1},{"bgm":"stop","chara":[{"id":102201,"tear":1},{"cheek":0,"face":"mtn_ex_000.exp.json","id":102103,"motion":1,"pos":2,"soulGem":0}],"nameLeft":"光","textLeft":"咦？@是谁……为什么在这里？"},{"bgm":"bgm01_anime02","chara":[{"id":102103}],"textRight":"经过走廊的时候@听到这边有哭声。"},{"chara":[{"id":102103}],"textRight":"一般来说都会想来看看@是怎么回事吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102103,"motion":100}],"textRight":"至于动机是好奇还是担心@都不重要……对吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":102201,"motion":200,"tear":1}],"textLeft":"好奇？"},{"bgm":"bgm01_anime02","chara":[{"id":102103,"motion":0}],"textRight":"别这么瞪着我嘛。@当然是因为担心啦。"},{"chara":[{"id":102103}],"textRight":"来，拿这个擦擦眼泪吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102201,"motion":1,"tear":1}],"textLeft":"谢谢。"},{"chara":[{"id":102103,"lipSynch":0}],"textRight":"……"},{"chara":[{"cheek":0,"eyeClose":1,"id":102201,"lipSynch":0,"tear":0}],"textLeft":"……"},{"chara":[{"eyeClose":0,"id":102201,"motion":0}],"textLeft":"请问……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":102103,"motion":100}],"textRight":"嗯？"},{"chara":[{"id":102201}],"textLeft":"是……高年级的学姐吧？@不好意思，让你看到我丢人的样子。"},{"chara":[{"id":102103}],"textRight":"没关系啦。@有没有稍微冷静一点？"},{"chara":[{"id":102201,"motion":300}],"textLeft":"啊、嗯……我没事了。@谢谢你……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102103,"motion":0}],"textRight":"呵呵，不用谢。@比起这个……"},{"chara":[{"id":102103,"motion":1}],"nameRight":"结菜","textRight":"我叫红晴结菜，请多关照。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":1}],"textLeft":"咦？@什么意思……"},{"chara":[{"id":102201,"motion":1}],"textRight":"那再见啦。"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":102103}],"textClear":1},{"chara":[{"id":102201,"motion":400}],"textLeft":"请、请等一下！"},{"chara":[{"id":102201,"lipSynch":0,"pos":1}],"textCenter":"……"},{"chara":[{"id":102201,"motion":0}],"textCenter":"走掉了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102201}],"textCenter":"她到底……"},{"chara":[{"id":102201,"motion":0}],"textCenter":"是来安慰我的，@还是只是来逗我玩……[chara:102201:lipSynch_0][wait:1.0][chara:102201:cheek_0][chara:102201:motion_200][chara:102201:face_mtn_ex_050.exp.json][chara:102201:lipSynch_1]啊。"},{"chara":[{"id":102201}],"textCenter":"忘记把手帕还给她了。"},{"autoTurnFirst":2.0,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":102201,"motion":1,"pos":1,"voice":"vo_char_1022_00_03","textHome":"以前的我是对什么都很快会腻的那类"}],"nameCenter":"光","textCenter":"曾经的我做什么事@都只有三分钟热度。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":102201}]},{"chara":[{"id":100201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}