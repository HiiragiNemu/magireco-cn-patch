n","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"结束社团活动的学生……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301101,"motion":1,"pos":2}],"nameRight":"夏目佳子","textRight":"还有刚下班的女白领……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303001,"motion":0}],"textLeft":"都会在这个时候@蜂拥而至啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303001,"motion":301}],"textLeft":"不好意思！@能再稍微帮我一阵子吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101101,"motion":0,"pos":2}],"nameRight":"枫","textRight":"当然可以！@我们来就是为了帮你嘛。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301101,"motion":100,"pos":2}],"nameRight":"夏目佳子","textRight":"嗯！嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303001,"motion":0}],"textLeft":"谢谢！"},{"chara":[{"effect":"fadeout","id":303001},{"effect":"fadeout","id":301101}],"narration":"在我的愿望治好阿姨的病之后@店里也从来没有这么热闹过@尤其是……","narrationBg":"bg_adv_21242.jpg","narrationEffect":"in"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":1}],"narrationEffect":"out","textCenter":"快看～这个好可爱～"},{"chara":[{"effect":"fadeout","id":800100}],"narration":"年轻的客人竟然排起了长龙@这简直是奢望","narrationBg":"bg_adv_21242.jpg","narrationEffect":"in"},{"narration":"现在店里生意这么好……@都是多亏了枫和佳子@多亏了遇到她们……"},{"narration":"如今我才能被最爱的鲜花……@以及众多客人的笑容包围……@才能在这家店里工作"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303001,"motion":100,"mouthOpen":1,"pos":1}],"nameCenter":"春名木乃美","narrationEffect":"out","textCenter":"欢迎光临！"},{"bgm":"bgm03_story03","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303001,"lipSynch":0,"motion":0}],"surround":"stop","textCenter":"（真怀念啊……）"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303001,"lipSynch":0,"motion":1}],"textCenter":"（一开始她们俩来到店里的时候，@都还是我的客人。）"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303001,"lipSynch":0}],"textCenter":"（刚开始……@我们彼此说话还会用敬语呢。）"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{