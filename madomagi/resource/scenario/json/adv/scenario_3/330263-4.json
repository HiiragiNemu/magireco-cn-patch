{"story":{"group_1":[{"bg":"bg_adv_21082.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302801,"motion":100,"pos":1}],"nameCenter":"三栗菖蒲","textCenter":"我回来啦！@有人先回来了吗？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302801}],"textCenter":"啊，叶月和木叶都在啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801,"motion":200}],"textCenter":"嗅嗅……@[chara:302801:lipSynch_0][wait:1.5][chara:302801:cheek_0][chara:302801:face_mtn_ex_010.exp.json][chara:302801:lipSynch_1]哦哦，还有饭菜的味道！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302801,"motion":0}],"textCenter":"叶月，今天的菜单是什么？"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701,"motion":0,"pos":0},{"id":302801,"pos":2}],"nameLeft":"游佐叶月","textLeft":"菖、菖蒲，欢迎回来……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302801,"motion":1}],"nameRight":"三栗菖蒲","textRight":"咦？叶月，@你不是在做饭吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701,"motion":1}],"textLeft":"因为我们上次吃完了木叶做的菜，@所以她有了干劲，"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302701}],"textLeft":"[chara:302701:effect_emotion_sad_0][se:7224_fall_into]今天她抢着@要做饭……"},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302801,"motion":400,"mouthOpen":1}],"textBg":"shout","textRight":"诶！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302601,"motion":100,"pos":0}],"nameLeft":"静海木叶","textLeft":"菖蒲，欢迎回来！@晚饭马上就做好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":302801,"motion":0,"pos":2}],"nameNarration":"静海木叶","narration":"就这样，我，静海木叶@克服做饭难吃的故事@有了一点点进展","narrationBg":"bg_adv_21082.jpg","narrationEffect":"in"},{"narration":"「做料理要用心」……@学到这一点之后@我的菜变得能让人吃完了"},{"narration":"从那以后@做菜变得更有趣了……@虽然我做的菜偶尔会让@菖蒲和叶月的惨叫响彻街道"},{"narration":"不过，唯独滑蛋鸡肉饭@她们不会有怨言"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302601,"motion":200}