{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_20252.jpg","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111802,"motion":0,"pos":2},{"cheek":1,"face":"mtn_ex_011.exp.json","id":111801,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story19","nameNarration":"","narration":"吸——","narrationBg":"bg_adv_20252.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":111802,"motion":300},{"id":111801,"motion":300}],"nameRight":"月咲","narrationEffect":"out","textRight":"哇……"},{"chara":[{"id":111802}],"textRight":"一场运动之后来一杯热带果汁，@真是沁人心脾！"},{"chara":[{"id":111801,"motion":100}],"nameLeft":"月夜","textLeft":"放松的感觉可真好啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":111802,"motion":1}],"textRight":"话说回来……"},{"chara":[{"id":111802}],"textRight":"七海八千代说的话是真的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":111801,"motion":200}],"textLeft":"毕竟是敌人，@她说的话我是不太敢信的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":111802,"lipSynch":0,"motion":300}],"textRight":"…………"},{"autoTurnLast":1.0,"bg":"bg_adv_20331.jpg","chara":[{"cheek":-1,"face":"mtn_ex_014.exp.json","id":100251,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_040.exp.json","id":111801,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":111802,"motion":0,"pos":1,"posX":-50}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100251,"motion":100}],"nameRight":"八千代","textRight":"来，这个给你。","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":111801}],"nameLeft":"月夜","textLeft":"这……是什么意思？"},{"chara":[{"id":100251,"motion":0}],"textRight":"这是热带果汁哦。@[chara:100251:lipSynch_0][wait:1.0][chara:100251:cheek_-1][chara:100251:face_mtn_ex_030.exp.json][chara:100251:lipSynch_1]难道你不喜欢喝这个？"},{"chara":[{"id":111801,"motion":200}],"textLeft":"也不是不喜欢……"},{"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100251,"motion":1}],"textRight":"据说热带果汁@对缓解中暑症状很有帮助。"},{"chara":[{"id":111802,"motion":300}],"nameCenter":"月咲","textCenter":"真的吗？我还是第一次听说……"},{"chara":[{"cheek":-1,"face":"mtn_ex_011.exp.json","id":100251}],"textRight":"是吗？不过这个说法@也是最近才流行起来的。"},{"chara":[{"id":100251},{"id":111801,"motion":1},{"id":111802,"motion":0}],"textRight":"而且它还可以缓解运动带来的疲劳，@你可以试试哦。"},{"chara":[{"cheek":-1,"face":"mtn_ex_014.exp.json","id":100251,"motion":201}],"textRight":"那我们就先回去了。"},{"autoTurnLast":0.5,"bg":"bg_adv_20252.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":111802,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_040.exp.json","id":111801,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":111802}],"nameRight":"月咲","textRight":"唔……不过这果汁挺好喝的，@就别管那么多啦。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111801,"motion":100}],"nameLeft":"月夜","textLeft":"呵呵，也对。"},{"chara":[{"cheek":1,"id":111801,"motion":1}],"textLeft":"啊，快看。"},{"chara":[{"id":111801}],"textLeft":"夕阳把海面染红了，真漂亮啊。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":111802,"motion":100}],"textRight":"真的！"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":111802,"motion":1}],"textRight":"啊……闭上眼的话，@就只听得见海浪的声音。"},{"chara":[{"id":111801,"motion":200}],"textLeft":"海边的游客越来越少了，@没之前那么嘈杂了。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111802}],"textRight":"嗯……"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":111802,"motion":300}],"textRight":"又安静又惬意……@我都快要睡着了……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":111802}],"textRight":"哎？@像我们这样看看海，睡个午觉……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":111801,"motion":100}],"textLeft":"这不就是梢说的@“总之就是放松一下”嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111802,"motion":100}],"textRight":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":111802,"motion":1}],"textRight":"我们问了3个人@享受阳光沙滩的方法……"},{"chara":[{"id":111802}],"textRight":"没想到不知不觉间都实现了。"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":111802,"motion":0}],"surround":"7003_wind","textRight":"月夜，今天你玩得开心吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":111801,"motion":200}],"textLeft":"这个嘛……"},{"chara":[{"id":111802}],"textRight":"嗯……"},{"bgm":"bgm03_story18","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111801,"motion":100,"mouthOpen":1},{"cheek":1,"face":"mtn_ex_011.exp.json","id":111802,"motion":100,"mouthOpen":1}],"nameCenter":"月夜&月咲","surround":"stop","textCenter":"非常开心哦。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":111802,"motion":400,"mouthOpen":0},{"id":111801,"mouthOpen":0}],"textRight":"啊……月夜……"},{"chara":[{"id":111801,"motion":1}],"textLeft":"我感觉从来没有哪一天@像今天这样过得这么充实。"},{"chara":[{"id":111801}],"textLeft":"虽然我们和七海八千代她们@有过节……"},{"chara":[{"id":111801,"motion":200}],"textLeft":"不过今天@姑且就忘记这层敌对关系吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111802,"motion":100}],"textRight":"呵呵，说的也是。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":111802,"motion":0}],"textRight":"唉，要是今天@永远不要过去就好啦——"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":111802,"motion":200}],"textRight":"我真想和你一起@开开心心地过每一天。"},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":111801,"motion":300}],"textLeft":"我也是这么想的……@但这个愿望现在还难以实现……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111801,"motion":0}],"textLeft":"所以我们要把今天一整天的美好@留在脑海里。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":111802,"motion":0}],"textRight":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":111801,"motion":100}],"textLeft":"天马上就要黑了呢。"},{"chara":[{"id":111801}],"textLeft":"我们差不多回去吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":111802,"motion":200}],"textRight":"啊，等等！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":111801,"motion":0}],"textLeft":"怎、怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":111802,"motion":1}],"textRight":"虽然平时都不怎么买东西，"},{"chara":[{"id":111802}],"textRight":"但今天还是想去看看……"},{"chara":[{"cheek":1,"id":111802,"motion":300}],"textRight":"要不……陪我去特产专卖店逛一圈？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111801,"motion":100}],"textLeft":"嗯。"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/31118_swim_amane_sisters_story/memoria_1366.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"月咲","narration":"―月咲―@『哇！真漂亮！』","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":30.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"nameNarration":"月夜","narration":"―月夜―@「就像是锁住了@大海的颜色一样……」"},{"nameNarration":"月咲","narration":"―月咲―@『嗯……』"},{"narration":"―月咲―@『形状也像月亮一样……简直就是@为我们量身定做的钥匙圈！』"},{"autoTurnLast":0.01,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":111802,"motion":1,"pos":2},{"cheek":1,"face":"mtn_ex_011.exp.json","id":111801,"motion":0,"pos":0}],"item":[{"path":"resource/scenario/img/31118_swim_amane_sisters_story/memoria_1366.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":111802}],"textRight":"以后一看到这个，@就能想起今天。","turnChangeOut":"fadeOut"},{"chara":[{"id":111801,"motion":100}],"textLeft":"嗯。"},{"chara":[{"id":111801}],"textLeft":"我不会忘记……@我们两个在海边度过的这段时光。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111802,"motion":100}],"textRight":"嗯！"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111800,"lipSynch":1,"motion":100,"pos":0,"posX":130,"voice":"vo_char_1118_00_05","textHome":"这是最好的回忆。@留下了最棒的回忆呢！"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111802,"lipSynch":1,"motion":100,"pos":2,"posX":-130,"voice":"vo_char_1118_00_05","textHome":"这是最好的回忆。@留下了最棒的回忆呢！"}],"nameCenter":"月夜&月咲","textCenter":"这是最美好的回忆呢。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":111801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}