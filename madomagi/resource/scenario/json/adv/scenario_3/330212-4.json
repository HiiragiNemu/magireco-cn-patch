{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_46103.jpg","bgm":"bgm05_event04","chara":[{"id":6103,"name":"sprite_0","pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":102100,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102100,"motion":100}],"nameRight":"结菜","textRight":"[chara:6103:effect_7001_attack02][surround:0001_jump01]到此为止了吧？","turnChangeOut":"fadeOut"},{"autoTurnLast":1.5,"bgEffect":"shakeSmall","chara":[{"effect":"7003_damage02","id":6103,"name":"sprite_0"}],"surround":"1005A02","textClear":1},{"autoTurnLast":0.0,"chara":[{"id":6103,"name":"sprite_0"}],"nameLeft":"0.5","textBg":"shout","textLeft":"沙沙…☆…◇…"},{"autoTurnLast":1.0,"bgm":"stop","chara":[{"effect":"fadeout","id":6103,"name":"sprite_0"}],"se":"3102_enemy_dead","textClear":1},{"autoTurnLast":1.0,"chara":[{"id":102100,"motion":0,"pos":1}]},{"autoTurnLast":0.5,"bg":"bg_adv_16043.jpg","bgChangeEffect":"exitWitchSpace","se":"7209_gate_close","textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_000.exp.json","id":102101,"motion":0,"pos":1}],"se":"7205_magic_girl","textClear":1},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":102101,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":0,"pos":2}],"nameLeft":"结菜","textLeft":"你俩都没事吧？"},{"chara":[{"id":302101,"motion":100}],"nameRight":"铃鹿朔夜","textRight":"我没问题！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102201,"motion":100,"pos":2}],"nameRight":"光","textRight":"我也是。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102201,"motion":0}],"textRight":"对不起……是我拖累了你们……"},{"chara":[{"id":102101,"motion":100}],"textLeft":"你没有率领好光之军团吧。"},{"chara":[{"id":102101}],"textLeft":"是因为你没有集中精力应战吗？"},{"chara":[{"id":102201,"motion":300}],"textRight":"听了朔夜的烦恼之后，@我就特别担心……"},{"chara":[{"id":102101,"motion":0}],"textLeft":"可是她本人倒是有在@集中精神应战啊？"},{"chara":[{"eyeClose":1,"id":102201,"motion":1}],"textRight":"是……"},{"chara":[{"id":102101,"motion":200}],"textLeft":"这样下去可不行啊……"},{"chara":[{"id":102101}],"textLeft":"你得一直保持专注才行。"},{"chara":[{"id":102101,"motion":0}],"textLeft":"对了，朔夜。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302101,"motion":200,"pos":2}],"nameRight":"铃鹿朔夜","textRight":"怎么了？"},{"chara":[{"id":102101,"motion":1}],"textLeft":"我记得田径部在训练时@也会锻炼队员的意志吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":100}],"textRight":"是啊，一流的运动选手@不仅要做身体上的较量……"},{"chara":[{"id":302101}],"textRight":"意志更坚定的一方才会获胜。"},{"chara":[{"id":302101,"motion":1}],"textRight":"为此田径部也有很多@锻炼意志的训练方法……"},{"chara":[{"id":102101,"motion":300}],"textLeft":"那有帮人提升注意力的训练吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302101,"motion":0}],"textRight":"当然有啊……@结菜，难道说……"},{"chara":[{"id":302101,"motion":100}],"textRight":"你想让我去训练光吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102101,"motion":100}],"textLeft":"没错，你听明白就好。"},{"chara":[{"id":302101,"motion":300}],"textRight":"但我知道的@也只是田径训练的方式……"},{"chara":[{"id":102101}],"textLeft":"在和魔女战斗时，@能不能也用上这种方法呢？"},{"chara":[{"id":302101}],"textRight":"能行吗……我也没有试过……"},{"chara":[{"id":102101,"motion":1}],"textLeft":"那我换个说法吧，你能试试吗？"},{"chara":[{"eyeClose":1,"id":302101,"motion":0}],"textRight":"应用了田径技巧的训练计划……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302101}],"textRight":"我会考虑的。"},{"chara":[{"id":102101,"motion":0}],"textLeft":"那就交给你了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":0,"pos":2},{"id":102101}],"textLeft":"那么……"},{"chara":[{"id":102101}],"textLeft":"光，让朔夜训练训练你。"},{"chara":[{"id":102101}],"textLeft":"你就好好锻炼一下注意力吧。"},{"chara":[{"id":102201,"motion":100}],"nameRight":"光","textRight":"我、我在！"},{"autoTurnLast":0.2,"chara":[{"id":102201,"motion":0,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302101,"motion":100,"pos":2}],"nameRight":"铃鹿朔夜","textRight":"好，既然要做，那就得全力以赴。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":200}],"textRight":"你做好准备了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102201,"motion":200}],"nameLeft":"光","textLeft":"当然了！"},{"autoTurnFirst":5.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":302101,"motion":200,"pos":1,"voice":"vo_char_3021_00_04","textHome":"うーんと、今日の報告事項は…特になし！"}],"nameCenter":"铃鹿朔夜","textCenter":"唔……今天也没什么好报告的！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302101,"motion":100}]},{"chara":[{"id":302101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}