{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21083.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800600}],"nameRight":"星罗的母亲","textRight":"星罗！吃饭啦！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0,"pos":2,"soulGem":0}],"nameRight":"三穗野星罗","textRight":"好～"},{"chara":[{"id":800700}],"nameLeft":"星罗的父亲","textLeft":"晚饭是炖猪肉块啊。　"},{"chara":[{"id":800700}],"textLeft":"看起来真好吃啊，@那我就先预定再来一碗吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901,"motion":200}],"textRight":"怎么能提前预定嘛！"},{"chara":[{"id":800700}],"textLeft":"哈哈，抱歉抱歉。"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303901}],"textRight":"我吃饱啦！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"motion":1}],"textRight":"啊，对了。"},{"chara":[{"id":303901}],"textRight":"你们能在这份文件上签下名吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800700}],"textLeft":"文件？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0}],"textRight":"这是升学意向调查表，@直属校生也要提交。"},{"chara":[{"id":800700}],"textLeft":"已经到这个时候了啊……"},{"chara":[{"id":800700}],"textLeft":"嗯？这是……@[chara:800700:lipSynch_0][wait:1.0][chara:800700:lipSynch_1]设计专业？"},{"chara":[{"id":303901,"motion":100}],"textRight":"嗯，我想进设计专业的预科班。"},{"chara":[{"id":303901}],"textRight":"因为我想成为电影导演。"},{"chara":[{"id":303901,"motion":1}],"textRight":"所以我想去上有电影专业的大学，@或者是相关的职业学校。"},{"chara":[{"id":303901}],"textRight":"为此我想在高中读设计专业，@边学习电影制作软件……"},{"chara":[{"id":303901,"motion":0}],"textRight":"边学习预备班的课程。"},{"chara":[{"id":800700}],"textLeft":"设计专业啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textLeft":"可是读了预备班，@就很难考取资格证书吧？"},{"chara":[{"id":303901}],"textRight":"这个就……"},{"bgm":"stop","chara":[{"id":800700,"lipSynch":0}],"textLeft":"……"},{"bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700}],"textLeft":"不行。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"motion":400},{"cheek":0,"face":"mtn_ex_050.exp.json","id":800600}],"textRight":"咦？！"},{"chara":[{"id":800700}],"textLeft":"电影和设计都是跟感性有关的。"},{"chara":[{"id":800700}],"textLeft":"就算学了也不一定能掌握。"},{"chara":[{"id":800700}],"textLeft":"这些全都要看运气的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"motion":300}],"textRight":"这……你说得确实没错……"},{"chara":[{"id":800700}],"textLeft":"但如果你有了证书，找到了工作，@那你的生活就会稳定不少。"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textLeft":"我也不是反对你读大学或职业学校。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700}],"textLeft":"但我不允许你为了电影那种东西@浪费你的人生。"},{"chara":[{"id":303901}],"textRight":"浪费……"},{"chara":[{"id":800700}],"textLeft":"总而言之，我是不会签名同意的！"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"……"},{"chara":[{"id":303901,"motion":0}],"textRight":"我知道了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":0}],"nameLeft":"星罗的母亲","textLeft":"星罗……"},{"bgm":"stop","chara":[{"id":303901,"lipSynch":0}],"textRight":"……"},{"bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901,"lipSynch":0}],"textRight":"（我明白了……）","turnEffect":"thinking"},{"chara":[{"id":303901,"lipSynch":0,"motion":300}],"textRight":"（只靠商量是没有办法@让爸爸理解我的……）"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"（如果要获得爸爸的认可@就必须向他展示我的决心）"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"（我要去拍电影）"},{"chara":[{"id":303901,"lipSynch":0}],"textRight":"（我要做出一部让爸爸@也为之感动的作品）"},{"chara":[{"id":303901,"lipSynch":0,"motion":100}],"textRight":"（我一定会让他认可我的）"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeI