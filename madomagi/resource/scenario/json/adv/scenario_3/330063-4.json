{"story":{"group_1":[{"bg":"bg_adv_13111.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300601,"motion":200,"pos":0},{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001,"motion":0,"pos":2}],"nameLeft":"木崎衣美里","nameRight":"阿见莉爱","textLeft":"嗯嗯嗯嗯嗯嗯嗯嗯嗯！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301001,"motion":400}],"textRight":"到底怎么了！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300601}],"textLeft":"好可爱……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"艾米莉？@你眼里怎么满是桃心……"},{"bgm":"bgm03_movie12","chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300601,"motion":400,"pos":0}],"nameLeft":"木崎衣美里","se":"7226_shock","textLeft":"超可爱！@超超超可爱啊！"},{"chara":[{"cheek":1,"effect":"emotion_joy_0","face":"mtn_ex_050.exp.json","id":300601,"motion":200}],"se":"7222_happy","textLeft":"诶——她是谁她是谁！？@是晶晶的熟人吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0}],"textLeft":"我问你哦，你叫什么名字？@多大了？哪个学校的？"},{"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301001,"lipSynch":0,"motion":0}],"textRight":"………………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601}],"textLeft":"告诉我呀！"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":301001,"lipSynch":0}],"se":"7226_shock","textRight":"（啊！）"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001,"motion":400}],"textRight":"我、我叫阿见莉爱！@是水名女子学园的……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300601,"motion":200}],"textLeft":"哇——我知道！@你超有名！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300601,"mouthOpen":1}],"textLeft":"你在当模特吧！@好厉害！棒呆了！"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301001,"motion":0}],"textRight":"没、没错！@我就是人见人爱的阿见莉爱！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":0}],"textLeft":"嗯——那就叫你……@[chara:300601:cheek_0:face_mtn_ex_010.exp.json]莉爱大人吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301001}],"textRight":"莉爱……大人？"},{"chara":[{"cheek":0,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":300601,"motion":100}],"se":"7222_happy","textLeft":"因为@你就像公主一样！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"她基本上……@都用自创的外号称呼别人。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001}],"textRight":"莉爱大人……@[chara:301001:cheek_1:face_mtn_ex_020.exp.json]嗯，可以！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301001,"lipSynch":0}],"textRight":"（被称为“大人”……真爽！）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"也就是说，莉爱大人是公主型吧。@我是小恶魔型哦！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601}],"textLeft":"我啊，@有个憧憬的姐姐～"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"怎么突然说起这个？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"哎，不知道为什么，@看到莉爱大人就想说了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0}],"textLeft":"我以那个憧憬的姐姐为目标，@和丘比太郎……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301001}],"textRight":"丘比太郎？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601}],"textLeft":"诶？[chara:300601:cheek_0:face_mtn_ex_030.exp.json:motion_300]啊——本名叫什么来着……@[chara:300601:cheek_0:face_mtn_ex_050.exp.json]想起来了，丘比！"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":301001,"motion":400}],"se":"7226_shock","textRight":"诶！？"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"呃，艾米莉，@别把那个名字挂在嘴边……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"lipSynch":0}],"textLeft":"（算了，就算说出来，@对方也不知道吧……）"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001,"motion":0}],"textRight":"你难道是……魔法少女？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801}],"textLeft":"是啊……"},{"bgm":"bgm01_anime07","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"mouthOpen":1}],"textLeft":"嗯？[chara:300801:cheek_2:motion_400:effect_emotion_surprise_0][se:7226_shock]诶——"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300601,"motion":400,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"不会吧！你知道魔法少女吗？@莉爱大人！？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001}],"textRight":"因为……@我也是……魔法少女……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801,"motion":200,"mouthOpen":1,"pos":0}],"nameLeft":"志伸晶","textLeft":"不会吧！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300601,"motion":200,"mouthOpen":1,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"真的吗！@好棒！太棒了！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801,"motion":300,"pos":0}],"nameLeft":"志伸晶","textLeft":"哎，真是太巧了啊。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300801,"lipSynch":0,"motion":0}],"textLeft":"（不，难道这也是@艾米莉的……什么天赋？）"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300601,"motion":200,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"好棒好棒，[chara:300601:effect_emotion_joy_0][se:7222_happy]莉爱大人！@你是炒鸡可爱的魔法少女啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301001}],"textRight":"是、是啊。@听你这么说，我很高兴！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001,"lipSynch":0}],"textRight":"（她人挺不错的嘛！@这么直白地说我可爱！）","turnEffect":"thinking"},{"chara":[{"cheek":1,"effect":"emotion_joy_0","face":"mtn_ex_010.exp.json","id":301001,"lipSynch":0,"motion":200}],"se":"7222_happy","textRight":"（啊——心情越来越好了……@来这里是对的！我有自信了！）"},{"chara":[{"cheek":0,"effect":"emotion_angry_0","face":"mtn_ex_020.exp.json","id":300601}],"se":"7219_strain","textLeft":"我决定了！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300601,"motion":0}],"textLeft":"我要和莉爱大人组队……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":400,"pos":0}],"nameLeft":"志伸晶","textLeft":"等等，你突然间怎么了！@怎么回事！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"因为我的目标是@成为最最可爱的魔法少女！"},{"chara":[{"cheek":0,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":300601,"motion":100}],"se":"7222_happy","textLeft":"和莉爱大人组队的话，@应该就能达到这个水平了吧！？"},{"chara":[{"cheek":0,"id":300601,"motion":200}],"textLeft":"好不好！莉爱大人！@和我组队吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":300,"pos":0}],"nameLeft":"志伸晶","textLeft":"艾米莉，你突然这么说，@莉爱大人会不知所措的……"},{"bgm":"bgm03_story09","chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301001,"motion":0}],"textRight":"好啊！"},{"chara":[{"cheek":1,"effect":"emotion_angry_0","face":"mtn_ex_020.exp.json","id":300801,"motion":200,"mouthOpen":1}],"se":"7219_strain","textLeft":"答应得太快了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":100,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"ＹＥＳ！组队成功！@我们要变得最最可爱哦！"},{"chara":[{"cheek":1,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":301001,"motion":100}],"se":"7222_happy","textRight":"和我在一起@是不会错的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":300,"pos":0}],"nameLeft":"志伸晶","textLeft":"真是的，[chara:300801:effect_emotion_sad_0][se:7224_fall_into]随你们的便吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"好！@那咱们去吃蜜豆吧！"},{"chara":[{"cheek":1,"id":301001,"motion":0}],"textRight":"蜜豆……@好啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601}],"textLeft":"晶晶也一起来！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":300,"pos":0}],"nameLeft":"志伸晶","textLeft":"总觉得好累，@想吃点甜的……"},{"chara":[{"cheek":0,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":300601,"motion":100,"pos":0}],"nameLeft":"木崎衣美里","se":"7222_happy","textLeft":"那就出动吧！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301001,"motion":0}],"textRight":"出、出动？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0}],"textLeft":"啊，就是出发！@哎呀，别在意别在意！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601}],"textLeft":"对了对了！我还有其他@想介绍给莉爱大人的女孩！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601}],"textLeft":"首先是香香～@然后是纱纱～"},{"nameNarration":"","narration":"衣美里就这样@又在毫不知情的状况下@消除了别人的烦恼","narrationBg":"bg_adv_13111.jpg","narrationEffect":"in"},{"autoTurnFirst":3.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"pos":1,"voice":"vo_char_3006_00_05","textHome":"莉爱她闪闪发亮的呢！@真让我心动不已！"}],"nameCenter":"木崎衣美里","narrationEffect":"out","textCenter":"莉爱大人闪闪发光呢！@我心跳加速啦！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300601}]},{"chara":[{"id":300601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}