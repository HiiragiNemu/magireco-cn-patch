{"story":{"group_1":[{"bg":"bg_adv_20031.jpg","bgm":"bgm03_story03","chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201,"motion":200,"pos":0}],"nameLeft":"吴纪里香","surround":"7001_birdsong","textLeft":"嗯！天气真好，@正适合出远门采购！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"bg":"bg_adv_21083.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400101,"motion":0,"pos":1}],"nameCenter":"美国织莉子","surround":"stop","textCenter":"不用啦。@别放在心上。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"bg":"bg_adv_20031.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"吴纪里香","textCenter":"（虽然织莉子叫我@『不要放在心上』……）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0}],"textCenter":"（但她肯定是顾虑到我的心情@才那样说的。）"},{"bg":"bg_adv_11041.jpg","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"吴纪里香","textCenter":"（因为，织莉子她……）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0}],"textCenter":"（因为，织莉子她都说了，@想要那个“大吉岭”！）"},{"bg":"bg_adv_21041.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":0}],"nameLeft":"","surround":"7102_townbuzz","textLeft":"欢迎光临～","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"lipSynch":0,"motion":0,"pos":2},{"effect":"fadeout","id":801000}],"nameRight":"吴纪里香","textRight":"（唔……我记得，@是在这边的货架上……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"motion":200}],"textRight":"有了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"lipSynch":0,"motion":0}],"textRight":"（呼……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"lipSynch":0}],"textRight":"（毕竟昨天买了那么多，@我还怕没有了呢……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0}],"textRight":"（还好没有卖完……）"},{"chara":[{"cheek":1,"face":"mtn_ex_012.exp.json","id":400201,"motion":100},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":0}],"surround":"stop","textRight":"这个我要了！"},{"bg":"bg_adv_11021.jpg","bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"吴纪里香","surround":"7001_birdsong","textCenter":"（织莉子也真是的……）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400201,"lipSynch":0}],"textCenter":"（根本就不需要@跟我客气嘛……）"},{"nameNarration":"吴纪里香","narration":"只要你喜欢@我甚至可以跑到地球另一端@把红茶买回来","narrationBg":"bg_adv_21171.jpg","narrationEffect":"in","surround":"stop","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"我从不觉得为你实现愿望@是件麻烦事哦"},{"narration":"我不都和你约好了嘛@永远对你死心塌地……@永远保护你"},{"narration":"织莉子@我是为了你@才成为魔法少女的"},{"narration":"只要能为你而活@我的愿望就算是实现了"},{"bg":"bg_adv_21081.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"motion":0,"pos":2}],"nameRight":"吴纪里香","narrationEffect":"out","textRight":"呼……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"motion":100}],"textRight":"太好了，赶在织莉子起床之前@把红茶买回来了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201}],"textRight":"要是被她知道@我去重新购置红茶了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201,"motion":0}],"textRight":"她可能就会说不需要，然后把我叫回来吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400201}],"textRight":"可是……@她也差不多该起床了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201}],"textRight":"平常都是@织莉子来泡茶……"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201,"motion":200}],"textRight":"今天就由我来吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400101,"motion":0,"pos":2}],"nameRight":"美国织莉子","textRight":"纪里香，@你来了啊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201,"motion":200,"pos":0}],"nameLeft":"吴纪里香","textLeft":"织莉子！@你醒了吗？织莉子！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400101}],"textRight":"这红茶……"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201,"motion":0}],"textLeft":"是织莉子说过的@大吉岭！"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400201}],"textLeft":"我起了个大早，@去神滨买来的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400101,"motion":300}],"textRight":"你专程去……@不用这么费心的呀。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400201,"motion":300}],"textLeft":"因为织莉子想喝的，@其实是这种红茶吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400201,"motion":200}],"textLeft":"要是没能@实现你的愿望，"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400201,"motion":0}],"textLeft":"我会过意不去的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400101,"motion":0}],"textRight":"纪里香……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":400201,"motion":100}],"textLeft":"织莉子？@我没弄错吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":400201,"motion":0}],"textLeft":"是这种红茶没错吧？@你不开心吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400101,"motion":200}],"textRight":"呵呵，别担心。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400101,"motion":0}],"textRight":"我想喝的@就是这种红茶哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400101}],"textRight":"谢谢你，纪里香。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":400201}],"textLeft":"……！@[chara:400201:cheek_1:face_mtn_ex_012.exp.json:motion_100]不用跟我道谢啦！"},{"chara":[{"cheek":1,"face":"mtn_ex_012.exp.json","id":400201}],"textLeft":"只要是为了织莉子，"},{"chara":[{"cheek":1,"face":"mtn_ex_012.exp.json","id":400201,"motion":200}],"textLeft":"无论何时，无论何地，@无论多少次，我都可以出发！"},{"chara":[{"cheek":1,"face":"mtn_ex_012.exp.json","id":400201,"lipSynch":0,"motion":0}],"textLeft":"（嗯！@对……就是这样！）"},{"narration":"我想看的，就是这份笑容。","narrationBg":"bg_adv_21171.jpg","narrationEffect":"in"},{"autoTurnFirst":3.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400201,"motion":200,"pos":1,"voice":"vo_char_4002_00_05","textHome":"为了你，就算是去地球的背面买红茶也完全@没问题的！"}],"nameCenter":"吴纪里香","narrationEffect":"out","textCenter":"只要是为了你，@我甚至可以跑到地球另一端，@把红茶买回来！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.4,"chara":[{"id":400201,"motion":300}]},{"chara":[{"id":400201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}