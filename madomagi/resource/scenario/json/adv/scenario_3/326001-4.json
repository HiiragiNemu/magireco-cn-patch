{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_20311.jpg","chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":101550,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":260000,"motion":200}],"nameLeft":"杏子","textLeft":"你没事吧？！","turnChangeOut":"fadeOut"},{"chara":[{"id":101550,"motion":300}],"nameRight":"忧","textRight":"杏子？"},{"bgm":"bgm03_story20","chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":400}],"textLeft":"啊？忧？"},{"chara":[{"id":101550,"motion":400}],"textRight":"我、我没事了……请放我下来吧。"},{"chara":[{"id":260000,"motion":0}],"textLeft":"你不是溺水了吗？"},{"chara":[{"id":101550}],"textRight":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101550,"motion":0}],"textRight":"我没有溺水，我是在游泳哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":1}],"textLeft":"什么？你那是在游泳？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101550}],"textRight":"是、是啊，@我算是在游泳的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101550,"motion":200}],"textRight":"我游给你看！"},{"autoTurnLast":0.3,"chara":[{"effect":"fadeout","id":101550}],"textClear":1},{"nameNarration":"","narration":"哗啦哗啦哗啦！","narrationEffect":"in"},{"chara":[{"id":260000,"lipSynch":0,"motion":0}],"narrationEffect":"out","textLeft":"（这就是在溺水吧……）"},{"chara":[{"id":260000,"lipSynch":0}],"textLeft":"（她是没沉下去……@可游成这样是怎么浮起来的啊？）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101550,"motion":100,"pos":2}],"textRight":"你看，我在游吧？"},{"chara":[{"id":260000,"motion":300}],"textLeft":"看什么啊……@怎么看都像是溺水啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101550,"motion":300}],"textRight":"诶！是、是吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1}],"textLeft":"你怎么一个人在这儿？@三日月别墅的其他人呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101550,"motion":0}],"textRight":"大家都有事，一大早就出门了。"},{"chara":[{"id":260000}],"textLeft":"那你就一个人过来了？"},{"chara":[{"id":101550}],"textRight":"嗯。"},{"chara":[{"id":101550,"motion":100}],"textRight":"啊，我有给她们留纸条，没事的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":100}],"textLeft":"我不是这个意思。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":260000}],"textLeft":"你一个小学生来海边，@出了事可怎么办啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101550,"motion":300}],"textRight":"唔……是、是这样没错啦……"},{"chara":[{"id":101550}],"textRight":"可我无论如何都想@赶在明天前学会游泳……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":0}],"textLeft":"赶在明天前？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101550,"motion":0}],"textRight":"嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000}],"textLeft":"那让御魂帮你调整一下不是更快吗？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101550}],"textRight":"我不想……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101550,"motion":400}],"textRight":"那么做可不行！@我一定要自己学会游泳！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":300}],"textLeft":"我说你啊……"},{"chara":[{"eyeClose":1,"id":101550,"lipSynch":0,"motion":0}],"textRight":"……"},{"bgm":"stop","chara":[{"eyeClose":0,"id":101550,"lipSynch":1,"motion":200}],"textRight":"杏子！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":0}],"textLeft":"嗯？"},{"chara":[{"id":101550}],"textRight":"如果我不能自己游的话，@那就请你和我一起练习吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":260000}],"textLeft":"啊？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":101550,"motion":100}],"textRight":"求你了！"},{"chara":[{"id":260000,"lipSynch":0}],"textLeft":"……"},{"bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"lipSynch":0,"motion":100}],"textLeft":"（也行吧。）"},{"chara":[{"id":260000,"lipSynch":0}],"textLeft":"（反正我也没什么事干。）"},{"chara":[{"id":260000,"lipSynch":0}],"textLeft":"（既然她想练习，@那就让她练个痛快吧。）"},{"chara":[{"id":260000,"lipSynch":1,"motion":1},{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101550,"motion":0}],"textLeft":"我知道了。"},{"chara":[{"id":260000}],"textLeft":"但你也别指望我来教你。"},{"chara":[{"id":260000}],"textLeft":"我只负责在旁边看着你。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":260000,"lipSynch":0}],"textLeft":"（毕竟我自己也不会游泳。）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101550,"motion":200},{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000}],"textRight":"谢谢！"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_03","textHome":"想要学会游泳、吗……@嗯，心情我倒是明白。"}],"nameCenter":"杏子","textCenter":"想学会游泳的心情……其实我也能理解。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]},{"chara":[{"id":260000}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}