{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_11081.jpg","bgm":"bgm03_story19","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800101,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800101}],"nameRight":"","textRight":"铃鹿，我今天跑得怎么样呢？","turnChangeOut":"fadeOut"},{"chara":[{"id":302101,"motion":1}],"nameLeft":"铃鹿朔夜","textLeft":"你跑的时候身体还是有点歪斜。"},{"chara":[{"id":800101}],"textRight":"我本来也想用正确的姿势跑步，@可是……"},{"chara":[{"id":302101,"motion":200}],"textLeft":"那你要不要试试锻炼躯干呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800101}],"textRight":"你说得对……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302101,"motion":0}],"textLeft":"我还要再完善一下训练内容，@你明天再来和我商量吧？"},{"chara":[{"id":800101}],"textRight":"嗯，谢谢！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800101,"motion":0}],"textRight":"那今天就辛苦你啦！"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":800101}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800203,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101}],"textRight":"学姐辛苦了！@不……"},{"chara":[{"id":800203}],"textRight":"教练辛苦了！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":302101,"motion":400}],"textLeft":"别这么叫我啊……"},{"chara":[{"id":800203}],"textRight":"可学姐已经很有教练的风范了！"},{"chara":[{"id":800203},{"id":302101,"motion":0}],"textRight":"你每次给的建议都很准确。"},{"chara":[{"id":800203}],"textRight":"而且还会为我们制定好@最合适的训练内容……"},{"chara":[{"id":800203}],"textRight":"[chara:800203:effect_emotion_joy_0][se:7222_happy]学姐就是我们最棒的教练！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800203,"motion":0}],"textRight":"当我听说你因为受伤@而不能尽情奔跑时……"},{"chara":[{"id":800203}],"textRight":"我真的很遗憾……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800203,"motion":0}],"textRight":"但我很高兴你依旧能留在社团，@给我们提供帮助。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":0}],"textLeft":"我才应该感谢你们。"},{"chara":[{"id":302101,"motion":100}],"textLeft":"很高兴大家能够接纳我。"},{"chara":[{"cheek":0,"id":800203}],"textRight":"说起来……@真亏学姐你能做这个决定啊。"},{"chara":[{"id":800203}],"textRight":"你一定是下了很大的决心@才选择成为教练的吧？"},{"chara":[{"id":800203}],"textRight":"是听取了别人的建议吗？"},{"chara":[{"id":302101,"motion":200}],"textLeft":"差不多是吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800203}],"textRight":"那个人是你的朋友吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800203}],"textRight":"还是说……是你以前学校里@田径部的同学？"},{"chara":[{"id":302101,"motion":300}],"textLeft":"唔……都不是哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302101,"motion":0}],"textLeft":"她们更像是我的家人。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302101,"motion":100}],"textLeft":"多亏了她们，@我才能找到全新的可能性。"},{"autoTurnFirst":7.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302101,"motion":300,"pos":1,"voice":"vo_char_3021_00_05","textHome":"くーっ！１日の締めのラーメン、しみるな～"}],"nameCenter":"铃鹿朔夜","textCenter":"呼！辛苦一天之后吃上一碗拉面@真是太棒了啊～","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":302101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}