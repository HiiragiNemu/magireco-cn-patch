{"story":{"group_1":[{"bg":"bg_adv_11081.jpg","bgm":"bgm03_story02","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101101,"motion":0,"pos":1}],"nameCenter":"枫","surround":"7001_birdsong","textCenter":"好……也喂过兔子了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101101,"motion":100}],"textCenter":"去游戏中心吧！"},{"chara":[{"effect":"fadeout","id":101101}],"nameNarration":"枫","narration":"虽然常有人对此表示意外……@但在放学后去游戏中心玩游戏@是我除了养宠物@和照顾家庭菜园外的乐趣之一","narrationBg":"bg_adv_11071.jpg","narrationEffect":"in"},{"narration":"我只玩抓娃娃机！@话虽如此@但我的技术很烂……","narrationBg":"bg_adv_21031.jpg","surround":"stop"},{"bg":"bg_adv_21031.jpg","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":100,"mouthOpen":1,"pos":0}],"nameLeft":"枫","narrationEffect":"out","textLeft":"哇啊！！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101101,"motion":0}],"textLeft":"又没抓上来……@我都花1500日元了……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101101,"motion":1}],"textLeft":"可是……@既然都已经花掉1500日元了……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101101}],"textLeft":"好、好吧！"},{"textRight":"你要自言自语到什么时候啊？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":100,"mouthOpen":1}],"textLeft":"哇啊！！"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":101101,"motion":400},{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":1,"pos":2}],"nameRight":"玲奈","se":"7226_shock","textLeft":"玲、玲奈……！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901}],"textRight":"蠢得让人看不下去。@换玲奈来吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textLeft":"啊！@好、好的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901}],"textRight":"你喜欢这个角色？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101}],"textLeft":"那个……@还好吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901}],"textRight":"啊？又不是特别喜欢，@你还在上面花这么多钱？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":1,"mouthOpen":1}],"textLeft":"怎么说呢……@一旦开始就……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101}],"textLeft":"想停也停不下来了……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":0}],"textRight":"典型的会玩抓娃娃机@玩到破产的类型呢。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textLeft":"哈！@[chara:101101:cheek_1:face_mtn_ex_030.exp.json:motion_300:effect_emotion_sad_0][se:7224_fall_into]唔、唔唔……"},{"chara":[{"effect":"fadeout","id":101101},{"effect":"fadeout","id":100901}],"narration":"虽然和桃子处得不错@已经能够自然地聊天了……","narrationBg":"bg_adv_21031.jpg","narrationEffect":"in"},{"narration":"但和玲奈说话时@我还是会很紧张……"},{"narration":"玲奈和迟钝的我正相反@非常果断……"},{"narration":"或许，我正因为这样@才会紧张的吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":1,"pos":0},{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":1,"pos":2}],"nameLeft":"玲奈","nameRight":"枫","narrationEffect":"out","textLeft":"给。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"mouthOpen":1}],"textRight":"——！！@呃……[chara:101101:motion_0]诶！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901}],"textLeft":"喏，抓起来了。"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":101101,"mouthOpen":1}],"se":"7226_shock","textRight":"啊！！好、好厉害！@这才抓第二次！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901}],"textLeft":"虽然为了调整位置@多使用了一次机会……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":200}],"textLeft":"不过，抓这种小东西，@两次就足够了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"好、好厉害……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":0}],"textLeft":"喏。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"诶？……[chara:101101:cheek_1]啊！@恭、[chara:101101:motion_100]恭喜你！！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100901,"motion":300}],"textLeft":"不不不……@你在恭喜什么啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":0}],"textLeft":"玲奈是说，@这个给你。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textRight":"诶？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":200}],"textRight":"这、这怎么行！这是玲奈@花钱抓起来的！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":1}],"textLeft":"聊表歉意。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textRight":"歉意？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901,"motion":0}],"textLeft":"就是先前说你@笨手笨脚的事。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"不、不用道歉啊！[chara:101101:motion_001]我本来……@就笨手笨脚。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901,"motion":1}],"textLeft":"这样就抵消了。@你不收下这个的话……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901}],"textLeft":"就说明你不肯原谅玲奈哦？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textRight":"哇！我、我收！@[chara:101101:motion_100]我会心怀感激地收下！！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":0}],"textLeft":"还有语气。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textRight":"诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901}],"textLeft":"那种总是毕恭毕敬的语气……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100901}],"textLeft":"太见外了，别这么说啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"啊……是……"},{"chara":[{"cheek":1,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":101101,"motion":400}],"se":"7226_shock","textRight":"啊！那个！@[chara:101101:motion_001]应该说，嗯？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100901,"motion":100}],"textLeft":"噗，@呵呵，[chara:100901:cheek_0]没错。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101}],"textRight":"啊……[chara:101101:motion_0]那个！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":0}],"textLeft":"嗯？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":1}],"textRight":"玲奈……你经常玩抓娃娃机吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100901,"motion":1}],"textLeft":"还好吧，@只会在有偶像周边的时候玩玩。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100901}],"textLeft":"……[chara:100901:motion_0]玲奈教你诀窍吧。"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101101,"motion":100}],"textRight":"好、好的！！@不对……嗯！！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100901}],"textLeft":"嗯，呵呵！[chara:100901:cheek_0:face_mtn_ex_010.exp.json]"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100901,"motion":1}],"textLeft":"好。@那就试试那边那个吧？"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101101,"motion":0}],"textRight":"嗯！！"},{"narration":"我相信……我和玲奈@一定能变成更好的朋友","narrationBg":"bg_adv_21171.jpg","narrationEffect":"in"},{"autoTurnFirst":4.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":0,"pos":1,"voice":"vo_char_1011_00_03","textHome":"我夹了13次都没夹到……玲奈好厉害！"}],"nameCenter":"枫","narrationEffect":"out","textCenter":"我先前抓了十三次都没抓到……@玲奈好厉害！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":100}]},{"chara":[{"id":101101}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}