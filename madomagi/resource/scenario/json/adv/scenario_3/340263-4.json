{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_20101.jpg","bgm":"bgm05_event05","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":830400,"motion":0,"pos":1,"posX":80}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":830500,"motion":0,"pos":2,"posX":40}]},{"chara":[{"id":830400}],"nameCenter":"","textCenter":"爱丽莎大人！","turnChangeOut":"fadeOut"},{"chara":[{"id":830400}],"textCenter":"面对敌人我居然试图逃跑……"},{"chara":[{"id":830500}],"textCenter":"此等失态，@我愿意接受任何惩罚！"},{"chara":[{"id":402601}],"nameLeft":"爱丽莎·瑟尔斯加","textLeft":"关于这件事……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":200}],"textLeft":"看在你们之后奋勇作战的份上@就一笔勾销吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":830500}],"nameRight":"","textRight":"但是……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0}],"textLeft":"都说不追究了。"},{"chara":[{"id":402601}],"textLeft":"虽然龙骑士团里有些胆小之人……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402601,"motion":1}],"textLeft":"但好在这也证明了……"},{"chara":[{"id":402601}],"textLeft":"骑士团里没有出现叛徒。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601}],"textLeft":"所以忘了这事，@今后继续做好本职工作吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":830400,"mouthOpen":1},{"cheek":0,"face":"mtn_ex_000.exp.json","id":830500,"mouthOpen":1}],"textBg":"shout","textCenter":"是！"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"effect":"fadeout","id":830400,"mouthOpen":0},{"effect":"fadeout","id":830500,"mouthOpen":0}],"textClear":1},{"chara":[{"id":402601},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800301,"motion":0,"pos":2}],"textLeft":"还有你……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":0}],"textLeft":"因为你的忠告……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402601}],"textLeft":"才让我们在虚假的城塞@成功对付了幽灵骑士。"},{"chara":[{"id":402601,"motion":100}],"textLeft":"我由衷地感谢你。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800301}],"textRight":"谢、谢谢您，@爱丽莎大人。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":0}],"nameRight":"佩蕾奈尔·弗拉梅尔","textRight":"没想到法国的使魔@居然渗透进了骑士团据点。"},{"chara":[{"id":831100}],"textRight":"还设下了那么高明的陷阱……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":831100}],"textRight":"爱丽莎小姐，@真亏你能发现。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":1}],"textLeft":"我只是仔细查探了……"},{"chara":[{"id":402601}],"textLeft":"丘卜提过的那种微弱魔力反应。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":0}],"textLeft":"然后我立刻就知道……"},{"chara":[{"id":402601}],"textLeft":"这里是结界的内部，@那三个人是使魔。"},{"autoTurnLast":0.01,"bg":"bg_adv_20121.jpg","chara":[{"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402601,"lipSynch":0,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":831100,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"eyeClose":1,"id":402601,"lipSynch":0}],"flashEffect":"flashWhiteSlow2","se":"7211_souljem_02","textLeft":"……@……","turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"effect":"ef_adv_01","eyeClose":0,"face":"mtn_ex_050.exp.json","id":402601,"motion":400}],"se":"7201_detect_magic","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":200}],"textLeft":"我知道了，佩蕾奈尔！@我知道这次事件的真相了。"},{"autoTurnLast":0.01,"bg":"bg_adv_20101.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":831100,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":831100}],"textRight":"原来如此……所以那个时候才……","turnChangeOut":"fadeOut"},{"chara":[{"id":810000,"pos":2,"posX":40,"posY":0}],"nameRight":"丘卜","textRight":"你说的「魔法弹」@也是骗人的吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":810000,"motion":0}],"textRight":"因为你已经知道犯人是谁，@想要一个解除结界的契机。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402601}],"textLeft":"嗯，没错。"},{"chara":[{"id":402601,"motion":1}],"textLeft":"那位侍女完全没有@要躲开枪口的意思。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402601}],"textLeft":"是位真正的忠义之士呢。"},{"chara":[{"id":810000}],"textRight":"不过……我还是有件事没搞懂。"},{"chara":[{"id":810000}],"textRight":"此次事件很大程度上@可以解释为"},{"chara":[{"id":810000}],"textRight":"骑士团被使魔的幻觉蒙骗……"},{"chara":[{"id":810000}],"textRight":"所以才会遭人肆意摆布。"},{"chara":[{"id":810000}],"textRight":"但依然不能解释@「爱丽莎被盯上的理由」。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":0}],"nameLeft":"佩蕾奈尔·弗拉梅尔","textLeft":"的确，一般来说@使魔不会针对特定的人。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100}],"textLeft":"难道是有人特地从法国派来了使魔？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":810000,"motion":0}],"textRight":"有这个可能。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0,"pos":0}],"nameLeft":"爱丽莎·瑟尔斯加","textLeft":"嗯……"},{"chara":[{"cheek":2,"id":402601,"motion":200}],"textLeft":"喂，谁让你随意加入对话的？"},{"chara":[{"id":402601,"mouthOpen":1}],"textBg":"shout","textLeft":"[chara:402601:effect_emotion_angry_1][se:7218_anger]不过就是个芝士蛋糕而已！"},{"autoTurnLast":0.8,"chara":[{"effect":"slideOutLeftFast","id":810000},{"id":402601,"mouthOpen":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":830300,"motion":0,"pos":2}],"nameRight":"","textRight":"[se:7107_arrivalone]爱丽莎大人！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402601,"motion":400,"mouthOpen":0}],"textLeft":"怎么了？"},{"chara":[{"id":830300}],"textRight":"沃尔肯斯泰因大人回来了！"},{"chara":[{"id":830300}],"textRight":"芭芭拉皇妃也与他同行。"},{"chara":[{"id":402601,"motion":0}],"textLeft":"沃尔爷爷回来了？[chara:402601:lipSynch_0][wait:1.2][chara:402601:lipSynch_1]@还跟母亲大人一起？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402601,"motion":1}],"textLeft":"知道了，@我这就过去。"},{"autoTurnLast":1.5,"bg":"bg_adv_20122.jpg","