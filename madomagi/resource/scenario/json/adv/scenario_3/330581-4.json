{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_13143.jpg","bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305801,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":305801,"lipSynch":0,"motion":300}],"nameCenter":"南津凉子","textCenter":"（久兵卫大人啊……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305801,"lipSynch":0}],"textCenter":"（我并不后悔成为魔法少女。）"},{"chara":[{"id":305801,"lipSynch":0}],"textCenter":"（但得知魔法少女会变成魔女时……）"},{"chara":[{"id":305801,"lipSynch":0}],"textCenter":"（就连我也感觉丘比故意隐瞒，@使我受到了欺骗。）"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305801,"lipSynch":0,"motion":0}],"textCenter":"……","turnEffect":"stop"},{"chara":[{"id":305801,"lipSynch":0}],"textCenter":"（或许这就是心胸宽广吧。）"},{"autoTurnLast":0.2,"chara":[{"id":305801,"pos":0}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":200,"pos":2}],"nameRight":"千春","textRight":"怎么了？@你还好吗？"},{"bgm":"bgm23_tokime02","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305801,"motion":0}],"nameLeft":"南津凉子","textLeft":"啊，嗯……@我刚才在想事情！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":2}],"nameRight":"沙绪","textRight":"你有什么……担心的事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":400}],"textLeft":"没有，没那么严重。"},{"chara":[{"id":305801}],"textLeft":"我只是觉得……"},{"chara":[{"eyeClose":1,"id":305801,"motion":1}],"textLeft":"你们还真信赖丘比啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100,"pos":2}],"nameRight":"静香","textRight":"毕竟，迄今为止@久兵卫大人都没说错过。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":1,"pos":2}],"nameRight":"沙绪","textRight":"我们只是一介魔法少女……"},{"chara":[{"id":102701}],"textRight":"久兵卫大人肯定比我们更有远见。"},{"chara":[{"cheek":0,"eyeClose":0,"id":305801,"motion":0}],"textLeft":"嗯，大概吧。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":2}],"nameRight":"静香","textRight":"迄今为止都是有久兵卫大人在，@日出之国才能得救。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"lipSynch":0}],"textLeft":"（嗯？）"},{"chara":[{"id":102501,"motion":200}],"textRight":"正是久兵卫大人让我们来神滨的。"},{"chara":[{"id":102501}],"textRight":"如果听久兵卫大人的，@拿到自动净化系统……"},{"chara":[{"id":102501}],"textRight":"我们就能为日出之国……"},{"chara":[{"cheek":0,"eyeClose":0,"id":102501,"motion":0}],"textRight":"发挥余热。"},{"chara":[{"cheek":0,"id":305801,"lipSynch":0,"motion":300}],"textLeft":"……"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"（为了……日出之国？）"},{"autoTurnLast":0.01,"turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"「你的妈妈拯救了日本」","narrationBg":"black","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"……","turnChangeOut":"fadeOut"},{"chara":[{"id":305801,"motion":100}],"textLeft":"嗯……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305801}],"textLeft":"啊，抱歉……"},{"chara":[{"id":305801,"motion":0}],"textLeft":"能让我再考虑下吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":1}],"textRight":"可以是可以……@你要考虑什么？"},{"bgm":"stop","chara":[{"id":305801}],"textLeft":"那当然是……"},{"chara":[{"id":305801,"motion":200}],"textLeft":"我要不要继续当你们的伙伴。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":305801},{"effect":"fadeout","id":102501}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"lipSynch":0,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":0,"pos":2}],"nameCenter":"众人","textCenter":"……"},{"bgm":"bgm03_story16","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":400,"mouthOpen":1},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"lipSynch":1,"motion":400,"mouthOpen":1},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":400,"mouthOpen":1}],"textBg":"shout","textCenter":"咦？！"},{"chara":[{"id":102601,"motion":200,"mouthOpen":0},{"id":102701,"mouthOpen":0},{"id":102501,"mouthOpen":0}],"nameCenter":"千春","textCenter":"事、事到如今还要考虑这个吗？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300,"mouthOpen":0}],"nameRight":"沙绪","textRight":"你要考虑一下，@也就是说……"},{"chara":[{"cheek":0,"id":102501,"motion":0,"mouthOpen":0}],"nameLeft":"静香","textLeft":"也有可能不当我们的伙伴？！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102701},{"effect":"fadeout","id":102601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0,"pos":0}],"nameRight":"沙绪","textRight":"我们说了什么让你不舒服的话吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":300,"pos":2}],"nameRight":"静香","textRight":"我们会道歉！@绝对会道歉的！"},{"chara":[{"id":305801,"motion":400}],"nameLeft":"南津凉子","textLeft":"啊，抱歉抱歉！@我不是这个意思。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305801}],"textLeft":"我不是不想和你们一起。"},{"chara":[{"id":102501,"motion":400}],"textRight":"那、那你就……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0}],"textLeft":"而是我现在配不上你们。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":2}],"nameRight":"沙绪","textRight":"为什么这么说？"},{"bgm":"bgm23_tokime01","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305801,"motion":1}],"textLeft":"其实我考虑了一下就发现……"},{"chara":[{"id":305801}],"textLeft":"你们时女一族@是因为之前的所见所闻……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0}],"textLeft":"才有了如今的这种思考方式。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":0,"pos":2}],"nameRight":"静香","textRight":"嗯……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_012.exp.json","id":305801,"motion":100}],"textLeft":"但只有我一个人……@只是因为血统才加入的，真的好吗？"},{"chara":[{"id":305801}],"textLeft":"这样对我和大家都不好吧。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":305801,"lipSynch":0,"motion":300}],"textLeft":"（感觉我和时女一族之间……）","turnEffect":"thinking"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"（有巨大的差距，@比如胸襟大小。）"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"（三言两语根本道不清……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100}],"textRight":"没想到你在顾虑这些……","turnEffect":"stop"},{"chara":[{"id":102501}],"textRight":"我知道了。@我们不会强迫你加入的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":300,"pos":2}],"nameRight":"千春","textRight":"但是……这样的话……"},{"chara":[{"id":102601}],"textRight":"是不是就不能和凉子一起战斗了？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":0}],"textLeft":"啊，你们可别误会了。"},{"chara":[{"id":305801,"motion":200}],"textLeft":"我也不是薄情寡义之人。@我会尽可能地帮助你们。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0}],"textLeft":"但就现在的我而言，@对时女实在是了解得太少。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305801}],"textLeft":"我不想以这种不上不下的状态@加入你们。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":100,"pos":2}],"nameRight":"沙绪","textRight":"那得让凉子更加地了解时女呢。"},{"chara":[{"id":305801,"motion":100}],"textLeft":"嗯，是这样的。"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":0}],"textLeft":"所以……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":200}],"textLeft":"请带我去时女村落看看吧！"},{"chara":[{"id":305801,"lipSynch":0}],"textLeft":"（如果去了那里……@我还是觉得不对劲……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"lipSynch":0,"motion":0}],"textLeft":"（我就……）"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":300,"pos":1,"voice":"vo_char_3058_00_03","textHome":"暴走した正義ほど、悪いもんはねェんだよ"}],"nameCenter":"南津凉子","textCenter":"没有比不受控的正义更深的罪孽了。","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":305801}]},{"chara":[{"id":305801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}