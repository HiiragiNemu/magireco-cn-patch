{"story":{"group_1":[{"bg":"bg_adv_21161.jpg","bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":0,"mouthOpen":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":400,"mouthOpen":1,"pos":0}],"nameLeft":"木崎衣美里","nameRight":"都雏乃","textLeft":"魔魔魔魔魔、@魔法少女已经做了五年?","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"id":300301,"motion":200,"mouthOpen":1}],"textRight":"所、[chara:300301:effect_emotion_angry_0][se:7219_strain]以、说！@不许吃惊！！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"不对不对，因为……@是吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":300,"mouthOpen":0}],"textRight":"我已经懒得冲你发火了……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":100,"mouthOpen":0}],"textLeft":"好啦好啦，我们都是魔法少女，@友好相处嘛！好吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textRight":"好随便……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"然后呢？@都……都……嘟～前辈。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textRight":"别给我取奇怪的昵称……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"mouthOpen":0}],"textLeft":"嘟～前辈，@你平时是做什么的呢？"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textRight":"不听我说话啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"mouthOpen":0}],"textRight":"平时？@平时……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textLeft":"啊，比如说，@学校啦、社团啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":100,"mouthOpen":0}],"textRight":"社团？@我是化学社的社长。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textLeft":"哎哟，社长小姐？@真是个可爱的社长呢。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":0}],"textRight":"喂，@你根本就是瞧不起我吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"不不不，@就是字面的意思啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textRight":"啊，好吧好吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"mouthOpen":0}],"textLeft":"话说回来，化学社吗，@化学啊。"},{"chara":[{"cheek":0,"id":300601,"mouthOpen":0}],"textLeft":"我还是初中生所以不明白呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textLeft":"升上高中之后，@“理科”会变成“化学”吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textRight":"说是“变成”……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"mouthOpen":0}],"textRight":"其实是理科分成了@化学啊生物啊之类的科目。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"哦——"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"mouthOpen":0}],"textLeft":"那，嘟～前辈@不就是理科女吗！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textRight":"理科……@啊？"},{"chara":[{"cheek":0,"id":300601,"motion":200,"mouthOpen":0}],"textLeft":"理科女！@学理科的女生的简称！"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textRight":"诶……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"然后呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"mouthOpen":0}],"textLeft":"作为理科女的嘟～前辈，@在化学社都做些什么呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textRight":"啊……举办面向小孩子的@化学活动……"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textRight":"就是……在小学@演示化学实验。"},{"chara":[{"cheek":0,"id":300601,"mouthOpen":0}],"textLeft":"通俗地说——"},{"chara":[{"cheek":0,"id":300601,"motion":100,"mouthOpen":0}],"textLeft":"就像@米(哗——)传(哗——)郎老师那样吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":0}],"textRight":"居然自己消音吗！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textLeft":"嘿——[chara:300601:effect_emotion_joy_0][se:7222_happy]似乎很有趣！似乎很有趣！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"mouthOpen":0}],"textLeft":"啊啊！我也想@举办开心的活动！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":100,"mouthOpen":0}],"textLeft":"对了！@让我当你的助手吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300301,"motion":0,"mouthOpen":0}],"textRight":"啊！？@为什么啊！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":1,"mouthOpen":0}],"textRight":"而且@你对化学没什么兴趣吧……！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"嗯——复杂的事情@我是不太明白啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":100,"mouthOpen":0}],"textLeft":"不过，现场实验活动@让人感觉心跳不已啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"mouthOpen":0}],"textLeft":"我很喜欢@这种让人心跳的事情哦。"},{"chara":[{"cheek":0,"id":300301,"motion":0,"mouthOpen":0}],"textRight":"什么“心跳不已”……"},{"chara":[{"cheek":0,"id":300601,"motion":0,"mouthOpen":0}],"textLeft":"而且，我……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textLeft":"很中意嘟～前辈嘛！"},{"chara":[{"cheek":0,"id":300601,"motion":100,"mouthOpen":0}],"textLeft":"哇啊！[chara:300601:effect_emotion_joy_0][se:7222_happy]中意认证！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":0}],"textRight":"不需要！什么鬼认证！"},{"chara":[{"cheek":0,"id":300301,"mouthOpen":0}],"textRight":"总而言之！"},{"chara":[{"cheek":0,"id":300301,"motion":0,"mouthOpen":0}],"textRight":"不管你是觉得有趣@还是什么心跳……"},{"chara":[{"cheek":0,"id":300301,"motion":200,"mouthOpen":0}],"textRight":"化学总是伴随着危险！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"mouthOpen":0}],"textRight":"像你这种粗枝大叶的人，@我怎么会让你做我的助手……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textLeft":"有什么关系嘛——！@别这么不讲人情嘛～"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300301,"motion":400,"mouthOpen":1}],"textRight":"唔哇！好难受……！"},{"chara":[{"id":300301,"mouthOpen":0}],"textRight":"笨蛋，别抱住我……！@呃……！"},{"chara":[{"cheek":0,"id":300601,"motion":0,"mouthOpen":0}],"textLeft":"嘟～前辈，@既娇小又可爱。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"mouthOpen":0}],"textLeft":"让人忍不住想抱紧你嘛！"},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":300301,"motion":200,"mouthOpen":1}],"textRight":"够——了，@放开我！！"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300301,"motion":1,"pos":1,"voice":"vo_char_3003_00_03","textHome":"并不是我的威严不够，是那家伙太狂妄了！"}],"nameCenter":"都雏乃","textCenter":"不是我不够威严。@是那家伙太狂妄了！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"id":300301,"motion":200}]},{"chara":[{"id":300301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}