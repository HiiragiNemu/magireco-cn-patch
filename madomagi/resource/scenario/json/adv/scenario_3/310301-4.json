{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21111.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1,"pos":0}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.5,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":0,"pos":2}],"textClear":1},{"chara":[{"id":103001,"motion":200}],"nameRight":"育梦","textRight":"真里爱！@对不起，让你久等了……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":100}],"nameLeft":"由贵真里爱","textLeft":"没关系，@毕竟是我叫你出来的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1}],"textLeft":"来，坐吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103001,"motion":0}],"textRight":"是的。"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":103001,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303601,"lipSynch":0}],"textLeft":"……","turnChangeOut":"fadeOut"},{"chara":[{"id":103001,"motion":300}],"textRight":"请问，有什么事吗？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303601,"motion":300}],"textLeft":"育梦，@你有好好吃饭吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":400}],"textRight":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":0}],"textLeft":"我看你脸色很不好……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103001,"lipSynch":0,"motion":300}],"textRight":"……"},{"chara":[{"eyeClose":1,"id":303601,"lipSynch":0}],"textLeft":"……"},{"chara":[{"eyeClose":0,"id":303601,"motion":200}],"textLeft":"有很多曾在玛吉斯之翼的女孩……@是叫前羽翼来着？"},{"chara":[{"id":303601}],"textLeft":"她们去找雏乃、八千代和十七夜了吧？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":0}],"textRight":"是的，是叫前羽翼……"},{"chara":[{"id":303601,"motion":1}],"textLeft":"她们跟一些没经验的女孩@好像是去咨询的。"},{"chara":[{"eyeClose":1,"id":303601}],"textLeft":"好像很烦恼今后该怎么办……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103001,"lipSynch":0,"motion":300}],"textRight":"（和我一样……）","turnEffect":"thinking"},{"chara":[{"id":103001,"lipSynch":0}],"textRight":"（但如果去咨询，@说不定会被拉拢……）"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303601}],"textLeft":"这说不定是我多管闲事……","turnEffect":"stop"},{"chara":[{"id":303601}],"textLeft":"但我听说你也曾在玛吉斯之翼……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":300}],"textLeft":"所以有点担心你，@就想亲自跟你见一面。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":1}],"textRight":"真里爱……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1}],"textLeft":"如果……你有什么想倾诉的，@能说给我听听吗？"},{"chara":[{"id":303601}],"textLeft":"我不能替你做决定……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":200}],"textLeft":"但这样一说，总比你独自烦恼@要来得轻松吧。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":103001,"lipSynch":0,"motion":300}],"textRight":"……"},{"chara":[{"eyeClose":1,"id":103001,"lipSynch":0}],"textRight":"……@……"},{"chara":[{"cheek":0,"eyeClose":0,"id":103001,"motion":0}],"textRight":"神滨魔法联盟邀请我加入了。"},{"chara":[{"id":103001}],"textRight":"我觉得她们关于解放的想法还不错……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103001,"motion":100}],"textRight":"但是……唔……我总觉得……@有些地方我还是不太赞成……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1}],"textLeft":"嗯。"},{"chara":[{"id":103001,"motion":1}],"textRight":"而且，时雨……@我的朋友也邀请了我……"},{"chara":[{"id":103001,"motion":1}],"textRight":"但是，她的提议有点……"},{"chara":[{"id":103001}],"textRight":"也不是说……"},{"chara":[{"id":103001}],"textRight":"玛吉斯不可原谅……但是……"},{"chara":[{"eyeClose":1,"id":103001}],"textRight":"就是……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":200}],"textLeft":"心里总觉得“不情愿”？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":0}],"textRight":"啊……是的。"},{"chara":[{"id":103001}],"textRight":"我有时会这么想……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103001,"motion":200}],"textRight":"但是……我也明白……@时雨的意思……"},{"chara":[{"eyeClose":1,"id":103001,"lipSynch":0}],"textRight":"……[wait:1][chara:103001:lipSynch_1]所以……"},{"chara":[{"eyeClose":1,"id":103001,"lipSynch":0,"motion":300}],"textRight":"……"},{"chara":[{"eyeClose":0,"id":103001}],"textRight":"总是……想到这里就不知道@该如何是好了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":1}],"textLeft":"一切都不尽如人意，对吧……"},{"chara":[{"id":103001,"motion":1}],"textRight":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601}],"textLeft":"所以，你不知道该怎么做决定了？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":0}],"textRight":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601}],"textLeft":"神滨魔法联盟的邀请，@还有朋友的邀请……"},{"chara":[{"id":303601}],"textLeft":"它们各有利弊……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":0}],"textLeft":"相较之下，不知道该选哪边才好。@对不对？"},{"chara":[{"id":103001,"motion":300}],"textRight":"你这么一说，或许确实是这样……"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":103001,"motion":0}],"textRight":"但是……[chara:103001:lipSynch_0][wait:1.2][chara:103001:lipSynch_1]@我还是不知道该怎么办……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":300}],"textLeft":"唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":200}],"textLeft":"如果自己找不到答案，@参考下其他人的做法或许不错。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":300}],"textRight":"其他人？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":300}],"textLeft":"嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601}],"textLeft":"比如你可以问问她们@“你们是怎么决定的？”"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103001,"motion":400}],"textRight":"啊！@或许可以……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103001,"motion":1},{"id":303601,"motion":1}],"textRight":"顺带一提，@真里爱是怎么决定的？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103001}],"textRight":"你加入了神滨魔法联盟了对吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601}],"textLeft":"嗯。"},{"chara":[{"id":303601}],"textLeft":"但我也没什么特殊的理由，@只是没理由拒绝罢了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103001,"motion":100}],"textRight":"咦！@只是这样？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601}],"textLeft":"一方面方便魔法少女活动……"},{"chara":[{"id":303601}],"textLeft":"另外她们要推广净化装置，@创造一个没有魔女的世界……"},{"chara":[{"id":303601,"motion":200}],"textLeft":"对吧？@我觉得这个想法也不错。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601}],"textLeft":"我不想变成魔女，@也不希望大家变成魔女。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103001,"motion":200}],"textRight":"我没办法跟你选择一样的做法……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303601,"motion":300}],"textLeft":"是啊……"},{"chara":[{"eyeClose":0,"id":303601}],"textLeft":"说我是随波逐流也确实没错，@这没什么参考价值呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":103001,"motion":400}],"textRight":"我、我不是这个意思……"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103001,"motion":0}],"textRight":"我只是……@没有你那么坚强……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103001,"lipSynch":0,"motion":300}],"textRight":"（一时头脑发热做了决定，@肯定不会有什么好结果……）","turnEffect":"thinking"},{"chara":[{"id":103001,"lipSynch":0}],"textRight":"（就像我成为魔法少女时那样……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303601,"motion":1},{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103001}],"textLeft":"别那么说。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601}],"textLeft":"育梦你啊……"},{"chara":[{"id":303601,"motion":200}],"textLeft":"有很多优点的。"},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":103001,"motion":1}],"textRight":"咦？@是吗？"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":303601,"motion":1}],"se":"7222_happy","textClear":1},{"autoTurnLast":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":103001,"motion":0}],"textClear":1},{"chara":[{"id":303601,"motion":300}],"textLeft":"好了，我们快吃吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":1}],"textLeft":"东西是有些凉了，@但饿着肚子可打不起精神。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103001,"motion":100}],"textRight":"好的！"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103001,"motion":200,"pos":1,"voice":"vo_char_1030_00_03","textHome":"为什么……我是这个样子呢。总是会陷入迷惘@……"}],"nameCenter":"育梦","textCenter":"我为什么……一直是这样呢。@总是犹豫不决……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103001}]},{"chara":[{"id":103001}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}