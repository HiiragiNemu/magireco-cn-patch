{"story":{"group_1":[{"bg":"bg_adv_13051.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":0,"mouthOpen":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"pos":2}],"nameLeft":"常盘七香","textLeft":"要说……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"id":300501,"mouthOpen":0}],"textLeft":"这个。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101301,"mouthOpen":0}],"nameRight":"龙城明日香","textRight":"诶，宣传单？"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300401,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"我看看……"},{"chara":[{"cheek":0,"id":300401,"motion":200,"mouthOpen":0}],"textRight":"＜华心流插花展＞？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300501,"motion":1,"mouthOpen":0}],"textLeft":"没错！@这是我们华心流的作品展！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"mouthOpen":0}],"textLeft":"我是希望找到能更多人去观看，@所以才叫住了你……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"菲莉希亚","textRight":"嗯……这个……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"mouthOpen":0}],"textRight":"不是说提到过魔女之类的事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":100,"mouthOpen":0}],"textLeft":"我是说偶尔也要忘记魔女的事，@放松一下～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300401,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"那神滨呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300501,"motion":1,"mouthOpen":0}],"textLeft":"这是我来神滨后@第一次办活动！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"龙城明日香","textRight":"那魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"mouthOpen":0}],"textLeft":"我是想请你们也去跟@其他魔法少女宣传一下……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501,"motion":400,"mouthOpen":0}],"textLeft":"哎呀，糟糕，@说起来我还真给忘了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":0,"mouthOpen":0}],"textLeft":"我本来是想把这个宣传单@邮寄给明日香的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300501,"motion":300,"mouthOpen":0}],"textLeft":"结果放在包里就给忘了！@抱歉，麻烦各位跑一趟……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101301,"motion":100,"mouthOpen":0}],"textRight":"不、不是！@所以，你要说的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"mouthOpen":0}],"textRight":"就是……这些吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300501,"motion":0,"mouthOpen":0}],"textLeft":"对，就这些。@不方便的话，也不用勉强……"},{"chara":[{"cheek":0,"id":101301,"motion":300,"mouthOpen":0}],"textRight":"啊，不会！@怎么会勉强呢……哈哈哈……[chara:101301:mouthOpen_1]"},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":300401,"lipSynch":0,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"美凪纱纱罗","textRight":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100501,"motion":200,"mouthOpen":0,"pos":2}],"nameRight":"菲莉希亚","textRight":"哇！@这叫什么事啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"mouthOpen":0}],"textRight":"就连重要情报这件事@都是臆想吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"龙城明日香","textRight":"是……是啊……@看来是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300501,"motion":100,"mouthOpen":0}],"textLeft":"怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":300401,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"美凪纱纱罗","textLeft":"反正她肯定会说……"},{"chara":[{"cheek":0,"id":101301,"lipSynch":0,"mouthOpen":0}],"nameRight":"龙城明日香","textRight":"…………"},{"chara":[{"cheek":2,"id":101301,"lipSynch":1,"motion":100,"mouthOpen":1,"tear":1}],"textRight":"我、我自杀谢罪！"},{"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101301,"motion":0,"mouthOpen":0,"pos":1}],"nameCenter":"龙城明日香","textCenter":"之后，一行人去参加了插花展……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"id":101301,"motion":300,"mouthOpen":0}],"textCe