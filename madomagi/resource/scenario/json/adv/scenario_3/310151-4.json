{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21203.jpg","bgm":"bgm05_event05","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101501,"lipSynch":0}],"nameCenter":"忧","textCenter":"…………","turnChangeOut":"fadeOut"},{"autoTurnLast":0.5,"item":[{"path":"resource/scenario/img/31015_ui_story/memoria_1338.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"升学意向调查表@（1）想去的学校@（2）想做的职业@（3）选择的理由","narrationBg":"","narrationEffect":"in","turnChangeOut":"fadeOut"},{"nameNarration":"忧","narration":"我在学校里的朋友@都说还没有决定……"},{"narration":"但灯花和音梦@都已经找到想做的事了"},{"narration":"理子@也以继承家业为目标"},{"narration":"月咲的未来@也差不多有方向了……"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0,"pos":1}],"item":[{"path":"resource/scenario/img/31015_ui_story/memoria_1338.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":101501,"motion":300}],"nameCenter":"忧","textCenter":"她们都有特长，","turnChangeOut":"fadeOut"},{"chara":[{"id":101501}],"textCenter":"或是有对自己而言@意义非凡的事物……"},{"chara":[{"eyeClose":1,"id":101501,"lipSynch":0}],"textCenter":"（我……）","turnEffect":"thinking"},{"chara":[{"id":101501,"lipSynch":0}],"textCenter":"（我却什么都没有，@这样真的好吗……）"},{"autoTurnLast":0.2,"bgm":"stop","chara":[{"effect":"fadeout","id":101501}],"textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201,"motion":0,"pos":0}],"nameLeft":"八千代","nameRight":"彩羽","textRight":"忧？"},{"chara":[{"id":100201,"motion":301}],"textLeft":"你有什么烦心事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0,"pos":0}],"nameLeft":"忧","textLeft":"姐姐……八千代……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":100}],"textRight":"有烦恼可以跟我倾诉哦？"},{"chara":[{"eyeClose":1,"id":101501,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"eyeClose":0,"id":101501,"motion":100}],"textLeft":"是这样的……"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":100101,"motion":200}],"nameLeft":"忧","nameRight":"彩羽","textRight":"原来如此，升学志愿啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101}],"textRight":"我的意见也跟月咲她们一样，@你不用太着急。"},{"chara":[{"id":101501}],"textLeft":"我不用着急吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201,"motion":300,"pos":2}],"nameRight":"八千代","textRight":"没错。"},{"chara":[{"eyeClose":1,"id":100201}],"textRight":"你看鹤乃虽想重振家业，@但这应该挺困难的。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100201}],"textRight":"菲莉希亚的话……@她应该根本就不会考虑这种问题吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100201,"motion":0}],"textRight":"不过我也没有资格去说别人就是了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101501,"motion":100}],"textLeft":"八千代也在烦恼吗？"},{"chara":[{"id":100201,"motion":200}],"textRight":"我到底是要继续当模特，"},{"chara":[{"id":100201}],"textRight":"还是要放弃当模特去找工作呢？"},{"chara":[{"id":100201}],"textRight":"我觉得现在是时候该好好想想了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100201,"motion":100}],"textRight":"但你还只是个小学生，"},{"chara":[{"id":100201}],"textRight":"有些事等你再大一点，@自然会想明白的。"},{"chara":[{"id":100201,"motion":301}],"textRight":"思考的过程才是最重要的，@你没必要着急。"},{"chara":[{"id":101501,"motion":300}],"textLeft":"嗯……"},{"autoTurnLast":0.2,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":100501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100401,"motion":1,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":100501,"lipSynch":0}],"nameLeft":"菲莉希亚","nameRight":"莎奈","textLeft":"…………","turnChangeOut":"rollOutFast"},{"chara":[{"id"