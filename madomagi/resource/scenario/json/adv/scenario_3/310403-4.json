{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21082.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp.json","id":104001,"motion":1,"pos":0,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameRight":"","textRight":"这是夜鹤小姐的赔偿金。","turnChangeOut":"fadeOut"},{"chara":[{"id":104001,"lipSynch":0}],"nameLeft":"夜鹤","textLeft":"……"},{"chara":[{"id":104001,"motion":100}],"textLeft":"居然有这么多……"},{"textRight":"是的，因为你母亲签署了@意外死亡保险……"},{"textRight":"所以在她因事故去世时，@你可以获得更多的赔偿金。"},{"textRight":"她肯定是为自己的独生女着想@才这么做的吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700}],"textRight":"真是一位好母亲啊……"},{"chara":[{"eyeClose":1,"id":104001,"lipSynch":0}],"textLeft":"……"},{"textRight":"那我就先告辞了。"},{"chara":[{"eyeClose":0,"id":104001,"motion":1}],"textLeft":"谢谢您……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800700}],"textClear":1},{"chara":[{"id":104001,"motion":0,"pos":1}],"nameCenter":"夜鹤","textCenter":"还要整理妈妈的遗物……"},{"chara":[{"id":104001}],"textCenter":"下周就要搬到伯父家里去住了……","turnEffect":"stop"},{"chara":[{"id":104001,"motion":300}],"textCenter":"这件衣服看起来还不错，@不知道能不能卖掉……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104001}],"textCenter":"我记得这是在钢琴演奏会上穿的……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104001,"motion":0}],"textCenter":"还是之后再做决定吧……"},{"chara":[{"id":104001,"motion":1}],"textCenter":"嗯？这是……"},{"bgm":"stop","textCenter":"日记？母子手册？"},{"bgm":"bgm03_story12","nameNarration":"","narration":"〇月×日@今天宝宝踢了我肚子好多下@是想要快点出来吗@再等等吧，我一定会好好疼爱你的","narrationEffect":"in","narrationHAlignment":"left","narrationPosX":100.0},{"narration":"〇月×日@医生说你是脚朝下的横产儿@你是想早点出来走走吧@别担心，只要我做体操就能@纠正你的位置@妈妈一定会加油的"},{"narration":"〇月×日@初次见面，小宝宝！@我想让你得到更多的爱@就给你取了夜鹤这个象征母爱的名字@这个世界上到处都充满了爱哦"},{"narration":"〇月×日@不好了！今天夜鹤竟然……翻了个身！！@你会动了之后也给妈妈添了不少麻烦啊@没关系，你就尽情地让我困扰吧"},{"autoTurnLast":0.2,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"夜鹤","narration":"我被这本第一次看见的@母子手册给深深吸引了","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"这上面写着在我懂事之前@妈妈和我之间发生的事"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104001,"motion":1,"pos":1,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"〇月×日@今天夜鹤弄哭了托儿所的小朋友……@夜鹤才1岁大，上托儿所早了些@都是妈妈不好@明天一起去道歉吧","narrationEffect":"in","narrationHAlignment":"left","narrationPosX":100.0,"turnChangeOut":"fadeOut"},{"narration":"〇月×日@托儿所的人今天又让我过去了@要是我再用心照顾一下夜鹤就好了@夜鹤没有错，都是妈妈太笨了"},{"autoTurnLast":0.2,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"夜鹤","narration":"从这本母子手册上看……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"我小时候似乎有点调皮@或者说是有点暴躁"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104001,"motion":1,"pos":1,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"〇月×日@我辞职了，这样夜鹤就不用去托儿所了@爸爸会赚更多的钱来补贴家用@所以你不用担心，我们一直都在一起","narrationEffect":"in","narrationHAlignment":"left","narrationPosX":100.0,"turnChangeOut":"fadeOut"},{"narration":"〇月×日@爸爸说他很累了@但是别担心，他会打钱过来的@妈妈也很不安，但妈妈会加油的@所以我不会让你因单亲家庭受委屈"},{"narration":"我会让你和其他孩子一样@过上正常的生活"},{"chara":[{"id":104001,"lipSynch":0}],"narrationEffect":"out","textCenter":"……"},{"chara":[{"eyeClose":0,"id":104001,"motion":0}],"textCenter":"原来是这样啊……"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"夜鹤","narration":"在我长大之后……@妈妈她还在写日记","turnChangeOut":"fadeOut"},{"narration":"这本日记上写满了她对我未来的担忧@以及对自己因过度焦躁而突然@变严厉这件事的忏悔"},{"narration":"最后一页里夹着那张我画给她的肖像画@就是那天被她撕碎的画"},{"narration":"她仔细地贴好了撕破的地方@也在一旁写下了感谢的话语@还笨拙地画了我的肖像画"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104001,"motion":0,"pos":1,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"eyeClose":1,"id":104001,"motion":100}],"textCenter":"对不起……妈妈……","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"夜鹤","narration":"这都怪我","turnChangeOut":"fadeOut"},{"narration":"妈妈包容了我的暴躁脾气@还努力让身边人不歧视我@离了婚也要让我过上「正常」生活……"},{"narration":"可我身在福中不知福……"},{"narration":"可我并没有完全原谅妈妈"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104001,"motion":0,"pos":1,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":104001,"lipSynch":0}],"textCenter":"（妈妈……你真是太愚蠢了……）","turnChangeOut":"fadeOut"},{"chara":[{"id":104001,"lipSynch":0,"motion":1}],"textCenter":"（真是个不合格的母亲啊……）"},{"chara":[{"eyeClose":1,"id":104001,"lipSynch":0}],"textCenter":"（但是为什么……）"},{"chara":[{"cheek":0,"id":104001,"lipSynch":0}],"textCenter":"（我好想见她……）"},{"chara":[{"eyeClose":0,"id":104001,"lipSynch":0,"motion":100}],"textCenter":"（我想和她道歉，再感谢她，@并好好夸奖她一番。）"},{"chara":[{"cheek":1,"id":104001,"lipSynch":0,"tear":1}],"textCenter":"（真的不能再见面了吗……）"},{"bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":104001,"lipSynch":0,"tear":1}],"textCenter":"（不，还能再见！）"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story09","narration":"我灵机一动@想到了一个绝妙的方法","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104001,"motion":0,"pos":1,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":104001,"motion":200}],"textCenter":"只要我死了就行了！","turnChangeOut":"fadeOut"},{"textCenter":"因为一开始就是我的错啊！"},{"chara":[{"id":104001,"motion":100}],"textCenter":"妈妈已经死了……@我这个罪魁祸首……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":104001}],"textCenter":"又有什么资格活着呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104001,"motion":300}],"textCenter":"而且死了就会下地狱，@我就能见到妈妈了！"},{"textCenter":"还能跟她道歉。"},{"chara":[{"eyeClose":1,"id":104001,"motion":100}],"textCenter":"只要我死了就能赎罪！就能一了百了！"},{"chara":[{"eye