{"story":{"group_1":[{"bg":"bg_adv_19221.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101,"motion":0,"pos":2}],"nameLeft":"胡桃爱香","nameRight":"和美","textLeft":"[chara:300902:effect_emotion_surprise_0][se:7226_shock]工、工作！？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902}],"textLeft":"不，@就算你突然说要工作……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101,"motion":200}],"textRight":"吃饭的钱，我会通过劳动还给你！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101}],"textRight":"洗盘子、打扫，@我什么都可以做！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":0}],"textLeft":"你不用去找你的朋友了吗……？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401101,"motion":0}],"textRight":"这个虽然也很重要……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101}],"textRight":"可是！[chara:401101:lipSynch_0][wait:0.8][chara:401101:motion_1][chara:401101:cheek_0][chara:401101:face_mtn_ex_030.exp.json][chara:401101:lipSynch_1]就这么离开，@我会过意不去的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101}],"textRight":"洗盘子也好，我什么都愿意做！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101,"motion":100}],"textRight":"我不会碍手碍脚的……@好吗！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101,"motion":0}],"textRight":"钱我之后也会付的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300}],"textLeft":"唔～"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":0}],"textLeft":"（说起来，父亲之前说过……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":0}],"textLeft":"（曾经让穷学生洗盘子@来抵押饭钱）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":1}],"textLeft":"那～@就有劳你啦？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902}],"textLeft":"我也不另收你饭钱了！"},{"chara":[{"cheek":0,"face":