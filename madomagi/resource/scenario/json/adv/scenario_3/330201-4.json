{"story":{"group_1":[{"bg":"bg_adv_19061.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302001,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301601,"motion":0,"pos":2}],"nameLeft":"真尾日美香","nameRight":"粟根心","textBg":"shout","textLeft":"我们来啦！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":302001},{"effect":"fadeout","id":301601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801200,"motion":0,"mouthOpen":1,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801300,"motion":0,"mouthOpen":1,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801,"lipSynch":0,"motion":1,"pos":1}],"nameCenter":"日美香的弟弟妹妹","textBg":"shout","textCenter":"我们来啦！"},{"chara":[{"id":302801,"motion":100}],"nameCenter":"三栗菖蒲","textBg":"shout","textCenter":"到山上啦！！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":801200},{"effect":"fadeout","id":801300},{"effect":"fadeout","id":302801}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302001,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":301601,"motion":0,"pos":2}],"textLeft":"各位！@如果有不明白的地方……"},{"chara":[{"id":302001}],"textLeft":"就向山的专家——@心老师请教哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301601}],"textRight":"没有啦……爬山只是我的爱好，@称不上专家……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":302001},{"effect":"fadeout","id":301601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801200,"motion":0,"mouthOpen":1,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801300,"motion":0,"mouthOpen":1,"pos":0}],"nameCenter":"日美香的弟弟妹妹","textBg":"shout","textCenter":"哇！！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801,"motion":200,"pos":2}],"nameLeft":"粟根心","nameRight":"三栗菖蒲","textRight":"麻烦你了！@心老师！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":0,"pos":0}],"textLeft":"诶……@[chara:301601:lipSynch_0][wait:0.8][chara:301601:cheek_0][chara:301601:face_mtn_ex_030.exp.json][chara:301601:lipSynch_1]嗯……也行吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301601,"motion":100}],"textLeft":"菖蒲你想要什么样的花？"},{"chara":[{"id":302801}],"textRight":"要蓝色的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302801,"motion":0}],"textRight":"就算不是绘本里的梦幻蓝色花，@菖蒲也想送蓝色的花。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301601}],"textLeft":"蓝色的啊……@好像挺难找的呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302801,"motion":400}],"textRight":"诶……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":0}],"textLeft":"啊，不！@只是我没有见到过而已……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801,"motion":0}],"textRight":"嗯，@一定有的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302001,"motion":100,"pos":0}],"nameLeft":"真尾日美香","textLeft":"各位！如果看到了蓝色的花，@就告诉菖蒲哦。"},{"chara":[{"id":302801,"motion":100}],"textRight":"一定要说哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801200,"motion":0,"pos":0}],"nameLeft":"日美香的妹妹","textLeft":"好——！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801300,"motion":0,"pos":0}],"nameLeft":"日美香的弟弟","textLeft":"真没办法。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801300,"motion":0}],"textLeft":"菖蒲实在靠不住，@我找到了会告诉你的。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302801,"motion":200}],"textRight":"你说什么！@嚣张的家伙……看招！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801}],"textRight":"[bgEffect:shakeLarge]咯吱咯吱咯吱！！"},{"chara":[{"id":801300}],"textLeft":"[bgEffect:shakeLarge]哇哈哈哈哈！@你竟敢！看我的！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302801,"motion":400}],"textRight":"[bgEffect:shakeLarge]哇哇！啊哈哈哈！@[chara:302801:lipSynch_0][wait:0.8][chara:302801:cheek_0][chara:302801:face_mtn_ex_011.exp.json][chara:302801:lipSynch_1]唔～看招！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801200,"motion":0,"pos":2}],"nameRight":"日美香的妹妹","textRight":"很好玩的样子！@我也加入！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302001,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":301601,"motion":0,"pos":2}],"nameLeft":"真尾日美香","textLeft":"啊——真是的！@要适可而止哦！"},{"chara":[{"id":301601}],"nameRight":"粟根心","textRight":"呵呵。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301601}],"textRight":"一家人……@果然和睦是最重要的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302001,"motion":0}],"textLeft":"对。"},{"chara":[{"id":302001}],"textLeft":"那一天的我……根本不敢奢望@我们一家还能有现在这样的日子。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301601,"motion":100}],"textRight":"那一天……@是我们认识那天？"},{"chara":[{"id":302001}],"textLeft":"对。"},{"chara":[{"eyeClose":1,"id":302001}],"textLeft":"当时也是……"},{"chara":[{"id":302001}],"textLeft":"“能治愈一切疾病的梦幻蓝色花”@是一切的导火索……"},{"autoTurnFirst":3.6,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302001,"motion":100,"pos":1,"voice":"vo_char_3020_00_03","textHome":"我的家人比什么都重要！"}],"nameCenter":"真尾日美香","textCenter":"果然在我心里，@只有家人是最重要的！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302001}]},{"chara":[{"id":302001}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}