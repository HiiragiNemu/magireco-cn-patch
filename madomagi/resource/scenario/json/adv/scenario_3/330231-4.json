{"story":{"group_1":[{"bg":"bg_adv_21221.jpg","bgm":"bgm01_anime03","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302301,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":1,"pos":2}],"nameLeft":"江利爱实","nameRight":"空穗夏希","textLeft":"[chara:302301:effect_emotion_joy_0][se:7222_happy]锵！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302301}],"textLeft":"这里就是@我推荐的咖啡店！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300201,"motion":100,"mouthOpen":1}],"textRight":"哦、哦哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302301,"motion":1}],"textLeft":"你不常来咖啡店吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0}],"textRight":"嗯，@我没怎么来过"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300201}],"textRight":"氛围很不错呢"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302301,"motion":100}],"textLeft":"对吧！这里气氛就是好！@[chara:302301:lipSynch_0][wait:0.8][chara:302301:cheek_2][chara:302301:face_mtn_ex_011.exp.json][chara:302301:lipSynch_1][chara:302301:effect_emotion_joy_0][se:7222_happy]能在这里约会就好了……"},{"nameNarration":"江利爱实","narration":"和隼人在咖啡店里约会……","narrationBg":"white","narrationEffect":"in"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":302301,"lipSynch":0}],"narrationEffect":"out","textLeft":"[chara:302301:effect_emotion_surprise_0][se:7226_shock]（呃，不行不行！@现在不是妄想的时候）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":301}],"textRight":"爱实？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":302301,"motion":1}],"textLeft":"抱歉抱歉！@没什么！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":302301}],"textLeft":"对、对了！@[chara:302301:lipSynch_0][wait:0.8][chara:302301:cheek_0][chara:302301:face_mtn_ex_010.exp.json][chara:302301:lipSynch_1]我们来决定点些什么吧"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":0}],"textRight":"嗯、嗯@[chara:300201:lipSynch_0][wait:0.8][chara:300201:cheek_0