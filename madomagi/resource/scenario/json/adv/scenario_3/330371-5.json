{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_46000.jpg","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.5,"bg":"bg_adv_12021.jpg","bgChangeEffect":"exitWitchSpace","bgm":"stop","se":"7209_gate_close"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303700,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"梅露","textCenter":"…………"},{"autoTurnLast":0.1,"textClear":1},{"bgm":"bgm03_story03","chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_030.exp.json","id":303701,"lipSynch":1,"motion":300,"mouthOpen":1,"pos":1}],"se":"7205_magic_girl","textCenter":"呼……"},{"autoTurnLast":0.01,"chara":[{"id":303701,"mouthOpen":0,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100,"pos":0}],"nameLeft":"八千代","textLeft":"你好像松了一口气呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303701,"motion":400}],"nameRight":"梅露","textRight":"咦、咦？这是哪儿！？"},{"autoTurnLast":0.1,"textClear":1},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_011.exp.json","id":100204,"motion":1,"pos":0}],"se":"7205_magic_girl","textLeft":"是水名区。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303701,"lipSynch":0,"motion":1}],"textRight":"（水名区……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303701,"lipSynch":0}],"textRight":"（我拼命逃离车子的追赶，@完全没看路。）"},{"chara":[{"id":303701,"lipSynch":0}],"textRight":"（原来我跑到这么远的地方来了……）"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":200}],"textLeft":"你是大东区的魔法少女吗？","turnEffect":"stop"},{"chara":[{"id":303701,"lipSynch":1}],"textRight":"是的……[chara:303701:lipSynch_0][wait:0.8][chara:303701:cheek_0][chara:303701:motion_400][chara:303701:face_mtn_ex_050.exp.json][chara:303701:lipSynch_1][chara:303701:effect_emotion_surprise_0][se:7226_shock]啊！"},{"autoTurnLast":0.2,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101601,"motion":200}],"nameCenter":"十七夜","textCenter":"中央区的西面不是我们的领土，","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":101601}],"textCenter":"千万别和西面的魔法少女接触。"},{"autoTurnLast":0.5,"bg":"bg_adv_12021.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":303701,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":303701,"lipSynch":0,"motion":300}],"nameRight":"梅露","textRight":"（怎么办……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":303701,"lipSynch":0}],"textRight":"（我没听十七夜的叮嘱……）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":300}],"textLeft":"一大早就碰上这种事，你也很辛苦呢……","turnEffect":"stop"},{"chara":[{"id":100204}],"textLeft":"最近东西两边的魔女都变少了，@大家的魔力都得不到补充。"},{"chara":[{"id":100204,"motion":0}],"textLeft":"所以一旦到了危急关头，@会有很多人陷入苦战。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100204,"motion":100}],"textLeft":"还好你没事。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303701,"lipSynch":1,"motion":1}],"textRight":"谢、谢谢你的关心……"},{"chara":[{"id":303701,"lipSynch":0}],"textRight":"（我听十七夜说西面的事时，）","turnEffect":"thinking"},{"chara":[{"id":303701,"lipSynch":0}],"textRight":"（还以为西面的人@对我们很苛刻……）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701,"lipSynch":0,"motion":100}],"textRight":"（不过还是有亲切的人在嘛！）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":301}],"textLeft":"话说回来……","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204}],"textLeft":"你大老远的跑到这里来，@是发生什么事了？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303701,"lipSynch":1,"motion":0}],"textRight":"这、这是因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303701,"motion":400}],"textRight":"唔……我喜欢占卜……所以在做占卜！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":0}],"textLeft":"诶？"},{"chara":[{"id":303701,"motion":100}],"textRight":"我的占卜结果绝对能应验！"},{"chara":[{"id":100204,"motion":1}],"textLeft":"是、是吗？"},{"chara":[{"id":303701}],"textRight":"我今天的占卜结果运势特别差，@有生命危险！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303701}],"textRight":"所以我原本打算窝在家里不出门，"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303701,"motion":400}],"textRight":"可十七夜偏把我强行带到外面来了！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":200}],"textLeft":"十七夜带你出来了？"},{"chara":[{"id":303701,"motion":1}],"textRight":"十七夜完全不相信我的占卜……"},{"chara":[{"id":303701}],"textRight":"我再也不想搭理她这种@完全不理解占卜的人了！"},{"bgm":"stop","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303701}],"nameNarration":"","narration":"[bgEffect:shakeSmall][chara:303701:effect_shake]……咚！","narrationEffect":"in"},{"bgm":"bgm03_story08","chara":[{"cheek":1,"eyeClose":0,"id":303701,"motion":300,"tear":1}],"narrationEffect":"out","textRight":"呜……好、好疼……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":301}],"textLeft":"从天上掉下了铁桶？"},{"chara":[{"id":303701,"tear":1}],"textRight":"呜、呜……@为什么……麻烦总找上我……"},{"chara":[{"eyeClose":1,"id":303701,"motion":1,"tear":1}],"textRight":"我想要回家……"},{"chara":[{"eyeClose":0,"id":303701,"tear":1}],"textRight":"可这里离家很远……@要是又出了什么事……"},{"chara":[{"id":303701,"motion":300,"tear":1}],"textRight":"我……我说不定真的，@就没法活着回去了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":300}],"textLeft":"嗯，我想想……"},{"chara":[{"id":100204,"motion":0}],"textLeft":"只要回家老实待着，@你就安全了吧？"},{"chara":[{"cheek":1,"id":303701,"motion":1,"tear":0}],"textRight":"是的……可是……"},{"chara":[{"id":100204}],"textLeft":"我也不清楚能不能帮上你的忙……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":100}],"textLeft":"我陪你一起去吧？@就别去学校了。"},{"chara":[{"cheek":1,"id":303701,"motion":200}],"textRight":"不、不麻烦你了……@我一个人就……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100204}],"textLeft":"别客气，好吗？"},{"autoTurnLast":1.0,"bg":"bg_adv_21201.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303701,"lipSynch":0,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_011.exp.json","id":100204,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story02","chara":[{"id":303701}],"textRight":"…………","turnChangeOut":"fadeOut"},{"chara":[{"id":303701,"lipSynch":1}],"textRight":"那个……这里是哪里？"},{"chara":[{"id":100204}],"textLeft":"这是我家哦。"},{"chara":[{"id":100204,"motion":301}],"textLeft":"你能把这里当成你家吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303701,"lipSynch":0,"motion":0}],"textRight":"…………"},{"chara":[{"id":303701,"lipSynch":1,"motion":200}],"textRight":"原、原来如此……@毕竟我离自己家很远……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701}],"textRight":"把这里当成我的家，@老实待着的话……"},{"chara":[{"id":100204,"motion":200}],"textLeft":"你就不会有危险了……@对吧？"},{"chara":[{"id":303701,"motion":0}],"textRight":"谢谢你，那个……"},{"chara":[{"id":100204}],"textLeft":"我叫七海八千代哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701,"motion":100}],"textRight":"谢谢你，七海学姐！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701}],"textRight":"我叫安名梅露！"},{"chara":[{"id":100204,"motion":0}],"textLeft":"安名，请多关照哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701,"motion":0}],"textRight":"请多指教！"},{"chara":[{"id":100204,"motion":100}],"textLeft":"你要喝茶吗？还是喝咖啡？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701,"motion":400}],"textRight":"啊……请等等！@我占卜一下决定！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204}],"textLeft":"是、是吗……"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701,"lipSynch":0,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303701}],"nameCenter":"梅露","textCenter":"（七海学姐……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":303701,"lipSynch":0}],"textCenter":"（她和顽固的十七夜不同……）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701,"lipSynch":0}],"textCenter":"（是个温柔可靠的人。）"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":303701,"lipSynch":0,"motion":0}],"textCenter":"…………","turnEffect":"stop"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303701,"lipSynch":0,"motion":200}],"textCenter":"（好！我决定了！）"},{"chara":[{"id":303701,"lipSynch":1}],"textCenter":"七海学姐！"},{"autoTurnLast":0.01,"chara":[{"id":303701,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100204,"motion":0,"pos":0}],"textLeft":"怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701,"motion":1}],"textRight":"请让我也加入七海学姐的队伍吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":301}],"textLeft":"什么？安名要加入？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303701}],"textRight":"我的占卜百试百灵，"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701,"motion":100}],"textRight":"我绝对会帮上七海学姐的忙的！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":200}],"textLeft":"唔……该怎么办呢……"},{"chara":[{"id":100204,"lipSynch":0}],"textLeft":"（我是没意见，@但安名是大东区的人……）","turnEffect":"thinking"},{"chara":[{"id":100204,"lipSynch":0}],"textLeft":"（她真的可以加入我的队伍吗？）"},{"chara":[{"id":100204,"motion":300}],"textLeft":"你能……等我一下吗？","turnEffect":"stop"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100204,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_narration.jpg","chara":[{"id":100204}],"nameCenter":"八千代","textCenter":"喂，十七夜？","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"autoTurnLast":0.01,"chara":[{"id":100204,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101601,"motion":200,"pos":2}],"nameRight":"十七夜","textRight":"怎么想起来给我打电话……@有什么事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":301}],"nameLeft":"八千代","textLeft":"那个，其实……"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":301,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":101601,"motion":200,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101601}],"textRight":"让安名加入你的队伍……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":1}],"textRight":"这样啊，没问题。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100204,"motion":400}],"textLeft":"咦！真的吗？"},{"chara":[{"id":101601}],"textRight":"要是安名想这么做，@那我没有理由拒绝。"},{"chara":[{"id":101601,"motion":100}],"textRight":"而且对安名来说，@和七海一起战斗也能学会很多。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100204,"motion":300}],"textLeft":"是吗……"},{"chara":[{"id":101601}],"textRight":"是的。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":1}],"textRight":"让你费心了……@安名她就拜托你了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100204,"motion":200}],"textLeft":"嗯，我会好好照顾她的。"},{"chara":[{"id":100204}],"textLeft":"我完全不介意的。"},{"autoTurnFirst":3.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303701,"motion":100,"pos":1,"voice":"vo_char_3037_00_03","textHome":"都说过了啊！我的占卜是绝对准确的！"}],"nameCenter":"梅露","textCenter":"所以我说过嘛！我的占卜绝对准确嘛！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303701}]},{"chara":[{"id":303701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}