{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21152.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":0,"pos":0}],"nameNarration":"？？？","narrationBg":"bg_adv_21152.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"narration":"「那我也能惩罚@你这个更坏的大叔吧？」"},{"chara":[{"id":800900,"lipSynch":0}],"nameRight":"","narrationEffect":"out","textRight":"[chara:800900:effect_emotion_surprise_0][se:7226_shock]嗯？！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800900,"lipSynch":1}],"textRight":"什、什么人？！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800900}],"textClear":1},{"bgm":"bgm03_story10","chara":[{"id":303401},{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0,"pos":2}],"nameRight":"纯美雨","textRight":"你是笨蛋吗？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303401,"motion":400}],"nameLeft":"惠萌花","textLeft":"噫！"},{"chara":[{"id":301201,"motion":200}],"textRight":"怎么就被这种强买强卖的人@给盯上了呢。"},{"textRight":"遇上这种人就别理他，@直接逃跑就行了。"},{"chara":[{"eyeClose":0,"id":303401,"motion":1}],"textLeft":"原、原来要这么做啊……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":301201},{"effect":"fadeout","id":303401}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900,"motion":0,"pos":1}],"textCenter":"小姑娘，这可不好说啊？"},{"textCenter":"要是你选择了逃跑……"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900}],"textCenter":"等着你的只会是……[chara:800900:lipSynch_0][wait:1.0][chara:800900:cheek_0][chara:800900:face_mtn_ex_020.exp.json][chara:800900:lipSynch_1]更加残暴的惩罚啊！"},{"autoTurnLast":0.5,"bgm":"stop","chara":[{"effect":"slideOutRightFast","id":800900}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":100,"pos":2},{"cheek":0,"effect":"slideInLeftFast","face":"mtn_ex_020.exp.json","id":800900,"motion":0,"pos":1}],"nameNarration":"","narration":"[chara:800900:effect_shake][chara:301201:cheek_0][chara:301201:motion_100:effect_shake]啪！","narrationEffect":"in"},{"bgm":"bgm24_story04","chara":[{"id":301201,"motion":200}],"narrationEffect":"out","textRight":"你动手了吧，我这算是正当防卫哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301201},{"id":800900}],"narration":"[chara:800900:effect_shake]咚！","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900}],"narrationEffect":"out","textCenter":"好痛！好痛啊！"},{"textRight":"别乱动，不然你会脱臼的。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textRight":"我还没回答你的问题呢。"},{"chara":[{"eyeClose":0,"id":301201}],"textRight":"你刚才问了我是什么人吧？"},{"chara":[{"id":301201,"motion":1}],"textRight":"那么……你听说过苍海帮吗？"},{"chara":[{"id":800900}],"textCenter":"苍海帮？@[chara:800900:lipSynch_0][wait:1][chara:800900:lipSynch_1][chara:800900:cheek_0][chara:800900:face_mtn_ex_020.exp.json]我听说过……"},{"textCenter":"那是一帮可恶的黑帮……@老是来妨碍我们做生意……"},{"textCenter":"而且我的兄弟们都说……"},{"chara":[{"id":800900}],"textCenter":"他们都是被一个力气很大的@团子头女高中生给干掉的……[chara:800900:lipSynch_0][wait:1][chara:800900:lipSynch_1][chara:800900:cheek_0][chara:800900:face_mtn_ex_050.exp.json]嗯？"},{"textCenter":"团子头的……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":301201},{"effect":"fadeout","id":800900}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":0,"pos":1}],"nameCenter":"惠萌花","textCenter":"女高中生？"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303401}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800900,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0,"pos":2}],"nameCenter":"","textCenter":"难道是你？！"},{"chara":[{"eyeClose":1,"id":301201}],"textRight":"你有一点说错了。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301201,"motion":100}],"textRight":"苍海帮不是黑帮，@而是一个互助组织。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800900,"mouthOpen":1}],"textBg":"shout","textCenter":"呜……哇——"},{"autoTurnLast":0.5,"chara":[{"effect":"slideOutLeftFast","id":800900}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":0}],"textRight":"哈哈哈！下次别来了！"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303401,"motion":100,"pos":0}],"nameLeft":"惠萌花","textLeft":"谢、谢谢你救了我！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":0}],"textLeft":"我刚才真的不知道该怎么办……@非常困扰！"},{"chara":[{"id":303401,"motion":300}],"textLeft":"我到底该怎么感谢你呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":300}],"textRight":"你别太在意了，@不然会被别人钻空子的。"},{"textRight":"我也只是做了该做的事……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0},{"id":303401,"motion":0}],"textRight":"这附近到处都是心怀不轨的人，@你自己也要小心一点。"},{"chara":[{"eyeClose":1,"id":301201}],"textRight":"我要说的就是这些，@这件事也就告一段落了。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":200}],"textRight":"你快走吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303401,"motion":100}],"textLeft":"好的！"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":303401}],"textClear":1},{"chara":[{"id":301201,"lipSynch":0,"motion":0}],"textRight":"……"},{"autoTurnLast":0.2,"turnChangeIn":"rollInFast","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303401,"lipSynch":0,"motion":1,"pos":0}],"textLeft":"（只要穿过这里……）"},{"bgm":"stop","narration":"[bgEffect:shakeSmall]啊啊啊啊啊！","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":400}],"narrationEffect":"out","textLeft":"[chara:303401:effect_emotion_surprise_0][se:7226_shock]咦？！"},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801100,"motion":0,"pos":2}],"nameRight":"","textRight":"[chara:801100:effect_shake]呜……呜……"},{"textLeft":"你、你没事吧？！@你好像摔得很厉害啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100}],"textRight":"已经没事了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":0}],"textLeft":"咦？！@[chara:303401:lipSynch_0][wait:0.8][chara:303401:cheek_0][chara:303401:face_mtn_ex_030.exp.json][chara:303401:lipSynch_1]但、但是你还在流血……"},{"textRight":"你的温柔已经治愈了我的疼痛。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801100}],"textRight":"对了，作为回礼，@就让我请你吃顿饭吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100}],"textRight":"这附近有家很好吃的意大利面哦。"},{"textRight":"来，我们走吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":200}],"textLeft":"我、我觉得……"},{"chara":[{"id":303401,"motion":1}],"textLeft":"既、既然你都流血了……@那就该吃些能补铁的……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801100}],"textRight":"你是在关心我吗？你好温柔啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801100}],"textRight":"那就照你说的办吧。"},{"chara":[{"id":303401,"motion":0}],"textLeft":"啊……我不是这个意思……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303401},{"effect":"fadeout","id":801100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301201,"motion":200,"pos":1}],"nameCenter":"纯美雨","textCenter":"给我住手！"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":0,"pos":0}],"textLeft":"啊，你是刚才那位……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":400}],"nameRight":"纯美雨","textRight":"为什么我刚和你说完，@你就又被搭讪了啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":300}],"textLeft":"啊……"},{"chara":[{"id":301201,"motion":0}],"textRight":"你根本就不用理这种人。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303401},{"effect":"fadeout","id":301201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801100,"motion":0,"pos":1}],"nameCenter":"","textCenter":"等、等一下啊！我的确是在搭讪……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":801100}],"textBg":"shout","textCenter":"可我好歹也流血了，@至少要夸夸我的诚意和干劲吧！"},{"autoTurnLast":0.2,"chara":[{"id":801100,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301201,"motion":200,"pos":2}],"textRight":"嗯？你是嫌血还流得不够多吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801100,"motion":0}],"nameLeft":"","textLeft":"我先回去了……"},{"autoTurnLast":1.0,"chara":[{"effect":"slideOutLeft","id":801100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303401,"motion":100,"pos":0}],"nameLeft":"惠萌花","textLeft":"谢……谢谢你帮了我那么多次！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0,"pos":2}],"nameRight":"纯美雨","textRight":"你这样走在路上实在是太不小心了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":300}],"textRight":"赶紧回去吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":300}],"textLeft":"哈哈……你说得对……"},{"chara":[{"id":303401,"motion":0}],"textLeft":"但我有件必须要做的事……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textRight":"是吗……那是我多管闲事了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303401,"motion":400}],"textLeft":"没有的事！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303401}],"textLeft":"那我就先告辞了，@真的非常感谢！"},{"autoTurnLast":1.0,"bgm":"stop","chara":[{"effect":"fadeout","id":303401}],"textClear":1},{"chara":[{"eyeClose":0,"id":301201,"lipSynch":0}],"surround":"7003_wind","textRight":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":300}],"textRight":"好担心她啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textRight":"还是跟在她后面看看吧……"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":301201}],"textClear":1},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303401,"motion":0,"pos":1}],"surround":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":2.3,"chara":[{"id":303401,"motion":300,"voice":"vo_char_3034_00_03","textHome":"虽然可