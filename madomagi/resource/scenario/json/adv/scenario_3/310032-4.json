{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301,"motion":0,"mouthOpen":0,"pos":0,"tear":1},{"cheek":0,"face":"mtn_ex_020.exp.json","id":300801,"motion":0,"mouthOpen":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_13021.jpg","bgm":"bgm03_story02","chara":[{"id":100301}],"nameLeft":"鹤乃","nameRight":"志伸晶","textLeft":"那个……@很抱歉……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"mouthOpen":0}],"textRight":"行了……@没关系……"},{"chara":[{"cheek":0,"id":300801,"motion":300,"mouthOpen":0}],"textRight":"虽然被人骂得狗血淋头……[chara:300801:effect_emotion_sad_0][se:7224_fall_into]"},{"chara":[{"cheek":1,"id":100301,"lipSynch":0,"motion":300,"mouthOpen":0,"tear":1}],"textLeft":"…………[chara:100301:effect_emotion_sad_0][se:7224_fall_into]"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":0,"mouthOpen":0}],"textRight":"不、不过！@找到狗就好！嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"mouthOpen":0}],"textRight":"至少比没找到要好，是吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301,"lipSynch":1,"motion":0,"mouthOpen":0}],"textLeft":"这、这样吗！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":300,"mouthOpen":0}],"textRight":"虽然……@[chara:300801:effect_emotion_sad_0][se:7224_fall_into]被骂得很惨……"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100301,"motion":300,"mouthOpen":1,"tear":1}],"textLeft":"很、很抱歉！"},{"chara":[{"cheek":0,"id":300801,"motion":0,"mouthOpen":0}],"textRight":"啊，一不留神就……抱歉！@我太没用了……"},{"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":100301,"motion":0,"mouthOpen":0}],"textLeft":"不！@怎么会呢，晶老师！"},{"chara":[{"cheek":0,"id":300801,"mouthOpen":0}],"textRight":"啊，对了……@关于老师……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100301,"lipSynch":0,"motion":100,"mouthOpen":0}],"textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":100,"mouthOpen":0}],"textRight":"我想到有一个人@比我更适合当老师。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301,"motion":400,"mouthOpen":1,"tear":1}],"textLeft":"不、不要啊！@我今后会认真努力的！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":200,"mouthOpen":0}],"textRight":"不！@我并不是要丢下你不管！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"mouthOpen":0}],"textRight":"只是，我还不够成熟，@没本事教别人……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":100,"mouthOpen":0}],"textRight":"而且，我介绍给你的人很厉害哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"motion":0,"mouthOpen":0}],"textLeft":"很厉害？[chara:100301:effect_emotion_surprise_0][se:7226_shock]"},{"chara":[{"cheek":0,"id":100301,"mouthOpen":0}],"textLeft":"真的吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":200,"mouthOpen":0}],"textRight":"绝对厉害！@我保证！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"mouthOpen":0}],"textRight":"我觉得，@你还是跟着那个人修行比较好。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301,"mouthOpen":0}],"textLeft":"既然晶老师如此认可那个人……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100301,"motion":101,"mouthOpen":0}],"textLeft":"那就拜托你了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":0,"mouthOpen":0}],"textRight":"嗯！@那我们明天再联系。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"mouthOpen":0}],"textRight":"找个地方集合，@一起去找那个人。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100301,"motion":201,"mouthOpen":0}],"textLeft":"唔——我燃起了斗志！@一定要变强！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":100,"mouthOpen":0,"tear":0}],"textRight":"是啊！@加油！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"lipSynch":0,"motion":0,"mouthOpen":0}],"textRight":"（话是这么说……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"id":300801,"lipSynch":0,"mouthOpen":0}],"textRight":"（但我还是很担心……）"},{"autoTurnFirst":3.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301