"bg":"bg_adv_21173.jpg","bgChangeEffect":"fade"},{"autoTurnLast":0.5,"bg":"bg_adv_21203.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story02","chara":[{"id":101501}],"nameLeft":"忧","nameRight":"彩羽","textLeft":"姐姐。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101}],"textRight":"嗯？"},{"chara":[{"id":101501,"motion":100}],"textLeft":"姐姐跟八千代都好厉害啊，@能管好所有人。"},{"chara":[{"id":100101}],"textRight":"诶？@[chara:100101:lipSynch_0][wait:0.8][chara:100101:motion_200][chara:100101:cheek_0][chara:100101:face_mtn_ex_010.exp.json][chara:100101:lipSynch_1]突然提这个做什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501}],"textLeft":"今天打架的时候，@你介入并阻止了我们对吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501}],"textLeft":"八千代也一直在关照三日月别墅里的人@跟其他魔法少女。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":0}],"textLeft":"我觉得……"},{"chara":[{"id":101501}],"textLeft":"这种能领导一群人的人很厉害呀。"},{"chara":[{"eyeClose":1,"id":101501,"motion":300}],"textLeft":"我也很向往成为能领导大家的人。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"lipSynch":0}],"textRight":"…………"},{"chara":[{"id":100101,"motion":0}],"textRight":"你是在考虑升学意向的事吗？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101501,"motion":0}],"textLeft":"嗯。"},{"chara":[{"id":101501,"motion":100}],"textLeft":"我很憧憬那种能带领人们前进的人，"},{"chara":[{"id":101501}],"textLeft":"虽然我暂时还没想到具体该怎么做……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":100}],"textRight":"不过你有在认真思考这件事吧。"},{"chara":[{"id":101501,"lipSynch":0,"motion":300}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":0}],"textLeft":"话说回来我还没问过你，"},{"chara":[{"id":101501}],"textLeft":"姐姐以后想从事什么职业呀？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101}],"textRight":"我吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":200}],"textRight":"我呢……现在想当一名护士。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101501,"motion":100}],"textLeft":"是因为我之前住院的缘故吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100101}],"textRight":"嗯……没错。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100101}],"textRight":"也有这个原因。"},{"chara":[{"eyeClose":0,"id":100101,"motion":0}],"textRight":"你之前住院时，@我就觉得那些照顾你的护士们"},{"chara":[{"id":100101}],"textRight":"看上去非常帅气，@我很想变成她们那样。"},{"chara":[{"id":101501,"motion":0}],"textLeft":"这样啊……@我之前都不知道……"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100101}],"textRight":"我也不是很早之前就立志@要当一名护士啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":301}],"textRight":"小时候觉得当一名@花店或面包店的店员也挺好的……"},{"chara":[{"id":100101}],"textRight":"无论什么职业，@只要是认真工作着的人，"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100101}],"textRight":"都会让人对他们的职业产生向往。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":100}],"textRight":"以后的经历或许也会@让我改变现在的想法呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101501,"lipSynch":0,"motion":300}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":0}],"textRight":"忧？"},{"chara":[{"id":101501}],"textLeft":"姐姐你经历了很多事呢。"},{"chara":[{"id":101501}],"textLeft":"所以才能找到自己真正想做的事……"},{"chara":[{"eyeClose":1,"id":101501}],"textLeft":"但我之前一直都在住院，@什么也没经历过……"},{"chara":[{"id":101501}],"textLeft":"所以比起其他人，@感觉自己一点想法都没有……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":200}],"textRight":"没这回事。"},{"chara":[{"eyeClose":1,"id":100101}],"textRight":"每个人都活在自己的时间里，"},{"chara":[{"id":100101}],"textRight":"经历着只属于自己的人生。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101501,"motion":0}],"textLeft":"什么意思？"},{"chara":[{"eyeClose":0,"id":100101,"motion":400}],"textRight":"意思就是，忧有忧自己独有的经历。"},{"chara":[{"id":101501}],"textLeft":"我独有的经历？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100101}],"textRight":"嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100101,"motion":0}],"textRight":"只是因为这些事都是你自己经历过的，@所以你会难以察觉罢了。"},{"chara":[{"id":100101,"motion":100}],"textRight":"你肯定有别人没经历过的、@只属于你的经历。"},{"chara":[{"id":101501,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":100}],"textLeft":"谢谢姐姐，我会好好考虑的。"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101501,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_04","textHome":"太好啦。@这样三日月别墅的大家就都能友好相处啦。"}],"nameCenter":"忧","textCenter":"太好了，这下就能跟@三日月别墅的人们好好相处了吧。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501}]},{"chara":[{"id":101501}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}