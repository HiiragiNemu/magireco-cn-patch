{"story":{"group_1":[{"bg":"bg_adv_19221.jpg","bgm":"bgm01_anime07","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"lipSynch":0,"motion":0,"pos":0},{"id":810000,"motion":0,"pos":2,"posX":40}],"nameLeft":"胡桃爱香","nameRight":"丘比","textLeft":"…………","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"id":810000}],"textRight":"店里还是一如既往，@很安静呢。"},{"chara":[{"cheek":1,"effect":"emotion_angry_0","face":"mtn_ex_020.exp.json","id":300902,"motion":400,"mouthOpen":1}],"se":"7219_strain","textLeft":"什么！@你这家伙！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902}],"textLeft":"唔……虽然……@[chara:300900:motion_300:effect_emotion_sad_0][se:7224_fall_into]我也没法否定[chara:300900:lipSynch_0]…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900,"motion":0,"pos":2}],"nameRight":"爱香的父亲","textRight":"爱香！@我差不多该出门咯！"},{"chara":[{"cheek":0,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300902,"motion":0}],"se":"7226_shock","textLeft":"啊，好的。@你又要去外面做厨师吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"是啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"多亏了@爱香帮咱们宣传啊！"},{"nameNarration":"胡桃爱香","narration":"是的@我的宣传很有效@我家餐厅一举成名……","narrationBg":"bg_adv_19221.jpg","narrationEffect":"in"},{"narration":"有幸的是@不仅有人点名我@还有人点名要吃我家餐厅的菜……"},{"narration":"但全都是委托我们外出做菜@客人并不光顾……"},{"narration":"不得不说@正如白狸猫所言……@我家餐厅还是门可罗雀……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"motion":1}],"nameLeft":"胡桃爱香","narrationEffect":"out","textRight":"那好！@我出门咯！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800900}],"textRight":"餐厅就交给你了。"},{"chara":[{"effect":"fadeout","id":800900},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902}],"textLeft":"啊，好的！@[chara:300900:motion_000]慢走！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902}],"textLeft":"什么@『交给你』啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300}],"textLeft":"今天也@根本不会有人来吧……"},{"bgm":"bgm03_story11","narration":"即便如此@工作源源不断@营业额也自然水涨船高……","narrationBg":"bg_adv_19221.jpg","narrationEffect":"in"},{"narration":"『你要让餐厅再像以前那样热闹起来』@爸爸虽然是这么说的"},{"narration":"但最近他每天都@开开心心地出门去"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":1}],"nameLeft":"胡桃爱香","narrationEffect":"out","textLeft":"爸爸这样就@心满意足了吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902}],"textLeft":"真的……@好安静啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902}],"textLeft":"爱香到底是为了什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":300}],"textLeft":"而努力@宣传的呢……"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":100,"pos":1,"voice":"vo_char_3009_00_04","textHome":"每天都好忙……这就是甜蜜的烦恼吧！"}],"nameCenter":"胡桃爱香","textCenter":"每天都很繁忙……@这就是幸福的抱怨吧！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.5,"chara":[{"id":300902,"motion":200}]},{"chara":[{"id":300902}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}