{"story":{"group_1":[{"bg":"bg_adv_20092.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":830300,"motion":0,"pos":2}],"nameLeft":"梅丽莎·德·维尼奥勒","nameRight":"","textLeft":"是吗……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":300}],"textLeft":"那样的话，@能换成5瓶红酒吗？"},{"chara":[{"cheek":0,"id":830300}],"textRight":"噢，这个可以提供哦！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":1}],"textLeft":"[chara:402301:effect_emotion_joy_0][se:7222_happy]哇啊，谢谢！"},{"chara":[{"cheek":0,"id":830300}],"textRight":"就这些了吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"是的，托你们的福，@必要的补给品都凑齐了！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301}],"textLeft":"真的非常感谢！"},{"chara":[{"cheek":0,"id":830300}],"textRight":"噢，如果有需要的话，@尽管再来！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":2}],"nameLeft":"梅丽莎·德·维尼奥勒","nameRight":"彩羽","textLeft":"彩羽，八千代……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301,"motion":1}],"textLeft":"在城塞的工作@已经全部完成了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":401}],"textRight":"咦，已经结束了？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":0}],"textRight":"也太快了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":300,"pos":2}],"nameRight":"八千代","textRight":"梅丽莎和别人交涉得@有条不紊呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"是因为有两位的护卫，@我才能提前到达城塞！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":300}],"textLeft":"真的非常感谢！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100,"motion":400,"pos":2}],"nameRight":"彩羽","textRight":"哪里，不用客气！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":2}],"nameRight":"八千代","textRight":"工作顺利完成是好事……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":200}],"textRight":"但还剩下不少空余时间呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100100,"motion":200,"pos":2}],"nameRight":"彩羽","textRight":"确实是结束得太早了呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":1}],"textLeft":"塔鲁特他们的主力军也会转移地点，@所以不能现在立即回去。"},{"chara":[{"cheek":0,"id":402301}],"textLeft":"看来我们负责补给的队伍@需要在这个城塞待两天。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":301}],"textRight":"两天……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":0}],"textRight":"要等挺久的呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":200,"pos":0}],"nameLeft":"八千代","textLeft":"是啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}],"textLeft":"我说，彩羽。"},{"chara":[{"cheek":0,"id":100200}],"textLeft":"如果附近有村落@或是城镇的话……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}],"textLeft":"要不要放松一下，@和梅丽莎一起出去走走？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":301}],"textRight":"诶……可以吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":300}],"textLeft":"彩羽和梅丽莎年纪差不多……"},{"chara":[{"cheek":0,"id":100200}],"textLeft":"而且，你还能当她的护卫不是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":200}],"textRight":"但是……@八千代你呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}],"textLeft":"我在这里留守。@我更喜欢待在城塞里面。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200}],"textLeft":"梅丽莎呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}],"textLeft":"有没有什么想去的地方？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402301,"lipSynch":0,"motion":0,"pos":2,"soulGem":0}],"nameRight":"梅丽莎·德·维尼奥勒","textRight":"…………"},{"chara":[{"cheek":1,"id":402301}],"textRight":"嗯！@那个，其实……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":400}],"textRight":"我一直想去一个教会看看！"},{"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":1,"pos":1,"soulGem":0}],"nameCenter":"梅丽莎·德·维尼奥勒","textCenter":"虽然开场白@变得有点长了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402301,"motion":300}],"textCenter":"但是，那场骚动的导火索，@就是我的这句话。"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":300,"pos":1,"voice":"vo_char_4023_00_03","textHome":"能帮上塔鲁特真是太开心了。"}],"nameCenter":"梅丽莎·德·维尼奥勒","textCenter":"能帮上塔鲁特的忙，@就是我的幸福。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301}]},{"chara":[{"id":402301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}