":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301001,"lipSynch":0,"motion":0,"pos":1}],"textCenter":"(虽然我也很喜欢@美丽的东西……)","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301001,"lipSynch":0,"motion":300}],"textCenter":"(不过却完全跟不上@她们俩的话题呢……)"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":301001}],"textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303301,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":303201,"motion":1,"pos":0}],"nameLeft":"梢麻友","nameRight":"史乃沙优希","textRight":"沙优希还要来看这次特別展！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301,"motion":100}],"textRight":"每天都会有不同的刀剑印章，@沙优希一定要集齐～！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303201}],"textLeft":"呵呵……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303201}],"textLeft":"我要不要把这次特別展的宣传册@留作纪念呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303201,"motion":0}],"textLeft":"咦？@宣传册没了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801100,"motion":0,"pos":2}],"nameRight":"","textRight":"那、那个……@你掉东西了哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303201,"motion":400}],"textLeft":"呃……啊，不好意思……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303201,"motion":100}],"textLeft":"谢谢你……！"},{"chara":[{"face":"mtn_ex_010.exp.json","id":801100}],"textRight":"不用谢。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303301,"motion":300,"pos":2}],"nameRight":"史乃沙优希","textRight":"啊哇哇……@麻友，真是太好了！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303201}],"textLeft":"是的！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303201,"motion":1}],"textLeft":"还好是被好心人捡到了，@真是太好了"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":801100,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"","textRight":"…………！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303201},{"effect":"fadeout","id":801100}],"textClear":1},{"chara":[{"cheek":0,"f