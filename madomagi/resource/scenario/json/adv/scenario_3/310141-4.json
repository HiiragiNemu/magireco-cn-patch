{"story":{"group_1":[{"autoTurnLast":0.5,"bg":"bg_adv_21111.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100701,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"nameNarration":"所有人","narration":"咦————？","narrationBg":"black","narrationEffect":"in","narrationFontSize":45.0,"turnChangeOut":"fadeOut"},{"bgm":"bgm03_story20","chara":[{"id":100701,"motion":400}],"nameRight":"灯花","narrationEffect":"out","textRight":"[textBlue:传闻]已经造好了！？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401,"motion":200}],"nameLeft":"音梦","textLeft":"当然。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100801,"motion":200,"pos":2}],"nameRight":"阿莉娜","textRight":"阿莉娜有点angry了哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100601,"motion":200,"pos":2}],"nameRight":"美冬","textRight":"就是啊！"},{"chara":[{"id":100601}],"textRight":"事先告诉我们一声不好吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401,"motion":100}],"textLeft":"昨天晚上@我感知到了魔力反应。"},{"chara":[{"id":101401}],"textLeft":"我担心我们藏起来的魔女被发现，"},{"chara":[{"id":101401,"motion":0}],"textLeft":"所以就抢先做了准备。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"lipSynch":0,"motion":400}],"textRight":"！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":1}],"textRight":"抱歉，@刚刚错怪你了……"},{"chara":[{"id":101401,"motion":300}],"textLeft":"没事，@你们会惊讶也正常。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101801,"motion":200,"pos":1},{"cheek":1,"face":"mtn_ex_020.exp.json","id":101901,"motion":0,"pos":2}],"nameCenter":"月夜","textCenter":"但我们刚才丢人丢大了！"},{"chara":[{"id":101901,"motion":100}],"nameRight":"月咲","textRight":"早知道就不取名字了！"},{"chara":[{"id":101801,"motion":100}],"textCenter":"对吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401,"motion":100}],"textLeft":"我想了解下各位对未来的想法，@就故意让你们自由发挥了一下。"},{"chara":[{"id":101401,"motion":200}],"textLeft":"而且，迟早也是要取名字的，"},{"chara":[{"id":101401},{"id":101801,"motion":1},{"id":101901,"motion":0}],"textLeft":"我很欣慰，你们取的名字里@都有“希望”这个词。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401,"motion":0}],"textLeft":"不过我得跟你们道歉，@让你们出糗了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100701,"motion":200,"pos":0},{"id":101801,"pos":2}],"nameLeft":"灯花","textLeft":"气鼓鼓？"},{"chara":[{"id":101801,"motion":200}],"nameRight":"月夜","textRight":"当然气鼓鼓！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401,"motion":0,"pos":0}],"nameLeft":"音梦","textLeft":"下次扩建的时候，@我可以先满足你们的愿望哦。"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101801,"motion":400}],"textRight":"真的吗？"},{"chara":[{"id":101401}],"textLeft":"嗯，因为现在就只有一个地下圣堂。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101901,"motion":100,"pos":2}],"nameRight":"月咲","textRight":"说起来，你的传闻居然还能扩建啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101401,"motion":100}],"textLeft":"我一开始不是说过吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401}],"textLeft":"『我要不断添加新章节，@充实故事内容。』"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":300}],"textRight":"你是说过，@但我当时没听明白……"},{"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100801,"motion":100,"pos":2},{"id":101401,"motion":0}],"nameRight":"阿莉娜","textRight":"那阿莉娜的atelier也能造吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100601,"motion":400,"pos":2}],"nameRight":"美冬","textRight":"还有我的浴室。"},{"chara":[{"id":101401,"motion":200}],"textLeft":"嗯，以后都可以造。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100701,"motion":100,"pos":2}],"nameRight":"灯花","textRight":"可这样一来@主体又模糊起来了，"},{"chara":[{"id":100701}],"textRight":"本来准备拿来打底的东西@全都成为素材了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":100,"pos":0}],"nameLeft":"美冬","textLeft":"音梦理想中的根据地是什么样的呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":1}],"textRight":"对哦，@昨天还没听你说就解散了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401,"motion":0,"pos":0}],"nameLeft":"音梦","textLeft":"我……"},{"bgm":"stop","chara":[{"id":101401,"lipSynch":0,"pos":1},{"effect":"fadeout","id":100701}],"nameCenter":"音梦","textCenter":"…………"},{"autoTurnLast":0.1,"chara":[{"effect":"fadeout","id":101401}],"textClear":1},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100801,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":1,"pos":2}],"textClear":1},{"autoTurnLast":0.01,"chara":[{"effect":"fadeout","id":100801},{"effect":"fadeout","id":100701}]},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":101801,"motion":1,"pos":1},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101901,"motion":0,"pos":2}]},{"autoTurnLast":0.01,"chara":[{"effect":"fadeout","id":100601},{"effect":"fadeout","id":101801},{"effect":"fadeout","id":101901}]},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101401,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"音梦","textCenter":"…………"},{"autoTurnLast":1.0,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":801300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm05_event06","nameNarration":"音梦","narration":"我呢……@只希望你们愿意喊我的名字@陪在我身边的话@怎么样都好","narrationBg":"narration","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"bg":"bg_adv_21081.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":800600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":801300,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"音梦","narration":"或许我是在寻求家庭的温暖","narrationBg":"narration","narrationEffect":"in","turnChangeOut":"fadeOut"},{"narration":"但作为今后活动的场所@也还是得划清界限"},{"autoTurnLast":1.0,"bg":"bg_adv_21111.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":101401,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"eyeClose":1,"id":101401,"motion":200}],"textCenter":"所以……@这里不该是公司或是学校","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":1,"id":101401}],"textCenter":"虽然同伴们会在这里生活@但它在下一秒可能会化作战场"},{"chara":[{"eyeClose":0,"id":101401}],"textCenter":"我们是工作人员@我们培育的魔女是客人"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101401,"motion":0}],"textCenter":"我想好了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100701,"motion":100,"pos":2},{"id":101401,"pos":0}],"textRight":"你想出来了？"},{"chara":[{"id":101401}],"textLeft":"嗯，我想创造酒店。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101401,"motion":100}],"textLeft":"它叫「Hotel Fenthope」。"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101401,"motion":300,"pos":1,"voice":"vo_char_1014_00_03","textHome":"要创造的话，首先就是大家的安身之地吧……"}],"nameCenter":"音梦","textCenter":"要创造的话@就得造出所有人的容身之所……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101401}]},{"chara":[{"id":101401}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}