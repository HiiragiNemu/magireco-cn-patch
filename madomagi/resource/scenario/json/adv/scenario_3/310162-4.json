{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":101601}],"nameLeft":"御魂","nameRight":"十七夜","textRight":"有十咎在，@暂时应该不会有什么危险。","turnChangeOut":"fadeOut"},{"chara":[{"id":101601,"motion":100}],"textRight":"但要是出了什么事，@还是叫我过来吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601}],"textRight":"为了志同道合之人，@我随叫随到。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}],"textLeft":"谢谢你，十七夜。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}],"textLeft":"我也不喜欢吓人的事啊，@到时候会立刻拜托你的。"},{"chara":[{"id":101601,"motion":0}],"textRight":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601}],"textRight":"这么说，调整屋在某种程度上@也还挺兴旺的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300}],"textLeft":"没有那回事哦。"},{"chara":[{"id":101700}],"textLeft":"大部分人的调整@还不到位呢。"},{"chara":[{"id":101700}],"textLeft":"虽说是兴旺，@但很多人都是第一次来……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":0}],"textRight":"是这样啊……"},{"chara":[{"id":101601,"lipSynch":0,"motion":300}],"textRight":"…………"},{"autoTurnLast":0.01,"bg":"bg_adv_21152.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":101601,"motion":400}],"nameLeft":"月咲","nameRight":"十七夜","textRight":"月咲！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101901,"lipSynch":0,"motion":400}],"textLeft":"——！？"},{"autoTurnLast":1.0,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":101601,"motion":300,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101700}],"nameLeft":"御魂","nameRight":"十七夜","textLeft":"怎么了，十七夜？","turnChangeOut":"fadeOut"},{"chara":[{"id":101601,"motion":1}],"textRight":"没有，只是在这附近@碰到了月咲她们。"},{"chara":[{"id":101601}],"textRight":"她们是来找你的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}],"textLeft":"是的，她们两个都是@本店的贵客哦。"},{"chara":[{"id":101601,"motion":200}],"textRight":"原来如此……@她们有在好好利用这里啊……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101601,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0}],"textLeft":"你怎么了？@从刚才就有点不对劲呢……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":400}],"textRight":"啊，没有……"},{"chara":[{"id":101601}],"textRight":"有次碰到她们的时候，@和她们打了招呼……"},{"chara":[{"id":101601,"motion":100}],"textRight":"我总感觉月咲在躲我……"},{"chara":[{"id":101601}],"textRight":"我在想我是不是@做了什么不好的事……"},{"chara":[{"eyeClose":1,"id":101601,"motion":300}],"textRight":"可我想不出来……"},{"chara":[{"id":101700,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"id":101700,"motion":300}],"textLeft":"原来如此……"},{"chara":[{"id":101700}],"textLeft":"月咲和月夜看起来@都有点严肃呢。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101601,"motion":0}],"textRight":"唔……发生什么了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}],"textLeft":"你和月咲的关系很好吧？"},{"chara":[{"id":101700}],"textLeft":"你直接去问问她@可能会比较好哦。"},{"chara":[{"id":101601,"lipSynch":0}],"textRight":"…………@[wait:1.0][chara:101601:lipSynch_1]是吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":100}],"textRight":"我知道了，@谢谢你的建议，八云。"},{"chara":[{"id":101601}],"textRight":"我会联系月咲的。"},{"chara":[{"id":101700,"motion":0}],"textLeft":"嗯。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101700,"lipSynch":0}],"textLeft":"（那件事对你来说，@肯定也很重要……）","turnEffect":"thinking"},{"autoTurnFirst":6.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":300,"pos":1,"voice":"vo_char_1016_00_04","textHome":"我们至今都一直被过去绊住了脚步。"}],"nameCenter":"十七夜","textCenter":"我们从以前开始，@就一直被过去束缚。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":101601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}