{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21073.jpg","chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story05","chara":[{"id":350101,"motion":100}],"nameLeft":"绫野梨花","textLeft":"怜，我可以现在拆开吗？","turnChangeOut":"fadeOut"},{"chara":[{"id":350100}],"nameRight":"五十铃怜","textRight":"嗯……可以哦……"},{"nameNarration":"","narration":"打开","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":350101}],"narrationEffect":"out","textLeft":"香薰蜡烛？！@[chara:350101:lipSynch_0][wait:1.0][chara:350101:motion_200][chara:350101:cheek_1][chara:350101:face_mtn_ex_011.exp.json][chara:350101:lipSynch_1]我一直想要这个！"},{"chara":[{"id":350100,"motion":0}],"textRight":"其实……我看到了……@烦恼咨询处的那本杂志……"},{"chara":[{"id":350100}],"textRight":"上面有……梨花的便签……"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":350101,"motion":0}],"textLeft":"你注意到了啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":201}],"textLeft":"谢谢你。"},{"chara":[{"id":350100,"motion":100}],"textRight":"不用谢……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101,"motion":1}],"textLeft":"那我也可以送你礼物吗？"},{"chara":[{"id":350100,"motion":0}],"textRight":"嗯……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":400}],"textLeft":"谢谢你愿意跟我当好朋友。"},{"chara":[{"id":350101}],"textLeft":"圣诞快乐！"},{"chara":[{"cheek":1,"id":350100,"motion":100}],"textRight":"嗯！@谢谢……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101}],"textLeft":"你打开看看？"},{"chara":[{"id":350100}],"textRight":"嗯……"},{"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":350100,"lipSynch":0}],"textRight":"…………[chara:350100:lipSynch_0][wait:1.0][chara:350100:motion_400][chara:350100:cheek_1][chara:350100:face_mtn_ex_050.exp.json][chara:350100:lipSynch_1]啊……@是烛台！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350100}],"textRight":"好可爱……@[chara:350100:lipSynch_0][wait:1.0][chara:350100:motion_0][chara:350100:cheek_0][chara:350100:face_mtn_ex_050.exp.json][chara:350100:lipSynch_1]不过……为什么送我这个？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":350101,"motion":200}],"textLeft":"啊……其实我会对蜡烛感兴趣……"},{"chara":[{"id":350101}],"textLeft":"主要是因为你。"},{"chara":[{"id":350100,"motion":1}],"textRight":"我？"},{"chara":[{"id":350101}],"textLeft":"嗯。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101,"motion":1}],"textLeft":"因为你说自己『喜欢蜡烛』，"},{"chara":[{"id":350101}],"textLeft":"我就查了很多，@渐渐地自己也喜欢上了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":100}],"textRight":"是这样啊……"},{"chara":[{"cheek":1,"id":350100,"lipSynch":0}],"textRight":"（梨花……）","turnEffect":"thinking"},{"chara":[{"id":350101,"motion":0}],"textLeft":"啊，其实那个烛台……","turnEffect":"stop"},{"chara":[{"id":350101}],"textLeft":"是一对一起卖的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":350100,"motion":0}],"textRight":"啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":350101,"motion":200}],"textLeft":"我想留下另一个……"},{"chara":[{"id":350101}],"textLeft":"这样我们用的就是一对了，@可以吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":350100,"motion":200}],"textRight":"嗯！@当然……可以！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350100}],"textRight":"我也想和你……凑成一对！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":100}],"textLeft":"真的？@怜，谢谢你。"},{"chara":[{"id":350100,"motion":0}],"textRight":"不用谢……"},{"chara":[{"id":350100}],"textRight":"谢谢你的礼物……@我会好好珍惜这个烛台的……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101}],"textLeft":"嗯，不客气！"},{"chara":[{"id":350100,"lipSynch":0,"motion":1}],"textRight":"（好久没和朋友用成对的东西了……）","turnEffect":"thinking"},{"chara":[{"eyeClose":1,"id":350100},{"id":350101,"motion":0}],"textRight":"呵呵……","turnEffect":"stop"},{"chara":[{"id":350101,"motion":201}],"textLeft":"你喜欢吗？"},{"chara":[{"eyeClose":0,"id":350100,"motion":100}],"textRight