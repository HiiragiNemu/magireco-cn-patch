{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21073.jpg","bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303901,"lipSynch":0}],"nameCenter":"三穗野星罗","textCenter":"（明天就要提交调查表了。）","turnChangeOut":"fadeOut"},{"chara":[{"id":303901,"lipSynch":0,"motion":300}],"textCenter":"（电影也赶在最后一刻做完了。）"},{"chara":[{"id":303901,"lipSynch":0}],"textCenter":"（没关系，@爸爸他一定会理解我的。）"},{"chara":[{"id":303901,"motion":100}],"textCenter":"好，上吧！"},{"autoTurnLast":0.01,"bg":"bg_adv_21083.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800700,"lipSynch":0}],"nameCenter":"星罗的父亲","textCenter":"……","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":800700,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"lipSynch":0,"motion":0,"pos":2,"soulGem":0}],"nameRight":"三穗野星罗","textRight":"……"},{"chara":[{"id":303901}],"textRight":"爸爸。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800700}],"nameLeft":"星罗的父亲","textLeft":"嗯？是星罗啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700}],"textLeft":"有什么事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901}],"textRight":"明天就该提交调查表了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textLeft":"你是说这个啊……"},{"chara":[{"id":800700}],"textLeft":"抱歉，但我并不打算认可你的想法。"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……[wait:1.0][chara:800900:lipSynch_1]爸爸之所以把你送进工匠学院。"},{"chara":[{"id":800700}],"textLeft":"是希望你能考取资格，@拥有平稳的人生。"},{"chara":[{"id":303901}],"textRight":"我很感谢爸爸推荐我进入工匠学院。"},{"chara":[{"id":303901}],"textRight":"可正是因为在工匠学院里，我才能@更早掌握不同于其他学校的知识。"},{"chara":[{"id":303901}],"textRight":"这样我也能离我的梦想更进一步……"},{"bgm":"stop","chara":[{"id":800700}],"textLeft":"梦想吗……"},{"bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700}],"textLeft":"别再白日做梦了。"},{"chara":[{"id":800700}],"textLeft":"你的梦想迟早会害了你。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"lipSynch":0}],"textRight":"！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"motion":300}],"textRight":"为什么？你为什么要这么说？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textLeft":"我才想问你为什么呢。"},{"chara":[{"id":800700}],"textLeft":"为什么……"},{"chara":[{"id":800700}],"textLeft":"你偏偏要选择电影啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"lipSynch":0,"motion":0}],"textRight":"？"},{"chara":[{"id":303901}],"textRight":"你在说什么啊？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800700}],"textLeft":"总而言之，@凭你这种吊儿郎当的决心是不行的！"},{"chara":[{"id":800700}],"textLeft":"只要不当上专业导演，@你就没办法养活自己！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303901,"motion":100}],"textRight":"我才没有吊儿郎当的啊！"},{"chara":[{"id":303901}],"textRight":"我拍的这部电影就是我决心的证据！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901}],"textRight":"你快看吧！"},{"chara":[{"id":303901}],"textRight":"只要看了你就能明白了，@我可是真心想成为导演的！"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textLeft":"不，我想说的不是这个……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"motion":0}],"textRight":"咦？"},{"chara":[{"id":303901}],"textRight":"这到底是怎么回事？"},{"bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901}],"textRight":"难道你连看都不愿意看吗？"},{"chara":[{"id":800700,"lipSynch":0}],"textLeft":"……"},{"chara":[{"id":303901,"motion":300}],"textRight":"什么……不会吧……"},{"chara":[{"id":303901}],"textRight":"我明明都这么努力了……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303901,"lipSynch":0,"tear":1}],"textRight":"……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303901,"motion":0,"tear":1}],"textRight":"对不起，我先去冷静一下。"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"cheek