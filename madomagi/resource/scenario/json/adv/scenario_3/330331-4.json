{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_12043.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303301,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":303301}],"nameCenter":"史乃沙优希","textCenter":"想要朋友！","turnChangeOut":"fadeOut"},{"chara":[{"id":303301,"motion":100}],"textCenter":"沙优希，@想要能一起分享感动的朋友！"},{"nameNarration":"史乃沙优希","narration":"许下这个愿望之后，@我便成为了魔法少女……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnLast":0.5,"bg":"bg_adv_12091.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story02","chara":[{"id":303301,"lipSynch":0}],"nameCenter":"史乃沙优希","textCenter":"…………","turnChangeOut":"fadeOut"},{"chara":[{"id":303301,"lipSynch":0,"motion":300}],"textCenter":"（之前那个女孩子……）","turnEffect":"thinking"},{"chara":[{"id":303301,"lipSynch":0}],"textCenter":"（她不在啊……）"},{"chara":[{"eyeClose":1,"id":303301,"lipSynch":0}],"textCenter":"（也对，@哪有这么巧嘛……）"},{"chara":[{"eyeClose":0,"id":303301,"lipSynch":0,"motion":0}],"textCenter":"…………","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303301,"lipSynch":0}],"textCenter":"（难得到这里，@还是来看刀吧～）","turnEffect":"thinking"},{"nameNarration":"史乃沙优希","narration":"能跟沙优希畅谈刀的话题@一同分享感动的朋友@这样的人并没有出现呢～","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"autoTurnLast":1.0,"bg":"bg_adv_12041.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301,"motion":1,"pos":0},{"id":810000,"motion":0,"pos":2,"posX":40,"posY":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":303301}],"nameLeft":"史乃沙优希","nameRight":"丘比","textLeft":"……请问……@沙优希的愿望真的实现了吗？","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"chara":[{"id":303301}],"textLeft":"完全没觉得能交到朋友……"},{"chara":[{"id":810000}],"textRight":"当然已经实现了，@我不会骗人的。"},{"chara":[{"id":303301,"motion":100}],"textLeft":"是吗……@那沙优希再等等吧……"},{"autoTurnLast":1.0,"bg":"bg_adv_12091.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303301,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":303301,"lipSynch":0,"motion":200}],"nameCenter":"史乃沙优希","textCenter":"（既然丘比都这么说了……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":303301,"lipSynch":0}],"textCenter":"（到时候就会出现吧……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303301,"lipSynch":0,"motion":300}],"textCenter":"（啊，到闭馆时间了……@差不多得出去了！）"},{"autoTurnLast":0.01,"bg":"bg_adv_12021.jpg","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301,"motion":1,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":303301,"lipSynch":0}],"textCenter":"（果然～@上桐先生锻造的刀最棒了……）","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"id":303301,"lipSynch":0}],"textCenter":"（虽然沙优希最喜欢古刀，@但上桐先生的刀要另当别论～）"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303301,"lipSynch":0,"motion":100}],"textCenter":"（真希望什么时候@他能为沙优希打造一把专属的刀～）"},{"autoTurnLast":0.2,"chara":[{"id":303301,"pos":0}],"textClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"nameLeft":"史乃沙优希","nameRight":"？？？","textRight":"你好……@能打扰一下吗？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303301,"motion":400}],"textLeft":"[chara:303301:effect_emotion_surprise_0][se:7226_shock]哇！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301}],"textLeft":"请问……@你是在叫沙优希吗？"},{"chara":[{"id":801000}],"textRight":"是啊，你经常在美术馆吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"我是做这行的……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303301,"lipSynch":0,"motion":0}],"textLeft":"（名片……）","turnEffect":"thinking"},{"chara":[{"id":303301,"lipSynch":0}],"textLeft":"（她是演艺事务所的……@经纪人？）"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"你有兴趣当偶像吗？","turnEffect":"stop"},{"bgm":"stop","chara":[{"id":303301,"motion":300}],"textLeft":"偶……像？"},{"bg":"bg_adv_21101.jpg","nameNarration":"史乃沙优希","narration":"『呜……好挤～@好难受……』","narrationBg":"","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"blackFrame"},{"narration":"『要被挤扁了……@谁能救救沙优希啊～』"},{"autoTurnLast":0.5,"bg":"bg_adv_12021.jpg","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story01","chara":[{"id":303301,"motion":400,"mouthOpen":1}],"nameLeft":"史乃沙优希","nameRight":"？？？","textBg":"shout","textLeft":"[bgEffect:shakeLarge]噫呀！@偶像不行！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000,"lipSynch":0},{"id":303301,"mouthOpen":0}],"textRight":"[chara:801000:effect_emotion_surprise_0][se:7226_shock]！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000}],"textRight":"你、你别紧张，冷静一点。"},{"chara":[{"id":303301,"motion":300}],"textLeft":"……呼……"},{"chara":[{"id":303301,"motion":1}],"textLeft":"失、失礼了……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":801000}],"textRight":"没事，我不介意。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"比起道歉……@你要不先听我说说具体情况？"},{"chara":[{"id":801000}],"textRight":"你要是感兴趣，@那我会和你的监护人说明的，好吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303301,"motion":100}],"textLeft":"不、不用了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301}],"textLeft":"沙优希对于偶像@有点接受不来……！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000}],"textRight":"这样啊……真遗憾……"},{"chara":[{"id":801000}],"textRight":"这次想打造的是通过刀剑等事物@宣传水名历史的当地偶像……"},{"chara":[{"id":801000}],"textRight":"我本来是感觉@这个人选非你莫属……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303301,"motion":0}],"textLeft":"刀剑……和历史？"},{"chara":[{"id":801000}],"textRight":"没错……"},{"chara":[{"id":801000}],"textRight":"比如采访在水名世代锻刀的@刀匠上桐先生之类的。"},{"chara":[{"id":303301,"motion":400}],"textLeft":"采、采访上、上桐先生！？"},{"chara":[{"id":801000}],"textRight":"真是好可惜……要是你没有兴趣，@那我就只好去找别人了……"},{"chara":[{"id":303301,"motion":300}],"textLeft":"可以见到……上桐先生？@真的吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000}],"textRight":"……你有兴趣吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301}],"textLeft":"唔……我也……@我也不是这个意思……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000}],"textRight":"那你先听我介绍一下吧？@一会儿就行，好吗？"},{"chara":[{"eyeClose":1,"id":303301,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"eyeClose":0,"id":303301,"motion":1}],"textLeft":"好、好吧，@既然你都说到这个份上了……"},{"nameNarration":"史乃沙优希","narration":"“一会儿就行”，","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"这其实是个陷阱……"},{"autoTurnLast":0.5,"bg":"bg_adv_21482.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":800600,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":800600}],"nameLeft":"？？？","nameRight":"沙优希的母亲","textRight":"你是说让沙优希，@当偶像……","turnChangeOut":"fadeOut"},{"chara":[{"id":801000}],"textLeft":"是的，作为宣传水名区的本地偶像！@请您一定考虑考虑！"},{"chara":[{"id":801000}],"textLeft":"我认为沙优希有那个天赋。"},{"chara":[{"id":800600}],"textRight":"嘛……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301,"motion":1,"pos":0}],"nameLeft":"史乃沙优希","textLeft":"妈、妈妈？"},{"chara":[{"id":303301,"lipSynch":0}],"textLeft":"（本以为以为妈妈能帮忙拒绝她，@[wait:0.8][chara:303301:motion_0]没、没想到……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textRight":"[chara:800600:effect_emotion_joy_0][se:7222_happy]你也看出来了是吧！？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600}],"textRight":"我这个当妈的@这么夸她可能不太好……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textRight":"可咱家这孩子长得确实很可爱吧？"},{"chara":[{"id":800600}],"textRight":"我以前就在想，@将来说不定会有这么一天呢！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303301,"motion":300}],"textLeft":"妈、妈妈……@你、你别说了～"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":0}],"nameLeft":"？？？","textLeft":"是的呀，她的确很可爱……"},{"chara":[{"id":801000}],"textLeft":"她到现在都没被星探挖掘，@真是难以置信。"},{"chara":[{"id":800600}],"textRight":"她还这么小，我不太放心，@但是交给你的话应该没问题。"},{"chara":[{"id":800600}],"textRight":"我家沙优希就拜托你了。"},{"chara":[{"id":801000}],"nameLeft":"沙优希的经纪人","textLeft":"好的，@我会负起责任培养好她的。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303301,"motion":200,"pos":0}],"nameLeft":"史乃沙优希","textLeft":"请、请等一下～"},{"chara":[{"id":303301}],"textLeft":"沙优希可没说要当偶像啊～"},{"chara":[{"id":800600}],"textRight":"但你说不定能借此机会@和喜欢的刀匠见面哦？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303301,"motion":300}],"textLeft":"可、可是……"},{"chara":[{"id":800600}],"textRight":"你要是存下工资的话，"},{"chara":[{"id":800600}],"textRight":"就能花钱让他帮你锻刀了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303301,"motion":0}],"textLeft":"让上桐先生……@为沙优希锻刀？"},{"chara":[{"id":800600}],"textRight":"用工作赚来的钱锻造自己最喜欢的刀，@很不错吧。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303301,"motion":100}],"textLeft":"那、那确实很不错呢……"},{"nameNarration":"史乃沙优希","narration":"在妈妈她们的劝说之下@沙优希不知不觉地@就在合同上签了字……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"没错……@沙优希一开始……"},{"narration":"明明只是想得到@能够“一起”分享“关于刀的感动”的@朋友而已……"},{"narration":"可不知怎的@就当起偶像来了……"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":1.9,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303301,"motion":400,"pos":1,"voice":"vo_char_3033_00_03","textHome":"啊嘞？本来只是想听听的……@沙优希就这么签下去了……？"}],"nameCenter":"史乃沙优希","textCenter":"咦？沙优希原本只想听听的……@怎么就签下字了？","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303301}]},{"autoTurnFirst":4.6,"chara":[{"id":303301,"motion":300}]},{"chara":[{"id":303301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}