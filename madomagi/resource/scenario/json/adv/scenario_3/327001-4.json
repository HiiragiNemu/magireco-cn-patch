{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21111.jpg","bgm":"bgm01_anime02","turnChangeIn":"fadeIn"},{"autoTurnLast":2.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"bg":"bg_adv_21121.jpg","bgChangeEffect":"fade"},{"autoTurnLast":2.0,"bg":"bg_adv_21091.jpg","bgChangeEffect":"fade"},{"autoTurnLast":2.0,"bg":"bg_adv_20221.jpg","bgChangeEffect":"fade"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":270000,"motion":0,"pos":1}],"nameCenter":"渚","nameLeft":"渚","nameRight":"杏子","textCenter":"所以说……"},{"chara":[{"id":270000,"motion":100}],"textCenter":"为什么你要跟着我走啊？！"},{"autoTurnLast":0.2,"chara":[{"id":270000,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200652,"motion":100,"pos":2}],"textRight":"难道不是你在跟着我吗？"},{"chara":[{"id":270000,"motion":400}],"textLeft":"难道你想嘴硬说这只是巧合吗？！"},{"chara":[{"id":270000}],"textLeft":"怎么可能会有这种事！"},{"chara":[{"id":270000}],"textLeft":"我每去一家店都会碰见你！"},{"chara":[{"id":270000,"motion":0}],"textLeft":"你到底是想去哪里啊？！"},{"chara":[{"id":200652,"motion":1}],"textRight":"我打算去车站前的@“Pink·Tapir”分店……"},{"chara":[{"id":200652}],"textRight":"那家店是做奖章巧克力出名的@品牌直销店。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000,"mouthOpen":1}],"textLeft":"[chara:270000:effect_emotion_surprise_0][se:7226_shock]什么？"},{"chara":[{"id":270000,"motion":300,"mouthOpen":0}],"textLeft":"我也要去那家店……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":270000}],"textLeft":"杏子你也想买粉色奖章巧克力吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":0}],"textRight":"原来你也喜欢吃那个啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":270000,"motion":200}],"textLeft":"何止是喜欢！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":270000}],"textLeft":"在我心中，那可是全宇宙@第二好吃的巧克力！"},{"chara":[{"id":200652,"motion":100}],"textRight":"那家的奖章巧克力因为保质期很长@所以不会打折出售。"},{"chara":[{"id":200652}],"textRight":"不过限定的巧克力就不一样了。"},{"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":270000,"motion":0}],"textLeft":"因为情人节一结束就没人会买了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652,"motion":200}],"textRight":"没错。"},{"chara":[{"id":200652}],"textRight":"按往年惯例，@应该马上就快打折了吧？"},{"chara":[{"id":270000,"motion":200}],"textLeft":"是的！"},{"chara":[{"id":200652,"motion":1}],"textRight":"今天没多少时间了，@也没法边走边吃。"},{"chara":[{"id":200652}],"textRight":"所以应该能便宜买到吧。"},{"chara":[{"id":200652}],"textRight":"其实我本来打算收集@情人节限定巧克力。"},{"chara":[{"id":200652}],"textRight":"所以在情人节这天，我最大的目标——"},{"chara":[{"id":200652}],"textRight":"就是“Pink·Tapir”这家店了。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":270000}],"textLeft":"唔……"},{"chara":[{"eyeClose":0,"id":270000}],"textLeft":"没想到你会对见泷原的@情人节消息掌握得如此透彻！"},{"chara":[{"id":270000,"motion":0}],"textLeft":"那我去每家店都能遇见你就是因为……"},{"chara":[{"id":200652,"motion":100}],"textRight":"要是我直接去买就太早了。"},{"chara":[{"id":200652}],"textRight":"所以我就在路上@随便逛了逛超市之类的地方……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000}],"textLeft":"去那种会提前搞促销的店里@看有什么特价商品吗！"},{"chara":[{"id":200652}],"textRight":"没错。"},{"chara":[{"id":200652,"motion":1}],"textRight":"你还挺懂的嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200652}],"textRight":"毕竟之后要去参加@麻美的巧克力派对。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200652}],"textRight":"所以我想在有限的时间里……"},{"chara":[{"id":200652}],"textRight":"尽量去各种店里看看！"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp.json","id":270000,"lipSynch":0,"motion":1}],"textLeft":"……@[wait:1.0]……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":270000,"motion":400},{"id":200652,"motion":0}],"textLeft":"[chara:270000:effect_emotion_angry_1][se:7218_anger]你到底有多少地方@都和我想到一块儿去了啊！"},{"chara":[{"id":270000}],"textLeft":"我们的确是同时@离开了“Sugar plum”……"},{"chara":[{"id":270000}],"textLeft":"如果想在路上尽量多逛几家店……"},{"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":270000,"motion":300}],"textLeft":"并在最后前往@“Pink·Tapir”的话……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200652,"motion":400}],"textRight":"那就只能这么走了吧？"},{"chara":[{"eyeClose":1,"id":270000,"lipSynch":0}],"textLeft":"……@[wait:1.0]……"},{"chara":[{"eyeClose":0,"id":270000}],"nameNarration":"渚","narration":"你真厉害！","narrationBg":"bg_adv_20221.jpg","narrationEffect":"in"},{"autoTurnLast":0.1,"turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000,"lipSynch":0,"motion":1}],"narrationEffect":"out","textLeft":"（没想到她和我的@行动路线完全相同……）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":270000,"lipSynch":0}],"textLeft":"（看来她也是个相当@优秀的巧克力猎人！）"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200652,"motion":1}],"textRight":"对了，刚才你说你还有事……","turnEffect":"stop"},{"autoTurnLast":0.01,"bg":"bg_adv_21221.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":270000}],"nameCenter":"渚","textCenter":"啊，我要先处理一点别的事再过去。","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_20221.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200652,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_051.exp.json","id":270000,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":200652}],"textRight":"其实就是去各家店看看促销活动吗？","turnChangeOut":"fadeOut"},{"chara":[{"id":270000,"motion":1}],"textLeft":"是的……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":270000,"motion":300}],"textLeft":"唉……没想到杏子@跟我有同样的计划。"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":270000,"motion":1,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"id":270000,"voice":"vo_char_2700_00_03","textHome":"是好久不见的见泷原的说。"}],"nameCenter":"渚","textCenter":"我好久没来见泷原了。","turnChangeOut":"fadeOut"},{"chara":[{"id":270000}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}