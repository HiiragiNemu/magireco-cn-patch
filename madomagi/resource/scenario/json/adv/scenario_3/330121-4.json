{"story":{"group_1":[{"bg":"bg_adv_14023.jpg","bgm":"bgm03_story10","chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700,"motion":0,"mouthOpen":1,"pos":2}],"textRight":"唔唔……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"你、你怎么回事……@怎么这么强……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":100,"pos":0}],"nameLeft":"纯美雨","textLeft":"你记好了，@这是苍碧拳。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"lipSynch":0,"motion":300}],"textLeft":"（虽然也有其他原因……）"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textLeft":"你们都给我乖乖收手，@明白了吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":800700}],"textRight":"明、明白了……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"我是明白了，@但这还没完呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":400}],"textLeft":"我不明白你的意思。@还想吃苦头吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"这份差事……@不会到此为止……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"我们不行的话，还有下一批人……@他们不行的话还有下下一批……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"他们一定会伺机摆平你们，@得到那块地……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301201,"motion":0}],"textLeft":"是谁指使你们的？"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700}],"textRight":"这我们可不知道……@我们只想拿到报酬……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":300}],"textLeft":"唉。@真麻烦……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":800700,"mouthOpen":1}],"textRight":"就算你嫌麻烦……@也还是会没完没了！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":800700,"mouthOpen":1}],"textBg":"shout","textRight":"怎么样！@活该！哈哈哈哈哈！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301201,"motion":200,"mouthOpen":1}],"flashEffect":"flashWhite1","textBg":"shout","textLeft":"哈！"},{"chara":[{"cheek":2,"effect":"shake","face":"mtn_ex_050.exp.json","id":800700,"mouthOpen":1}],"flashEffect":"flashRed1","se":"3001_chara_damage","textRight":"啊！？"},{"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":800700,"mouthOpen":0}],"textRight":"唔……咳……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textLeft":"[chara:800700:effect_fadeout]真烦人。@你就先睡一会儿吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"motion":300}],"textLeft":"不过……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301201,"motion":0}],"textLeft":"这件事确实@有点棘手啊……"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301201,"motion":0,"pos":1,"voice":"vo_char_3012_00_03","textHome":"沟通已经无法解决问题了，真是粗鲁的家伙。"}],"nameCenter":"纯美雨","textCenter":"谈判竟然没法解决问题，@他们也太粗暴了。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"id":301201,"motion":200}]},{"chara":[{"id":301201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}