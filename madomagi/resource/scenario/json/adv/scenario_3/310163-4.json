{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":300,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm05_event07","chara":[{"id":101601,"lipSynch":0}],"nameLeft":"御魂","nameRight":"十七夜","textRight":"…………","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/51028_tower_kanagi/memoria_1229.jpg","posX":0,"posY":150,"scale":1.5,"setVisible":1}],"turnChangeIn":"fadeIn"},{"nameNarration":"十七夜","narration":"以月咲为首","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":50.0,"narrationLineSpace":25.0,"turnChangeOut":"fadeOut"},{"narration":"许多东边的魔法少女都被玛吉斯拉拢@离开了我……"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101601,"motion":300,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":101601,"lipSynch":0}],"textRight":"…………","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_21143.jpg","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":101901,"motion":300}],"nameLeft":"月咲","textLeft":"东边的魔法少女们@应该和我有相同的想法……","turnChangeOut":"fadeOut"},{"chara":[{"id":101901}],"textLeft":"即使无法从东边的处境中解脱，@也想从魔女化的命运中解放。"},{"chara":[{"id":101901}],"textLeft":"为此……只有依靠玛吉斯才行……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101901,"motion":200}],"textLeft":"就算玛吉斯的手段是歪门邪道，@我们也是这么想的！"},{"autoTurnLast":1.0,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":300,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101601}],"nameLeft":"御魂","textRight":"正如月咲所言啊……","turnChangeOut":"fadeOut"},{"chara":[{"id":101700}],"textLeft":"正因为她们都@遭受过不合理的待遇……"},{"chara":[{"id":101700}],"textLeft":"所以才更想从这种处境中@获得救赎。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300}],"textLeft":"因此她们很容易就会@赞同玛吉斯的目的。"},{"chara":[{"id":101601,"motion":0}],"textRight":"是这样……吗……"},{"chara":[{"id":101601,"lipSynch":0}],"textRight":"…………"},{"chara":[{"id":101601,"motion":100}],"textRight":"我很喜欢生我养我的大东区。"},{"chara":[{"id":101601}],"textRight":"而且，不仅是大东……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":400}],"textRight":"我想让神滨里的所有人@都过上和平且平等的生活。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601}],"textRight":"我是这么想的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":200}],"textRight":"而且，我也明白。"},{"chara":[{"eyeClose":1,"id":101601}],"textRight":"我为此该怎么做。"},{"autoTurnLast":0.01,"bg":"bg_adv_17112.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":0,"pos":0,"soulGem":0},{"id":810000,"motion":0,"pos":2,"posX":40,"posY":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":101601,"motion":400}],"nameLeft":"十七夜","textLeft":"所以请你抹消掉@神滨的这段历史吧。","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_11061.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101700}],"nameLeft":"御魂","textLeft":"摧毁这浸透城市的历史……","turnChangeOut":"fadeOut"},{"chara":[{"id":101700,"motion":200}],"textLeft":"以及根植于这段历史上的神滨……"},{"chara":[{"id":101601,"motion":400}],"textRight":"是的。"},{"chara":[{"id":101601}],"textRight":"要想摧毁历史，"},{"chara":[{"id":101601}],"textRight":"必须先彻底摧毁神滨本身。"},{"chara":[{"id":101601,"motion":300}],"textRight":"失去一切的人们@将回归到无关家世和财产的"},{"chara":[{"id":101601}],"textRight":"平等公平的关系。"},{"chara":[{"id":101601,"motion":100}],"textRight":"在不得不相互携手、@共同努力的情况下，"},{"chara":[{"id":101601}],"textRight":"人们对历史和地区的偏见@也会逐渐消除吧。"},{"autoTurnLast":1.0,"bg":"bg_adv_21153.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":101601,"lipSynch":0}],"nameCenter":"十七夜","surround":"7003_wind","textCenter":"…………","turnChangeOut":"fadeOut"},{"nameNarration":"十七夜","narration":"然而……@我并没有摧毁神滨的力量","narrationBg":"black","narrationEffect":"in"},{"narration":"那我眼下能做好的只有两件事：@一是保护因魔女而陷入混乱的城市@二是帮助并保护留在东边的@魔法少女们"},{"chara":[{"id":101601,"lipSynch":0}],"narrationEffect":"out","textCenter":"…………"},{"chara":[{"id":101601,"lipSynch":0,"motion":300}],"textCenter":"（我要超越当下能力的极限。）","turnEffect":"thinking"},{"chara":[{"id":101601,"lipSynch":0}],"textCenter":"（如果可以做到，@那我就能实现夙愿。）"},{"chara":[{"id":101601,"lipSynch":0}],"textCenter":"（如果那一刻到来……）"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/51028_tower_kanagi/memoria_1229.jpg","posX":0,"posY":0,"setVisible":1}],"surround":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"nameNarration":"十七夜","narration":"为了这片我深爱的市街……@我会亲手@[textRed:摧毁神滨]","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bgm":"stop","narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":3.5,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101601,"motion":0,"pos":1,"voice":"vo_char_1016_00_05","textHome":"虽然空虚，但也无可奈何……@因为这座城市里只有舍弃的理由……"}],"nameCenter":"十七夜","textCenter":"虽然空虚，但也无可奈何……@因为这座城市里只有舍弃的理由……","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"id":101601,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":101601}]},{"chara":[{"id":101601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}