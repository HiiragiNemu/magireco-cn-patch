{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_13143.jpg","bgm":"bgm23_tokime02","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102601,"lipSynch":0}],"nameCenter":"众人","textCenter":"……","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102601},{"effect":"fadeout","id":102701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":100,"pos":1}],"nameCenter":"南津凉子","textCenter":"让大家久等了。@我决定好了。"},{"autoTurnLast":0.2,"chara":[{"id":305801,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":1,"pos":2}],"nameLeft":"南津凉子","nameRight":"静香","textRight":"只要是你选的，@我们都会接受。"},{"chara":[{"id":102501}],"textRight":"请讲吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":0}],"textLeft":"嗯。"},{"chara":[{"id":305801,"motion":1}],"textLeft":"首先，我和静香你们不一样。"},{"chara":[{"id":305801}],"textLeft":"我没有为日出之国许愿。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":100,"pos":2}],"nameRight":"沙绪","textRight":"这、这点上我也……"},{"chara":[{"eyeClose":1,"id":102701}],"textRight":"不过，你想说的不是这个吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":200}],"textLeft":"嗯，这虽然很伟大……"},{"chara":[{"id":305801}],"textLeft":"但我对时女“伟大”这点抱有疑问。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":0}],"textLeft":"老实说……"},{"chara":[{"id":305801}],"textLeft":"在村落看到那个名册后……"},{"chara":[{"id":305801}],"textLeft":"我多少感到自己和时女的价值观不合。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":1,"pos":2}],"nameRight":"千春","textRight":"那、那么……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801,"motion":100}],"textLeft":"我的妈妈也是如此。"},{"chara":[{"id":305801}],"textLeft":"和时女的魔法少女一样。@为了拯救日出之国，牺牲了生命……"},{"chara":[{"eyeClose":1,"id":305801}],"textLeft":"留下我一个人，@死掉了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":300,"pos":2}],"nameRight":"静香","textRight":"你吃了不少苦吧……"},{"chara":[{"id":102501}],"textRight":"你把这件事代入到了时女身上……@然后你对牺牲自我拯救他人的人……"},{"chara":[{"eyeClose":0,"id":305801,"motion":0}],"textLeft":"没错，@我怀疑这种做法。"},{"chara":[{"id":305801}],"textLeft":"甚至觉得不能接受。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":1,"pos":1}],"nameCenter":"南津凉子","textCenter":"但我现在能好好地面对了。"},{"chara":[{"id":305801}],"textCenter":"妈妈并不是想成为英雄。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801}],"textCenter":"她虽然被周围那些人捧成了英雄……"},{"chara":[{"id":305801,"motion":200}],"textCenter":"但她自己只是保护了@想保护的东西。"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":305801}],"textCenter":"仅此而已。"},{"chara":[{"id":305801,"motion":100}],"textCenter":"这一点上我也一样。"},{"chara":[{"id":305801}],"textCenter":"看到有困难的人就要帮助他，@而不会考虑太多。"},{"chara":[{"id":305801,"motion":1}],"textCenter":"我要保护想保护的东西，@也绝不宽恕罪行。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305801}],"textCenter":"我向丘比许愿时@也是这么想的……"},{"chara":[{"id":305801}],"textCenter":"妈妈的想法和我是一样的……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":200}],"textCenter":"这就是遗传吧。"},{"autoTurnLast":0.2,"bgm":"stop","chara":[{"id":305801,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"lipSynch":0,"motion":0,"pos":2}],"nameLeft":"南津凉子","nameRight":"静香","textRight":"……"},{"bgm":"bgm23_tokime01","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0}],"textLeft":"于是我就想……"},{"chara":[{"id":305801}],"textLeft":"供奉于时女的那些人……"},{"chara":[{"id":305801}],"textLeft":"说不定也是一样的想法吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":100}],"textLeft":"毕竟我和妈妈一样，@都流着时女的血。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":200}],"textRight":"结果还是得出这个结论了啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102501}],"textRight":"啊——真是绕了一大圈。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":1,"pos":2}],"nameRight":"千春","textRight":"唔，也就是说……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":1}],"textLeft":"嗯，虽然思维方式可能@多少有些差异……"},{"chara":[{"id":305801}],"textLeft":"但本质上来讲，@我和时女之间没有根本性的矛盾。"},{"chara":[{"id":305801,"motion":0}],"textLeft":"所以，请让我重新说一句。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":200}],"textLeft":"我会加入时女一族，@和你们共同奋战！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":200}],"textRight":"太好了～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102701,"motion":1,"pos":2}],"nameRight":"沙绪","textRight":"请多指教！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102501,"motion":100,"pos":2}],"nameRight":"静香","textRight":"我们很欢迎你哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":1}],"textLeft":"那么……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305801}],"textLeft":"今天去吃烤肉庆祝一下！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":100,"pos":2}],"nameRight":"千春","textRight":"太好啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":2}],"nameRight":"静香","textRight":"无论遇上什么你都要吃肉呢……"},{"autoTurnLast":2.0,"bg":"bg_adv_13131.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":305801}],"nameCenter":"南津凉子","surround":"7003_wind","textCenter":"妈妈，@我又来了。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":305801}],"textCenter":"我还挺孝顺的吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801,"motion":100}],"textCenter":"我决定了。@我要作为时女战斗下去。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305801}],"textCenter":"到底怎么做才是对的。@这种难题我还回答不上来……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305801,"motion":200}],"textCenter":"但我要为了保护自己重要的东西，@为了保护这个世界而战斗。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305801}],"textCenter":"这点是不会变的。"},{"chara":[{"id":305801,"motion":0}],"textCenter":"我要像妈妈一样，@好好加油。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305801}],"textCenter":"人人把你当英雄，可你只是个宠孩子的@妈妈，我要变得像你一样。"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_012.exp.json","id":305801,"motion":200,"pos":1,"voice":"vo_char_3058_00_05","textHome":"よし、何もかも完全に解決したな！"}],"nameCenter":"南津凉子","textCenter":"好，事情都解决了！","turnChangeOut":"fadeOut"},{"chara":[{"id":305801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}