{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21083.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102701}],"nameLeft":"沙绪","textLeft":"真的不用你俩陪我……","turnChangeOut":"fadeOut"},{"chara":[{"id":102501}],"nameRight":"静香","textRight":"那可不行。"},{"chara":[{"id":102501}],"textRight":"你要去神滨也还没告诉他们……"},{"chara":[{"id":102501}],"textRight":"至少跟他们说一声@物产展的事吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":200,"pos":2}],"nameRight":"千春","textRight":"是啊。"},{"chara":[{"id":102601}],"textRight":"万一他们不答应，@我们也会帮你说情的！"},{"chara":[{"id":102701,"motion":300}],"textLeft":"但是……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100,"pos":2}],"nameRight":"静香","textRight":"反正我们都跟到这里了嘛。"},{"chara":[{"id":102701,"lipSynch":0}],"textLeft":"……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102701},{"effect":"fadeout","id":102501}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":1}],"nameCenter":"沙绪的母亲","textCenter":"沙绪，你回来啦。"},{"chara":[{"id":800600}],"textCenter":"哎呀，静香和千春也一起来啦。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":1,"pos":2}],"nameLeft":"千春","textLeft":"打扰了！"},{"chara":[{"id":102501}],"nameRight":"静香","textRight":"久疏问候。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":0}],"nameLeft":"沙绪","textLeft":"我回来了……"},{"autoTurnLast":0.2,"chara":[{"id":102501},{"id":102701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"nameLeft":"静香","textLeft":"沙绪妈妈，其实……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600}],"nameRight":"沙绪的母亲","textRight":"有点晚了啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":400}],"textLeft":"咦？"},{"bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600}],"textRight":"啊，别在意，@我是在和沙绪讲话。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":0}],"textLeft":"这样啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0}],"textRight":"沙绪，@你不是说今天能早点回来吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":0}],"nameLeft":"沙绪","textLeft":"对不起……"},{"chara":[{"id":800600}],"textRight":"我没让你道歉。@我只是在担心你。"},{"chara":[{"id":800600}],"textRight":"说吧，为什么这么晚回来？"},{"chara":[{"id":102701,"motion":300}],"textLeft":"唔，@我有点事去了趟村落……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800600}],"textRight":"去村落？@你没告诉过我呀？"},{"chara":[{"id":102701,"motion":400}],"textLeft":"对不起，@我忘说了……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600}],"textRight":"都说了，@我不是让你道歉。"},{"chara":[{"id":800600}],"textRight":"你能跟我解释一下吗？"},{"chara":[{"id":102701,"motion":1}],"textLeft":"其实……"},{"autoTurnLast":1.0,"bg":"bg_adv_21083.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800600}],"textRight":"物产展啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":1,"pos":0}],"nameLeft":"千春","textLeft":"只要办得成功就能拯救村落了！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":0,"pos":0}],"nameLeft":"静香","textLeft":"能让沙绪和我们一起去吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"lipSynch":0,"motion":0}],"textRight":"……"},{"chara":[{"id":800600}],"textRight":"只有你们几个去城镇？@没有大人陪着？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":1,"pos":0}],"nameLeft":"沙绪","textLeft":"是、是的……"},{"chara":[{"id":800600}],"textRight":"这样啊……就你们几个初中生……"},{"chara":[{"id":102701}],"textLeft":"小千的妈妈已经联系了超市……"},{"chara":[{"id":800600}],"textRight":"问题不只是这个。"},{"chara":[{"id":800600}],"textRight":"怎么能让你们这些初中生去打工呢？"},{"chara":[{"id":800600}],"textRight":"而且也只有你们负责往镇上搬商品吧？"},{"chara":[{"id":800600}],"textRight":"又要搬重东西，@还要工作一整天……"},{"chara":[{"id":102701,"motion":100}],"textLeft":"不、不是打工，@我们只是去帮忙……"},{"chara":[{"id":800600}],"textRight":"你们是走着去超市的吧？@回来也晚……"},{"chara":[{"id":800600}],"textRight":"还有，超市附近安全吗？@治安怎么样？"},{"chara":[{"id":102701,"motion":300}],"textLeft":"这……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102701},{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":0,"pos":0}],"nameRight":"静香","textRight":"请、请听我说……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"nameLeft":"沙绪","textLeft":"抱歉，你们今天请先回去吧。"},{"chara":[{"id":102701}],"textLeft":"我一定会说服父母的。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102701},{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":300,"pos":0}],"nameLeft":"千春","textLeft":"好、好的。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"还要叫上你爸，@大家好好谈谈……"},{"chara":[{"id":102701,"motion":200}],"nameLeft":"沙绪","textLeft":"我知道了！"},{"chara":[{"id":102701,"motion":0}],"textLeft":"那先这样，@我们明天见！"},{"aut