{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_19223.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story19","chara":[{"id":800100}],"nameLeft":"","textLeft":"真好吃啊！","turnChangeOut":"fadeOut"},{"chara":[{"id":800300}],"nameRight":"","textRight":"嗯！我们下次再来吧！"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800300},{"effect":"fadeout","id":800100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":300902,"motion":400,"pos":1}],"nameCenter":"胡桃爱香","textCenter":"感谢您的光临！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":0}],"nameCenter":"胡桃爱香","textCenter":"接下来……"},{"autoTurnLast":0.2,"chara":[{"id":300902,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":200,"pos":0}],"nameLeft":"若菜纺","textLeft":"该准备关店了吧！@那就赶紧来收拾吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":200}],"nameRight":"胡桃爱香","textRight":"店里都打烊了，@你怎么还理所当然地坐在这里啊？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":1}],"textLeft":"别担心我啦！"},{"chara":[{"id":302401}],"textLeft":"我和妈妈联系过了，@让她不用准备我的晚饭！"},{"chara":[{"id":300902,"motion":1}],"textRight":"我才没有担心这些事啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0}],"textLeft":"可我也征求到了爱香爸爸的许可哦？"},{"chara":[{"eyeClose":1,"id":300902,"motion":300}],"textRight":"爸爸他到底在干什么啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"motion":300}],"textLeft":"真是的，我都过来帮你收拾了，@你怎么还这么冷淡啊！"},{"chara":[{"eyeClose":0,"id":300902,"motion":0}],"textRight":"因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":100}],"textRight":"你其实就是想要店里的剩饭吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":100}],"textLeft":"嘿嘿……被发现了吗。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":1}],"textRight":"我倒是很高兴可以不用浪费食材……"},{"chara":[{"id":300902}],"textRight":"可你每次都缠着我做饭，@这也让我挺不爽的啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302401,"motion":200}],"textLeft":"爱香！让我吃你做的饭嘛！@我肚子饿了！"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":300902,"motion":100}],"textRight":"好啦好啦！你就敞开了吃吧！"},{"chara":[{"id":300902}],"textRight":"可你得好好帮我收拾店里哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401,"motion":400}],"textLeft":"好！"},{"chara":[{"id":302401,"mouthOpen":1}],"nameNarration":"","narration":"嚼嚼嚼嚼@嚼嚼嚼嚼","narrationBg":"","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0,"mouthOpen":0}],"narrationEffect":"out","textLeft":"唔！这、这是……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":100}],"textLeft":"[chara:302401:effect_emotion_joy_0][se:7222_happy]实在是太好吃了……@简直就要升天了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":200}],"textRight":"还有别的感想吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":1}],"textLeft":"唔……我有点在意清汤的味道。"},{"chara":[{"id":302401}],"textLeft":"这里面放了洋葱吧？@感觉和平时用的不一样呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902}],"textRight":"你的味觉还是那么灵啊……@没错，我稍微换了一种食材。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"motion":100}],"textLeft":"这样的确好吃，@但跟你做的菜不太搭。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"motion":100}],"textRight":"这样啊……我明白了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302401}],"textLeft":"可这个确实很好吃！@真想在一大早就能喝到这个！"},{"chara":[{"id":302401,"motion":1}],"textLeft":"爱香真的好厉害呀……@而且你的厨艺每天都在进步……"},{"chara":[{"id":300902,"motion":1}],"textRight":"这其中有一半都是你的功劳哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0}],"textLeft":"真的吗！@[chara:302401:lipSynch_0][wait:0.8][chara:302401:cheek_0][chara:302401:face_mtn_ex_011.exp.json:motion_400][chara:302401:lipSynch_1]太好了！"},{"chara":[{"id":302401}],"textLeft":"我的建议终于起到作用了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300902,"lipSynch":0,"motion":200}],"textRight":"（纺还是老样子啊……）","turnEffect":"thinking"},{"chara":[{"id":300902,"lipSynch":0}],"textRight":"（只要说到食物就会露出@开心幸福的表情……）"},{"chara":[{"eyeClose":1,"id":300902,"lipSynch":0}],"textRight":"（只要能看见她的笑容，我就……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0}],"textLeft":"咦？你怎么不说话了？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302401,"motion":300}],"textLeft":"该不会是觉得我的建议很多余吧？"},{"chara":[{"eyeClose":0,"id":300902,"lipSynch":1,"motion":100}],"textRight":"才没有呢。"},{"chara":[{"id":300902}],"textRight":"你的建议可是给了我不少的帮助。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300902,"motion":200}],"textRight":"可想要提高烹饪水平@并没有那么简单……"},{"chara":[{"id":300902}],"textRight":"不是通过一两句建议就能得到改善的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302401,"motion":0}],"textLeft":"那你刚才怎么说@有一半是我的功劳呢？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":300902,"lipSynch":0,"motion":0}],"textRight":"……"},{"chara":[{"eyeClose":0,"id":300902,"lipSynch":1,"motion":300}],"textRight":"其实厨师都是很单纯的人。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":300902}],"textRight":"只要有人能打心底觉得@自己做的饭菜好吃……"},{"chara":[{"eyeClose":0,"id":300902,"motion":1}],"textRight":"他们就能从中获得动力。"},{"chara":[{"id":302401,"motion":400}],"textLeft":"原来是这样啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":200}],"textLeft":"那我也要继续加油，@夸你做的饭菜好吃！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300902,"motion":400}],"textRight":"纺，你的点评里本来就有@一大半都在说『好吃』了啊。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":100}],"textLeft":"因为你做的饭菜就是很好吃呀！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300902,"lipSynch":0}],"textRight":"……[wait:1.0][chara:300902:cheek_0][chara:300902:face_mtn_ex_010.exp.json:motion_0:eyeClose_1][chara:300902:lipSynch_1]你这人也真是的……"},{"chara":[{"eyeClose":0,"id":300902,"motion":100}],"textRight":"纺，你听我说。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302401,"motion":0}],"textLeft":"怎么了？"},{"chara":[{"id":300902}],"textRight":"今后我会让你吃我做的菜吃到腻的。"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":300902,"motion":200}],"textRight":"所以你要做好心理准备哦。"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":400}],"textLeft":"太好啦！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302401,"motion":100}],"textLeft":"只要是你做的东西，@不论多少我都吃得下……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401}],"textLeft":"所以你也不用客气，@就让我尽情享用你做的美食吧！"},{"autoTurnLast":0.1,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnFirst":1.4,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":302401,"motion":0,"pos":1,"voice":"vo_char_3024_00_05","textHome":"哈啊～…每天都能吃到美味的东西真是太幸福@了…！"}],"nameCenter":"若菜纺","textCenter":"啊～每天都能吃到美食，@我真是太幸福了！","turnChangeOut":"fadeOut"},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":302401}]},{"autoTurnFirst":3.1,"chara":[{"id":302401}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302401,"motion":100}]},{"chara":[{"id":302401}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}