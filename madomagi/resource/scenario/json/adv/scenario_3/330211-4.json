{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_11093.jpg","bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102201}],"nameRight":"光","textRight":"原来你是在烦恼这个啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102201,"motion":200}],"textRight":"看来我是来对了。"},{"chara":[{"id":302101,"motion":300}],"nameLeft":"铃鹿朔夜","textLeft":"结菜对你说了什么吗？"},{"chara":[{"id":102201,"motion":100}],"textRight":"她说她很担心你，才让我过来看看。"},{"chara":[{"id":102201,"motion":1}],"textRight":"看来她在见到你之后……"},{"chara":[{"id":102201}],"textRight":"就注意到你在烦恼了吧。"},{"chara":[{"eyeClose":1,"id":302101,"motion":0}],"textLeft":"这样啊……"},{"chara":[{"id":102201,"motion":0}],"textRight":"那么……你现在感觉怎么样？"},{"chara":[{"id":102201}],"textRight":"尽情奔跑之后，心情舒畅了吗？"},{"chara":[{"eyeClose":0,"id":302101,"motion":200}],"textLeft":"应该是这样……@可我并不这么觉得。"},{"chara":[{"id":302101}],"textLeft":"跑完之后是很有成就感，@可我还是不满足……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102201,"motion":400}],"textRight":"你是指还没跑够吗？"},{"chara":[{"id":302101,"motion":0}],"textLeft":"应该不是。"},{"chara":[{"id":302101}],"textLeft":"我的确很想跑步……"},{"chara":[{"id":302101,"motion":300}],"textLeft":"抱歉……我形容不出来。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102201,"motion":300}],"textRight":"是吗……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102201}],"textRight":"但也不能就这么算了。"},{"chara":[{"id":102201,"motion":200}],"textRight":"那只能这样了……"},{"chara":[{"id":102201}],"textRight":"我们去找个能理解你的人商量一下吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302101,"motion":400}],"textLeft":"那个人是指……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102201,"motion":100}],"textRight":"当然是指结菜了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102201,"motion":1}],"textRight":"不过今天已经很晚了，@我们改天再去吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json",