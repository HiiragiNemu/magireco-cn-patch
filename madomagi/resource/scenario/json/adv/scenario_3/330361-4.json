{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21025.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303601,"motion":400}],"nameCenter":"由贵真里爱","textCenter":"时间安排得有些紧……@但这项可不能删掉吧？","turnChangeOut":"fadeOut"},{"chara":[{"id":303601}],"nameCenter":"由贵真里爱","textCenter":"还有……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800200,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"nameLeft":"","textLeft":"真里爱大人，你在干什么呢？"},{"chara":[{"id":800300}],"nameRight":"","textRight":"这是最近刚建好的地方吧？@你是要去这里约会吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200}],"nameLeft":"","textLeft":"这是很适合亲子游的地方吧。"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300,"pos":2}],"nameRight":"","textRight":"很适合亲子游……"},{"chara":[{"id":800300}],"nameRight":"","textRight":"你是要和去世丈夫留下的@私生子一起去吗？"},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303601,"motion":0,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"好了～别再说啦！"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303601,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"你们每次都在玩这个@把我当成寡妇的游戏……"},{"chara":[{"id":303601,"motion":200}],"nameLeft":"由贵真里爱","textLeft":"这到底是在干嘛呀？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":2}],"nameRight":"","textRight":"其实最近还新加了设定，@是住小区的已婚女性哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303601}],"nameLeft":"由贵真里爱","textLeft":"什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":300}],"nameLeft":"由贵真里爱","textLeft":"我看起来有那么老吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"与其说是因为显老，不如说是因为@你总是给人充满母性的感觉。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":2}],"nameRight":"","textRight":"毕竟在真里爱大人面前，@我们就都是小孩子嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"我想当真里爱大人的小孩！@想对真里爱大人撒娇！"},{"chara":[{"eyeClose":1,"id":303601}],"nameLeft":"由贵真里爱","textLeft":"原来这都得怪我啊……"},{"chara":[{"id":303601,"motion":0}],"nameLeft":"由贵真里爱","textLeft":"我明白了，那就这样吧。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":1}],"nameLeft":"由贵真里爱","textLeft":"我来当你们的母亲……@你们觉得如何？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"什么？！"},{"chara":[{"id":303601,"pos":1}],"nameCenter":"由贵真里爱","textCenter":"快叫我妈妈呀。"},{"chara":[{"id":800300}],"nameRight":"","textRight":"咦！什么？！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601}],"nameCenter":"由贵真里爱","textCenter":"呵呵，这不是你自己说的吗？"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":800300,"pos":2}],"nameRight":"","textRight":"妈、妈妈……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800200,"motion":0,"pos":0}],"nameLeft":"","textLeft":"你都脸红了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800300,"pos":2}],"nameRight":"","textRight":"真是说不过真里爱大人啊。"},{"chara":[{"id":303601,"motion":100,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"哎呀，不继续说下去了吗？@呵呵，真是遗憾呀。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800200,"motion":0,"pos":2}],"nameRight":"","textRight":"所以你这到底是什么计划呢？"},{"chara":[{"id":303601,"motion":1}],"nameLeft":"由贵真里爱","textLeft":"在我兼职的地方有一对母子，@他们打算在周末一起出去玩。"},{"chara":[{"id":303601}],"nameLeft":"由贵真里爱","textLeft":"所以我现在是在帮他们制定计划。"},{"chara":[{"id":303601}],"nameLeft":"由贵真里爱","textLeft":"就在想有没有什么地方能让@他们母子一起放松学习。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"原来在托儿所打工还会做这些事啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800200,"motion":0,"pos":2}],"nameRight":"","textRight":"那这段时间的时薪是多少呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303601,"motion":0,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"不收费的哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"这只不过是我自己揽的活。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"你在免费帮别人做事？！@你为什么要这么做啊？！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601,"motion":300,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"要说为什么……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303601,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"可他们这么困扰，我哪能置之不理呢。"},{"autoTurnLast":1.0,"bg":"bg_adv_21483.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.5,"bgm":"bgm01_anime02","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":2}],"nameRight":"","textRight":"晚上好。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":800100,"pos":0}],"nameLeft":"","textLeft":"啊，是小慎的妈妈啊，晚上好。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800100,"pos":0}],"nameLeft":"","textLeft":"小慎～你妈妈来接你了哦～"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":800100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":0,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"晚上好。"},{"chara":[{"id":801000}],"nameRight":"","textRight":"晚上好，真里爱。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":1,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"我已经帮您制定好计划了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":801000,"pos":2}],"nameRight":"","textRight":"真的吗？！我可以看看吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":303601,"pos":0}],"nameRight":"","textRight":"哇～你做得好认真呀。"},{"chara":[{"id":801000}],"nameRight":"","textRight":"原来现在还有这种地方啊～"},{"chara":[{"id":801000}],"nameRight":"","textRight":"谢谢你！"},{"chara":[{"id":801000}],"nameRight":"","textRight":"我们一定能度过一个完美的周末！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":801000,"pos":2}],"nameRight":"","textRight":"我一直担心自己一个人能不能做好。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"pos":2}],"nameRight":"","textRight":"但我现在真的很期待周末！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303601,"motion":400,"pos":0}],"nameLeft":"由贵真里爱","textLeft":"嗯，周末一定要玩得开心哦！"},{"autoTurnFirst":2.6,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303601,"motion":0,"pos":1,"voice":"vo_char_3036_00_03","textHome":"解决了一件事…的话就好了…"}],"nameCenter":"由贵真里爱","textCenter":"希望这件事能就这样圆满结束啊……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303601}]},{"chara":[{"id":303601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}