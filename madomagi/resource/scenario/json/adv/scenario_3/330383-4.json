{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21026.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303901}],"nameRight":"三穗野星罗","textRight":"没想到那里挖开之后@真的是一座古墓呢。","turnChangeOut":"fadeOut"},{"chara":[{"id":303801}],"nameLeft":"古町美仓","textLeft":"没错。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":2}],"nameRight":"吉良手鞠","textRight":"而且规模还那么庞大。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":1,"pos":2}],"nameRight":"三穗野星罗","textRight":"现在到处都在讨论这件事，@没想到这竟然是一位女高中生发现的。"},{"chara":[{"id":303901}],"textRight":"古町学姐也在一夜之间成为了名人啊。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303801,"motion":100}],"textLeft":"那是因为市议员故意@把消息透露给了媒体……"},{"chara":[{"id":303801}],"textLeft":"他们说只要古坟话题被炒起来，就能@让道路施工计划从中止变为停止了……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":2}],"nameRight":"吉良手鞠","textRight":"「让教授也佩服不已的女高中生……」"},{"chara":[{"eyeClose":0,"id":303801}],"textLeft":"别说了，太丢人了。"},{"chara":[{"id":303801}],"textLeft":"不过也多亏了这件事，@才能在完好的状态下发掘墓室。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":0}],"textLeft":"就结果而言也不错。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":303901,"motion":0,"pos":2}],"nameRight":"三穗野星罗","textRight":"而我们也正好趁机@借用古町学姐的名声……"},{"chara":[{"id":303901}],"textRight":"以历史研究社的名义，@成立了一个轻松自由的社团。"},{"chara":[{"id":303901,"motion":100}],"textRight":"所以我也觉得很不错哦！"},{"chara":[{"id":303801,"lipSynch":0,"motion":1}],"textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303901,"motion":0}],"textRight":"那份报告书很有趣吗？"},{"chara":[{"id":303801}],"textLeft":"我是觉得挺有趣的，@你要看看吗？"},{"chara":[{"id":303801,"motion":0}],"textLeft":"这里还有最新的内部照片哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303901,"motion":1}],"textRight":"真漂亮啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304001,"motion":100,"pos":2}],"nameRight":"吉良手鞠","textRight":"这些随葬品和壁画的保存状态@几乎可以说是完美啊。"},{"chara":[{"id":303801}],"textLeft":"对吧？"},{"chara":[{"id":303801,"motion":200}],"textLeft":"没想到能保存得如此完整，@这在学界也引起了巨大的轰动。"},{"chara":[{"id":303801,"motion":400}],"textLeft":"哇！我还是第一次看到这个随葬品。"},{"chara":[{"eyeClose":1,"id":303801}],"textLeft":"幸好它们没被破坏掉……"},{"chara":[{"id":304001,"lipSynch":0}],"textRight":"……"},{"chara":[{"id":304001,"lipSynch":0,"motion":1}],"textRight":"（这些1000年以前的东西……）","turnEffect":"thinking"},{"chara":[{"id":304001,"lipSynch":0}],"textRight":"（真的会保存得这么完整吗？）"},{"chara":[{"id":304001,"lipSynch":0,"motion":200}],"textRight":"（这一连串的事件里面……）"},{"bgm":"stop","chara":[{"id":304001,"lipSynch":0}],"textRight":"（到底又有哪些是@丘比创造的奇迹呢？）"},{"bgm":"bgm03_story05","chara":[{"eyeClose":0,"id":303801,"motion":0}],"textLeft":"这件事也有吉良的功劳哦。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304001}],"textRight":"嗯？这不都是丘比做的吗？"},{"chara":[{"eyeClose":1,"id":303801}],"textLeft":"要是我当时选择了放弃，@肯定就没法挖掘了。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":1}],"textRight":"啊……这倒也是。"},{"chara":[{"eyeClose":0,"id":303801}],"textLeft":"都是因为吉良愿意相信我，@这件事才出现了转机。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303801}],"textLeft":"所以我想要对你说声谢谢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":0}],"textRight":"不客气。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":303901,"motion":1,"pos":2}],"nameRight":"三穗野星罗","textRight":"太好了！"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":0,"pos":1,"voice":"vo_char_3038_00_05","textHome":"请多关照，“历史研究部”"}],"nameCenter":"古町美仓","textCenter":"还请多多关照「历史研究社」咯。","turnChangeOut":"fadeOut"},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303801}]},{"chara":[{"id":303801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}