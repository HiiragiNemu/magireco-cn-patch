{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21202.jpg","bgm":"bgm03_story19","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304301,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":304301}],"nameCenter":"万年樱的传闻","textCenter":"｜打扰了。｜","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":304301,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":0,"pos":0}],"nameLeft":"忧","nameRight":"万年樱的传闻","textLeft":"啊，樱子！@你今天回来得好晚啊。"},{"chara":[{"id":101501}],"textLeft":"发生什么事了吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100101,"lipSynch":0,"motion":301,"pos":0}],"nameLeft":"彩羽","textLeft":"…………"},{"chara":[{"id":304301,"motion":100}],"textRight":"｜嗯。@我交到了朋友。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":0}],"textLeft":"[chara:100101:effect_emotion_surprise_0][se:7226_shock]诶？@你交到了朋友？"},{"chara":[{"id":304301}],"textRight":"｜嗯，彩羽说得对，@去学校挺开心的。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101501,"motion":100,"pos":0}],"nameLeft":"忧","textLeft":"那太好了！@是怎样的人呀？"},{"chara":[{"id":304301,"motion":200}],"textRight":"｜观鸟令，是新闻社的。@就读于南凪自由学园初中三年级。｜"},{"chara":[{"id":304301}],"textRight":"｜她找我去当观鸟报的吉祥物。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101501}],"textLeft":"吉祥物？"},{"chara":[{"id":304301,"motion":0}],"textRight":"｜另外我们还约好要一起过午休。｜"},{"chara":[{"id":304301}],"textRight":"｜一起过午休的就是朋友，@这样理解对吗？｜"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101501,"motion":200}],"textLeft":"没错，这不是挺好的嘛！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100101,"motion":200,"pos":0}],"nameLeft":"彩羽","textLeft":"我想想，我记得她是魔法少女吧？@以前当过白翼的……"},{"chara":[{"id":304301}],"textRight":"｜嗯。｜"},{"chara":[{"id":304301,"motion":100}],"textRight":"｜说起来，她给了我一封信，@让我给监护人。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101}],"textLeft":"信……"},{"chara":[{"id":100101,"motion":0}],"nameNarration":"","narration":"打开","narrationBg":"narration","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100101,"motion":0}],"nameNarration":"令的信","narration":"致樱子的监护者们","narrationBg":"bg_adv_narration.jpg","narrationHAlignment":"left","narrationPosX":180.0},{"narration":"我明白你们想让她学习如何适应社会@但希望你们能对她多进行一点情操教育后@再让她进入社会@勉强她去上学可不是个好主意"},{"narration":"还有，你们好像有去拜托过雏乃@但那个人自己也有很多要忙的事@把这份工作强塞给她也不太好吧"},{"narration":"看在同为魔法少女的份上@我今后也会多照看樱子的"},{"narration":"作为条件@她将作为新闻部吉祥物进行活动@你们可别抱怨哦@我可是征得了本人同意的"},{"chara":[{"id":100101,"motion":301}],"narrationEffect":"out","textLeft":"她说得对，我无话可说……@强加给别人确实不好……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101501}],"nameRight":"忧","textRight":"姐姐？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304301,"motion":0,"pos":2}],"nameRight":"万年樱的传闻","textRight":"｜她说这是封让你们允许我加入新闻部@的信，不是吗？｜"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100101,"motion":0}],"textLeft":"嗯。"},{"chara":[{"id":100101}],"textLeft":"是这样没错，只是绕了点弯子……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101501,"motion":200,"pos":0}],"nameLeft":"忧","textLeft":"你交到了一个好朋友，真是太好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304301,"motion":100}],"textRight":"｜嗯。｜"},{"chara":[{"id":304301}],"textRight":"｜今天，令给我看了她的观鸟报。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304301,"motion":1}],"textRight":"｜我喜欢音梦的文章，@令的文章我也喜欢。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304301}],"textRight":"｜所以我才回来晚了……｜"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100101,"motion":200,"pos":0}],"nameLeft":"彩羽","textLeft":"樱子。"},{"chara":[{"id":100101}],"textLeft":"你现在不讨厌去学校了吗？"},{"chara":[{"id":304301,"motion":0}],"textRight":"｜嗯。｜"},{"chara":[{"id":304301}],"textRight":"｜去学校能看没看过的观鸟报，｜"},{"chara":[{"id":304301,"motion":200}],"textRight":"｜而且樱子的什么什么专栏……｜"},{"chara":[{"id":304301}],"textRight":"｜还要定好内容才行。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100101,"motion":100}],"textLeft":"这样啊……你有想做的事了呢。"},{"chara":[{"id":304301,"motion":300}],"textRight":"｜也不知道是想做还是不得不做。｜"},{"chara":[{"id":304301}],"textRight":"｜我还不太明白。｜"},{"chara":[{"id":304301,"motion":0}],"textRight":"｜但是……@我觉得雏乃说的是对的。｜"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101501,"motion":100,"pos":0}],"nameLeft":"忧","textLeft":"她说了什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304301,"motion":100}],"textRight":"｜她说交到朋友的话，@学校生活可能也会有趣起来。｜"},{"autoTurnFirst":5.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304301,"motion":300,"pos":1,"voice":"vo_char_3043_00_05","textHome":"｜那样的人，可以称之为朋友吗？｜"}],"nameCenter":"万年樱的传闻","textCenter":"｜那样的人就叫朋友吗？｜","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":304301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}