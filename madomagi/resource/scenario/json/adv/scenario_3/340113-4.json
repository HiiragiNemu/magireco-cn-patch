{"story":{"group_1":[{"bg":"bg_adv_19221.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0,"pos":1}],"nameCenter":"都雏乃","textCenter":"灵感枯竭的我，@在来这里之前去过公园……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"textCenter":"一边走，一边漫无边际地思考……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":200}],"textCenter":"但还是没有想法！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"textCenter":"就在我长叹了一口气时，@听到了那个声音。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301,"motion":0}],"nameNarration":"牧薰","narration":"我是牧薰！@请多指教！！","narrationBg":"bg_adv_21141.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300301}],"narrationEffect":"out","textCenter":"即使离得很远，@也能感受到那种@运动系的热情活力……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300301,"motion":300}],"textCenter":"那份热情！@怎么就不能运用在我的实验中呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301}],"textCenter":"就是这份渴望促使我记住她了！@嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401101,"motion":400,"pos":0},{"id":300301,"pos":2}],"nameLeft":"和美","textLeft":"是、是哪里的公园！？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":0}],"nameRight":"都雏乃","textRight":"啊，正好手头有纸和笔，@我画个简易地图吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300301,"motion":200}],"textRight":"在这里这样走，@再那样走……嗯，就是这里！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401101,"motion":100}],"textLeft":"是这里啊！@谢谢你！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300902,"motion":100,"pos":2}],"nameRight":"胡桃爱香","textRight":"和美，那你快走吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401101,"motion":0}],"textLeft":"嗯！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401101,"motion":1}],"textLeft":"那个……我还会再来的！@[chara:401101:lipSynch_0][wait:0.8][chara:401101:cheek_0][chara:401101:face_mtn_ex_011.exp.json][chara:4011