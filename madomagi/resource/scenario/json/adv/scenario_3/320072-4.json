{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_14061.jpg","bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":200701,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":200501}],"nameLeft":"麻美","nameRight":"渚","textLeft":"我……","turnChangeOut":"fadeOut"},{"chara":[{"id":200501}],"textLeft":"之前在这个城市做了件很失败的事……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200701}],"textRight":"失败……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200701,"lipSynch":0}],"textRight":"（会不会@和那场“骚动”有关呢？）","turnEffect":"thinking"},{"chara":[{"eyeClose":1,"id":200501,"motion":1}],"textLeft":"认为自己是正确的这件事，@真的是正确的吗……","turnEffect":"stop"},{"chara":[{"id":200501}],"textLeft":"如果无法用正确的方法来拯救一切，@就必须全都放弃吗……"},{"chara":[{"cheek":1,"id":200501}],"textLeft":"遇到这种情况……我该怎么办呢……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200501,"motion":400}],"textLeft":"啊，抱歉。@你肯定听不懂我在说什么吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200701,"motion":0}],"textRight":"没关系的说！你继续说下去！"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200501,"motion":0}],"textLeft":"嗯。"},{"chara":[{"id":200501,"motion":100}],"textLeft":"我想……改写自己犯下的错误……"},{"chara":[{"id":200501}],"textLeft":"拯救那些被牵扯进来的人……"},{"chara":[{"id":200501}],"textLeft":"还有那些与之相关的人……"},{"chara":[{"eyeClose":1,"id":200501,"motion":200}],"textLeft":"但结果……反而犯下了更大的错误。"},{"chara":[{"id":200501}],"textLeft":"我原本想帮助大家，@结果反倒给大家添了麻烦。"},{"chara":[{"eyeClose":0,"id":200501}],"textLeft":"你一定觉得我很傻吧……@我真是没脸见人。"},{"chara":[{"id":200501,"motion":0}],"textLeft":"到底是为什么呢……"},{"chara":[{"id":200501}],"textLeft":"我明明也调整过自己的情绪，@但依然放不下那件事……"},{"chara":[{"id":200501,"motion":300}],"textLeft":"所以现在才来到这个城市……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200701,"motion":300}],"textRight":"这样呀……"},{"chara":[{"eyeClose":1,"id":200501,"lipSynch":0}],"textLeft":"…………"},{"bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":200501,"motion":400}],"textBg":"shout","textLeft":"啊，还是当我没说好了！@把我刚才说的都忘了吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200501}],"textLeft":"真是的，我都对小渚说了些什么呀……"},{"chara":[{"id":200501,"motion":0}],"textLeft":"抱歉！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200701,"motion":0}],"textRight":"啊～@你又道歉啦～"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200501}],"textLeft":"啊……"},{"bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200701,"motion":100}],"textRight":"啊哈哈！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200501}],"textLeft":"一不小心又道歉了……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200501,"motion":100}],"textLeft":"那我请小渚吃冰淇淋吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200701}],"textRight":"真的吗？@[chara:200701:lipSynch_0][wait:0.8][chara:200701:motion_200][chara:200701:effect_emotion_joy_0][se:7222_happy][chara:200701:cheek_0][chara:200701:face_mtn_ex_011.exp.json][chara:200701:lipSynch_1]太好了的说！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200701}],"textRight":"我想吃奶酪奶油味的冰淇淋的说！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200501}],"textLeft":"奶酪奶油？@原来你喜欢奶酪啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200701,"motion":100}],"textRight":"[chara:200701:effect_emotion_joy_0][se:7222_happy]没错的说！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200501,"motion":200}],"textLeft":"嗯！那我们走吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200701}],"textRight":"去吃冰淇淋啦！"},{"bgm":"stop","nameNarration":"渚","narration":"这件事要慢慢来@没法让她一口气全都告诉小渚的说","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"不过不出所料@麻美一定是在这个城市@经历了些什么……"},{"narration":"那么当时到底发生什么了……的说"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":4.7,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200701,"motion":300,"pos":1,"voice":"vo_char_2007_00_04","textHome":"心里总感觉乱乱的……好担心的说……"}],"nameCenter":"渚","textCenter":"总感觉心里有点忐忑不安……@好担心的说……","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"id":200701,"motion":0}]},{"chara":[{"id":200701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}