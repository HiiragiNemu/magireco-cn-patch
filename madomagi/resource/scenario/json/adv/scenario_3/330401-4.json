{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21061.jpg","turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801,"motion":0,"pos":2}],"nameNarration":"吉良手鞠","narration":"第二天早上……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"bgm":"bgm03_story19","chara":[{"id":304001,"motion":300}],"nameLeft":"吉良手鞠","narrationEffect":"out","textLeft":"大清早的就好困啊……"},{"chara":[{"id":303801,"motion":300}],"nameRight":"古町美仓","textRight":"那当然了。"},{"chara":[{"id":303801}],"textRight":"我们不仅要上学，还要去狩猎魔女。"},{"chara":[{"id":304001,"motion":200}],"textLeft":"再加上我们俩都要跨区上学。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":101}],"textRight":"不过吉良你刚才不是@一直在电车上看书吗？"},{"chara":[{"id":303801}],"textRight":"既然困的话，你怎么不睡一会儿呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":1}],"textLeft":"不是说读书用的是另一个胃？@还是另一个脑子来着？"},{"chara":[{"id":303801,"motion":0}],"textRight":"好吧……"},{"chara":[{"id":100100,"motion":0}],"textLeft":"而且我昨晚一直在写东西。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303801,"motion":400}],"textRight":"[chara:303801:effect_emotion_surprise_0][se:7226_shock]咦，你没睡觉吗？！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":100}],"textLeft":"因为我想尝试用羽毛笔写字的感觉。"},{"chara":[{"id":303801,"motion":1}],"textRight":"羽毛笔？"},{"autoTurnLast":1.0,"item":[{"path":"resource/scenario/img/51078_storyselect_history/memoria_1427.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303801}],"nameNarration":"吉良手鞠","narration":"―手鞠―@是的……准确来说这并不是羽毛笔@而是金属制的仿制羽毛笔","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":0}],"narration":"―手鞠―@在追求古今文学的过程中@我应该参考一下文豪们的创作环境"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":0}],"narration":"―手鞠―@而且也要尽量使用贴近@那个年代的书写用具进行创作……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":0}],"narration":"―手鞠―@只要能熟练地运用这支笔@我就能明白……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":0}],"narration":"―手鞠―@当时的文豪们是以怎样的想法、思绪@以及感受才创作出了那些字句"},{"autoTurnLast":1.0,"bg":"bg_adv_21061.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":1,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":303801}],"item":[{"path":"resource/scenario/img/31301_iroha_yachiyo_story/memoria_1390.jpg","visible":"hide"}],"textRight":"也就是说，@吉良你现在正沉迷于近代文学吗。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304001,"motion":400}],"textLeft":"[chara:304001:effect_emotion_surprise_0][se:7226_shock]你怎么知道的？！"},{"chara":[{"id":303801,"motion":100}],"textRight":"如果是更早的文学作品，@你就不会用金属制的笔。"},{"chara":[{"id":303801}],"textRight":"而是用中世纪真正的羽毛笔或羊皮纸。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"lipSynch":0,"motion":200}],"textLeft":"（她观察得可真敏锐啊……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303801,"motion":200}],"textRight":"而且吉良你也因为这个理由@买过和歌用的毛笔吧？"},{"chara":[{"id":304001,"motion":100}],"textLeft":"是的，而且我现在也在用。"},{"chara":[{"id":304001}],"textLeft":"虽然和歌的世界非常博大精深……"},{"chara":[{"id":304001}],"textLeft":"不过现在我更想体验近代文学的魅力。"},{"chara":[{"id":303801,"motion":0}],"textRight":"可你的武器是毛笔啊？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303801}],"textRight":"那你的魔法可能和书写工具没关系吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":100}],"textRight":"而且我想你的能力……"},{"chara":[{"id":303801}],"textRight":"也不会是流畅地阅读外国作品原文。"},{"chara":[{"id":303801}],"textRight":"也不是巧妙地写出@出众且高雅的拟古文。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304001,"motion":400}],"textLeft":"为什么这么说呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303801,"motion":200}],"textRight":"因为你兴趣变化得太快了。"},{"chara":[{"id":303801}],"textRight":"所以我不觉得你的能力@会固定于某个具体的领域。"},{"chara":[{"id":303801,"motion":0}],"textRight":"因为说不定你明天就会@沉迷于文学评论了呀？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":300}],"textLeft":"你说得对，@我的文学阅历又怎能少了文学评论呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801}],"textRight":"打住！再不快走就要迟到了哦。"},{"autoTurnLast":0.01,"bg":"bg_adv_21024.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"chara":[{"id":304001}],"nameNarration":"吉良手鞠","narration":"放学后……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"enableSkipAutoTurn":1,"nameNarration":"","narration":"下课铃声～响起～～","narrationBg":"","narrationEffect":"in","surround":"7104_schoolbell","turnChangeOut":"fadeOut"},{"bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":303901,"lipSynch":0,"motion":300,"pos":2}],"enableSkipAutoTurn":0,"nameRight":"三穗野星罗","narrationEffect":"out","surround":"stop","textRight":"……"},{"chara":[{"id":304001}],"nameLeft":"吉良手鞠","textLeft":"你怎么一脸严肃啊？"},{"chara":[{"id":303901}],"textRight":"其实……"},{"chara":[{"id":303901}],"textRight":"我有点在意昨天八云说的@那个魔法少女团体的事情……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":1,"pos":2}],"nameRight":"古町美仓","textRight":"那个团体基本上是互帮互助吧。"},{"chara":[{"id":303801}],"textRight":"她们会平分悲叹之种，@互换情报。"},{"chara":[{"id":303801}],"textRight":"既然有那么多人加入，@就证明这个团体能带来好处。"},{"chara":[{"id":304001,"motion":300}],"textLeft":"我是不太想加入……毕竟我很怕生。"},{"chara":[{"id":304001}],"textLeft":"我还是想维持三人合作的状态。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303901,"motion":200,"pos":2}],"nameRight":"三穗野星罗","textRight":"那我们就继续这样战斗吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303801,"motion":100,"pos":2}],"nameRight":"古町美仓","textRight":"那就在加入组织之前@努力尽自己所能吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304001,"motion":400}],"textLeft":"谢谢。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303801,"motion":300}],"textRight":"但是……"},{"chara":[{"id":303801}],"textRight":"为此我们也要积累更多经验，@变得更加强大才行。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304001,"lipSynch":0,"motion":200}],"textLeft":"……"},{"chara":[{"id":304001,"motion":100}],"textLeft":"那我们……"},{"chara":[{"id":304001}],"textLeft":"要不要去挑战@八云说的那个「无尽镜界」呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303901,"motion":100,"pos":2}],"nameRight":"三穗野星罗","textRight":"好啊！今天就去那里吧！"},{"autoTurnFirst":4.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304001,"motion":100,"pos":1,"voice":"vo_char_3040_00_03","textHome":"任何事物，若没有亲历过遍不会知道。"}],"nameCenter":"吉良手鞠","textCenter":"凡事都要尝试啊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":304001}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}