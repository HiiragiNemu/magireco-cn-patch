{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_21241.jpg","bgm":"bgm05_event07","chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp.json","id":103900,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":103900,"motion":200}],"nameLeft":"月出里","textLeft":"呼呼呼呣呣！","turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":100601,"lipSynch":0,"motion":100}],"nameCenter":"美冬","textCenter":"（那句话是在告诉夜鹤，）","turnChangeOut":"fadeOut"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（「你被跟踪了」吧。）"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100601,"lipSynch":0}],"textCenter":"（我现在也能给她们施加幻觉，@借机脱身……）"},{"chara":[{"id":100601,"lipSynch":0,"motion":1}],"textCenter":"（不，那样不行。）"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（这样就不能调查她们了，@和我最初的目的相悖。）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":0}],"textCenter":"（我还没弄清她那些难以理解的@行动是怎么回事……）"},{"chara":[{"id":100601,"lipSynch":0,"motion":0}],"textCenter":"（而且，也确实感到@跟踪和观察的作用有限……）"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"lipSynch":0}],"textCenter":"（现在还是老实点放弃……@不逃跑，隐藏身份……）"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103900,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":0}],"nameRight":"月出里","textRight":"呼呣呼呣呼呣呼呼！"},{"nameLeft":"夜鹤","textLeft":"请问……你是在跟踪我吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":200}],"textLeft":"月出里说……@[chara:104000:lipSynch_0][wait:1.5][chara:104000:cheek_0:face_mtn_ex_000.exp.json][chara:104000:lipSynch_1]你一直在盯着这边看。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":1}],"textLeft":"请问……是出于什么目的……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"美冬","textRight":"……"},{"textRight":"关于跟踪一事，@我向你道歉。"},{"chara":[{"eyeClose":1,"id":100601,"motion":1}],"textRight":"非常抱歉。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100601}],"textRight":"其实我想和夜鹤……"},{"chara":[{"id":100601,"motion":0}],"textRight":"想和你们聊聊，@才会选择跟踪。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}],"textLeft":"聊聊吗……"},{"chara":[{"id":104000,"motion":100}],"textLeft":"那向我搭话就好了啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000}],"textLeft":"难道说，我看上去很难搭话吗？"},{"chara":[{"id":104000,"motion":300}],"textLeft":"我已经在很努力地@表现得平易近人了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"motion":400}],"textRight":"没、没这回事。请你放心。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100601}],"textRight":"但是……"},{"chara":[{"id":100601,"lipSynch":0}],"textRight":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"莉薇娅","textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":104101,"motion":400}],"textLeft":"对了，月出里。@我疏忽了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103900,"motion":300,"pos":2}],"nameRight":"月出里","textRight":"呼？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":200}],"textLeft":"我们还有事没干呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":104000,"motion":0,"pos":2}],"nameRight":"夜鹤","textRight":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":103900,"motion":200,"pos":2}],"nameRight":"月出里","textRight":"呼呼呼？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"motion":100}],"textLeft":"没错没错，你想起来了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":1,"pos":2}],"nameRight":"夜鹤","textRight":"不，她说的是@「有这回事吗？」……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":0}],"textLeft":"总之……夜鹤，你来跟她聊聊吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}],"textRight":"咦……"},{"chara":[{"eyeClose":1,"id":104000,"lipSynch":0},{"id":104101,"motion":1}],"textRight":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"lipSynch":0}],"textLeft":"……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":100}],"textRight":"我、我明白了……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":104101},{"effect":"fadeout","id":104000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100601,"lipSynch":0,"motion":400,"pos":1}],"textCenter":"（啊！@刚才那番对话中……）"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"lipSynch":0}],"textCenter":"（恐怕用心灵感应说了什么吧！）"},{"chara":[{"id":100601,"lipSynch":0,"motion":1}],"textCenter":"（是密约？还是作战计划？@好啊……就让我瞧瞧吧。）"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":100601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp.json","id":103900,"motion":1,"pos":2}],"textLeft":"那就拜托你了。"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":104101},{"effect":"fadeout","id":103900}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"motion":0,"pos":2}],"nameLeft":"夜鹤","textLeft":"那、那我们过去吧。@我来带路……"},{"chara":[{"id":100601,"motion":100}],"nameRight":"美冬","textRight":"是的，麻烦了。"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"id":104000,"motion":100,"voice":"vo_char_1040_00_03","textHome":"安心してください、何があろうと中立です"}],"nameCenter":"夜鹤","textCenter":"请放心。@不管发生什么，我们都会保持中立。","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"id":104000,"motion":400}]},{"chara":[{"id":104000}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}