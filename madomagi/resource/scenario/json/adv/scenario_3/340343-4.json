":0,"pos":1}],"nameCenter":"成见亚里纱","narrationEffect":"out","textCenter":"不是这样的……"},{"chara":[{"id":403301}],"textCenter":"因为千里你@什么也没有做错啊。"},{"nameNarration":"诗音千里","narration":"就是这么一句话……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"autoTurnLast":0.2,"bg":"bg_adv_21025.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403301,"motion":1,"pos":2},{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":403401,"motion":300,"pos":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":403401,"lipSynch":0}],"textLeft":"…………","turnChangeOut":"fadeOut"},{"chara":[{"id":403301}],"textRight":"怎么样？没事吧？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403401,"motion":0}],"textLeft":"嗯"},{"chara":[{"id":403401}],"textLeft":"亚里纱……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403301,"motion":0}],"textRight":"什么？"},{"bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403401,"motion":100}],"textLeft":"从今往后，4名少女@也得齐心协力才行！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403301,"motion":100}],"textRight":"哈哈！@嗯，没错！"},{"chara":[{"id":403301}],"textRight":"稍微练习一下@怎么样才能发出光波吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403401,"motion":1}],"textLeft":"那我就练习@如何放出导弹吧～"},{"chara":[{"id":403301,"motion":200}],"textRight":"哦，不错呢！@下次来练习吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403401}],"textLeft":"还是算了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403301,"motion":1}],"textRight":"什么嘛～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403401,"motion":100}],"textLeft":"啊哈哈！"},{"nameNarration":"诗音千里","narration":"在艰辛之时有支持你的同伴……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"这对我而言@可能才是最棒的「魔法」！"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":2.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403401,"mot