{"story":{"group_1":[{"bg":"bg_adv_20033.jpg","bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0,"pos":1}],"nameCenter":"杏子","textCenter":"都是因为被她缠上，@害我耽搁到现在。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601}],"textCenter":"之前没听说@这里还有黑色的魔法少女啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"lipSynch":0}],"textCenter":"（她知道@我和麻美今天要来神滨。）"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"lipSynch":0,"motion":300}],"textCenter":"（她是怎么知道的？）"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textCenter":"神滨、黑色的魔法少女……@怪事太多了。"},{"bg":"bg_adv_21231.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0,"pos":2}],"nameRight":"杏子","textRight":"喂——我回来了。@由麻？由麻——","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"lipSynch":0}],"textRight":"[chara:200601:lipSynch_1]由麻？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textRight":"喂！@[chara:200601:motion_200]由麻！由麻！[chara:200601:cheek_0:face_mtn_ex_021.exp.json]"},{"bg":"bg_adv_20023.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"motion":400,"pos":0}],"nameLeft":"杏子","surround":"7009_night_townbuzz","textLeft":"由麻那家伙……@到底去哪里了啊！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"nameRight":"","textRight":"佐仓！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601},{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":200,"pos":2}],"nameRight":"保澄雫","surround":"stop","textLeft":"雫？@怎么了……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0}],"textRight":"由麻她！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textLeft":"——！？@[chara:200601:motion_400]由麻！？"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"motion":200}],"textLeft":"喂！你知道由麻@现在在哪里吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700}],"textRight":"她在神滨走失了！"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"motion":300}],"textLeft":"神滨！？@怎么会！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700}],"textRight":"我不清楚详情……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700,"motion":300}],"textRight":"但我听说，@她提起过佐仓……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0}],"textRight":"我就想，佐仓你跟我说过的，@可能就是那孩子……"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601}],"textLeft":"等一下……@[chara:200601:motion_400]你是从谁那里听说的？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"说起来……@我没问她的名字呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"是个穿白衣的……@魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601}],"textLeft":"——！？@白衣的……魔法少女！？"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"motion":300}],"textLeft":"织莉子！"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"lipSynch":0,"motion":400}],"textLeft":"（可恶！@为什么……为什么会这样！）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"lipSynch":0}],"textLeft":"（为什么非要@和我们扯上关系！？）"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}],"textRight":"“织莉子”？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textLeft":"喂。"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601}],"textLeft":"不好意思，麻烦你那么多次，@可以再帮我一回吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601}],"textLeft":"我会支付相应的报酬。"},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":200601,"motion":400}],"textLeft":"麻烦你@立刻送我去神滨。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":401}],"textRight":"明白！"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":400301,"motion":1,"pos":1,"voice":"vo_char_4003_00_04","textHome":"杏子……在哪……？杏子去哪里了……？"}],"nameCenter":"千岁由麻","textCenter":"杏子……在哪？@你在哪啊？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"id":400301,"motion":200}]},{"chara":[{"id":400301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}