{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21091.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":102701,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102701,"motion":300}],"nameCenter":"沙绪","textCenter":"呼……","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"chara":[{"id":102701,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":2}],"nameRight":"静香","textRight":"沙绪，辛苦你了。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":0}],"nameLeft":"沙绪","textLeft":"静香、小千……你们也辛苦了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":1,"pos":2}],"nameRight":"千春","textRight":"今天店里格外热闹呢！@尤其是后半段！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100,"pos":2}],"nameRight":"静香","textRight":"昨天来过的客人@今天也来了不少吧？"},{"chara":[{"id":102501}],"textRight":"沙绪，你注意到了？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":200}],"textLeft":"是的……"},{"chara":[{"id":102701}],"textLeft":"有几个客人是我接待过的。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102501}],"textRight":"你这么细心地接待他们，@还详细介绍了“橙橙果”……"},{"chara":[{"id":102501}],"textRight":"他们肯定是留下了印象才会再过来的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0}],"textRight":"而且多亏了沙绪@应对那些麻烦的客人……"},{"chara":[{"id":102501}],"textRight":"其他店员才能更有效地工作。"},{"chara":[{"id":102501}],"textRight":"小千抓住了小偷……"},{"chara":[{"id":102501,"motion":200}],"textRight":"我也能专心做自己的工作。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501}],"textRight":"这都要感谢沙绪你坚持不懈地@完成了自己的工作。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":100,"pos":2}],"nameRight":"千春","textRight":"嗯！"},{"chara":[{"id":102701,"motion":100}],"textLeft":"谢谢你们。"},{"chara":[{"id":102701}],"textLeft":"看来我的努力是有意义的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":0,"pos":2}],"nameRight":"静香","textRight":"当然了，我和小千都敢打包票。"},{"chara":[{"id":102501}],"textRight":"一直在现场看着你的父母@肯定也有同样的想法。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"辛苦了。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0}],"textLeft":"啊……"},{"chara":[{"id":102701,"lipSynch":0}],"textLeft":"（我只顾着接待客人，@完全没注意到……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":2}],"nameRight":"沙绪的父亲","textRight":"你看上去很努力啊。","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300}],"textLeft":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700}],"textRight":"沙绪……"},{"bgm":"stop","chara":[{"id":800700}],"textRight":"对不起。"},{"bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":400}],"textLeft":"咦？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"我也要向你道歉。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":0}],"textLeft":"你们……为什么要跟我道歉？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":0,"pos":2}],"nameRight":"沙绪的父亲","textRight":"爸爸和妈妈看了今天的沙绪之后@非常后悔。"},{"chara":[{"id":800700}],"textRight":"你那么努力……"},{"chara":[{"id":800700}],"textRight":"但我们却没能信任你。"},{"chara":[{"id":800700}],"textRight":"你长大了，@而且比我们想的还要优秀。"},{"chara":[{"id":800700}],"textRight":"但我们却只知道担心你……"},{"chara":[{"id":800700}],"textRight":"对你的努力视而不见。"},{"chara":[{"id":800700}],"textRight":"如今再后悔或许为时已晚……"},{"chara":[{"id":800700}],"textRight":"但我们今后想好好地面对你。"},{"chara":[{"id":800700}],"textRight":"沙绪，一直以来对不起。"},{"chara":[{"id":102701,"motion":300}],"textLeft":"什么……意思？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"你因自己成了巫非常自责……"},{"chara":[{"id":800600}],"textRight":"为了不让我们担心，@一个人拼命努力。"},{"chara":[{"id":800600}],"textRight":"但那件事根本不是你的责任。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800700,"motion":0,"pos":2}],"nameRight":"沙绪的父亲","textRight":"没错，我们实在是不想让你@和时女扯上关系……"},{"chara":[{"id":800700}],"textRight":"所以什么都没和你说。"},{"chara":[{"id":800700}],"textRight":"我们应该告诉你一切……"},{"chara":[{"id":800700}],"textRight":"然后我们一家三口一起努力。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":800600,"motion":0,"pos":2}],"nameRight":"沙绪的母亲","textRight":"沙绪，对不起。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":102701,"lipSynch":0,"motion":1}],"textLeft":"……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102701}],"textLeft":"爸爸，妈妈，谢谢你们。"},{"chara":[{"id":102701}],"textLeft":"我们要是能早点这么谈一次就好了。"},{"chara":[{"id":800600}],"textRight":"嗯，是啊……对不起。"},{"chara":[{"id":102701,"motion":100}],"textLeft":"我才应该道歉……对不起。"},{"chara":[{"id":102701}],"textLeft":"都怪我没有自信，@总是逃避……"},{"chara":[{"id":102701}],"textLeft":"但是，已经没问题了。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102701,"motion":0}],"textLeft":"只要有静香和小千在，@我就有自信。"},{"chara":[{"id":102701}],"textLeft":"今天也是因为有她们在……"},{"chara":[{"id":102701}],"textLeft":"我才能为了让爸爸和妈妈放心，@一直努力到最后。"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102701},{"effect":"fadeout","id":800600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":0,"pos":2}],"nameLeft":"静香","textLeft":"沙绪……"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800700,"motion":0,"pos":2}],"nameLeft":"沙绪","textLeft":"爸爸，妈妈，我有个请求。"},{"chara":[{"id":800700}],"nameRight":"沙绪的父亲","textRight":"什么都行，你说吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300}],"textLeft":"我是巫，所以我要做的事@可能会害你们担心……"},{"chara":[{"id":102701}],"textLeft":"但我有一个要跟静香和小千@一起实现的目标。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102701}],"textLeft":"为了实现它，@今后可能会很忙。"},{"chara":[{"id":102701,"motion":100}],"textLeft":"爸爸，妈妈……"},{"chara":[{"id":102701}],"textLeft":"让我去神滨吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701}],"textLeft":"我可能还会让你们操心，@但静香和小千也和我在一起。"},{"chara":[{"id":102701,"motion":0}],"textLeft":"所以，请相信我吧……"},{"autoTurnFirst":2.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102701,"motion":100,"pos":1,"voice":"vo_char_1027_00_05","textHome":"遇到了这么多能友好交往的人真是太好了"}],"nameCenter":"沙绪","textCenter":"能遇见这些好朋友，@我真是太幸运了。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":102701}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}