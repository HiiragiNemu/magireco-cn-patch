{"story":{"group_1":[{"bg":"bg_adv_20071.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":0,"mouthOpen":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_041.exp.json","id":100100,"motion":0,"pos":2}],"nameLeft":"梅丽莎·德·维尼奥勒","nameRight":"彩羽","textLeft":"唉……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":1}],"textLeft":"[chara:402301:effect_emotion_joy_0][se:7222_happy]终于放我们走了！"},{"chara":[{"cheek":0,"id":100100}],"textRight":"真是太不容易了……"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100100,"motion":301}],"textRight":"受到大家欢迎是好事，@但他们却一直不肯放我们回来。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":300}],"textLeft":"都怪我一开始任性地说@想要去教会！"},{"chara":[{"cheek":1,"eyeClose":1,"id":402301}],"textLeft":"给你添麻烦了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":400}],"textRight":"哇，没事啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}],"textRight":"不要道歉！@反正我们也平安回来了呀！"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"不过，我也松了一口气……"},{"chara":[{"cheek":1,"eyeClose":1,"id":402301}],"textLeft":"身为“圣女”的侍从，@我没有做出失礼的举止。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100100,"motion":200}],"textRight":"但最后，@还是有人误会着呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100}],"textRight":"说梅丽莎就是@传说中的“圣女”！"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":300}],"textLeft":"这让我有点头疼。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"不过，我也在想去的教会@祈祷过了。"},{"chara":[{"cheek":0,"id":402301}],"textLeft":"而且还收到了很多@非常棒的礼物……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":10}],"textLeft":"真的是太好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":301}],"textRight":"说起来，梅丽莎。"},{"chara":[{"cheek":0,"id":100100}],"textRight":"收下礼物的时候，@你似乎和大家聊了很久呢？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"啊……因为机会难得，@我希望他们能分我一些东西。"},{"chara":[{"cheek":0,"id":402301}],"textLeft":"现在全部都收集齐了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}],"textRight":"是什么东西？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":100}],"textLeft":"呵呵，@之后你就知道了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"那么，我们赶紧回去吧！"},{"chara":[{"cheek":0,"id":402301}],"textLeft":"不然八千代她们会担心哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":400}],"textRight":"嗯！"},{"bg":"bg_adv_20091.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":0}],"nameLeft":"八千代","nameRight":"彩羽","textRight":"我回来了，八千代！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301,"motion":1,"pos":2,"soulGem":0}],"nameRight":"梅丽莎·德·维尼奥勒","textRight":"多亏了彩羽，@我们平安回来了！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200}],"textLeft":"辛苦了。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}],"textLeft":"本来是想让你们放松一下的，@但看来，你们一路上挺辛苦呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":100100,"motion":0,"pos":2}],"nameRight":"彩羽","textRight":"是的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100}],"textRight":"但是也聊了很多，@我非常高兴！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301,"motion":300,"pos":0,"soulGem":0}],"nameLeft":"梅丽莎·德·维尼奥勒","textLeft":"我也是，彩羽！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"那我就先去准备晚饭了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":401}],"textRight":"诶，这么早就开始准备？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301,"motion":300}],"textLeft":"是的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"因为要花不少时间……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":301}],"textRight":"诶诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":301,"pos":0}],"nameLeft":"八千代","textLeft":"到底要做什么？"},{"bg":"bg_adv_20092.jpg","bgm":"bgm01_anime03","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":830300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":830400,"motion":0,"pos":2}],"nameLeft":"","nameRight":"","textLeft":"哦哦，这个甜品很好吃啊！@是叫蒙布朗吗？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"id":830400}],"textRight":"虽然我不太喜欢吃甜食，@但这个甜品有多少我都能吃得下！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301,"motion":300,"pos":0}],"nameLeft":"梅丽莎·德·维尼奥勒","textLeft":"大家能喜欢@就再好不过了！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"八千代和彩羽@也请品尝一下！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":2}],"nameRight":"彩羽","textRight":"哇啊，谢谢！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100}],"textRight":"哇，好棒……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":301}],"textRight":"外观看起来@就是真正的蒙布朗呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":100,"pos":2}],"nameRight":"八千代","textRight":"赶紧尝尝看吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"lipSynch":0,"motion":0}],"textRight":"[chara:100200:effect_emotion_surprise_0][se:7226_shock]——！？"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100,"motion":400,"pos":2}],"nameRight":"彩羽","textRight":"这个……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100,"motion":100}],"textRight":"和我们吃过的蒙布朗@一模一样！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402301}],"nameLeft":"梅丽莎·德·维尼奥勒","textLeft":"[chara:402301:effect_emotion_joy_0][se:7222_happy]太好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":200,"pos":2}],"nameRight":"八千代","textRight":"这里面是使用了蜂蜜吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"是的！"},{"chara":[{"cheek":1,"id":402301}],"textLeft":"我做了一些改动，@用蜂蜜来代替缺少的材料！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402301,"motion":0}],"textLeft":"之前我一直找不到栗子……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301}],"textLeft":"但在教会所在的村子里，@我发现了很多栗子树。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301,"motion":300}],"textLeft":"所以我就跟村民们商量，@能不能送给我一些栗子！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":0,"pos":2}],"nameRight":"彩羽","textRight":"啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100}],"textRight":"你出发前，@原来就是和村民们说这个啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":300,"pos":2}],"nameRight":"八千代","textRight":"真让人吃惊呢。"},{"chara":[{"cheek":0,"id":100200}],"textRight":"仅仅是听了我们的描述，@就能完美地做出蒙布朗！"},{"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":402301,"motion":100,"soulGem":0}],"textLeft":"[chara:402301:effect_emotion_joy_0][se:7222_happy]呵呵……@谢谢你们！"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":810000,"motion":0,"pos":2}],"nameRight":"丘卜","textRight":"似乎大受好评呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":401,"pos":2}],"nameRight":"彩羽","textRight":"啊，丘卜。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402301,"motion":1}],"textLeft":"天使大人！"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":810000,"motion":0,"pos":2}],"nameRight":"丘卜","textRight":"事情我都听说了哦，梅丽莎。"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":810000,"motion":0}],"textRight":"法国军也士气高涨，@真是太好了！"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":402301,"motion":300}],"textLeft":"非、非常感谢！@天使大人！"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":810000,"motion":0}],"textRight":"你真的很了不起啊。"},{"chara":[{"cheek":2,"id":810000}],"textRight":"明明不是魔法少女，@却能给法国军做出非凡贡献。"},{"chara":[{"cheek":2,"id":810000}],"textRight":"即使面对敌人，@也毫不胆怯。"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json"}],"textRight":"再加上后勤工作也做得非常完美。"},{"bgm":"bgm03_story01","chara":[{"cheek":2,"id":810000}],"textRight":"你果然很适合@当一名魔法少女啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402301}],"textLeft":"天使大人……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":402301,"motion":0}],"textLeft":"是、是吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100,"lipSynch":0,"motion":200,"pos":2}],"nameRight":"彩羽","textRight":"（嗯……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"id":100100,"lipSynch":0}],"textRight":"（和后勤工作的能力@应该没什么关系吧！？）"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402301,"motion":300,"pos":1,"voice":"vo_char_4023_00_05","textHome":"我会为了能帮上更多的忙而努力的！"}],"nameCenter":"梅丽莎·德·维尼奥勒","textCenter":"今后我也会继续努力，@给大家帮忙的！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402301}]},{"chara":[{"id":402301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}