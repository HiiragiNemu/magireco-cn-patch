{"story":{"group_1":[{"bg":"bg_adv_19221.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":0,"pos":2}],"nameLeft":"杏子","nameRight":"胡桃爱香","textLeft":"那好，我差不多该走了。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901}],"textRight":"好的！请务必@再次光顾本店哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":100}],"textRight":"爱香会好好露一手的！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":300}],"textLeft":"等我有兴趣的吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300901,"lipSynch":0,"motion":0}],"textRight":"…………@[chara:300901:lipSynch_0][wait:1.0][chara:300901:lipSynch_1]佐仓……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300901,"motion":300}],"textRight":"你……@该怎么说呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textLeft":"嗯？@什么？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300901,"motion":0}],"textRight":"爱香不知道@佐仓你过去经历了什么……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901}],"textRight":"但当佐仓你@光临本店的时候……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":400}],"textRight":"爱香会笑着@为你端上饭菜的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300901,"motion":0}],"textRight":"无论何时，@这一点是不会变的哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200601,"motion":400}],"textLeft":"[chara:200601:effect_emotion_surprise_0][se:7226_shock]你突然说什么呢！@[chara:200601:lipSynch_0][wait:1.2][chara:200601:cheek_0][chara:200601:face_mtn_ex_010.exp.json][chara:200601:lipSynch_1]不过，谢谢你。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":100}],"textLeft":"但是，你是魔法少女吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textLeft":"有时间做饭，@还不如去狩猎魔女呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":1}],"textLeft":"也许你是为了别人而做饭。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textLeft":"可是当你的灵魂宝石污浊的时候，@不一定会有人来救你。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textLeft":"你身为魔法少女，@还是只为自己考虑吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":300}],"textLeft":"所以啊，@你……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300901,"motion":1}],"textRight":"不对，佐仓。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"lipSynch":0,"motion":0}],"textLeft":"？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300901}],"textRight":"爱香不是为了别人……@而是为了自己。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":100}],"textRight":"因为爱香会觉得开心……@想看到别人的笑容……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300901}],"textRight":"如果有人遭遇不幸……@如果发生了这样的事情……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":400}],"textRight":"爱香会用倾注在饭菜上的热情，@让大家重拾笑容。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":200}],"textRight":"爱香会做出美味的饭菜，@把不幸统统赶走！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textLeft":"你真是个奇怪的家伙。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300901,"motion":0}],"textRight":"[chara:300901:effect_emotion_surprise_0][se:7226_shock]什么！很奇怪吗？"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200601}],"textLeft":"嗯，你是个超级奇怪的家伙！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200601,"motion":100}],"textLeft":"不过，我喜欢你的饭菜！@等我有兴趣的时候会再来的！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300901,"motion":400}],"textRight":"等一下，@这和你刚才说的话没分别嘛。"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200601,"motion":200}],"textLeft":"喂喂，不要认为可以如此轻易地@改变一个人哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300901,"motion":0}],"textRight":"唔……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901}],"textRight":"可是，@就算说的内容没有变……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":1}],"textRight":"说话方式@还是改变了一点吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200601,"motion":100}],"textLeft":"什么，笨蛋！@才没变呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601}],"textLeft":"再见啦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300901,"motion":100}],"textRight":"真的！@请再次光顾哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":0}],"textLeft":"嗯，@谢谢。"},{"nameNarration":"杏子","narration":"做饭的魔法少女@虽然是个奇怪的家伙……","narrationBg":"bg_adv_19221.jpg","narrationEffect":"in"},{"narration":"但却能做出……@好吃又温暖的饭菜"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":4.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":300,"pos":1,"voice":"vo_char_2006_00_04","textHome":"不知道已经多久……@没有在这么时髦的饭店里吃饭了啊？@真好吃。"}],"nameCenter":"杏子","textCenter":"我多久没有在时尚的店里@吃过饭了？真好吃啊。","turnChangeOut":"fadeOut"},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200601,"motion":1}]},{"chara":[{"id":200601}]},{"autoTurnLast":2.0,"narrationEffect":"out","turnChangeIn":"fadeIn"}]},"version":3}