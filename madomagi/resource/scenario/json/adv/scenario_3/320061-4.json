{"story":{"group_1":[{"bg":"bg_adv_11021.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":0,"pos":2}],"nameLeft":"五十铃怜","nameRight":"杏子","textLeft":"谢谢你……@救了我。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302501}],"textLeft":"我……@误会了你……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"我不是来救你的，@你也不用道谢。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":1}],"textRight":"我刚才也说过了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601}],"textRight":"我是来狩猎魔女的，@仅此而已。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302501,"motion":1}],"textLeft":"可是……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":100}],"textRight":"像你这么弱小的家伙，@记得下次不要自不量力。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"别说恶意的魔女了，@你连使魔都赢不了。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501,"motion":200}],"textLeft":"但是……@如果拥有保护别人的力量……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501}],"textLeft":"就应该……@运用这份力量……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0}],"textRight":"你不明白吗？@你没有那种力量。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302501,"motion":400}],"textLeft":"——！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601}],"textRight":"如果我没有来，你就死了，@连自己都无法保护。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":100}],"textRight":"还妄想保护别人，@真是太可笑了。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302501,"lipSynch":1,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501}],"textLeft":"我会……@我会变强的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501,"motion":200}],"textLeft":"我会……变得更！@变得更强的……！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302501,"motion":100}],"textLeft":"这样一来……我就能@成为保护别人的魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textRight":"嗯，如果你能成为@最强大的魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601}],"textRight":"别人就无话可说了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200601,"motion":1}],"textRight":"拿去。"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302501,"motion":400}],"textLeft":"哇……！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302501,"motion":1}],"textLeft":"这是……悲叹之种……@我可以收下吗……？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":100}],"textRight":"像你这样天真的@魔法少女会过早丧命的。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601}],"textRight":"就拿去用吧。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302501,"motion":0}],"textLeft":"可是……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0}],"textRight":"我感觉你会堆积很多负面情绪。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"motion":1}],"textLeft":"谢谢，@你真是个温柔的人。"},{"chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":200601,"motion":400}],"textRight":"我才不温柔呢。@[chara:200601:lipSynch_0][wait:1.0][chara:200601:cheek_1][chara:200601:face_mtn_ex_010.exp.json][chara:200601:lipSynch_1]那就再见啦。"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":200601}]},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302501,"motion":100}],"textLeft":"那个……！真的……@非常感谢……！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200601,"motion":0,"pos":1},{"effect":"fadeout","id":302501}],"nameNarration":"杏子","narration":"真是的……@我究竟在做什么","narrationBg":"bg_adv_11021.jpg","narrationEffect":"in"},{"narration":"…………@不过，感觉还不错"},{"chara":[{"cheek":0,"id":200601,"motion":300}],"nameCenter":"杏子","narrationEffect":"out","textCenter":"真是的，我到底在做什么啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200601}],"textCenter":"嘿嘿。"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200601,"motion":0,"pos":1,"voice":"vo_char_2006_00_03","textHome":"越是单纯的人……@是不是就越容易受伤啊……"}],"nameCenter":"杏子","textCenter":"越是单纯的人……@就越容易受伤吧……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"autoTurnFirst":3.0,"chara":[{"id":200601,"motion":100}]},{"chara":[{"id":200601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}