{"story":{"group_1":[{"armatureList":[{"animation":["in","stay"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/4000_darkmist.ExportJson","zOrder":"charaBack"}],"autoTurnLast":0.01,"bg":"bg_adv_20073.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":760100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"bgEffect":"shakeLarge","chara":[{"id":402600,"motion":1}],"flashEffect":"flashWhite2","surround":"3023A01","turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"bgEffect":"shakeLarge","chara":[{"effect":"shake","id":760100}],"flashEffect":"flashRed2","nameLeft":"","surround":"3023A05","textLeft":"БЯяЯЯ……"},{"autoTurnLast":1.2,"chara":[{"effect":"fadeout","id":760100}],"se":"3002_chara_dead","textClear":1},{"autoTurnLast":0.01,"deleteArmatureList":[1]},{"autoTurnLast":0.2,"chara":[{"id":402600,"pos":0}],"textClear":1},{"autoTurnLast":0.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100,"motion":0,"pos":2}]},{"autoTurnLast":0.8,"bgm":"stop","chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_030.exp.json","id":402601,"motion":0,"pos":0}],"se":"7205_magic_girl"},{"chara":[{"id":402601}],"nameLeft":"爱丽莎·瑟尔斯加","textLeft":"呼……"},{"bgm":"bgm03_story06","chara":[{"id":831100}],"nameRight":"佩蕾奈尔·弗拉梅尔","textRight":"能让我们三人都中了幻术……"},{"chara":[{"id":831100}],"textRight":"我还以为是多么强大的魔女呢……"},{"chara":[{"id":831100}],"textRight":"原来那是使魔的结界啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402601,"motion":400}],"textLeft":"等等！"},{"chara":[{"id":402601}],"textLeft":"我们居然被区区使魔骗了吗！？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":200}],"textLeft":"让我们以为在和领主说话……@甚至连信都递过去了！？"},{"chara":[{"id":810000,"pos":2,"posX":40,"posY":0}],"nameRight":"丘卜","textRight":"这个使魔极为特殊。"},{"chara":[{"id":810000}],"textRight":"如今在法国境内……"},{"chara":[{"id":810000}],"textRight":"到处徘徊着奇怪的魔女和使魔。"},{"chara":[{"id":810000}],"textRight":"它们甚至无需用结界隐藏自己，@就能光明正大地四处游荡。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":0}],"nameLeft":"佩蕾奈尔·弗拉梅尔","textLeft":"它们跨越了国界，@来到了神圣罗马帝国？"},{"chara":[{"id":810000}],"textRight":"嗯。"},{"chara":[{"id":810000}],"textRight":"但和法国境内的那些不同，@它们很少在人前现身。"},{"chara":[{"id":831100}],"textLeft":"这反倒证明事态已经严重得不可估量。"},{"chara":[{"id":831100}],"textLeft":"这种跨越国界的特殊使魔……"},{"chara":[{"id":831100}],"textLeft":"究竟有多少藏身在我国呢……"},{"autoTurnLast":0.2,"chara":[{"id":831100,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":1,"pos":0}],"nameLeft":"爱丽莎·瑟尔斯加","textLeft":"要讨论事态的严重性是好……"},{"chara":[{"id":402601}],"textLeft":"但别忘了我们的任务。"},{"chara":[{"id":402601,"motion":200}],"textLeft":"我们还要把信带给真正的领主！"},{"chara":[{"id":402601}],"textLeft":"必须弥补我们耽误的时间，@尽快赶往城塞……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100,"motion":0}],"nameRight":"佩蕾奈尔·弗拉梅尔","textRight":"关于这件事……"},{"chara":[{"id":831100}],"textRight":"我们要去的城塞，@以及那里的领主是真实存在的吗？"},{"chara":[{"id":810000,"pos":2,"posX":40,"posY":0},{"id":402601,"motion":0}],"nameRight":"丘卜","textRight":"就我所知，@这附近没有城塞。"},{"chara":[{"id":810000}],"textRight":"这里的一切名称都是假的。"},{"chara":[{"id":810000}],"textRight":"正如字面意思，@是个「幽灵城塞」呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402601,"lipSynch":0,"motion":400,"pos":0}],"textLeft":"！？"},{"chara":[{"id":402601,"motion":0}],"textLeft":"我们被派去给一个@不存在的城塞送信？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601}],"textLeft":"也就是说……"},{"chara":[{"id":402601}],"textLeft":"难道这个任务也是@什么人设下的陷阱？"},{"chara":[{"id":402601,"motion":200,"mouthOpen":1}],"textLeft":"真是的……@你知道了就早说啊！"},{"chara":[{"id":402601,"mouthOpen":0}],"textLeft":"真是个派不上用场的芝士蛋糕！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0,"pos":2}],"nameRight":"佩蕾奈尔·弗拉梅尔","textRight":"没能察觉到是个陷阱的我也有责任。@先来验证下我们的猜想吧。"},{"chara":[{"id":831100}],"textRight":"请给我看看那封信。"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":831100,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":831100}],"textRight":"果然……@虽然做工很精巧，","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100,"motion":0}],"textRight":"但这是仿冒的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402601,"motion":400}],"textLeft":"居然敢骗我！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":831100,"motion":1}],"textRight":"再加上这个任务过于危险，@普通的骑士根本无法完成。"},{"chara":[{"id":831100}],"textRight":"毫无疑问，@这是一场伪装成宫廷命令的阴谋。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402601,"lipSynch":0,"motion":300}],"textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":831100,"motion":0}],"textRight":"爱丽莎小姐，@究竟是何人谋划了此事，"},{"chara":[{"id":831100}],"textRight":"您身为王族，是否有什么头绪？"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402601}],"textLeft":"嗯……"},{"chara":[{"eyeClose":0,"id":402601,"motion":1}],"textLeft":"多得数都数不清。"},{"autoTurnFirst":4.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402601,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_4026_00_03","textHome":"哼！真无聊呢。"}],"nameCenter":"爱丽莎·瑟尔斯加","textCenter":"哼！@还真是无聊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":402601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}