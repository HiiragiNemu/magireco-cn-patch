{"story":{"group_1":[{"autoTurnLast":0.1,"bg":"bg_adv_19081.jpg","bgm":"bgm03_story13","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100601}],"nameCenter":"美冬","textCenter":"欢迎来到玛吉斯之翼。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":304601,"motion":1,"pos":2}],"nameNarration":"观鸟令","narration":"这事我只跟你说……@我至今仍无法信任@玛吉斯之翼和玛吉斯们","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"但观鸟我还是决定加入玛吉斯之翼……"},{"narration":"我不是想要依靠她们或是组织的力量@而是为了利用玛吉斯的能力解放自己"},{"chara":[{"id":304601}],"nameLeft":"美冬","nameRight":"观鸟令","narrationEffect":"out","textRight":"老实说，我现在还不信任你们。"},{"chara":[{"id":304601}],"textRight":"我来这里是为了实现解放。"},{"chara":[{"id":304601}],"textRight":"这样也没关系吗？"},{"chara":[{"id":100601,"motion":200}],"textLeft":"当然。"},{"chara":[{"id":100601}],"textLeft":"我们需要的不是你对组织的忠诚，@而是你对解放的执着。"},{"chara":[{"id":100601,"motion":1}],"textLeft":"而且……@这种执着也是因人而异的。"},{"chara":[{"id":100601}],"textLeft":"互相利用……"},{"chara":[{"id":100601}],"textLeft":"如果这种想法会让你觉得轻松点，@那你大可以这么想。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304601,"motion":200}],"textRight":"真是说不过你。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100601,"motion":100}],"textLeft":"呵呵，因为我们的经验丰富程度不同吧？@毕竟我也只有资历算得上久。"},{"nameNarration":"观鸟令","narration":"我加入玛吉斯之翼之后@进入了本部……","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp.json","id":715104,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":100600}],"nameLeft":"美冬","nameRight":"观鸟令","textLeft":"她们是你要负责带领的黑翼。","turnChangeOut":"fadeOut"},{"chara":[{"id":715104}],"textRight":"好的。"},{"autoTurnLast":0.2,"chara":[{"id":715104,"pos":0}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":715005,"motion":0,"pos":2}]},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":715104,"lipSynch":0}],"nameLeft":"观鸟令","textLeft":"（嗯？她是那时的……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":715005,"mouthOpen":1}],"nameRight":"牧野郁美","textRight":"啊！","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":715104,"lipSynch":0},{"id":715005,"mouthOpen":0}],"textLeft":"（她也注意到我了吗？）","turnEffect":"thinking"},{"nameNarration":"观鸟令","narration":"我和牧野再会了","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"autoTurnLast":2.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":305301,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":304601}],"nameLeft":"观鸟令","nameRight":"牧野郁美","narrationEffect":"out","textLeft":"这就是我加入玛吉斯之翼之前的事。","turnChangeOut":"fadeOut"},{"chara":[{"id":304601}],"textLeft":"之后的事牧野你也知道了。"},{"chara":[{"id":305301}],"textRight":"令……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304601,"motion":200}],"textLeft":"你别这么消沉嘛。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601}],"textLeft":"对观鸟我来说都是过去的事了。"},{"chara":[{"id":304601,"motion":1}],"textLeft":"我可不需要你同情我哦。"},{"chara":[{"id":305301,"motion":0}],"textRight":"嗯。@我知道的啦……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305301}],"textRight":"我们是为了赢得未来@才来到这里的嘛。"},{"chara":[{"id":304601}],"textLeft":"嗯。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304601,"motion":0}],"textLeft":"说起来……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305301}],"textRight":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601}],"textLeft":"你从刚才开始都没在装可爱。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305301,"lipSynch":0,"motion":400}],"textRight":"[chara:305301:effect_emotion_surprise_0][se:7226_shock]！？"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":305301,"motion":300,"tear":1}],"textRight":"哇啊啊啊啊……@才、才没那回事呢～！"},{"chara":[{"id":305301,"tear":0}],"textRight":"郁美才没有装可爱呢～！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304601,"motion":200}],"textLeft":"是是是。"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":305301,"motion":200}],"textRight":"真是的～你不信嘛～？@人家可要生气气了哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601}],"textLeft":"生气了我也不怕。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":305301}],"textRight":"唔～"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305301,"motion":0}],"textRight":"啊！@对了！令。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305301}],"textRight":"你要是写好了郁美的报道，@要告诉我哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304601,"motion":0}],"textLeft":"诶？@我不会写在宣传报上的。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":305301,"motion":200}],"textRight":"诶～！@为什么呀～！"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":304601,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"id":304601}],"textLeft":"跟你对话的是观鸟我，@所以你才会说这些吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":304601,"motion":200}],"textLeft":"观鸟我可不会随便把这些@内容写进宣传报里的。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305301,"lipSynch":0}],"textRight":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":305301,"motion":0}],"textRight":"呵呵！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304601,"motion":0}],"textLeft":"诶……怎么了？"},{"chara":[{"id":305301,"motion":100}],"textRight":"不～@没什么～！"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":305301,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":304601}],"textLeft":"一不留神聊了这么久，@我差不多该回去了。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305301,"motion":400}],"textRight":"哇～都这么晚了～@迟到的话要被凶凶了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305301}],"textRight":"啊……那个，令。"},{"chara":[{"id":304601}],"textLeft":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305301,"motion":200}],"textRight":"我们要一起加油哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304601,"lipSynch":0,"motion":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":200}],"textLeft":"当然啦。"},{"chara":[{"id":304601}],"textLeft":"牧野@那就明天见了～"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305301,"motion":100}],"textRight":"嗯！@明天见！"},{"autoTurnLast":2.0,"bg":"bg_adv_17041.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":0,"pos":2},{"id":830800,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story15","chara":[{"id":830800}],"nameLeft":"","nameRight":"观鸟令","textLeft":"[se:7101_catvoice]喵——","turnChangeOut":"fadeOut"},{"chara":[{"id":304601,"motion":400}],"textRight":"哦！@发现猫猫！"},{"chara":[{"id":304601,"motion":1}],"textRight":"乖乖让我拍一张哦……@[chara:304601:lipSynch_0][wait:0.8][chara:304601:cheek_0][chara:304601:face_mtn_ex_011.exp.json][chara:304601:lipSynch_1]对对……真乖……"},{"autoTurnLast":0.01,"item":[{"path":"resource/scenario/img/33046_ryou_story/memoria_1276.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn"},{"nameNarration":"观鸟令","narration":"―令―@你就是下一期观鸟报的明星","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":28.0,"narrationLineMargin":15.0,"narrationLineSpace":10.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":1,"pos":2},{"id":830800,"pos":0}],"item":[{"path":"resource/scenario/img/33046_ryou_story/memoria_1276.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":830800}],"textLeft":"[se:7101_catvoice]喵——","turnChangeOut":"fadeOut"},{"chara":[{"id":304601}],"textRight":"谢谢啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304601}],"textRight":"多亏了你，下一期的每日一猫@会有不错的内容。"},{"chara":[{"effect":"fadeout","id":830800},{"cheek":0,"face":"mtn_ex_020.exp.json","id":304601,"motion":0,"pos":1}],"nameNarration":"观鸟令","narration":"从观鸟我出生在大东区的那一刻开始@就被迫承担着不幸","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in"},{"narration":"我无法从中逃脱@人的出生……人的过去是无法改变的"},{"narration":"我也有时也会觉得@从契约中得到的能力是一种负担"},{"narration":"但我自己决定了如何使用力量@这是我思考过后决定的，所以我不在乎"},{"narration":"然而……我们签订契约后@在不知情的情况下背负了残酷的命运"},{"narration":"这很重要……它关乎着包括观鸟在内的@所有魔法少女们的未来……"},{"chara":[{"id":304601,"lipSynch":0,"motion":200}],"nameCenter":"观鸟令","narrationEffect":"out","textCenter":"（只有这点，我无法认同。）","turnEffect":"thinking"},{"chara":[{"id":304601,"lipSynch":0}],"textCenter":"（我一定要改变这个命运。）"},{"chara":[{"eyeClose":1,"id":304601,"lipSynch":0}],"textCenter":"…………","turnEffect":"stop"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":400}],"textCenter":"我得赶紧回去整理报道才行。"},{"bgm":"stop","nameNarration":"观鸟令","narration":"为此……@我也做好了受人憎恨的心理准备","narrationBg":"black","narrationEffect":"in"},{"autoTurnLast":0.01,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnFirst":5.4,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304601,"motion":300,"pos":1,"voice":"vo_char_3046_00_05","textHome":"我成为棋子就只有这一刻而已。"}],"nameCenter":"观鸟令","textCenter":"观鸟我作为棋子的日子@也该到此为止了。","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":304601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}