{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301,"motion":0,"mouthOpen":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_13111.jpg","bgm":"bgm03_story07","chara":[{"id":100301}],"nameRight":"鹤乃","textRight":"你好……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"哦哦，鹤鹤！@你还好吗？怎么了？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300601,"motion":200,"mouthOpen":0}],"textLeft":"对了，修行怎样了？@变强了吗？"},{"chara":[{"cheek":0,"id":100301,"mouthOpen":0}],"textRight":"那个……晶老师今天会来吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300601,"motion":0,"mouthOpen":0}],"textLeft":"阿晶？@应该很快就会来吧？"},{"chara":[{"cheek":0,"id":100301,"motion":300,"mouthOpen":0}],"textRight":"这样啊……@那我先跟艾米莉老师道歉吧……"},{"chara":[{"cheek":0,"id":100301,"mouthOpen":0}],"textRight":"之后，@我还得跟晶老师和美雨老师道歉才行……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300601,"motion":300,"mouthOpen":0}],"textLeft":"道歉？@为什么？"},{"chara":[{"cheek":0,"id":100301,"motion":0,"mouthOpen":0}],"textRight":"因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":100,"mouthOpen":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"啊——！鹤乃！@你来得正好！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"mouthOpen":0}],"textRight":"晶老师！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0,"mouthOpen":0}],"textLeft":"美雨！@鹤乃在这里！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"纯美雨","textLeft":"唔！@鹤乃，真巧啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301,"motion":400,"mouthOpen":1}],"textRight":"啊！@连美雨老师也在！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":100,"mouthOpen":0,"pos":2}],"nameRight":"木崎衣美里","textRight":"啊，这不是纯纯吗！@好久不见！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301201,"mouthOpen":0}],"textLeft":"不要这样称呼我……"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100301,"motion":0,"mouthOpen":0,"pos":2}],"nameRight":"鹤乃","textRight":"上、上一次我真的……@那个……那个……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100301,"motion":200,"mouthOpen":0}],"textRight":"很、很抱歉！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"诶？@为什么要道歉？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301,"motion":300,"mouthOpen":0}],"textRight":"就、就是工厂的那件事，@那个……我搞砸了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301201,"motion":200,"mouthOpen":0,"pos":0}],"nameLeft":"纯美雨","textLeft":"对了！@厂长有话拜托我转达给你。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"motion":0,"mouthOpen":1,"tear":0}],"textRight":"诶！？@[chara:100301:effect_emotion_surprise_0][se:7226_shock][chara:100301:lipSynch_0][wait:1.0][chara:100301:cheek_1][chara:100301:face_mtn_ex_030.exp.json][chara:100301:mouthOpen_0][chara:100301:tear_1][chara:100301:lipSynch_1]呜呜……果然是要骂我……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":100,"mouthOpen":0}],"textLeft":"他说@『希望你有时间的话再去帮忙』。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"mouthOpen":0}],"textRight":"诶？"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"id":301201,"motion":0,"mouthOpen":0}],"textLeft":"鹤乃那么努力工作，@工厂的人都很开心。"},{"chara":[{"cheek":0,"id":301201,"mouthOpen":0}],"textLeft":"大家很高兴，也都打起精神来了。@所以希望你还能去帮忙。"},{"chara":[{"cheek":0,"id":100301,"mouthOpen":0}],"textRight":"诶？诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":200,"mouthOpen":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"我也有给鹤乃的口信，@是迷路小狗的主人给你的哦！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"mouthOpen":0}],"textLeft":"她说谢谢你帮忙找到了小狗！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0,"mouthOpen":0}],"textLeft":"它的主人是个独居的老奶奶。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300801,"mouthOpen":0}],"textLeft":"所以，那只小狗是她唯一的家人。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":100,"mouthOpen":0}],"textLeft":"她很开心，@并且十分感谢鹤乃哦！"},{"chara":[{"cheek":0,"id":100301,"motion":400,"mouthOpen":0}],"textRight":"诶？诶？诶？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300601,"motion":200,"mouthOpen":0,"pos":0}],"nameLeft":"木崎衣美里","textLeft":"鹤鹤，干得不错！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":0,"mouthOpen":0,"pos":0}],"nameLeft":"志伸晶","textLeft":"鹤乃，谢谢你啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301201,"motion":200,"mouthOpen":0,"pos":0}],"nameLeft":"纯美雨","textLeft":"你还会去帮忙吧？"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":100301,"motion":101,"mouthOpen":1,"tear":1}],"textRight":"当、当然！"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":0,"mouthOpen":0,"pos":2},{"cheek":0,"face":"mtn_ex_011.exp.json","id":100201,"motion":0,"mouthOpen":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_21201.jpg","chara":[{"id":100301,"motion":101}],"nameLeft":"八千代","nameRight":"鹤乃","textRight":"结果就变成了这样！[chara:100301:effect_emotion_joy_0][se:7222_happy]","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"id":100201,"motion":100,"mouthOpen":0}],"textLeft":"太好了呢，鹤乃！"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100301,"mouthOpen":0}],"textRight":"也就是说……"},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":100,"mouthOpen":0}],"textRight":"修行成功了！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100201,"motion":0,"mouthOpen":0}],"textLeft":"啊，是、是吗？@我有点不太明白……"},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100201,"mouthOpen":0}],"textLeft":"不过，@算是有了一个好结果吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100301,"motion":0,"mouthOpen":0}],"textRight":"嗯，没错！@这样一来……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100301,"motion":200,"mouthOpen":0}],"flashEffect":"flashWhite1","textRight":"我也变强了！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100201,"motion":100,"mouthOpen":0}],"textLeft":"嗯？@你说的是……精神上吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100301,"motion":101,"mouthOpen":0}],"textRight":"不，我说的是全面的！@大概是因为得到了很好的经验吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201,"motion":300,"mouthOpen":0}],"textLeft":"呃，我觉得应该不是这样的……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100301,"motion":201,"mouthOpen":0}],"textRight":"八千代师父——！@让我展现一下我现在的实力吧！"},{"chara":[{"cheek":0,"id":100201,"motion":0,"mouthOpen":0}],"textLeft":"啊，她没听见吗？@唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":100,"mouthOpen":0}],"textRight":"来训练吧！@请和我较量较量！[chara:100301:effect_emotion_joy_0][se:7222_happy]"},{"chara":[{"cheek":0,"id":100201,"lipSynch":0,"mouthOpen":0}],"textLeft":"…………"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100201,"lipSynch":1,"motion":100,"mouthOpen":0}],"textLeft":"我去叫桃子她们过来！"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301,"motion":300,"pos":1,"voice":"vo_char_1003_00_05","textHome":"结局是让八千代溜走了呀……@啊对！玲奈在哪呢!?"}],"nameCenter":"鹤乃","textCenter":"结果还是让八千代逃了。@对了，玲奈在哪——！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"motion":201}]},{"chara":[{"id":100301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}