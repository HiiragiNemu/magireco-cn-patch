{"story":{"group_1":[{"autoTurnLast":0.01,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bg":"bg_adv_21143.jpg","bgm":"bgm03_story07","chara":[{"id":100301,"lipSynch":0}],"nameLeft":"鹤乃","nameRight":"菲莉希亚","textLeft":"——！！@[wait:1.0][chara:100301:lipSynch_1]菲莉希亚！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301,"lipSynch":0,"motion":300}],"textLeft":"…………@[wait:1.0][chara:100301:lipSynch_1]我啊……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":200}],"textBg":"shout","textRight":"抱歉！！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"motion":0}],"textLeft":"诶？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"我刚刚说你家很有趣……@让你不高兴了吧？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"说了让你伤心的话……@我很抱歉……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301}],"textLeft":"菲莉希亚……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"不过……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"lipSynch":0}],"textLeft":"？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501}],"textRight":"我并不是……@在说你的坏话……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"那个……@“有趣”说的是……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"从参政的“名门望族”？……@变身成开中华饭店的……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501}],"textRight":"这个巨大的转变……"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100301}],"textLeft":"嗯……"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100501}],"textRight":"所以！[chara:100501:lipSynch_0][wait:1.0][chara:100501:motion_300][chara:100501:cheek_1][chara:100501:face_mtn_ex_030.exp.json][chara:100501:lipSynch_1]啊……@我说的“有趣”，那个……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501}],"textRight":"并没有……@说你家很丢人的意思……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"应该说是很厉害……@或者很惊人……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":200}],"textRight":"是这样的意思！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100301}],"textLeft":"这样啊。"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"因为啊！是从什么政治军事之类的@变成了中华饭店哦！？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501}],"textRight":"感觉就像是@「热情！中华万万岁！」的那种感觉……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":200}],"textRight":"真的……@仿佛漫画一样的情节！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"motion":0}],"textRight":"要真有这样的杰作漫画，@人气肯定会很火爆的！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"motion":200}],"textRight":"因为很有趣！@很厉害嘛！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100301,"lipSynch":0}],"textLeft":"…………"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"lipSynch":0,"motion":0}],"textRight":"——！！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501}],"textRight":"我……又说了@让你不开心的话？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"为什么会这样……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"lipSynch":0}],"textRight":"（为什么……@我总是没办法好好表达……）","turnEffect":"thinking"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301}],"textLeft":"噗！呵呵！@[chara:100301:lipSynch_0][wait:1.0][chara:100301:motion_200][chara:100301:cheek_1][chara:100301:face_mtn_ex_011.exp.json][chara:100301:lipSynch_1]啊哈哈哈哈！！","turnEffect":"stop"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"motion":0}],"textRight":"哈……诶！？"},{"chara":[{"cheek":2,"id":100301,"motion":100,"tear":1}],"textLeft":"嘶……@肚子好痛！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501}],"textRight":"什么……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301,"motion":0}],"textLeft":"因为你突然拿漫画@来做例子啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301,"motion":101}],"textLeft":"竟然连名字都想好了……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"对不起……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301,"motion":400}],"textLeft":"不是……不是啦！@哎呀真是的……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100301,"motion":0,"tear":0}],"textLeft":"我真的……很喜欢菲莉希亚的@这种独特的品味！"},{"bgm":"bgm03_story03","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100301,"motion":100}],"textLeft":"我果然很喜欢菲莉希亚啊！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"lipSynch":0,"motion":0}],"textRight":"——！！"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100501,"lipSynch":0}],"textRight":"（不……她明白我的意思了……@鹤乃她……明白了……）","turnEffect":"thinking"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"我也……","turnEffect":"stop"},{"autoTurnLast":0.01,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100101,"motion":0,"mouthOpen":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":100101,"motion":400}],"nameLeft":"彩羽","textLeft":"找到了！！","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100201,"motion":400}],"nameRight":"八千代","textRight":"菲莉……@[chara:100201:cheek_0:face_mtn_ex_051.exp.json]鹤乃也在！"},{"autoTurnLast":0.01,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100301,"motion":0,"pos":0},{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"nameLeft":"鹤乃","nameRight":"菲莉希亚","textLeft":"呜啊……","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100301,"motion":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201,"motion":0,"pos":2}],"nameRight":"八千代","textLeft":"很抱歉……@我突然跑出来……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100201,"motion":1}],"textRight":"没什么，不用道歉……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100101,"motion":301,"pos":2}],"nameRight":"彩羽","textRight":"菲莉……希亚……@我刚刚也……"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":0,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"我……！"},{"bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100501,"lipSynch":0}],"textLeft":"（咕咕！咕噜噜……）"},{"bgm":"bgm03_story05","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100101,"lipSynch":0,"motion":0}],"textRight":"——！！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"lipSynch":0,"motion":300}],"textLeft":"谁叫……我还没有吃到……@回锅肉什么的……"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100201,"motion":100,"pos":2}],"nameRight":"八千代","textRight":"噗！呵呵……"},{"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":100101,"motion":300,"pos":2,"tear":1}],"nameRight":"彩羽","textRight":"噗、啊哈哈……！@讨厌……刚刚的那个！哈哈！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100301,"motion":100,"mouthOpen":1,"pos":0}],"nameLeft":"鹤乃","textLeft":"呵呵！啊哈！啊哈哈！@就是！好大的声音！"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100501,"motion":200,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100201,"motion":0,"pos":2}],"nameRight":"八千代","textRight":"好了好了，@难得出来吃一次饭。"},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100201,"motion":201}],"textRight":"回锅肉还有炒饭……@都吃够了再回去吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100301,"motion":200,"mouthOpen":1,"pos":0}],"nameLeft":"鹤乃","textLeft":"哦！赞成！！"},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100501,"motion":200,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"我也是！@赞成！"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100101,"motion":100,"pos":2}],"nameRight":"彩羽","textRight":"呵呵，我也是！"},{"autoTurnFirst":3.7,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_e