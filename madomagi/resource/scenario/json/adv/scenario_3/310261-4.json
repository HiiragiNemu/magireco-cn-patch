{"story":{"group_1":[{"autoTurnLast":0.3,"bg":"bg_adv_50013.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm23_tokime03","chara":[{"id":102601,"motion":200}],"nameCenter":"千春","textBg":"shout","textCenter":"静香——","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":102601,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":0,"pos":0}],"nameLeft":"静香","textLeft":"咦？@小千？"},{"chara":[{"id":102501}],"textLeft":"这么晚了有什么事吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":1}],"nameRight":"千春","textRight":"我打算去找找！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601}],"textRight":"静香也一起去吧！好不好？"},{"chara":[{"id":102501,"motion":200}],"textLeft":"找？找什么？@啊，是要找“代代果”吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":100}],"textRight":"不是啦！@是亮点，我要去找亮点！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501}],"textLeft":"你、你冷静点，@总之……你先进来吧？"},{"autoTurnLast":0.5,"bg":"bg_adv_21443.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":1,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":102601}],"textRight":"啊，沙绪也在！","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701}],"nameLeft":"沙绪","textLeft":"小千，晚上好。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801000,"motion":0,"pos":0}],"nameLeft":"静香的母亲","textLeft":"哎呀，千春，@欢迎！"},{"chara":[{"id":801000}],"textLeft":"你要跟我们一起吃晚饭吗？"},{"chara":[{"id":102601,"motion":0}],"textRight":"不用了，我妈妈给我做好了！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102501,"motion":1,"pos":0}],"nameLeft":"静香","textLeft":"那你现在还要出门吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501}],"textLeft":"唔……你要去干什么来着？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":200}],"textRight":"所以说啊！@我要去找这个村子独有的亮点！"},{"nameNarration":"","narration":"[chara:102601:effect_shake]抖抖抖抖抖……","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":100}],"narrationEffect":"out","textLeft":"小千，快别抖腿了……"},{"chara":[{"id":102601,"motion":100}],"textRight":"不是的！@我这是在模仿将军！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0,"pos":2}],"nameCenter":"静香＆沙绪","textCenter":"将军？"},{"autoTurnLast":1.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm01_battle05","chara":[{"id":102701}],"nameRight":"沙绪","textRight":"「爱抖腿将军」……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300}],"textRight":"好像在哪里听说过……"},{"chara":[{"id":102501,"motion":300}],"nameLeft":"静香","textLeft":"所以那个人是真实存在的吗？"},{"chara":[{"eyeClose":1,"id":102701,"motion":1}],"textRight":"唔，怎么说呢……"},{"chara":[{"eyeClose":0,"id":102701}],"textRight":"说不定有人物原型，不过……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":1,"pos":2},{"id":102501,"motion":0}],"nameRight":"千春","textRight":"将军微服私访时，@偶然造访了一个贫穷的村子。"},{"chara":[{"id":102601}],"textRight":"那里的村民日子贫困，@却心地善良，将军放不下他们。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":200}],"textRight":"于是他找到了村子的亮点，@借此挣了钱，救了村子！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":1}],"textLeft":"哇！很像小时候听过的故事呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":200,"pos":0}],"nameLeft":"沙绪","textLeft":"也就是说，小千想做的是……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":100}],"textRight":"没错，我要找到我们村子的亮点，@用它赚大钱！"},{"chara":[{"id":102601,"motion":1}],"textRight":"我和大家都觉得这个村落里@什么也没有……"},{"chara":[{"id":102601}],"textRight":"但说不定还有很多我们没发现的亮点！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":100}],"nameLeft":"沙绪","textLeft":"亮点啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":0}],"textRight":"比如埋有德川留下的宝藏……"},{"chara":[{"id":102601}],"textRight":"那边的山上，@说不定住着战败武者的后裔……"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":102601,"motion":300}],"textRight":"山上还可能住着熊猫……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":300}],"textLeft":"熊猫……这可就难说了……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":100}],"textRight":"不一定哦？！@可能是我们还没发现！"},{"chara":[{"id":102601}],"textRight":"将军找到熊猫和战败武者的时候@也大吃一惊呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0}],"textLeft":"啊，原来是在说古装剧啊……"},{"chara":[{"id":102601,"motion":200}],"textRight":"静香你觉得呢？！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"静香","textLeft":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":1}],"textRight":"静香？@喂——"},{"chara":[{"id":102501,"lipSynch":1,"motion":400}],"textLeft":"啊，抱歉。@我想问问……"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":200}],"textLeft":"那个德川留下的宝藏……@轻易就能找到吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102701,"motion":100,"pos":2}],"nameRight":"沙绪","textRight":"不，当然不……@不如说这根本只是个传说……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501}],"textLeft":"传说？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102501,"motion":100}],"textLeft":"可战败武者的后裔不是传说哦。"},{"chara":[{"id":102501}],"textLeft":"毕竟也有我们这一族的村落嘛。"},{"chara":[{"id":102701,"motion":1}],"textRight":"唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102501,"motion":300}],"textLeft":"还有，熊猫是什么？@既然在山上，那就是某种动物吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":0,"pos":2}],"nameRight":"千春","textRight":"静香你真的什么都不知道啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":100}],"textRight":"一起去的时候我都告诉你。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102701,"motion":0,"pos":0}],"nameLeft":"沙绪","textLeft":"去？去哪里？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102601,"motion":0}],"textRight":"讨厌啦，沙绪。"},{"chara":[{"id":102601}],"textRight":"就像将军一样，@我们也要去找村落的亮点啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102601,"motion":200}],"textRight":"我们三个一起的话很快就能找到！@晚饭前就能回来！"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":102501,"motion":100,"pos":0}],"nameLeft":"静香","textLeft":"行啦，都给我慢着！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":400}],"textRight":"[chara:102601:effect_emotion_surprise_0][se:7226_shock]哇？！"},{"bgm":"bgm03_story02","chara":[{"id":102501}],"textLeft":"天已经黑了哦？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102501,"motion":1}],"textLeft":"现在出门的话，@小千的晚饭都会凉透的。"},{"chara":[{"id":102501}],"textLeft":"你的妈妈肯定也很担心你。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102701,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_030.exp.json","id":102601,"motion":0}],"nameCenter":"沙绪","textCenter":"是啊，小千。"},{"chara":[{"id":102701}],"textCenter":"不要着急，村子的亮点也不会@自己长腿跑掉啊。"},{"chara":[{"id":102701,"motion":200}],"textCenter":"等到了明天，@我们三个再一起去找吧？"},{"chara":[{"eyeClose":1,"id":102601,"motion":300}],"textRight":"唔……"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102601,"motion":100}],"textRight":"我知道了！说好了哦！"},{"autoTurnFirst":5.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102601,"motion":1,"pos":1,"voice":"vo_char_1026_00_03","textHome":"静香她，真的什么都不知道呢……"}],"nameCenter":"千春","textCenter":"静香你真的什么都不知道啊！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"chara":[{"id":102601}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}