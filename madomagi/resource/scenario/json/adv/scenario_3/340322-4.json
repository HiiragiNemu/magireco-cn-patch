{"story":{"group_1":[{"autoTurnLast":1.0,"bg":"bg_adv_13021.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":403201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":300101,"motion":100,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":403201}],"nameLeft":"日向茉莉","nameRight":"矢宵鹿乃子","textLeft":"因为那是我的梦想啊……","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300101,"motion":200}],"textRight":"梦想？"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403201,"motion":100}],"textLeft":"嗯，梦想！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403201}],"textLeft":"去各种地方看各种事物……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403201,"motion":200}],"textLeft":"遇见形形色色的人……@就是我的梦想！"},{"chara":[{"id":300101,"lipSynch":0,"motion":0}],"textRight":"……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300101}],"textRight":"难道……@那就是你许的愿？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403201,"motion":300}],"textLeft":"虽然没有直接关系……"},{"chara":[{"eyeClose":1,"id":403201}],"textLeft":"其实我原本是看不见东西的。"},{"chara":[{"id":403201}],"textLeft":"所以当丘比出现时，@我许了这样的愿望……"},{"chara":[{"eyeClose":0,"id":403201,"motion":0}],"textLeft":"希望让眼睛能看见东西。"},{"chara":[{"id":300101,"motion":100}],"textRight":"对不起，我好像提了不该提的事！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403201,"motion":400}],"textLeft":"咦？@啊，你不用在意的！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403201,"motion":100}],"textLeft":"就算是眼睛看不见的时候，@身边人也都很善良，我活得很快乐。"},{"chara":[{"id":403201}],"textLeft":"我从没觉得自己不幸。"},{"chara":[{"id":403201,"motion":200}],"textLeft":"只是，我不想总受大家的照顾。"},{"chara":[{"id":403201}],"textLeft":"难得有那样的机会，@我便许下了这个愿望。"},{"chara":[{"id":300101,"motion":1}],"textRight":"这样啊。@那你刚才说的梦想……"},{"chara":[{"eyeClose":1,"id":403201,"motion":300}],"textLeft":"实现愿望后，我才第一次知道……"},{"chara":[{"id":403201}],"textLeft":"自己长什么样……@周围的人长什么样……"},{"chara":[{"id":403201}],"textLeft":"太阳有多么耀眼，@大海有多么透明。"},{"chara":[{"eyeClose":0,"id":403201,"motion":0}],"textLeft":"原来自己长这么大……@依旧对这个世界一无所知……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300101,"motion":200}],"textRight":"好！我知道了！@我们走吧！到各种各样的地方去！"},{"chara":[{"id":300101}],"textRight":"神滨还有很多奇奇怪怪的地方呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403201,"motion":100}],"textLeft":"是吗！@感觉会很有趣呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403201}],"textLeft":"唔～但是……"},{"chara":[{"id":403201,"motion":1}],"textLeft":"去哪里好呢……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300101,"lipSynch":0,"motion":300}],"textRight":"……"},{"chara":[{"id":300101,"lipSynch":0}],"textRight":"（知道了她的故事……）"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":300101,"lipSynch":0}],"textRight":"（无论如何都想帮她找到@「能让人永远记住的鲷鱼烧」呢。）"},{"chara":[{"eyeClose":1,"id":300101,"lipSynch":0,"motion":1}],"textRight":"（得再仔细想想……）"},{"chara":[{"id":300101,"lipSynch":0}],"textRight":"（把我为数不多的神滨知识@全部运用起来……）"},{"chara":[{"id":300101,"lipSynch":0}],"textRight":"（找到神滨特有的东西……）"},{"chara":[{"id":300101,"lipSynch":0}],"textRight":"……"},{"chara":[{"eyeClose":0,"id":300101,"motion":200}],"textRight":"有了！！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403201,"motion":400}],"textLeft":"怎么了吗？！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300101}],"textRight":"去调整专家那里吧！"},{"autoTurnFirst":3.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403201,"motion":1,"pos":1,"voice":"vo_char_4032_00_04","textHome":"神滨真是个不可思议的地方啊。感觉还有很多@这样的地方在等着我！"}],"nameCenter":"日向茉莉","textCenter":"神滨真是个不可思议的地方。@感觉应该还有更多别的……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403201,"motion":100}]},{"chara":[{"id":403201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}