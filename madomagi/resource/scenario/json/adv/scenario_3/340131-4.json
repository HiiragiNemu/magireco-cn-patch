{"story":{"group_1":[{"bg":"bg_adv_21141.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301,"motion":0,"pos":2}],"nameLeft":"空穂夏希","nameRight":"牧薰","textRight":"等我回过神来时，@和美跟海香都不见了……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301}],"textRight":"只有我自己一个人在那个公园里。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201,"motion":300}],"textLeft":"发生了这种事啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201}],"textLeft":"果然是魔女干的好事吗……？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301,"motion":1}],"textRight":"虽然没有根据，@但也只能这样解释了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201,"motion":0}],"textLeft":"怎么说呢，@感觉你好冷静啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"因为平时就经常遇到麻烦状况，@我已经习惯了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"还有呢，我是足球部的，@平时一直都有锻炼……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":1}],"textRight":"不管是心理上还是身体上！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301,"motion":300}],"textRight":"虽然有时也会在大好时机射偏啦……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301}],"textRight":"哈哈哈哈……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201,"motion":300}],"textLeft":"能和你这样的人搭档，@一定会很安心吧……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"那么，我们搭档吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":0}],"textLeft":"[chara:300201:effect_emotion_surprise_0][se:7226_shock]哎！？"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":401301,"motion":0}],"textRight":"如果能得到你的帮助，@我也会很感激的……！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201}],"textLeft":"哎……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":100}],"textLeft":"那么，不嫌弃的话……！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300201}],"textLeft":"请多指教了，@薰！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"随意一点就好！@请多指教！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401301,"motion":0}],"textRight":"那么事不宜迟……@希望你和我说说神滨的事。"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401301}],"textRight":"像是哪一带人流密集……@哪一带人流稀少……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401301,"motion":400}],"textRight":"啊，对了……还要先问一下……@这座公园，是处于什么位置！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":1}],"textLeft":"交给我吧，薰！"},{"autoTurnFirst":3.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301,"motion":0,"pos":1,"voice":"vo_char_4013_00_03","textHome":"神滨的魔法少女…到底，是怎么样的呢……？"}],"nameCenter":"牧薰","textCenter":"这个神滨的魔法少女……@究竟是什么样的人呢……？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":4.0,"chara":[{"id":401301,"motion":300}]},{"chara":[{"id":401301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}