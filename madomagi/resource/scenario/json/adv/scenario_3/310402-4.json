{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_14111.jpg","bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100601,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":100601,"lipSynch":0}],"nameCenter":"美冬","textCenter":"（夜鹤，再见。@谢谢你……）","turnChangeOut":"fadeOut"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（今天这半天，我观察了你，@还和你一同度过……）"},{"chara":[{"id":100601,"lipSynch":0,"motion":100}],"textCenter":"（但只是一味加深了@少女调整者的谜团而已。）"},{"chara":[{"eyeClose":1,"id":100601,"lipSynch":0}],"textCenter":"（不过……）"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100601,"lipSynch":0,"motion":1}],"textCenter":"（夜鹤，我弄清楚了。）"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（你是一个时常关心周围，@非常温柔的人。）"},{"chara":[{"id":100601,"lipSynch":0,"motion":200}],"textCenter":"（虽说有时会白忙一场……）"},{"chara":[{"id":100601,"lipSynch":0}],"textCenter":"（我会向大家好好汇报的。）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100601,"lipSynch":0}],"textCenter":"（我会告诉她们……@夜鹤是一个很温柔的人……）"},{"autoTurnLast":1.5,"bg":"bg_adv_14122.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp.json","id":103900,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm23_puella02","nameNarration":"","narration":"＜几小时后＞","narrationBg":"bg_adv_14122.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":104101,"motion":1}],"nameRight":"莉薇娅","narrationEffect":"out","textRight":"我回来了——"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103900,"motion":100}],"nameLeft":"月出里","textLeft":"呼呼嗯呼！"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":0}],"nameLeft":"夜鹤","textLeft":"欢迎回来。"},{"chara":[{"id":104101,"motion":200}],"textRight":"所以那女孩怎么样了？"},{"textRight":"她消除戒心了吗？"},{"chara":[{"id":104000,"motion":300}],"textLeft":"嗯……@说实话，我不太清楚。"},{"textLeft":"话说一半时，@有应许之血的客人来了……"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":104101,"motion":400}],"textRight":"那还真是糟透了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101}],"textRight":"不过，看你表情，@似乎还挺开心的。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100}],"textLeft":"是的……@我们聊得很开心。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"motion":100}],"textRight":"那就行。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":104000}],"textLeft":"啊，不过，@气氛有点糟的时候……"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101}],"textLeft":"我试着扮鬼脸缓和一下气氛，@结果冷场了。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000}],"textLeft":"笔记上写着，@推荐用玩笑缓和气氛……"},{"chara":[{"id":104101,"motion":1}],"textRight":"那肯定是玩笑不够好笑。"},{"textRight":"只要多加训练，肯定能成功。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400}],"textLeft":"训练啊……"},{"chara":[{"id":104101,"motion":0}],"textRight":"要说的话，@算是你的特训啦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103900,"motion":200,"pos":2}],"nameRight":"月出里","textRight":"呼呣呼呼呣呼！"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":100}],"textLeft":"唉……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000}],"textLeft":"但是老师……@今天也太过分了。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":100,"pos":2}],"nameRight":"莉薇娅","textRight":"怎么？说丧气话啊？"},{"chara":[{"id":104000,"motion":1}],"textLeft":"该说是丧气话吗……"},{"autoTurnLast":0.2,"bg":"bg_adv_21241.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":1,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameLeft":"莉薇娅","textLeft":"总之……夜鹤，你来跟她聊聊吧。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}],"nameRight":"夜鹤","textRight":"咦……"},{"chara":[{"eyeClose":1,"id":104000},{"id":104101,"motion":1}],"surround":"7202_telepathy","textLeft":"看来这女孩对我们戒心很重。","turnEffect":"ef_adv_02"},{"textRight":"啊……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101}],"textLeft":"所以，@夜鹤你要去消除她的戒心。"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":104000,"motion":100}],"textRight":"让、让我来吗？"},{"autoTurnLast":0.2,"bg":"bg_adv_14122.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":1,"pos":0}],"surround":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"},{"nameLeft":"夜鹤","textLeft":"这个命令明显不适合我。","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}],"textLeft":"因为我……"},{"bgm":"stop","chara":[{"id":104000,"motion":100}],"textLeft":"可是欠缺[textRed:温柔的感情]啊？"},{"textLeft":"我没有一颗温柔的心。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}],"textLeft":"肯定难以消除别人的戒心。"},{"bgm":"bgm03_story06","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":200}],"nameRight":"莉薇娅","textRight":"所以才让你去啊，@这也是特训的一环。"},{"textRight":"你有好好参考那个笔记吗？"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1}],"textLeft":"嗯……@能做的事我应该都做了。"},{"textLeft":"虽说冷场了，但也学到了新的知识。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":300}],"textRight":"那就好。"},{"textRight":"身为调整专家，@要洞察对方的内心状态。"},{"chara":[{"id":104101,"motion":100}],"textRight":"为此，必须保持温柔、理解温柔。"},{"textRight":"很遗憾，@你身上没有一个调整专家必备的温柔。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"motion":1}],"textRight":"所以才要用到那份笔记。"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":100}],"textLeft":"嗯，非常感谢。"},{"chara":[{"eyeClose":0,"id":104000},{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101}],"textLeft":"老师为我提出了这份记载着@温柔行为的笔记，"},{"textLeft":"只要按照上面写的来……"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":400}],"textLeft":"我就能伪装成一个温柔的人。"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000},{"cheek":0,"face":"mtn_ex_050.exp.json","id":104101}],"narration":"咕噜噜～～","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103900,"motion":400,"pos":2}],"nameRight":"月出里","narrationEffect":"out","textRight":"嗯呼！@嗯呼呼呣呼呼！"},{"bgm":"bgm03_story13","chara":[{"id":104000,"motion":100}],"textLeft":"这个肚子的叫声表示饥饿！"},{"textLeft":"那面对饥饿的人，@温柔的人应该怎么办呢……"},{"chara":[{"id":104000,"motion":1},{"id":103900,"motion":0}],"narration":"翻翻……","narrationEffect":"in"},{"narrationEffect":"out","textLeft":"找到了！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":200}],"textLeft":"要提供饭菜！"},{"textLeft":"那我马上去准备饭菜……"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}],"textLeft":"啊！@但现在已经是傍晚了，"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100}],"textLeft":"这时候马上就要吃晚饭了，@所以……"},{"narration":"翻翻……","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000}],"narrationEffect":"out","textLeft":"找到了！"},{"textLeft":"要提供少量甜品。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}],"textLeft":"那我去做些简单的甜品。"},{"textLeft":"也会做老师的份。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104101,"motion":0,"pos":2}],"nameRight":"莉薇娅","textRight":"没错。"},{"textRight":"就算肚子不饿，@看见旁边人吃东西自己也会想吃。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":104101,"motion":200}],"textRight":"也要好好考虑到这种心理。"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0}],"textLeft":"是的，这个情况在笔记上也有记录。"},{"autoTurnLast":1.0,"bg":"bg_adv_21081.jpg","nameNarration":"夜鹤","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"narration":"我为什么会欠缺温柔呢","turnChangeOut":"fadeOut"},{"narration":"那是因为，我许了这样的愿望"},{"narration":"事情要回溯到……@我还很温柔的时候"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":801201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":800600,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"nameRight":"夜鹤的母亲","textRight":"夜鹤，你真厉害～@做得好！","turnChangeOut":"fadeOut"},{"textLeft":"哇，好开心！"},{"textRight":"真期待你长大后的样子呢～"},{"narration":"那时我还很年幼、很温柔……@也很不自由","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","turnEffect":"stop"},{"autoTurnLast":0.01,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"autoTurnFirst":4.3,"chara":[{"id":104000,"motion":300,"voice":"vo_char_1040_00_04","textHome":"生きていくには邪魔なものが多すぎます"}],"nameCenter":"夜鹤","textCenter":"有太多东西妨碍我活下去了。","turnChangeOut":"fadeOut"},{"chara":[{"id":104000}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}