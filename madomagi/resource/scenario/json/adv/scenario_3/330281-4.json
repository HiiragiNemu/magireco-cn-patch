{"story":{"group_1":[{"bg":"bg_adv_15021.jpg","bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"夏目佳子","textCenter":"（这样下去@事情会闹大的……！）","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"lipSynch":0,"motion":400}],"textCenter":"（我要加油才行！@必须想想办法！）"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"motion":0}],"textCenter":"两位……@你们真的要战斗吗？","turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp.json","id":302801,"motion":200,"pos":2}],"nameLeft":"菲莉希亚","nameRight":"三栗菖蒲","textRight":"当然啦！","turnChangeIn":"rollInFast","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100501,"motion":200}],"textLeft":"让我们一决胜负，@看看谁才是更强的魔法少女吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":200,"pos":2}],"nameRight":"夏目佳子","textRight":"太危险了！@万一受伤可怎么办……！？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100501,"motion":0}],"textLeft":"那也没办法啊~@这场比试势在必行！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"motion":400}],"textRight":"为、为什么……！？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302801,"motion":0,"pos":2}],"nameRight":"三栗菖蒲","textRight":"因为……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302801,"motion":100}],"textRight":"我绝对不要输给菲莉希亚！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100501,"motion":200}],"textLeft":"我也不想输给菖蒲！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"夏目佳子","textLeft":"（总觉得，这两个人的纠纷……）","turnEffect":"thinking"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"lipSynch":0}],"textLeft":"（就好像在书上看到的@野生动物争抢地盘一样……）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"lipSynch":0,"motion":400}],"textLeft":"[chara:301101:effect_emotion_surprise_0][se:7226_shock]（现、现在不是@想这种事的时候！）"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101}],"textLeft":"那那那那那个！","turnEffect":"stop"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302801,"motion":200}],"textRight":"[chara:302801:effect_emotion_angry_0][se:7219_strain]干嘛啊~真是的~！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301101,"motion":0}],"textLeft":"抱、抱歉！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101,"motion":1}],"textLeft":"那个……那个，@不要战斗啦……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"motion":1}],"textLeft":"至少用其他方式@来决胜负如何！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302801,"motion":0}],"textRight":"？其他方式？@什么意思？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":0,"pos":2}],"nameRight":"菲莉希亚","textRight":"用其他方式@来决胜负？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"motion":100}],"textLeft":"呃、呃，那个……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":400}],"textLeft":"什、什么都可以的！@[chara:301101:lipSynch_0][wait:0.8][chara:301101:cheek_0][chara:301101:face_mtn_ex_011.exp.json][chara:301101:lipSynch_1]比如说……那个……"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"motion":0}],"textLeft":"绕口令……？"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302801,"motion":100,"mouthOpen":1,"pos":2}],"nameRight":"三栗菖蒲","textRight":"[chara:302801:effect_emotion_angry_0][se:7219_strain]啊？你说什么啊！？"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301101,"motion":300}],"textLeft":"那就，呃……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101}],"textLeft":"百、百人一首@怎么样？"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100501,"motion":200,"pos":2}],"nameRight":"菲莉希亚","textRight":"那样怎么分出谁更强！"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":200}],"textLeft":"总而言之！@我想说的是……"},{"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301101,"motion":400}],"textLeft":"必须是不会受伤的比赛才行！"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101}],"textLeft":"我不想看到你们受伤……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"motion":0}],"textRight":"唔……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100501,"motion":300}],"textRight":"这样啊……抱歉……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302801,"motion":200,"pos":0}],"nameLeft":"三栗菖蒲","textLeft":"啊，那么，@破坏废墟游戏如何？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100501,"motion":200}],"textRight":"抛掷汽车怎么样！？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301101,"motion":0,"pos":2}],"nameRight":"夏目佳子","textRight":"也不能给周围的人添麻烦……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101}],"textRight":"啊！不如挑几个项目，全都比一次"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"motion":400}],"textRight":"全方位比拼@身为魔法少女的各项才能吧！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302801,"motion":100}],"textLeft":"哦，感觉这个很有趣呢！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100501,"motion":200,"pos":0}],"nameLeft":"菲莉希亚","textLeft":"好啊，不过可别太麻烦！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301101,"lipSynch":0,"motion":100}],"textRight":"（太、太好了！@两人都同意了！）","turnEffect":"thinking"},{"autoTurnFirst":2.1,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302801,"motion":1,"pos":1,"voice":"vo_char_3028_00_03","textHome":"这不是很有趣嘛！我的斗志燃烧起来了——！"}],"nameCenter":"三栗菖蒲","textCenter":"很有趣嘛！@菖蒲的斗志燃烧起来了！","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302801,"motion":100}]},{"chara":[{"id":302801}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}