{"story":{"group_1":[{"bg":"bg_adv_21073.jpg","bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":1,"pos":2}],"nameLeft":"空穗夏希","nameRight":"志伸晶","textRight":"然后呢？@结果怎么样？","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300201}],"textLeft":"和今天一样，@大获全胜哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300801,"motion":200}],"textRight":"真厉害！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":300}],"textLeft":"不不，@打败魔女的是那个女孩。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0}],"textLeft":"但是，@我当时产生了一个想法。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201}],"textLeft":"魔法少女和棒球一样，@声援的力量都是可以传达到的。"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101101,"motion":1,"pos":2}],"nameRight":"枫","textRight":"不过，那个女孩……@很厉害……"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101101}],"textRight":"能自己下定决心@不逃避……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":1}],"textLeft":"今天的枫也很厉害哦？"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101101}],"textRight":"我……如果没有夏希@鼓励我的话……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0}],"textLeft":"从结论来说，你很努力啊，@已经很厉害了哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0,"pos":2}],"nameRight":"志伸晶","textRight":"没错没错。"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":300,"pos":2}],"nameRight":"枫","textRight":"谢、谢谢……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0,"pos":2}],"nameRight":"志伸晶","textRight":"夏希不管是作为拉拉队队长……@还是魔法少女……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":1}],"textRight":"都是大家可靠的@支持者呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":1}],"textLeft":"没错，而且还是经理哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":0,"pos":2}],"nameRight":"枫","textRight":"经理？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0}],"textLeft":"我同时兼任着@拉拉队社和棒球社经理哦。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":100,"pos":2}],"nameRight":"志伸晶","textRight":"哦哦，你简直就是@大家完美的支持者呢。"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300201}],"textLeft":"是吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":0}],"textRight":"不过啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801}],"textRight":"棒球社的三年级学生，@已经临近毕业了吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801}],"textRight":"真让人寂寞啊。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":301}],"textLeft":"是啊……"},{"bgm":"bgm01_anime07","chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101101,"motion":100,"pos":2}],"nameRight":"枫","textRight":"啊！@[chara:101101:effect_emotion_surprise_0][se:7226_shock]已、已经这么晚了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300801,"motion":400,"pos":2}],"nameRight":"志伸晶","textRight":"呜哇！真的啊！@打扰得太久了！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":400}],"textLeft":"哦哦，一不小心！@抱歉、抱歉！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201,"motion":0}],"textLeft":"我送你们回去！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300801,"motion":0}],"textRight":"谢啦"},{"chara":[{"cheek":0,"effect":"emotion_surprise_0","face":"mtn_ex_050.exp.json","id":300201}],"se":"7226_shock","textLeft":"啊！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101101,"motion":0,"pos":2}],"nameRight":"枫","textRight":"嗯？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300201}],"textLeft":"晶，我把拉拉队的@队服借给你吧？"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":300801,"motion":400,"pos":2}],"nameRight":"志伸晶","textRight":"诶！？不不、不用了！@别给我啊！"},{"chara":[{"cheek":0,"effect":"emotion_joy_0","face":"mtn_ex_011.exp.json","id":300201,"motion":200}],"se":"7222_happy","textLeft":"诶——@还以为你会想穿呢。"},{"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":300801,"motion":200}],"textRight":"我没想过！@根本没想过！！"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101101,"motion":1,"pos":2}],"nameRight":"枫","textRight":"呵呵呵。"},{"autoTurnFirst":2.8,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201,"motion":0,"pos":1,"voice":"vo_char_3002_00_04","textHome":"“毕业”这样的词，会让我心头一紧。@真的……会变寂寞啊。"}],"nameCenter":"空穗夏希","textCenter":"听到毕业这个词，我的心猛地一跳。@真的……会变得寂寞啊。","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201,"motion":301}]},{"chara":[{"id":300201}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}