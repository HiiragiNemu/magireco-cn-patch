{"story":{"group_1":[{"bg":"bg_adv_14041.jpg","bgm":"bgm03_story11","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":0,"pos":2}],"nameLeft":"空穂夏希","nameRight":"牧薰","textLeft":"有同伴时……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"刚才我打前锋，@夏希在后方支援……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"战斗起来真的非常轻松……！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":301}],"textLeft":"非常……轻松？"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":1}],"textRight":"因为我平时就是和同伴组队战斗的……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"所以一直都很重视团队的协调性。"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":0}],"textRight":"可是，我和你明明是第一次组队……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"我们的合作却非常顺畅！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":0}],"textLeft":"真的……！？"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401301,"motion":0}],"textRight":"像棒球和足球，@每个球员都会负责不同的位置吧？"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300201}],"textLeft":"嗯……"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"如果每个人都是前锋、四棒，@那队伍就不成立了……"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401301,"motion":100}],"textRight":"每个人各司其职，@才能发挥出团队的优势……！"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300201,"motion":200}],"textLeft":"在拉拉队中，@每个队员也有不同的任务……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":0}],"textRight":"没错！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301}],"textRight":"大家都完成好自己的任务，@才能发挥出团队的优势……！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":100}],"textRight":"所以，夏希你应该@采用最适合自己的战斗方式！"},{"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":401301}],"textRight":"没事的！@夏希你是个很强的魔法少女！"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401301,"motion":0}],"textRight":"所以，@别勉强自己啊……！"},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300201,"motion":0}],"textLeft":"薰……！@[chara:300201:lipSynch_0][wait:0.8][chara:300201:cheek_1][chara:300201:face_mtn_ex_030.exp.json][chara:300201:lipSynch_1]那个……"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300201,"motion":100}],"textLeft":"谢谢你……！"},{"bgm":"stop","nameNarration":"牧薰","narration":"就在那时……","narrationBg":"bg_adv_14041.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401301},{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":0}],"narrationEffect":"out","textRight":"[chara:401301:effect_ef_adv_01][se:7201_detect_magic]！？"},{"bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300201,"motion":400}],"textLeft":"灵魂宝石……！"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401301,"motion":400}],"textRight":"有反应了……！"},{"autoTurnFirst":5.3,"bg":"bg_adv_narration.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401301,"motion":0,"pos":1,"voice":"vo_char_4013_00_04","textHome":"神滨……和我们居住的地方情况不一样啊……"}],"nameCenter":"牧薰","textCenter":"神滨和我们居住的城市@不太一样呢……","turnChangeIn":"fadeIn","turnChangeOut":"fadeOut","turnEffect":"stop"},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401301}]},{"chara":[{"id":401301}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}