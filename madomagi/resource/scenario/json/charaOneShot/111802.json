111802,"lipSynch":0,"motion":0,"pos":1,"voice":"vo_char_1118_00_18","textHome":"小时候，母亲似乎也带我来过海边。@小时候么……难道说？@对，或许是和月咲一起的呢。"}]},{"autoTurnFirst":3.0,"chara":[{"id":111800,"lipSynch":0},{"cheek":0,"face":"mtn_ex_050.exp.json","id":111802,"lipSynch":1}]},{"autoTurnFirst":1.3,"chara":[{"id":111802,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":111802,"lipSynch":0},{"id":111800,"lipSynch":1,"motion":100}]}],"group_12":[{"autoTurnFirst":1.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":111800,"lipSynch":1,"motion":100,"pos":0,"voice":"vo_char_1118_00_19","textHome":"请看吧，我已经熟悉了如何操纵香蕉船！"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111802,"lipSynch":0,"motion":1,"pos":1,"voice":"vo_char_1118_00_19","textHome":"请看吧，我已经熟悉了如何操纵香蕉船！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":111800}]}],"group_13":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111800,"lipSynch":1,"motion":0,"pos":0,"voice":"vo_char_1118_00_20","textHome":"看着大海，@我会觉得自己的烦恼其实都微不足道。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111802,"lipSynch":0,"motion":0,"pos":1,"voice":"vo_char_1118_00_20","textHome":"看着大海，@我会觉得自己的烦恼其实都微不足道。"}]},{"autoTurnFirst":5.0,"chara":[{"id":111800,"motion":300}]}],"group_14":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111800,"lipSynch":0,"motion":1,"pos":0,"voice":"vo_char_1118_00_21","textHome":"给水枪加水的时机是很重要的哦！@我们也刚掌握这一诀窍，战术更加灵活了呢。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":111802,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_1118_00_21","textHome":"给水枪加水的时机是很重要的哦！@我们也刚掌握这一诀窍，战术更加灵活了呢。"}]},{"autoTurnFirst":3.7,"chara":[{"id":111802,"lipSynch":0},{"id":111800,"lipSynch":1,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":111800,"motion":200}]}],"group_15":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":111800,"lipSynch":1,"motion":400,"pos":0,"voice":"vo_