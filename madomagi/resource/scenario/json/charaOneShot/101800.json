{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_01","textHome":"在下天音月夜。如此场合之下，不知应提起@何等话题……嗯，是天音月咲的双胞胎姐姐，@平日担任水名女子学园筝曲部部长之余，也练习@各种技艺。心爱之物……那便是月咲妹妹了。"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101800}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"id":101800,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"id":101800,"motion":100}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_18","textHome":"在外婆指示下，忙于各种技艺练习的我还有@最后一道槛。那就是在这鸟笼一般的家庭中@学会独立。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":200}]}],"group_11":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_19","textHome":"愿我演奏的音色，能响彻更远的地方。"}]},{"autoTurnFirst":4.2,"chara":[{"id":101800,"motion":100}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_20","textHome":"身为姐姐，这样就能守护月咲妹妹了吗？"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_13":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_21","textHome":"撒娇与哭喊是无意义的。此乃忍受万难，@为解放而尽力的结果。"}]},{"autoTurnFirst":4.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":100}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_22","textHome":"仅仅忍耐下去，终会摧残心灵，@人终究需要治愈与活力。而对我来说，@无需多言，那便是月咲妹妹了。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":200}]}],"group_15":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_23","textHome":"于忍耐中，饱含自尊的美丽精神，自制……！@得益于此，我也能堂堂正正做人。@今后我要为了解放自己和守护月咲妹妹，@成为顶天立地的人。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":200}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_24","textHome":"状态如何？我今天也要专心学艺……@但是无妨，有这根与月咲妹妹一对的笛子@陪着我。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":101800}]}],"group_17":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_25","textHome":"早安。今日无论遭遇何等不讲理的语言暴力，@我都会努力忍耐的！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]}],"group_18":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_26","textHome":"月咲妹妹现在，是否正在用午餐呢？@每天都吃着和男生们一样的饭食，@真担心营养会不会欠缺……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":300}]}],"group_19":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_27","textHome":"月咲妹妹现在，为了学徒们的晚饭和洗衣@而拼命准备着，我却都交给了母亲……@真是没有出息……"}]},{"autoTurnFirst":5.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":300}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_03","textHome":"忍耐……乃是崇高的精神。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":100}]}],"group_20":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_28","textHome":"沐浴以后，在身体发冷之前就寝最佳。@温暖的被褥，就像月咲妹妹一样治愈人心。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"id":101800,"motion":100}]}],"group_21":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_29","textHome":"稍微得闲，就教你如何吹奏竹笛吧？@首先注意不要用指尖去按孔。"}]},{"autoTurnFirst":4.5,"chara":[{"id":101800,"motion":1}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_30","textHome":"准备完毕就出发吧！月咲妹妹在等着了！@今天要一起去逛街购物！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":101800,"motion":1}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_31","textHome":"所谓镜之魔女，又是个麻烦的事物呢……@可是我和月咲妹妹本来就是双胞胎，@如果进去的话又会变成怎样呢……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":300}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_32","textHome":"虽然擅长和别人联手，但那只是表面上的。@真正能够信赖的人是有限的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]},{"autoTurnFirst":6.0,"chara":[{"id":101800,"motion":300}]}],"group_25":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_33","textHome":"有些难以启齿，从客人那里收受了西式点心@就不禁心花怒放。因为平时都只有和式点心。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":1}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_34","textHome":"有道是庭中种植枇杷树会使人患病，@但那只是虚言。我的身体非常健康。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_35","textHome":"由比鹤乃……善动脑筋，故是危险人物。@深月菲莉希亚……毫无头脑，@故行为使人难以看透……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":300}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_36","textHome":"若谈及学校中喜好的地点，那便是医务室了。@在学校里总是莫名其妙地被尊敬着，@一直提心吊胆。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]}],"group_29":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_37","textHome":"相比笛声，切削木头的声音反而更让我安心。@恐怕是与父亲共同生活时的记忆作祟吧。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":300}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_04","textHome":"由父亲手中所得的笛子，有着特殊的意义。"}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_38","textHome":"最后一次见到月咲已经是十多年之前了，@所以我之前连有个双胞胎妹妹都不知道。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_39","textHome":"我能与月咲妹妹再会，多亏了有父亲给与我的@竹笛……我会一生都把它当作宝物……"}]},{"autoTurnFirst":4.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":101800,"motion":100}]}],"group_32":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_40","textHome":"请不要过多提及关于玛吉斯之翼的话题……"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":200}]}],"group_33":[{"autoTurnFirst":9.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_41","textHome":"哈……果然随煎茶的方式不同，绿茶的味道@也完全不一样呢……啊，非常抱歉！@一个人的时候就松懈下来了……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101800,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":101800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101800,"motion":300}]}],"group_34":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_42","textHome":"来，开始表演吧。"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_43","textHome":"做到了！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_44","textHome":"这也是忍耐的恩赐吧。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_45","textHome":"感谢聆听。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_46","textHome":"演出到此结束。"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_63","textHome":"请放心。凭这一击拉下帷幕。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_05","textHome":"相伴之人唯有彼此，@我与月咲妹妹将会一直在一起。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_64","textHome":"结束无用的战斗吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101800,"motion":200}]}],"group_41":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_65","textHome":"满载信念的一击，请收下吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":100}]}],"group_42":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_66","textHome":"演出是否应该结束了呢？"}]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_02","textHome":"初次见面，在下天音月夜。虽说想奏出悦耳的@音色，但月咲妹妹在否呢？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":100}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_13","textHome":"唯努力、忍耐与月咲妹妹不可辜负。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101800,"motion":200}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_14","textHome":"这也是耐心且努力的结果。"}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_15","textHome":"那么，就用这琴音来表达吧……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_8":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_16","textHome":"得益于外婆指示下的毛笔和硬笔书法练习，@在学校的活动中，老师也经常托付给我。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_9":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_17","textHome":"得益于外婆指示下的器乐练习，@现在我担任了筝曲部的部长。@被周围的后辈们仰慕，@没有比这更让人高兴的了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":101800,"motion":100}]}]},"version":3}