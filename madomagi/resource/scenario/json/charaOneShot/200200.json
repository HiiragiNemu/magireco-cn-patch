{"story":{"group_1":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_2002_00_01","textHome":"我有必须完成的事情。为此，无论存在什么@障碍，我都会加以排除。无论背负什么罪孽，@我都不在乎。我自己怎样都无所谓。@在那时……被她拯救的那个时刻，@我就已经下定决心了。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":200200,"motion":200}]},{"autoTurnFirst":5.75,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":200200}]},{"autoTurnFirst":10.0,"chara":[{"eyeClose":0,"id":200200,"motion":1}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_17","textHome":"为了拯救救下我的小圆，这次由我来成为魔法@少女。但是，最终总是以她的牺牲结束。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"id":200200,"motion":101}]},{"autoTurnFirst":2.9,"chara":[{"eyeClose":1,"id":200200}]}],"group_11":[{"autoTurnFirst":6.45,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_18","textHome":"我一定要在这条拯救她的道路上找到出口。@所以无论跨越多少次时空我都愿意……@只要能拯救小圆！"}]},{"autoTurnFirst":5.0,"chara":[{"id":200200,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200200,"motion":300}]}],"group_12":[{"autoTurnFirst":6.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_19","textHome":"我感受到了力量……@只要继续下去，我就能变得更强。"}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_20","textHome":"这种感觉……我的感官开始敏锐起来了。"}]},{"autoTurnFirst":2.55,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200200}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_21","textHome":"在我的目的达成之前，我绝不会停下脚步。@我已经下定决心，只要有一丝可能，@我就会不断地……不断地尝试。"}]},{"autoTurnFirst":6.5,"chara":[{"id":200200,"motion":1}]},{"autoTurnFirst":2.7,"chara":[{"id":200200,"motion":300}]}],"group_15":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_22","textHome":"无论多少力量我都想拥有。如果无法打倒魔女@之夜，小圆就会和丘比签订契约。@获得巴麻美、美树沙耶香的协力恐怕很难。@如果佐仓杏子也不和我一起战斗的话……@就只好靠我一人了。"}]},{"autoTurnFirst":5.0,"chara":[{"id":200200,"motion":200}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":200200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":200200,"motion":300}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_24","textHome":"你来了。我只是做我应该做的事情而已。@所以，不管你做什么都是你的自由，@只要不打扰到我就行了。可以吗？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":200200,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":200200,"motion":100}]}],"group_18":[{"autoTurnFirst":6.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_2002_00_25","textHome":"等不到天亮的夜晚是不存在的。@早晨自然而然地会到来。但我现在特别理解，@早晨的到来也是有着它的道理的。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200200,"motion":100}]}],"group_19":[{"autoTurnFirst":9.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_26","textHome":"饿了的话，最好赶紧吃点什么。@比起在危急关头行动迟钝，@还是预先应对为好。"}]},{"autoTurnFirst":3.2,"chara":[{"id":200200,"motion":300}]}],"group_2":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_02","textHome":"我赋予了自己使命，为此我会不断战斗。无论@过去还是现在……我是晓美焰，是魔法少女。"}]},{"autoTurnFirst":3.45,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":200200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"id":200200,"motion":0}]}],"group_20":[{"autoTurnFirst":6.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_27","textHome":"世界被夜色笼罩……@也就是说，黑暗开始扩散。@当心藏身于黑暗中蠢蠢欲动的魔女……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200200,"motion":100}]}],"group_21":[{"autoTurnFirst":4.35,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_28","textHome":"有一个平静安稳的夜晚，@就已经是很幸福的事情了。@在梦醒之前，应该好好享受那份幸福。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":200200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200200,"motion":100}]}],"group_22":[{"autoTurnFirst":7.85,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_29","textHome":"虽然我们看不到时间，但它确实在流逝。@现在也是如此。我比任何人都明白这件事。"}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200200,"motion":0}]}],"group_23":[{"autoTurnFirst":6.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_30","textHome":"抓紧时间。我要监视丘比不让它和小圆接触。@决战的准备也已经差不多了……@无论如何也要抢在前面阻止它才行……"}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200200,"motion":300}]}],"group_24":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_31","textHome":"在战斗中经历各种各样的状况的话，@一旦遇到突发状况，身体也能作出反应。@开始吧。希望比热身活动有趣。"}]},{"autoTurnFirst":0.01,"chara":[{"eyeClose":0,"id":200200}]},{"autoTurnFirst":6.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200200,"motion":1}]}],"group_25":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_2002_00_32","textHome":"即使在混战中也存在着胜机。@只要战斗的时候不迷失自我，@无论什么样的状况都可以找出机会。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200200,"motion":200}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_33","textHome":"把不可能变为可能……确实算是奇迹吧。@但是，成为魔法少女，换来的就是失去一切。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":200200}]}],"group_27":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_34","textHome":"我们魔法少女战斗的理由只有一个……@就是为了自己的愿望，无论那样是多么的孤独。"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200200,"motion":101}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":200200,"motion":300}]}],"group_28":[{"autoTurnFirst":7.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_35","textHome":"最大的敌人就是那个魔女……只要能打倒它，@一切就会结束。所以，我只好用尽手段。"}]},{"autoTurnFirst":4.2,"chara":[{"id":200200,"motion":300}]}],"group_29":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":101,"pos":1,"tear":0,"voice":"vo_char_2002_00_36","textHome":"我不打算去依赖任何人……@也不期望什么人能理解我。@我要靠我自己来打破这段命运……！"}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200200,"motion":300}]}],"group_3":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":101,"pos":1,"tear":0,"voice":"vo_char_2002_00_03","textHome":"无论多少次轮回，我的想法都不会变。"}]}],"group_30":[{"autoTurnFirst":9.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":101,"pos":1,"tear":0,"voice":"vo_char_2002_00_37","textHome":"巴麻美的茶会招待，佐仓杏子给我的食物，@是她们展示友好的方式。@就算改变了过去，这也不会改变。"}]},{"autoTurnFirst":4.0,"chara":[{"id":200200,"motion":300}]}],"group_31":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":101,"pos":1,"tear":0,"voice":"vo_char_2002_00_38","textHome":"无数次跨越时空，无数次和小圆相遇，@她始终都是那么温柔。@但是她的温柔有时会束缚我的心。"}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":200200,"motion":300}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":101,"pos":1,"tear":0,"voice":"vo_char_2002_00_39","textHome":"一旦成为了魔法少女，@就已经拯救不了自己了。@但是，只要赌上自己的一切……@就能够拯救别的某个人……"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":200200}]},{"autoTurnFirst":0.01,"chara":[{"eyeClose":0,"id":200200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200200,"motion":0}]}],"group_33":[{"autoTurnFirst":6.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_40","textHome":"绝不会让丘比……不，孵化者的阴谋得逞。@我会不断抗争，粉碎它的企图……！"}]},{"autoTurnFirst":6.5,"chara":[{"id":200200,"motion":200}]}],"group_34":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_41","textHome":"在同样的时间中反复轮回，@我也记住了许多事情。@像是上课的内容还有学生的行动。@我记得那个男同学好像是中泽吧。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":200200,"motion":200}]}],"group_35":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_42","textHome":"我一个人就够了。"}]}],"group_36":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_43","textHome":"我不会在这个地方失败……！"}]}],"group_37":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_44","textHome":"你们真是捡了一条命。"}]}],"group_38":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_45","textHome":"所以我……会战斗下去。"}]}],"group_39":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0}]}],"group_4":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_04","textHome":"答案应该就藏在什么地方。"}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":200200}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_63","textHome":"这一次……做个了结吧！"}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0}]}],"group_42":[{"autoTurnFirst":3.8,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_65","textHome":"（空）"}]}],"group_43":[{"autoTurnFirst":1.2,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":100,"pos":1,"tear":0,"voice":"vo_char_2002_00_66","textHome":"（空）"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":1,"id":200200}]}],"group_5":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_2002_00_05","textHome":"无论事态变成什么样子，@我要做的事情都不会变。"}]},{"autoTurnFirst":2.4,"chara":[{"eyeClose":0,"id":200200,"motion":200}]}],"group_6":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":200200,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_2002_00_13","textHome":"我拥有力量……所以我要到达更高的地方。"}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200200,"lipSynch":1,"motion":200,"pos":1,"tear":0,"voice":"vo_char_2002_00_14","textHome":"我不认为这里就是终点……@但是，确实更加顺手了。"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":200200,"motion":101}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":200200,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_2002_00_15","textHome":"嗯……前景不错。我能看到前进的方向了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":200200,"motion":200}]}],"group_9":[{"autoTurnFirst":9.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200200,"lipSynch":1,"motion":300,"pos":1,"tear":0,"voice":"vo_char_2002_00_16","textHome":"我以前没什么自信，只会一个劲给别人@添麻烦，什么事都做不好。但是，小圆却向@那样的我伸出了手。"}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200200,"motion":1}]}]},"version":3}