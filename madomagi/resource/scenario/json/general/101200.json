{"story":{"group_1":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_01","textHome":"我乃生于万圣节的魔法少女，魔法花凛。给我@糖果的话我就会说Treat and Trick !然后恶作剧！哎？嗯，不是@or而是and的说。得到糖果就@会进行打败魔女的恶作剧，@是这样设定的说！很帅气吧？"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_18","textHome":"《怪盗少女魔法希凛第30话：Trick @and Treat奇迹的恶魔驱除》，@对我来说这就是魔法少女的根基的说！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_19","textHome":"哼哼哼，吾之红莲南瓜，寄宿着全新的@炼狱之炎的说！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_20","textHome":"因为有大家，我才能变强，所以现在我要去@帮助大家的说。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":200}]}],"group_13":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300,"pos":1,"voice":"vo_char_1012_00_21","textHome":"那时的我，只是个冒牌的主角的说。但是，@现在的我不一样。我能自信地说出，我是@为了大家在战斗。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":101200,"motion":200}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_22","textHome":"我已超越了魔法花凛，成为了魔法花凛满月！@获得了万圣节和满月之力，魔界的@魔法少女！用这白银的大镰刀，将魔女的@灵魂收割殆尽的说！太好了，全都念出来了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101200,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_23","textHome":"之前一直拿来耍小手段的，偷走任何东西的@力量，现在真心希望能用它帮助别人。@因为我终于能赶上怪盗少女希凛，变得比以前@更自信了的说。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":2.5,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_24","textHome":"哼哼哼，今天也在生于万圣节的魔法少女，@魔法花凛面前现身了。那就走吧，@去帮助弱小的人们！"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200}]}],"group_17":[{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":101200,"motion":400,"pos":1,"voice":"vo_char_1012_00_25","textHome":"又、又起晚了……！为什么看漫画会@停不下来呢？只是因为看到书架上有，@就忍不住熬夜了……"}]},{"autoTurnFirst":3.2,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":101200,"motion":100}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":101200,"motion":400,"pos":1,"voice":"vo_char_1012_00_26","textHome":"什么时候就已经是午休时间了!?一直在画画@完全没察觉到的说。但是这一张……好像是@至今为止画得最好的说！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":300}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]}],"group_19":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_27","textHome":"该吃晚饭了的说。我最喜欢的当然是南瓜汤…@骗你的说，其实最喜欢的是@妈妈做的浓汤的说。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]}],"group_2":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_03","textHome":"陷入危机的魔法花凛……结局会如何！的说…"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101201}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_28","textHome":"杂志和单行本还有网站和APP……满世界@都是漫画了的说！这样下去今晚不用睡了！@但是，还有作业的说……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_29","textHome":"因为扮演了魔法花凛，最近开始觉得@cosplay好像也挺有趣的。大家都是@手工制作的那些衣服的吗？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":0}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":400,"pos":1,"voice":"vo_char_1012_00_30","textHome":"感受到了魔女的反应……也许是有魔法少女@陷入了苦战……哼哼哼，魔法花凛@出场的时间到了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":200}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_31","textHome":"镜之魔女……要是遇到被复制的自己就麻烦了@的说。一定会演变成互相偷东西的。"}]},{"autoTurnFirst":5.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_32","textHome":"哪里有需要帮助的人，哪里就有魔法花凛！@祈求帮助者正高举糖果！@Trick and Treat!!"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":200}]}],"group_25":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_33","textHome":"万圣节是两个世界相连，魔物出现的日子@的说。所以说要扮装成和它们相似的样子！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_26":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_34","textHome":"据说分发糖果，是为了不让魔物进到家里来。@所以我只要拿到糖果，就会帮助别人！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_35","textHome":"奶奶她就好像杰克先生一样，去不了天堂也@去不了地狱，只能拿着提灯到处彷徨……"}]},{"autoTurnFirst":5.0,"chara":[{"id":101200,"motion":100}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_36","textHome":"嗯——，虽然说不清楚，但是你知道那种又@激动人心，又浪漫，但又充满悬念的漫画吗？"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_37","textHome":"虽然别人说我活泼，但其实我也不是很喜欢@吵吵嚷嚷的。所以一直默不作声画画的@阿莉娜学姐在的时候，会感觉很开心。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_3":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_04","textHome":"给自己找了借口，这样是不行的……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":101200,"motion":300}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_38","textHome":"高冷但温柔的八千代，还有严厉又神秘的@阿莉娜学姐，虽然性格不同不能比较，@但两位都是很出色的人。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_39","textHome":"每次败给逆境的时候就会想到。奶奶她虽然@每天都过得很不容易，却能直面弱小的@自己，总觉得奶奶真的很厉害！"}]},{"autoTurnFirst":8.5,"chara":[{"id":101200,"motion":100}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_40","textHome":"每当听大人们说人生故事的时候，我就感觉@如果可以支撑别人度过一段困难的时期，@也会是一件幸福的事情。"}]},{"autoTurnFirst":5.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":300}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_41","textHome":"哼…让我觉醒了么。我乃魔法花凛的里人格，@嘲讽花凛……骗你的说。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"id":101200,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_42","textHome":"魔法花凛，到达现场！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_43","textHome":"这就是欢乐万圣节。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_44","textHome":"没有这把镰刀无法猎取之物。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_45","textHome":"下次带上糖果就放过你。"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_46","textHome":"此乃由另一个世界而来的魔物之力。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_63","textHome":"潜藏在隔离的世界里那古老的灵魂哟。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_05","textHome":"魔法少女当中，有着这么多闪光的人啊……"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":100}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_64","textHome":"赋予我彷徨炼狱的力量！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_65","textHome":"去吧，这是我全部魔力的结晶！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_66","textHome":"这就是生于万圣节的力量的说！"}]}],"group_43":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_02","textHome":"我乃魔法花凛…生于万圣节的魔法少女！@带着这样的设定战斗，我叫御园花凛@的说！今后请多关照！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":101200,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_13","textHome":"之前被学姐当成笑话的画，感觉现在稍微@进步一些了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_14","textHome":"学姐快来看！我的画，是不是有长进了！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]}],"group_7":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_15","textHome":"此乃连接着我与他人的故事中的一页……"}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_16","textHome":"那个，有个叫做《怪盗少女魔法希凛》的@漫画。那是连接着我和奶奶的，充满回忆的@漫画的说！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_17","textHome":"为了取回被盗走的圣物而驱除恶魔，敌方头目@却是意中的男孩子，《怪盗少女魔法希凛》@真是太刺激了的说！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]}]},"version":3}