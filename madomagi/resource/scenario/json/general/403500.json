{"story":{"group_1":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_01","textHome":"那么，请容我再次自我介绍……我是奏遥香。@不管是在学校还是在魔法少女的活动中，我@都被交予了领袖的职务，所以我很擅长领导@工作。如果需要有人担任领导者，无论何时@都请来找我哦。我一定会帮上你的忙的。"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]}],"group_10":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_17","textHome":"姐姐连画画也很擅长。她在大赛里拿到了金奖@，也收到过在活动上画画的委托……那个时@候，我真的很嫉妒那样的她。"}]},{"autoTurnFirst":6.3,"chara":[{"id":403500,"motion":100}]},{"autoTurnFirst":2.3,"chara":[{"id":403500,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":403500}]}],"group_11":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_18","textHome":"虽然现在除了上课的时候，我也已经不再画画@了……但是，偶尔画一画或许也不错呢。"}]},{"autoTurnFirst":3.7,"chara":[{"id":403500,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_19","textHome":"我感觉自己越过了一重障壁哦。谢谢你。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_20","textHome":"我还有很大的提升空间，可不能在这里松懈下@来。"}]},{"autoTurnFirst":2.5,"chara":[{"id":403500,"motion":200}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_21","textHome":"嗯，我在逐渐便器。不管是做什么事情，积累@都是很重要的呢。一步一个脚印地、脚踏实@地地成长下去吧。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]}],"group_15":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_22","textHome":"怎么样？我觉得自己更加接近完美了哦。但是@，可不能因此就骄傲自满呢。虽然有很多人@都会在最后的关头松懈下来，但我觉得在那@里坚实地踏出步伐是非常重要的。再努力一@把吧。"}]},{"autoTurnFirst":2.8,"chara":[{"id":403500,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403500}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400}]}],"group_16":[{"autoTurnFirst":4.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400,"pos":1,"voice":"vo_char_4035_00_23","textHome":"快看！我已经强大到几乎无法被超越的地步了@！如果是现在，感觉不管是什么事情都能做@到……真的很感谢你一直陪我走到这里。我@打算将这份力量为了守护人们而使用。无论@何时，都尽管来依靠我吧。"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":403500,"motion":1}]},{"autoTurnFirst":2.7,"chara":[{"id":403500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":403500,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":403500,"motion":200}]}],"group_17":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":400,"pos":1,"voice":"vo_char_4035_00_24","textHome":"欢迎，我等你很久了哦。……哎呀，刚才的话@不是在批评你迟到哦。只是想表达一下我很@想见你而已。"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]}],"group_18":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_25","textHome":"早上好。我在进行早晨的打招呼活动。最近不@好好打招呼的学生太多了，所以我才提议了@进行这样的活动。"}]},{"autoTurnFirst":2.1,"chara":[{"id":403500,"motion":0}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":200}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_26","textHome":"我的午饭经常是在学生会室吃的。因为这样就@能在同时处理学生会的工作。在没有工作的@日子，我有时也会和亚里纱她们一起吃哦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_02","textHome":"初次见面，我是奏遥香。在学校，我从属于学@生会，而作为魔法少女，我也作为队长领导@着茉莉她们。请多指教哦。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400}]}],"group_20":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_27","textHome":"作为魔法少女的活动，学生会的工作……我有@很多要做的事情，所以放学之后是我最繁忙@的时候。但是，我不会偷懒的。"}]},{"autoTurnFirst":4.2,"chara":[{"id":403500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":403500,"motion":200}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_28","textHome":"哎呀，你还醒着呢。要是还不睡，明天可是会@晕晕乎乎的哦？……如果睡不着的话，需要@我帮你泡杯热牛奶吗？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0}]},{"autoTurnFirst":2.2,"chara":[{"id":403500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":403500,"motion":400}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_29","textHome":"偶尔休息一下也是有必要的哦。毕竟在喘息、@放松过后，效率也会上升呢。就是这样，我@会泡壶茶的，你要和我一起喝吗？"}]},{"autoTurnFirst":4.2,"chara":[{"id":403500,"motion":200}]},{"autoTurnFirst":2.4,"chara":[{"id":403500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]}],"group_23":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_30","textHome":"……到巡逻的时间了呢。可不能放着向人们播@撒不幸的魔女不管。不仅是作为魔法少女…@…作为一个人，这也是理所应当的。"}]},{"autoTurnFirst":4.1,"chara":[{"id":403500,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":403500}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":403500}]},{"autoTurnFirst":3.0,"chara":[{"id":403500,"motion":0}]}],"group_24":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_31","textHome":"就算姿态同为魔法少女，但敌人就是敌人……@可不能心生迷惘呢。毕竟如果领袖感到迷惘@，大家的内心也会动摇的啊。"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":403500,"motion":200}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_32","textHome":"要由魔法少女组成小队，然后互相战斗吗。队@长的位置就交给我吧。我会负责领导大家，@斩落完美的胜利的。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400}]}],"group_26":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_33","textHome":"你知道“开膛手”的传闻吗？听说被盯上的都@是十几岁的女孩子哦。……其真实身份也有@可能是魔女，所以你也要小心一点。"}]},{"autoTurnFirst":3.7,"chara":[{"eyeClose":1,"id":403500}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":403500}]},{"autoTurnFirst":2.0,"chara":[{"id":403500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403500}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_34","textHome":"茉莉光是在场，就能缓和那里的局面。比如她@的氛围，还有笑容……我觉得，这也是某种@才能哦。"}]},{"autoTurnFirst":1.0,"chara":[{"id":403500,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100}]}],"group_28":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_35","textHome":"亚里纱虽然也有一段不安分的时期，但是好像@在遇见千里之后就改头换面了。她们两人年@级也一样，关系真的很好呢。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1}]},{"autoTurnFirst":5.2,"chara":[{"id":403500,"motion":100}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_36","textHome":"学生会的工作虽然确实非常麻烦，但是非常有@做的价值哦。你要是也有兴趣的话，要不要@试着加入看看？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_03","textHome":"真的太差劲了……我真的是……最差劲的人类@啊……"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":403500}]}],"group_30":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_37","textHome":"我的家人有……父亲和母亲……还有，我曾经@有个姐姐。不过，现在已经没有了。那个姐@姐，是个不管做什么事情，都能做到完美的@人。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403500}]},{"autoTurnFirst":3.0,"chara":[{"id":403500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":403500}]}],"group_31":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_38","textHome":"不管是我多么努力做到的事情，姐姐都能轻易@超越。她就是个这样的天才。所以，我才觉@得自己绝对没有受到任何人的期待。"}]},{"autoTurnFirst":5.5,"chara":[{"id":403500,"motion":0}]}],"group_32":[{"autoTurnFirst":4.7,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_39","textHome":"在我难受的时候，一直都是姐姐来安慰我的。@明明那个人比起我要痛苦得多，她却一直都@会带着同样的笑容来找我。"}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":0,"id":403500}]},{"autoTurnFirst":3.0,"chara":[{"id":403500,"motion":400}]}],"group_33":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_40","textHome":"现在回想起来，我觉得我是得到了很多关爱的@。不管是从父母那里，还是从姐姐那里……@但是那时候的我还很幼稚……没能明白这一@切。"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":403500}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":403500}]},{"autoTurnFirst":5.0,"chara":[{"id":403500,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":403500}]}],"group_34":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":200,"pos":1,"voice":"vo_char_4035_00_41","textHome":"不管学习还是运动都很擅长，因而受到大家的@信赖……其实我……并不是那样的人……只@是努力地装作是那样罢了……我才不是完美@的。"}]},{"autoTurnFirst":6.5,"chara":[{"id":403500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":403500}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":200,"pos":1,"voice":"vo_char_4035_00_42","textHome":"没关系，有我在呢。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_43","textHome":"呼……大家都没事吧？"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_44","textHome":"作为领袖，我有将大家导向胜利吗？"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":200,"pos":1,"voice":"vo_char_4035_00_45","textHome":"大家的动作都非常不错哦。"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_46","textHome":"真是无懈可击的完美胜利呢。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":403500,"motion":200,"pos":1,"voice":"vo_char_4035_00_04","textHome":"什么领袖啊……什么完美啊……我……"}]},{"autoTurnFirst":1.7,"chara":[{"id":403500,"motion":400}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":403500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":403500}]}],"group_5":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300,"pos":1,"voice":"vo_char_4035_00_05","textHome":"有错的全都是我……都是自作主张的我不好。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":403500}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":100,"pos":1,"voice":"vo_char_4035_00_13","textHome":"我又变强了呢。但是，这还远远不是尽头哦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":400,"pos":1,"voice":"vo_char_4035_00_14","textHome":"谢谢你。这样一来，就算被说“完美”，我也@能挺胸抬头地接受了。"}]}],"group_8":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":403500,"motion":1,"pos":1,"voice":"vo_char_4035_00_15","textHome":"呵呵，我们偶尔也来一起慢慢说会儿话吧。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403500}]}],"group_9":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":403500,"motion":0,"pos":1,"voice":"vo_char_4035_00_16","textHome":"小时候，我很喜欢画画。如果画得好了，我就@会想着拿去给父母看……但是到最后，我还@是没有这么做呢。"}]},{"autoTurnFirst":4.5,"chara":[{"id":403500,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403500,"motion":300}]}]},"version":3}