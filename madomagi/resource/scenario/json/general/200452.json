,"face":"mtn_ex_040.exp3.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_46","textHome":"太无聊了我都快睡着了！"}]}],"group_39":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_63","textHome":"我不会输……我怎么可能会输！"}]},{"autoTurnFirst":3.7,"chara":[{"id":200400,"motion":400}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_05","textHome":"这里有这么多的魔法少女，真是吓了我一跳。"}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_64","textHome":"呀啊！"}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_65","textHome":"还有还有，还不止这样！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":200}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_66","textHome":"看到了吗，我真正的实力！"}]}],"group_43":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":201,"pos":1,"voice":"vo_char_2004_00_02","textHome":"久等啦！正义的魔法少女——美树沙耶香，前@来造访！嗯嗯，因为我很强，所以有什么事@尽管交给我就行了……开玩笑的啦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":200400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":200400,"motion":201}]}],"group_5":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200400,"motion":400,"pos":1,"voice":"vo_char_2004_00_13","textHome":"噢噢!?我感觉全身充满了魔法的力量……！"}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_14","textHome":"嗯，好久没有这么舒服了！爽快爽快！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400}]},{"autoTurnFirst":2.7,"chara":[{"id":200400,"motion":100}]}],"group_7":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_15","textHome":"谢谢你一直和我在一起。让我总能放下心。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":200400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":200400}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_16","textHome":"身经百战后，我也算是个合格的魔法少女了，@不过我依然是我。@魔法少女沙耶香，之后也请多指教！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"id":200400,"motion":200}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_17","textHome":"我这个人并没有什么特别的天赋和才能。@但即便如此，我也变得这么强了……@可以稍微骄傲一下吗？"}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200400}]}]},"version":3}