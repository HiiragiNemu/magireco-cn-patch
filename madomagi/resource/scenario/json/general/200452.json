{"story":{"group_1":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_01","textHome":"呼～一路追着麻美学姐，一不留神我也来到了@神滨……这里确实很奇怪。不仅能撞见魔女@和使魔，而且……那是什么？传闻？@那些家伙真是出乎意料的可怕！@嘛，麻美学姐倒是不会输给那些家伙就是……"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200400}]},{"autoTurnFirst":4.5,"chara":[{"id":200400,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":100}]}],"group_10":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_18","textHome":"我已经不再是过去的我了。@如今站在这里的我，@只靠自己一个人是绝对无法成就的。@那么现在，就让我勇往直前吧！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":200400,"motion":200}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_19","textHome":"感觉超棒……！@现在的我，开心得快飞起来了哦！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":200400,"motion":100}]}],"group_12":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_20","textHome":"呜哇……我感觉，世界看起来都不一样了。"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_21","textHome":"嗯，我似乎变强了一些……@就算是之前一筹莫展的对手，@现在我也觉得能赢了。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200400,"motion":1}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":300,"pos":1,"voice":"vo_char_2004_00_22","textHome":"我的愿望是治好青梅竹马的伤病。@不仅如此……我还想获得力量，@能一直保护好重要的人。@所以我不后悔成为魔法少女。我不能后悔。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":200400}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":200400,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":200400,"motion":1}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_23","textHome":"我很开心自己能够变强。@那样就能不依靠别人，保护自己想保护的人了@对吧？我讨厌和那些见死不救，利用他人的@家伙们一起行动。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200400,"motion":1}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200400,"motion":0}]}],"group_16":[{"autoTurnFirst":6.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200452,"motion":1,"pos":1,"voice":"vo_char_2004_52_24"}]},{"autoTurnFirst":4.4,"chara":[{"eyeClose":1,"id":200452}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp3.json","id":200452,"motion":100}]}],"group_17":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200452,"motion":400,"pos":1,"voice":"vo_char_2004_52_25"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200452}]},{"autoTurnFirst":3.0,"chara":[{"id":200452,"motion":201}]}],"group_18":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200452,"motion":1,"pos":1,"voice":"vo_char_2004_52_26"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200452}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200452,"motion":400}]},{"autoTurnFirst":3.2,"chara":[{"id":200452,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":200452}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":200452}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200452,"motion":1,"pos":1,"voice":"vo_char_2004_52_27"}]},{"aut