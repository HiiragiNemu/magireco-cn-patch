{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_01","textHome":"我是塔鲁特的……圣女大人的随从，@但因为我们年龄相仿，所以非常亲密。@父亲大人是人称「愤怒」的佣兵，@而我也是在见证着战场与战斗中长大的。@也许是我和慷慨激昂的父亲大人相似吧，@一提到塔鲁特的事情，我就容易失去理智……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"id":402300}]}],"group_10":[{"autoTurnFirst":7.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_18","textHome":"圣女大人原本名叫「贞德」，@「塔鲁特」是天使大人特别送给她的化名……@叫起来很好听对吧！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300,"motion":400}]}],"group_11":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_19","textHome":"谢谢……我会用这份力量，@将希望之光守护到最后。"}]}],"group_12":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_20","textHome":"一起祈祷吧……@为了成为拯救这个国家的力量……"}]}],"group_13":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_21","textHome":"在我小的时候，我就已经置身战场，@照顾父亲大人的部队了……@不过那时完全没想到我会亲自进行战斗。"}]},{"autoTurnFirst":4.5,"chara":[{"id":402300,"motion":1}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_22","textHome":"塔鲁特的道路，对大家来说就是希望之光……@我深信着这一点成为了魔法少女。@所以我不会后悔。那天立下的誓言，@我要和同伴一起走到最后。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402300}]},{"autoTurnFirst":4.2,"chara":[{"id":402300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_15":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_23","textHome":"我的命运一直都和塔鲁特相连。@所以我今后会和她一起战斗。@塔鲁特是法兰西的希望之光……@她是那唯一能让人民停止哀叹的存在，@就像天使大人说的那样……！"}]},{"autoTurnFirst":3.5,"chara":[{"id":402300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402300}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_24","textHome":"我在等着您呢，今天也一起好好努力吧！@尽管能力有限，但我会全力为你加油的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":400}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_25","textHome":"早上好。早饭我已经为您准备好了。@还要喝点热的东西吗？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":300}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_26","textHome":"到午饭时间了。@今天也怀着对能够平安得到食物的感谢之情，@一起去吃午饭怎么样？"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_19":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":400,"pos":1,"voice":"vo_char_4023_00_27","textHome":"不好了，我得赶紧去准备晚饭了……！@我马上就能做好了，请稍等一下。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]}],"group_2":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_03","textHome":"能帮上塔鲁特真是太开心了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_28","textHome":"那么，夜深了……不要熬得太晚，@获取足够的睡眠，来为明天做准备吧。"}]},{"autoTurnFirst":4.5,"chara":[{"id":402300,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_29","textHome":"我的朋友说过，伤疤就是战斗结束后，@活下来的证明……所以我也会勇敢前进。"}]},{"autoTurnFirst":6.2,"chara":[{"eyeClose":1,"id":402300}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":402300}]},{"autoTurnFirst":6.0,"chara":[{"id":402300,"motion":300}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_30","textHome":"差不多该上阵了！为了不输给魔女和使魔，@不要松懈，一起加油吧！"}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":400}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_31","textHome":"要和镜子里的敌人战斗吗？@因为我是挥舞着大型武器战斗的，@所以不太能打中敌人……@ 不过只要打中了的话！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":400}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_32","textHome":"我听说这里是和魔法少女组队，@一起较量的竞技场。@如果需要我帮忙的话，@我会很乐意尽一份力的……！"}]},{"autoTurnFirst":2.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_25":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_33","textHome":"听说我实战时的战斗方式，@和平常给人的印象不同……@因为重要的人一旦受到了伤害，@我就会变得忘记了自我……"}]},{"autoTurnFirst":5.0,"chara":[{"id":402300,"motion":300}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_34","textHome":"塔鲁特明明在战场上一副威风凛凛的样子，@但胜利之后，她就像个在祭典上欢闹的孩子。@我想这也是塔鲁特的魅力之处吧！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":402300,"motion":300}]}],"group_27":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_35","textHome":"外号「愤怒」的父亲是一位身经百战的佣兵。@比起像这样平静的生活，@他在战场上度过的时间要更长。"}]},{"autoTurnFirst":5.5,"chara":[{"id":402300,"motion":1}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_36","textHome":"丘比……是说的丘卜大人吗？@那位可是上帝的使者……天使大人哦！@才不是什么烤奶酪蛋糕呢！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":400}]}],"group_29":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_37","textHome":"我是在同一天认识莉兹和塔鲁特的。@莉兹她早在我之前，@就是和塔鲁特并肩作战的战友了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":402300,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_04","textHome":"大家……一起活着回去吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":402300,"motion":400}]}],"group_30":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_38","textHome":"我生气时耳朵会变红，似乎是遗传我父亲……@但是父亲他平常对我都很好，@是我温柔的父亲大人哦。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_39","textHome":"除了塔鲁特和莉兹，我也有其他重要的朋友。@因为有她们一直和我在一起，@所以我才能走到这里……少了谁都办不到。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402300,"motion":300}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_40","textHome":"如今我，最想做的就是能帮到「圣女」的……@塔鲁特的忙。初次见面时塔鲁特的身姿……@真的如同奇迹一般！"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":402300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":402300,"motion":400}]}],"group_33":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_41","textHome":"不可以让塔鲁特喝酒……因为她会变奇怪的！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402300}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":400,"pos":1,"voice":"vo_char_4023_00_42","textHome":"我是不会输的！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_43","textHome":"干得漂亮！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":400,"pos":1,"voice":"vo_char_4023_00_44","textHome":"赢，赢了……！"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_45","textHome":"哈啊……太好了……"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":400,"pos":1,"voice":"vo_char_4023_00_46","textHome":"真不敢相信……！"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_63","textHome":"你……惹怒我了呢？"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_05","textHome":"我会为了能帮上更多的忙而努力的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":200,"pos":1,"voice":"vo_char_4023_00_64","textHome":"绝……对……不会饶恕你！！不可原谅！"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":402300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":402300,"motion":400}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":200,"pos":1,"voice":"vo_char_4023_00_65","textHome":"我会放过你吗————！！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_66","textHome":"……我并不打算听你狡辩。"}]}],"group_43":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_02","textHome":"我是梅丽莎·德·维尼奥勒。@作为塔鲁特……啊不，圣女大人的随从，@负责照顾圣女大人的生活！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402300,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":402300,"motion":300}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_13","textHome":"就叫我梅丽莎吧……！"}]}],"group_6":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_14","textHome":"我的力量竟然……@这就是被称为「愤怒」的父亲大人的血统吗？"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_15","textHome":"羁绊进一步变深的话，就会变成这样吧……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_8":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_16","textHome":"我和父亲大人的初次相遇，@是在母亲大人的墓前祈祷的时候。@因为分开生活的缘故，我一直都不知道@父亲大人的存在。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":402300,"motion":1}]}],"group_9":[{"autoTurnFirst":1.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_17","textHome":"我和塔鲁特第一次相遇的时候，@她还矮小得让人吃惊……但最让人惊讶的是，@天使大人就待在她的肩上！"}]},{"autoTurnFirst":3.2,"chara":[{"id":402300,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300}]}]},"version":3}