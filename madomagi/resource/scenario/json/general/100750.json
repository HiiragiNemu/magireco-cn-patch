{"story":{"group_1":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_01","textHome":"嗯？诶？一定要和我说才行吗？@天才的时间很宝贵的，这次就算特别待遇哦。@我是里见灯花。在宇宙相关的领域相当有名，@还写了书哦。另外，家里是医疗相关的团体，@对人体也很了解。有什么想知道的尽管问吧。"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":7.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"id":100700,"motion":200}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]}],"group_10":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_17","textHome":"了解宇宙会使人类进化哦？@某种意义上，就像逐渐解开阿卡西纪录一样。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_11":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_18","textHome":"在魔法少女的历和人类的进化当中，@牺牲如影随形哦。@所以了解宇宙也是需要牺牲的。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":100}]}],"group_12":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_19","textHome":"465亿光年的彼岸，又近了一步！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_20","textHome":"我成长了喵？因为本来就太厉害了，@所以我也不清楚喵——"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400}]}],"group_14":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_21","textHome":"叔父大人说，希望我把才能用来造福所有人。@虽然稍微有点那种感觉了，但是好难啊。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":300}]}],"group_15":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_22","textHome":"爸爸说过，才能是有限的，@所以要最大限度地发挥它的效用。@所以我每当到了不得不取舍时，就会这样想。@毕竟我有着这么强大的力量嘛。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":100700,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]}],"group_16":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_23","textHome":"人与人之间连接着看不见的细丝，@所以只考虑效率是不行的。@叔父大人正因为知晓如此，@才说要救所有的人……@嗯，我也决定了，为了大家去运用我的才能。"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":300}]},{"autoTurnFirst":8.5,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":201}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201,"pos":1,"voice":"vo_char_1007_50_24","textHome":"哇——真的很蓝，真的很宽！@还有圆滑的水平线！@我的神经受到了刺激，@有种分泌了大量多巴胺的感觉！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":300,"pos":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100700,"motion":200,"pos":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_18":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":100700,"motion":201,"pos":1,"voice":"vo_char_1007_50_25","textHome":"嘶——哈——海浪的气息，宽广的世界。@一早就被折服了。@嗯哼，早饭前稍微到处走走吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_50_26","textHome":"好神奇！@只是把面条煮熟淋上酱汁就这么好吃了！@为什么呢？是不是在酱汁里下药了啊？@海之家真的好神奇！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400}]}],"group_2":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_02","textHome":"两个人可以相遇的概率是很——低的。@所以这大概是命运的相逢吧。@我是里见灯花，请指教！"}]},{"autoTurnFirst":3.3,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_50_27","textHome":"再晚一会儿的庆典，会有很多摊位吧？@虽然很期待有些什么，@但吃路边卖的东西不会弄坏肚子喵？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":300}]}],"group_21":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_50_28","textHome":"快看看看！@反射了焰火的闪光，海面变得好亮！@兴奋得要睡不着觉了！多来点多来点！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":100700,"motion":100}]}],"group_22":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_50_29","textHome":"物体本身是没有颜色的哦。@是由于光的反射，才在我们眼中显出颜色。@海也是如此，因为只有蓝光没被吸收，@所以看起来就是蓝色。"}]},{"autoTurnFirst":1.5,"chara":[{"id":100700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":100700}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":201,"pos":1,"voice":"vo_char_1007_50_30","textHome":"真是，难得能大家一起玩，@还出现魔女真是糟透了！@这魔女稍微看下场合行不行啊。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":100700,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"id":100700,"motion":100}]}],"group_24":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_50_31","textHome":"要去无尽镜界的话，先把衣服换了吧。@要是我穿着泳装被复制了，@那看上去也太傻了吧。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":200}]}],"group_25":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_50_32","textHome":"说到战斗的话，我会成为众人的大脑哦。@不管是沙滩排球、夺旗还是长距离游泳，@都可以来问我哦。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400}]}],"group_26":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_50_33","textHome":"不用担心，我已经涂好了防晒霜了。@我也不想到家之后才开始疼的呀。"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100700,"motion":201}]},{"autoTurnFirst":4.5,"chara":[{"id":100700,"motion":200}]}],"group_27":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_50_34","textHome":"不会游泳也没事哦。我是有同伴的。@你看，海豚！@乘上它，就会受到保护了，放心吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_50_35","textHome":"浸泡在海水里，就会感到安心。@大概是……因为母亲的羊水@和海水的成分相近吧。"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":5.0,"chara":[{"id":100700,"motion":400}]}],"group_29":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_50_36","textHome":"哇噗！……咳咳，咸死了喵……@啊！好疼好疼！海水进眼睛里了！@救命啊，要死在海里了！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100700,"motion":201}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100700,"motion":400,"tear":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100700,"motion":300,"tear":1}]}],"group_3":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_03","textHome":"这样就完美了！能集合多少人喵？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_30":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":300,"pos":1,"voice":"vo_char_1007_50_37","textHome":"啊……仔细想想，@海水跟各种动物的排泄物混在一起啊……@怎么办……啊！不行不行！@不能再想下去了，真是的！"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":100}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_50_38","textHome":"能看见银河吗？@那个啊，是我们身处在银河系当中的证据。@话说我更喜欢通过近红外线看到的哦。"}]},{"autoTurnFirst":5.5,"chara":[{"id":100700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_50_39","textHome":"我的整个世界，从医院内部，变成了神滨市，@又变成了海洋。虽然宇宙更大，@但海也相当宽广，让我感到了自身的渺小。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":300}]}],"group_33":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_50_40","textHome":"学校的泳池一次都没想过要下水，@但是大家一起来海边真是快乐啊。@嗯，能过来真是太棒了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400}]}],"group_34":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":300,"pos":1,"voice":"vo_char_1007_50_41","textHome":"总觉得布料有点少，感觉好怪……@可能是害羞吧。@奇、奇怪的话就直说啊！@父亲大人还给我买了别的泳装啊！"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":2.0,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":200}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_42","textHome":"出发吧，和全宇宙的能量一起！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_43","textHome":"不愧是我，诶嘿！"}]}],"group_37":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_44","textHome":"嗯嗯，分泌了不少肾上腺素！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_38":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_45","textHome":"我觉得你很努力哦？辛苦啦——"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_04","textHome":"小学就教过的问题，没错吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_63","textHome":"宇宙的能量倾泻而下！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_64","textHome":"收缩吧，大坍缩开始——"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201,"pos":1,"voice":"vo_char_1007_00_65","textHome":"宇宙大爆炸——!!"}]}],"group_43":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_66","textHome":"嗯哼，这就是宇宙的诞生哦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_05","textHome":"姐姐大人好温柔！@我像喜欢忧一样喜欢姐姐大人！"}]}],"group_6":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_13","textHome":"哇，魔法少女成长也会分泌荷尔蒙之类的吗？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]}],"group_7":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_14","textHome":"我作为魔法少女，已经是大人了哦！@因为很强啊！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]}],"group_8":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_15","textHome":"虽然说说我自己也未尝不可，@但还是换做你来谈谈未来吧！"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]}],"group_9":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_16","textHome":"我呢，想知道宇宙的一切！@起初如何诞生，如今由什么构成，全部都要！@总有一点我会弄明白的！"}]},{"autoTurnFirst":2.6,"chara":[{"id":100700,"motion":201}]},{"autoTurnFirst":3.9,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}]},"version":3}