{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_01","textHome":"我的双亲被魔女所杀，街坊们都以为是失踪了@可那是一份虚假的记忆，@是由我缔结契约时所许下的「愿望」形成的。@但是！我会永远记住真实的记忆！@之后我就边当佣兵边杀魔女，今后也会如此！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":300}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_18","textHome":"话说啊，要是想和我干架就尽管来！@看我一个个给你们揍趴下，@让你们晓得啥是超强佣兵！"}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_19","textHome":"哦哦——这感觉！@……毫无疑问是有突破了！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_20","textHome":"嗯，心情不错！还能往上走~！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_21","textHome":"要说让人开心的时候，@那就是没有麻烦的时候。@烦心事儿一概没有！可以随心所欲的时候！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_14":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_22","textHome":"做饭、扫除……这不就是家务活？超麻烦啊！@我完全不爱做这些，会做也不爱做。@啊——不管了不管了！@垃圾再多忍忍就完事了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":400}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_23","textHome":"我想象中最赞的生活嘛，首先是饭来张口，@然后想去哪都有人接送。@总之就是自己什么也不用做！就是这样！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_24","textHome":"噗哈哈！今天你也来啊！@浑身都酥酥麻麻的，感受到夏天了！@真的，这种时候莫名其妙的就兴致很高啊！"}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_17":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_50_25","textHome":"哦——起来啦。咱正要去海边呢！@早上第一件事就是和鹤乃比拼游泳！@看我大幅领先赢她！"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":200}]}],"group_18":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_50_26","textHome":"鹤乃！准备好没！@今天午饭是「超级爆裂尼亚加拉流水素面」！@打起精神来吃吧！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":200}]}],"group_19":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_50_27","textHome":"说到夏天哦，白天那么长，多好呀！@可以在外面玩很久！@但是相对的，到了秋天就很打击人了……"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":300}]}],"group_2":[{"autoTurnFirst":3.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_03","textHome":"七香那家伙！@从初次见面的时候就觉得与她合不来！"}]},{"autoTurnFirst":4.3,"chara":[{"id":100500,"motion":200}]}],"group_20":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100500,"motion":400,"pos":1,"voice":"vo_char_1005_50_28","textHome":"哈？夏天夜晚干嘛非得要讲鬼故事啦？@嗯？这故事太……原来还有这种事啊？@哪、哪有在害怕啦！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200}]}],"group_21":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_29","textHome":"在阳光直射的户外@喊出「夏天夏天夏天耶！」的感觉棒极了，@不过在空调房里轻轻松松地过也是夏天啦~"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_30","textHome":"感觉探险配夏天正合适嘛。@对吧对吧？所以，咱们就出去看看吧！"}]},{"autoTurnFirst":1.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_23":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_31","textHome":"嗯……不是啊，这地方跟往常没啥两样吧？@才、才不是因为夏天就联想到试胆大会，@没、没、没这回事！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":200}]}],"group_24":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_50_32","textHome":"夏日祭典棒极了！@今天也来了这么多人……@咱就第一个点燃这场祭典的气氛吧！"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_25":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_50_33","textHome":"好，放烟花啦！@就那个会滋地喷出火花来的！@拿起一大把，一口气点燃很好玩不是吗！？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":400}]},{"autoTurnFirst":2.6,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_26":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_50_34","textHome":"呀！怎么样……@啊！4秒啊……还是挤不进3秒嘛……@这样在吃西瓜比赛是赢不了菖蒲的！"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":200}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_35","textHome":"噗哈！这热天里大口喝水真爽！@嗯……一杯不够！大叔再来一杯！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":300,"pos":1,"voice":"vo_char_1005_50_36","textHome":"热死……不行了，今天一步也不走了……@唉唉！有没有冰冰凉凉的果汁啊？@还有咱喜欢的葡萄冰棒呢！"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_29":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_37","textHome":"打西瓜？咱来！好，开始吧！@右边？诶，左边？@啊，真是的，好乱啊！直接抡了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":100500,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100500,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":100500}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp.json","id":100500}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_04","textHome":"可恶！被人给骗了！@这不是只有我一个人去战斗了吗！"}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_50_38","textHome":"哎呀，好烦啊……菖蒲又跑来嚷嚷要比赛了。@切，咱忙着乘凉呢，哪有空陪那家伙玩嘛。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":100500}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_50_39","textHome":"海边不错，泳池也好！@咱就先来回游起来了！@然后就能睡个香甜的午觉……@那可不棒透了！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":100500}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"vo