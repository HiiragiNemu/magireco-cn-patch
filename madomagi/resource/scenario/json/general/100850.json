,"motion":100}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_17","textHome":"和魔女的接触，颠覆了阿莉娜的人生。@但那也不是坏事，倒不如说是件好事。"}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_013.exp.json","id":100800}]}]},"version":3}