{"story":{"group_1":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_01","textHome":"要说自己的话题，真是麻烦死了耶。@话说回来，如果你去看看美术杂志，@就会知道阿莉娜是天才艺术家了。@所以，就自己先去看看再来问行吧。@私人的事情就放在以后，理解了吗？"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800}]}],"group_10":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_18","textHome":"阿莉娜心跳加速了。@因为马上有杰作要诞生了。@看看就明白了吧？这高度……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":100}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_19","textHome":"啊……有什么东西熟透了，@就在阿莉娜身体里……"}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_20","textHome":"入门就是培养基础，和绘画是一样的。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_21","textHome":"感觉又上了一层楼……@哼，就好像第一次找到了@自己想表现的style一样的感觉。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":100}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100800,"motion":400,"pos":1,"voice":"vo_char_1008_00_22","textHome":"什么，这是……没见过……@阿莉娜没见过的……真是刺激爆了！@哈……太强了，就好像发现了新大陆……@怎么办，兴奋极了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":100800}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":100800,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":100}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_23","textHome":"这兴奋的感觉，就好像变得无所不能一样。@仿佛连牺牲一切展现毁灭之美也能表现出来。@啊……大家会来看吗……阿莉娜的最终作品。"}]},{"autoTurnFirst":6.5,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":200}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_50_24","textHome":"啊，怎么你也来了？@热得浑身是汗，@阿莉娜现在是bad mood，@别来搭话最好。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":400}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_50_25","textHome":"嗯……哇啊啊啊！@蝉，蝉，蝉！太Noisy了！@话说，一大早就开窗户，@是哪里的家伙干的！？"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_021.exp.json","id":100800,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":2,"face":"mtn_ex_021.exp.json","id":100800,"motion":1}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_50_26","textHome":"可从没听说过会这么热啊……@谁来给地球开开空调啊。@啊，法兰克福香肠，@是阿莉娜点的……"}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":200}]}],"group_19":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_50_27","textHome":"好好我开动了……@我对海边的晚餐并没有什么兴趣。@啊呜……嗯！？有点好吃……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100800,"motion":100}]}],"group_2":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_03","textHome":"阿莉娜的作品，本应该更加优秀才对……"}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_50_28","textHome":"夏天24小时都充满了生命力。@像这样的夜晚，星星遍布，@气温炎热，虫鸣声也很吵。@总之对阿莉娜来说no good。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100800,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":1.5,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400}]}],"group_21":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_50_29","textHome":"Sorry……今天的阿莉娜有点带刺呢。@都怪这个热过了头的夏天，@觉得麻烦的话快点去别处比较好。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_50_30","textHome":"在我心情不好的时候出现，@魔女也不挑时机呢。@打也好养起来也好，@让我开心一点吧，啊哈。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100800}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800}]}],"group_23":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_50_31","textHome":"无尽镜界和大海其实挺像的呢。@深层都充满了奥秘，@连使魔也有着生死的循环。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":100}]}],"group_24":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_50_32","textHome":"这天气本来就很热，@还要被卷入更热的战斗里，@只能说No thank you。@还是你自己搞去吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100800}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":100800,"motion":200}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_50_33","textHome":"嗯？因为累了才看看原稿的。@不趁着休息的时候看的话，@会有很烦的fool girl的。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":100}]}],"group_26":[{"autoTurnFirst":2.5,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100800,"motion":1,"pos":1,"voice":"vo_char_1008_50_34","textHome":"哈～仔细想来，夏天的海边真是好极了。@是在大家穿泳装时@发掘好身材的chance呢。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":2.5,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":100}]}],"group_27":[{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_50_35","textHome":"疼，是谁……用沙滩球打阿莉娜？@哈……阿莉娜现在正在写生，@要玩的话去远点的地方玩……"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":1,"id":100800,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":0}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_50_36","textHome":"对阿莉娜来说做沙堡也太easy了吧。@虽然想看的话做一个也不是不行……@毕竟阿莉娜的作品评价很高呢。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":300}]}],"group_29":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_50_37","textHome":"嗯～阿莉娜心目中最佳的夏日活动……@最emotional又心跳不已的@还要属盂兰盆节。@简直让人心头一紧呢……"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":100}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_04","textHome":"只能创作出阿莉娜最终的作品了……"}]}],"group_30":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400,"pos":1,"voice":"vo_char_1008_50_38","textHome":"Shut up！希望你不要过来搭话！@想到一个非常棒的点子，用汗把颜料涂开！@啊，不快点画的话……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_50_39","textHome":"忘记买特产了……@因为目的地已经暴露了，@要是什么都不买的话，@那个fool girl一定又会闹的……"}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":100800,"motion":300}]}],"group_32":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_50_40","textHome":"嗯……说实话真是不可思议呢。@因为对阿莉娜来说没有平等关系的人，@所以有人一起玩本身都是很新鲜的。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"po