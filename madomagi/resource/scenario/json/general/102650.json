TurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102600,"motion":200,"pos":1,"voice":"vo_char_1026_00_44","textHome":"今天的英雄是我哦！"}]}],"group_38":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102600,"motion":0,"pos":1,"voice":"vo_char_1026_00_45","textHome":"这份胜利，就是改变成规的第一步！"}]},{"autoTurnFirst":1.5,"chara":[{"id":102600,"motion":100}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102600,"motion":200,"pos":1,"voice":"vo_char_1026_00_46","textHome":"因为我的体内也流淌着时女的血！"}]}],"group_4":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102600,"motion":300,"pos":1,"voice":"vo_char_1026_00_04","textHome":"或许沙绪比起我要更像英雄一些……"}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102600,"motion":0,"pos":1,"voice":"vo_char_1026_00_63","textHome":"可别因为是十手就瞧不起！"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102600,"motion":100,"pos":1,"voice":"vo_char_1026_00_64","textHome":"这就是让你悔改的，最后一招！！"}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102600,"motion":400,"pos":1,"voice":"vo_char_1026_00_65","textHome":"呀啊啊啊啊啊啊啊啊！！"}]}],"group_43":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102600,"motion":0,"pos":1,"voice":"vo_char_1026_00_66","textHome":"啊，可能干的太过火了……"}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102600,"motion":100,"pos":1,"voice":"vo_char_1026_00_05","textHome":"和大家也都处好了关系，@来这一趟真好！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102600}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102600,"motion":100,"pos":1,"voice":"vo_char_1026_00_13","textHome":"来看，我这十手的招式！@这也是和静香认真对练的成果哦！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102600,"motion":1}]}],"group_7":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":102600,"motion":300,"pos":1,"voice":"vo_char_1026_00_14","textHome":"这就是捕头的绝技！嘿唰唰唰唰！@你已经，逃不掉了……"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":102600}]},{"autoTurnFirst":2.0,"chara":[{"id":102600,"motion":200}]},{"autoTurnFirst":3.1,"chara":[{"id":102600,"motion":0}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102600,"motion":1,"pos":1,"voice":"vo_char_1026_00_15","textHome":"想听听我的经历，你可真有闲趣呢。@要听听我找宠物的事吗？"}]},{"autoTurnFirst":3.0,"chara":[{"id":102600,"motion":0}]}],"group_9":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102600,"motion":0,"pos":1,"voice":"vo_char_1026_00_16","textHome":"一次我迷路的时候，被派出所的叔叔帮了忙，@从那之后我就一直憧憬着成为英雄啦。@这不算什么很特别的经历对吧？诶嘿……"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102600,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102600,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102600}]}]},"version":3}