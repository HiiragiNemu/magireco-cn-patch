n":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200500,"motion":0,"pos":1,"voice":"vo_char_2005_00_14","textHome":"身体好轻……嗯！没错！这样的感觉最棒了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp3.json","id":200500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":200500,"motion":200}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200500,"motion":0,"pos":1,"voice":"vo_char_2005_00_15","textHome":"我的魔力还能更上一层吗？@确认一下试试。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":200500,"motion":100}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200500,"motion":0,"pos":1,"voice":"vo_char_2005_00_16","textHome":"我是祈愿延续自己生命的魔法少女。@所以，我的魔法似乎也是从那个愿望而来的。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp3.json","id":200500}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":200500,"motion":200}]}],"group_9":[{"autoTurnFirst":4.7,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200500,"motion":0,"pos":1,"voice":"vo_char_2005_00_17","textHome":"虽然我能使用各种各样的魔法，@但是肯定还有继续研究的余地。@必须要更加精进才行。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp3.json","id":200500,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":200500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp3.json","id":200500,"motion":200}]}]},"version":3}