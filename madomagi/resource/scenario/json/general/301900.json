{"story":{"group_1":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_01","textHome":"喜欢的词语是笑容！喜欢的事情是逗人笑！@喜欢的东西是笑话，爱好是看搞笑节目@但是未来的梦想~是成为职业拳击手！@……这样的话，不就是搞笑艺人了嘛！@啊——哈哈！这就叫吐槽了吧！"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_18","textHome":"我最喜欢TPO了！……嗯？啊，是搞笑组合的@名字啦！因为他们才刚刚剧场公演！知名度@可能还很低。但是，超有意思的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301900,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_19","textHome":"嗯~精力充沛！@我现在感觉能量多得都要涌出来了！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_20","textHome":"嗯嗯嗯！毬子小姐，级别上升啦！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_13":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_21","textHome":"没有过去的我……也就没有现在乐观积极的我。@所以说，我要感谢过去的我才行。"}]},{"autoTurnFirst":2.8,"chara":[{"face":"mtn_ex_010.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]}],"group_14":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_22","textHome":"无论什么时候都想保持着乐观开朗……@许下这样愿望的……不是别人，而是我自己。@所以说，靠着这份决心而获得改变的我，@毫无疑问就是真正的我。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301900,"motion":1}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200,"pos":1,"voice":"vo_char_3019_00_23","textHome":"向前！向前！一起向前吧！好不容易获得了新@生！要是这样还要悲观的话，那就太浪费了！@就算不如所愿，今后我也会不断改变！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"id":301900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":301900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_24","textHome":"哇呼！你好你好！毬子今天也是精神十足的@活泼女孩！要是~没有精神的话，我就把我的@能量分给你哦！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]}],"group_17":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_25","textHome":"早上啦！一起做体操吧！？第5568套@广播体操~！诶！？为什么不吐糟我？@你的反射弧也太长啦——！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"id":301900,"motion":0,"pos":1}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":400,"pos":1}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":200,"pos":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":400,"pos":1}]}],"group_18":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_26","textHome":"肚子饿的能量归零了……一直以来的精神也……@不过不过！在听到今天的便当是荞麦面之后，@我就立刻打起精神了——！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":301900,"motion":200}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_27","textHome":"对了对了！一起去买东西吧！我知道个好地@方！保证你想把店里的东西全都买一遍！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"id":301900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]}],"group_2":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_03","textHome":"嗯……虽然笑点和我想的不一样……@但是个好孩子呢！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":1}]}],"group_20":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100,"pos":1,"voice":"vo_char_3019_00_28","textHome":"我最喜欢睡觉了！被窝好舒服！所以进到被窝@里就精神起来了！诶……那样不是想睡都睡不着@了嘛！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200,"pos":1,"voice":"vo_char_3019_00_29","textHome":"不只是衣服，只要发现有趣的东西，我都会@忍不住想买！看我的手机套上还挂着炸虾哦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":300,"pos":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100,"pos":1}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_30","textHome":"魔女是散布诅咒的存在……也就是把世界变成@黑暗的存在。那样的话，就只能消灭她了吧！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"id":301900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100}]}],"group_23":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_31","textHome":"我不适应镜之魔女的结界啦。到处都是镜子，@完全是个迷宫！……嘛！总之先前进再说，@总会有办法的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200}]}],"group_24":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200,"pos":1,"voice":"vo_char_3019_00_32","textHome":"要和大家热热闹闹地战斗啦！这样我就活力@倍增！……咦？害怕会输？……也是哦。@我只会考虑胜利啦！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":301900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200,"pos":1,"voice":"vo_char_3019_00_33","textHome":"我喜欢奇怪的衣服！像这样的，你在哪买的？@是我想要的图案！前段时间，我买了件上面@画着寿司包得溢出来的T恤！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301900,"motion":100,"pos":1,"voice":"vo_char_3019_00_34","textHome":"我最喜欢笑话了！我虽然也喜欢滑稽短剧，@不过最喜欢的还是相声了！@那种速度感真是太棒了！"}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_010.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301900}]},{"autoTurnFirst":5.0,"chara":[{"id":301900,"motion":300}]}],"group_27":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_35","textHome":"我可以在杂货店待上一整天！你不觉得那里@就像是主题乐园吗？到处都是想要的东西！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_36","textHome":"要问我是吐槽还是被吐槽的，我应该是吐槽的@那个吧？「快停下来啊——！」像这样@一本正经的吐槽真是让人心情愉快啊！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":0}]}],"group_29":[{"autoTurnFirst":5.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_37","textHome":"搞笑艺人真的好厉害！我要开始整活啦~这样@宣言的话……真的就能让人爆笑不止呢！@真是帅气的工作！"}]},{"autoTurnFirst":2.8,"chara":[{"face":"mtn_ex_011.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":301900,"motion":0}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":400,"pos":1,"voice":"vo_char_3019_00_04","textHome":"我真的变了啊……@变成了憧憬的朋友那样……！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100}]}],"group_30":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_38","textHome":"我喜欢orange！……啊！说的不是水果而是@颜色的话题吧？黄色我也喜欢！这两个都有@维他命的感觉，能让人打起精神来！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900}]}],"group_31":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_39","textHome":"小时候的朋友？嗯！是令我骄傲的朋友呢！@我不会嫉妒她啦，那种感情和我不相配。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900}]}],"group_32":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301900,"motion":300,"pos":1,"voice":"vo_char_3019_00_40","textHome":"刚刚放声大笑的我和羡慕朋友到不行的我，@毫无疑问，哪一个都并非他人，而是我自身。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0}]},{"autoTurnFirst":1.3,"chara":[{"id":301900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100}]}],"group_33":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301900,"motion":400,"pos":1,"voice":"vo_char_3019_00_41","textHome":"这、这个！？这个怎么说呢，算是……段子笔记@吧……不不不！我才不是想要成为艺人呢！？@只是写了日常的小段子……而已。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":301900,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"id":301900}]},{"autoTurnFirst":1.5,"chara":[{"id":301900,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"face":"mtn_ex_010.exp.json","id":301900,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"face":"mtn_ex_011.exp.json","id":301900}]}],"group_34":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_42","textHome":"没问题没问题！虽然没什么根据但是没问题！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"pos":1}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":200,"pos":1,"voice":"vo_char_3019_00_43","textHome":"哦哦——！气氛高涨呢！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":100,"pos":1,"voice":"vo_char_3019_00_44","textHome":"真是毫不意外的对手呢！"}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":0,"pos":1,"voice":"vo_char_3019_00_45","textHome":"果然！？我就觉得自己能行！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":1,"pos":1}]}],"group_38":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"voice":"vo_char_3019_00_46","textHome":"借着这股势头再来……！我要上啦~！？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900,"motion":200,"pos":1}]}],"group_39":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":100,"pos":1,"voice":"vo_char_3019_00_63","textHome":"来了来了！一下子就要活跃起来了"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301900}]}],"group_4":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301900,"motion":1,"pos":1,"