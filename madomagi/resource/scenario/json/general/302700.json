{"story":{"group_1":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_01","textHome":"在我小时候，双亲就在旅行中因故去世了，@只剩下我一个人。之后，我被亲戚推来推去，@最终落脚到了杜鹃之家孤儿院……@不过，我却觉得这很幸运。@而且我还有了新的家人！"}]},{"autoTurnFirst":4.5,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":302700,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":100}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_18","textHome":"如果对方有机可乘的话，就要一直压制对方。@虽然可能有些无情，@不过这就是取得主导权的手段。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":200}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_19","textHome":"我清楚地感觉到了，我的力量在提高。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_20","textHome":"呼……感觉不错。周围的景色也有些变了呢。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":1}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_21","textHome":"在失去双亲独自生活以来，@我就会经常去观察其他人。@这个习惯也延续到了现在。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":1}]}],"group_14":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_22","textHome":"虽说要仔细观察别人，@但如果按照字面意思一直盯着别人看的话，@反而会引起他人的警戒。@所以，迅速收集细微的情报，@勾勒一个整体面貌是很重要的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":7.5,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_23","textHome":"如果掌握了对方的大体个性，@那最后决胜的一手就是自己的直觉了。@说起来，我最近基本上都靠的是它！@但是，因为直觉是自己的本能，@所以我也觉得它是最能信任的部分。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":200}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_24","textHome":"啊啊，你来了呢。感觉如何？@嗯，我也给自己随便找了点事做。@所以，今天也好好休息休息吧？"}]},{"autoTurnFirst":1.5,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]}],"group_17":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_25","textHome":"……嗯……啊啊，早上好……@啊，但是不行……@我还要再睡会儿，我早上完全起不来……@就让我再睡一小会儿……晚安……"}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":300}]}],"group_18":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_26","textHome":"这个时间我还是没完全清醒啊～@吃点辣的能不能提提神呢？@嗯——咖喱怎么样？或者担担面？"}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":302700}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_27","textHome":"接下来，就稍微到处逛逛吧……@啊，我并没有在玩啦。@我只是作为魔法少女在巡逻……顺便玩玩！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":5.5,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]}],"group_2":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_03","textHome":"常盘七香她啊。@长得很漂亮，感觉是个厉害角色……"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":3.5,"chara":[{"id":302700,"motion":200}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_28","textHome":"嗯……啊，今天看来已经撑不住了。@作业的话，就明天早起再做吧。@早上？没问题啦！我肯定起得来的！"}]},{"autoTurnFirst":3.5,"chara":[{"id":302700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]}],"group_21":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_29","textHome":"时间这种东西，@到底是慢慢地流，还是哗哗地流呢，@真是搞不明白啊。@根据不同的心情和情况，感受也会不一样吧？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_22":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_30","textHome":"结果，一个人能做的事情还是有限的。@所以，我只会完成自己的使命。@就算勉强自己去做了，那也不是自己的风格。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"id":302700,"motion":1}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":300,"pos":1,"voice":"vo_char_3027_00_31","textHome":"哎呀呀，要战斗吗……@不过，我也不打算输呢。@好，我觉得自己没问题，那就来吧。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":200}]}],"group_24":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_32","textHome":"这里聚集了好多人啊。@这不是个人战，如果大家各想各的就赢不了，@战斗时候注意这一点吧～"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":200}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_33","textHome":"不知道为什么，我有时能感受到对方的想法。@不过只能感觉到个大概，细节部分就不清楚了。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_015.exp.json","id":302700,"motion":100}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_26":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_34","textHome":"在天气好的日子，@坐在河堤上发呆什么也不想真是最棒了。@那种让大脑放空的感觉——"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":302700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_35","textHome":"虽然不想让自己太累，@不过排着队的店还是想要去排队。@因为我很在意店里卖的东西到底有多美味！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":1}]}],"group_28":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_36","textHome":"生活中不是会有那种无可奈何的事嘛？@这就意味着，不管怎么做它都无可奈何，@所以就不要太慌张啦。"}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]}],"group_29":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_37","textHome":"这种城市到底有多少魔法少女呢？@可以的话，真想让大家都手下留情啊……@不过，就算这么希望，也是实现不了的吧……"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":200}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_04","textHome":"终于找到了啊。那么，开始吧……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]}],"group_30":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_38","textHome":"这个世界上，最麻烦的就是「表与里」。@你以为它是表面，其实它是里面，@反过来也是一样……@每次都要仔细思考，真的很麻烦。"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302700,"motion":200}]}],"group_31":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_39","textHome":"神滨市也有各种有趣的地方，@有时间的话去逛逛也是不错的。@下次，就三个人一起去吧。"}]},{"autoTurnFirst":3.3,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":1}]}],"group_32":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_40","textHome":"对我来说，和木叶、菖蒲一起活下去就是一切。@不好意思，任何事在这件事面前都要让步。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":300}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_41","textHome":"我啊，终于找到了呢……满意的调味料搭配！@只要有这个，@不管做什么菜我都能更上一个台阶！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_42","textHome":"那么，就赶紧开始吧……！"}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":200}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":100,"pos":1,"voice":"vo_char_3027_00_43","textHome":"好，结束了！收工～"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_44","textHome":"嗯，本来就不可能输嘛。"}]}],"group_37":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":100,"pos":1,"voice":"vo_char_3027_00_45","textHome":"赢了赢了～感觉很不错吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_46","textHome":"抱歉，我不会在这停下脚步的。"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_63","textHome":"好啦好啦……吃我这招！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":100}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_05","textHome":"魔女已经打倒了，希望一切都能顺利吧～"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":200}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_64","textHome":"就我个人而言啊……也想用这招了结你了！"}]},{"autoTurnFirst":3.5,"chara":[{"id":302700,"motion":200}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_65","textHome":"事先说明，这招可相当厉害……！"}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":200}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_66","textHome":"到此为止吧……是时候结束了！"}]},{"autoTurnFirst":2.0,"chara":[{"id":302700,"motion":200}]}],"group_43":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_02","textHome":"嗯……我？啊啊，我是游佐叶月。@你好你好，请多指教……嗯……@啊，你要喝点什么吗？我请你吧。@咖啡怎么样？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"id":302700,"motion":0}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":300}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]}],"group_5":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_13","textHome":"总之先这样吧。感觉还不错？"}]},{"autoTurnFirst":3.5,"chara":[{"id":302700,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_14","textHome":"噢——就是这个！@嗯，我明白的。很不错的感觉呢～"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700,"motion":1}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":200,"pos":1,"voice":"vo_char_3027_00_15","textHome":"这就是……隐藏的门被打开的感觉吧。@总之，继续前进吧。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1}]}],"group_8":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":0,"pos":1,"voice":"vo_char_3027_00_16","textHome":"在和别人谈判的时候，@如果对方的想法很固执，@就要想办法制造出一点空隙来。@就像用脚卡住快要关上的门那样吧。"}]},{"autoTurnFirst":4.5,"chara":[{"id":302700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":302700,"motion":1}]}],"group_9":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302700,"motion":1,"pos":1,"voice":"vo_char_3027_00_17","textHome":"在谈判发现突破口的时候，@就一定要提高要求。@然后，看准适当时机降低要求的话，@就很容易被对方接受了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":302700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":302700,"motion":200}]}]},"version":3}