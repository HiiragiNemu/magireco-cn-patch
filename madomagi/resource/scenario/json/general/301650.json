{"story":{"group_1":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_01","textHome":"和家人的回忆？记得最清楚的，是小时候全家@一起去登山的事情吧。最近呢…怎么说呢？@基本上就没和家人一起出去过了……啊，@抱歉。气氛有点尴尬。你和家人的回忆@又是什么样的呢？"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_18","textHome":"最近开始编织毛衣了。想做成稍微复杂一点的@北欧风格……大概会成为至今为止@最好的作品吧。"}]},{"autoTurnFirst":6.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnLast":4.0,"chara":[{"id":301600,"motion":100}]}],"group_11":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_19","textHome":"拿山做比喻的话～现在是爬了几层呢？呵呵，@目前的行程算是告一段落了呢。"}]},{"autoTurnFirst":3.5,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_20","textHome":"有种焕然一新的感觉。从现在开始……@再次启程吧。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":0}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_21","textHome":"我为了守护家庭，而背负起了全部的责任，@听起来是一件很了不起的事情。@因为那不是我一个人能做到的。"}]},{"autoTurnFirst":4.5,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":301600,"motion":300}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_22","textHome":"我真的希望……能够有一个幸福的家庭。@但是……那不是我一个人能建立起来的。@因为是家庭嘛。爸爸、妈妈，还有我。@不是三个人共同建立的话就没有意义了。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnLast":1.5,"chara":[{"eyeClose":0,"id":301600}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":0,"id":301600,"motion":200}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_23","textHome":"为了再次拥有幸福的家庭，我尽我所能。@但是……既不能勉强，也不能独自承受。@如果要牺牲谁才能拥有幸福的家庭，@那样的家庭已经失去了原有的意义了"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":301600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]}],"group_16":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1,"pos":1,"voice":"vo_char_3016_50_24","textHome":"啊，来了来了！这边，位置已经占好了。@就在海之家和海的中间。@嗯哼，是最佳地点吧！"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_50_25","textHome":"早上好。@哈——天气不错，感觉会是快活的一天。@要是平时，就会是“登山去！”的感觉，@今天的话就去海水浴吧！"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":100}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_26","textHome":"到中午啦！@今天呢，做了凉菜沙拉！@用了能防止夏倦的猪肉，还有应季的野菜。@味道怎么样？"}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":100}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":300,"pos":1,"voice":"vo_char_3016_50_27","textHome":"呼……好热啊，浑身都火辣辣的。@补充水分，好好休息，然后做晚饭吧。@有什么想吃的菜吗？"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":5.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"id":301600,"motion":100}]}],"group_2":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_03","textHome":"离开的人……是无法理解理解@被丢下一方的感受的……！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]}],"group_20":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":400,"pos":1,"voice":"vo_char_3016_50_28","textHome":"啊，等下！关掉空调，打开窗户试试。@你看，凉快吧？@把门也打开，让空气流通，多凉快啊。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":4.3,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":3.6,"chara":[{"id":301600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":301600,"motion":100}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_50_29","textHome":"我喜欢长距离游泳。@先是1公里，然后2公里，@像这样踏踏实实地达成目标，就像登山一样。"}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"id":301600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_30","textHome":"那，出发吧！@啊，带上这个如何？贝壳形的腰包！@泳装不好带小物件，有它就方便了，@所以我试着做了一个。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_31","textHome":"要是能和自己的复制品一起出去的话……@我想去登山。因为我最了解自己嘛。@登山可谓是意气相投呢！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":200}]}],"group_24":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_32","textHome":"家人、情侣、朋友们……海水浴场有很多人，@但是共同点就是，大家都喜笑颜开。@嗯，太棒了！"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":301600}]},{"autoTurnFirst":3.8,"chara":[{"id":301600,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_25":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_50_33","textHome":"夏天用的编织物……好像没什么想法啊？@腰包啦，杯袋啦，夏天能用的@毛线小制品很多呢。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_50_34","textHome":"海真大啊——因为没有遮挡的物体，@就更加有这种感觉了吧？@跟登山看见的景色完全不一样，感觉很新鲜！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_35","textHome":"哇！沙滩上有好多东西——@贝壳、海藻、水母、别针、杂志……@嗯？这个是……日记本！？@不行不行！偷看太没礼貌啦！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":6.2,"chara":[{"id":301600,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":301600,"motion":300}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_50_36","textHome":"日美香家的弟弟们，一点儿都不会夏倦。@大概多亏了日美香为他们做的饭吧！@不仅仅节约了开支，也考虑了营养呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_50_37","textHome":"虽然去过好几次海水浴，@但好像没有全家一起去过的印象……@这次就邀请爸爸妈妈去吧。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_04","textHome":"这是靠我的愿望……才取回的东西。@我一定……要保护好……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":301600}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1,"pos":1,"voice":"vo_char_3016_50_38","textHome":"御魂她最受不了暑气了吧……@总是受她关照，带点东西去看看她吧？@至于带什么好，和真良商量下吧。"}]},{"autoTurnFirst":5.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_50_39","textHome":"你看见过真良游泳吗？@虽然我看过好几次了，但真的感觉好快啊！@下次请她指点一下游得快的秘诀吧。"}]},{"autoTurnFirst":2.7,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":301600,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_50_40","textHome":"虽说跟真良两人一起去挑了泳装，@可真良她啊，竟然说平时的泳装就可以了！？@明明好不容易才去一趟海边哦……"}]},{"autoTurnFirst":1.0,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"id":301600,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":300}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_50_41","textHome":"想去夏季祭典玩！@大家穿浴衣，逛摊位，跳盂兰盆舞，看烟花。@嗯哼，一定会留下难忘的回忆！"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_42","textHome":"为了大家，我要全力以赴！"}]}],"group_35":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_43","textHome":"大家没受伤吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_44","textHome":"啊，真刺激！嗯哼。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":300,"pos":1,"voice":"vo_char_3016_00_45","textHome":"放心下来就有种脱力感了。"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_46","textHome":"没问题。我会保护你的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_63","textHome":"现在正是大举进攻的时机!"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_05","textHome":"我不会再忽视自己的内心了。为了我自己，@我会陪在你身边的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_64","textHome":"别小看了这份守护的心意！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":1}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_65","textHome":"不会让你轻易击垮的!"}]}],"group_42":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_66","textHome":"这一发……是最后的一击!"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":400}]}],"group_43":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_02","textHome":"初次见面，我是粟根心。需要帮忙的话@随时来找我吧。同样身为魔法少女的伙伴，@如果有困难我会帮忙的。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"id":301600,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":3.0,"chara":