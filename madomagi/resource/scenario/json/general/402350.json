ar_4023_00_64","textHome":"绝……对……不会饶恕你！！不可原谅！"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":402300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":402300,"motion":400}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402300,"motion":200,"pos":1,"voice":"vo_char_4023_00_65","textHome":"我会放过你吗————！！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_66","textHome":"……我并不打算听你狡辩。"}]}],"group_43":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_02","textHome":"我是梅丽莎·德·维尼奥勒。@作为塔鲁特……啊不，圣女大人的随从，@负责照顾圣女大人的生活！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402300,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":402300,"motion":300}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_13","textHome":"就叫我梅丽莎吧……！"}]}],"group_6":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_14","textHome":"我的力量竟然……@这就是被称为「愤怒」的父亲大人的血统吗？"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_15","textHome":"羁绊进一步变深的话，就会变成这样吧……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_8":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_16","textHome":"我和父亲大人的初次相遇，@是在母亲大人的墓前祈祷的时候。@因为分开生活的缘故，我一直都不知道@父亲大人的存在。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":402300,"motion":1}]}],"group_9":[{"autoTurnFirst":1.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_17","textHome":"我和塔鲁特第一次相遇的时候，@她还矮小得让人吃惊……但最让人惊讶的是，@天使大人就待在她的肩上！"}]},{"autoTurnFirst":3.2,"chara":[{"id":402300,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300}]}]},"version":3}