{"skipTransitionList":[],"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_01","textHome":"我是塔鲁特的……圣女大人的随从，@但因为我们年龄相仿，所以非常亲密。@父亲大人是人称「愤怒」的佣兵，@而我也是在见证着战场与战斗中长大的。@也许是我和慷慨激昂的父亲大人相似吧，@一提到塔鲁特的事情，我就容易失去理智……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402300,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"id":402300}]}],"group_10":[{"autoTurnFirst":7.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_18","textHome":"圣女大人原本名叫「贞德」，@「塔鲁特」是天使大人特别送给她的化名……@叫起来很好听对吧！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402300,"motion":400}]}],"group_11":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_19","textHome":"谢谢……我会用这份力量，@将希望之光守护到最后。"}]}],"group_12":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_20","textHome":"一起祈祷吧……@为了成为拯救这个国家的力量……"}]}],"group_13":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":0,"pos":1,"voice":"vo_char_4023_00_21","textHome":"在我小的时候，我就已经置身战场，@照顾父亲大人的部队了……@不过那时完全没想到我会亲自进行战斗。"}]},{"autoTurnFirst":4.5,"chara":[{"id":402300,"motion":1}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402300,"motion":300,"pos":1,"voice":"vo_char_4023_00_22","textHome":"塔鲁特的道路，对大家来说就是希望之光……@我深信着这一点成为了魔法少女。@所以我不会后悔。那天立下的誓言，@我要和同伴一起走到最后。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402300}]},{"autoTurnFirst":4.2,"chara":[{"id":402300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402300}]}],"group_15":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402300,"motion":1,"pos":1,"voice":"vo_char_4023_00_23","textHome":"我的命运一直都和塔鲁特相连。@所以我今后会和她一起战斗。@塔鲁特是法兰西的希望之光……@她是那唯一能让人民停止哀叹的存在，@就像天使大人说的那样……！"}]},{"autoTurnFirst":3.5,"chara":[{"id":402300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402300}]}],"group_16":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402350,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4023_50_24"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402350}]},{"autoTurnFirst":2.5,"chara":[{"id":402350,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402350}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402350,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4023_50_25"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402350}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402350,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":402350}]}],"group_18":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402350,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4023_50_26"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402350,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402350,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402350}]}],"group_19":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402350,"lipSy