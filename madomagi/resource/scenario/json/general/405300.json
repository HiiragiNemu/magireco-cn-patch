{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_01","textHome":"我是八神疾风，小学五年级学生，同时也是一@位魔法师！我的特长是群体魔法还有……料@理！下次，就让你尝尝我的手艺吧——"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":405300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_10":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_17","textHome":"八神疾风，版本升级啦！这样子我对大家的帮@助又能更进一步了！"}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1,"pos":1,"voice":"vo_char_4053_00_18","textHome":"我擅长的是广域魔法。不进行目标瞄准，把目@标交给大范围轰击！除此之外……我就靠融@合来努力吧！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":405300,"motion":300}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_19","textHome":"谢谢帮忙。夜天之书的调整，完成了！"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":1.5,"chara":[{"id":405300,"motion":100}]}],"group_13":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":400,"pos":1,"voice":"vo_char_4053_00_20","textHome":"噢噢，我的胸口涌现出了力量……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_14":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_21","textHome":"我珍贵的宝物，夜天之书。为了成为配得上它@的主人，从此以后我也会努力的！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_22","textHome":"就算道路有些不同，但是不断战斗的大家目标@都是一样的。不想让任何人悲伤，不想让任@何人受伤，大家都能幸福地生活……为了这@样的明天，我要不断磨练从那个人手中获得@的力量！"}]},{"autoTurnFirst":4.0,"chara":[{"id":405300,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":405300}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":200}]}],"group_16":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_23","textHome":"我一个人是无法战斗的。因为有大家陪着我，@支撑着我，我才能变得强大。我要连同他们@的份努力下去，从今往后也拜托你了！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":405300,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100,"pos":1,"voice":"vo_char_4053_00_24","textHome":"今天也见到你了呢。怎么样，有精神吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]}],"group_18":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":1,"pos":1,"voice":"vo_char_4053_00_25","textHome":"早上好。今天也要一起努力哦♪"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_26","textHome":"吃午饭的时间到了。我做了便当，要一起吃吗@？"}]},{"autoTurnFirst":2.5,"chara":[{"id":405300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]}],"group_2":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_02","textHome":"我叫八神疾风。是担任时空管理局搜查官的小@学五年级学生。请多关照～"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":100}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_27","textHome":"回过神来，天都已经暗了。虽然工作很重要，@但晚饭也要好好考虑才行。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405300}]},{"autoTurnFirst":2.5,"chara":[{"id":405300,"motion":300}]}],"group_21":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_28","textHome":"夜深了。要睡的话就要去床上好好睡哦？要是@感冒了可就麻烦了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":405300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_22":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_29","textHome":"嗯？怎么啦？有时间陪陪我的话，我会很开心@的。"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]}],"group_23":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_30","textHome":"我准备好出发了哦？不要着急，慢慢工作吧！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":200}]}],"group_24":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":400,"pos":1,"voice":"vo_char_4053_00_31","textHome":"能来一场模拟战吗？我想试试最近练习的配合@。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":2.5,"chara":[{"id":405300,"motion":100}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_32","textHome":"似乎正在举行大会呢。要去试试吗？要去的话@我也会努力的♪"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":400}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_33","textHome":"嗯，是在在意我吗？那么就一起聊会儿吧♪"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":300}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_34","textHome":"这件衣服？是骑士甲胄，算是我的战斗服吧。@我很喜欢这个帽子的形状哦～"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_35","textHome":"我的魔法是贝尔卡式，是一种少见的古老魔法@。我能使用是……多亏了琳芙斯和夜天之书@吧？"}]},{"autoTurnFirst":1.5,"chara":[{"id":405300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":200}]}],"group_29":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_36","textHome":"奈叶和菲特是我的救命恩人，也是我重要的朋@友。虽然我们年龄相同，但个子好像是我最@小。"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_3":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_03","textHome":"八神疾风，会努力的！"}]},{"autoTurnFirst":1.5,"chara":[{"id":405300,"motion":100}]}],"group_30":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_37","textHome":"我的口音？很在意吧。是因为小时候居住地区@的影响啦。"}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":300}]}],"group_31":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_38","textHome":"我的装备是夜天之书和剑十字。两个都是我重@要的宝物。有了它们我就能帮到大家了，今@天我也要成为活力满满的魔法少女。"}]},{"autoTurnFirst":3.5,"chara":[{"id":405300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":400}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_39","textHome":"我过去也是孤零零一人。所以我没办法不管那@些和我一样悲剧的孩子们。虽然有些任性…@…不过我必须要帮助他们。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":405300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":405300}]},{"autoTurnFirst":2.2,"chara":[{"id":405300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":405300,"motion":100}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_40","textHome":"在继承了那个一直守护着我，拯救我的人的名@字和资质之后，她降临了，琳芙斯II。我@必须要成为她合格的主人才行。"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":405300}]},{"autoTurnFirst":8.5,"chara":[{"eyeClose":0,"id":405300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":200}]}],"group_34":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_41","textHome":"过去我没办法一个人行走，经常被抱着走路。@所以我现在也喜欢被人抱着。……我没有在@催你啦？"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":405300,"motion":400}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":100,"pos":1,"voice":"vo_char_4053_00_42","textHome":"那么，让我打倒它吧！"}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":300,"pos":1,"voice":"vo_char_4053_00_43","textHome":"总算是结束了～"}]}],"group_37":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":200,"pos":1,"voice":"vo_char_4053_00_44","textHome":"下次也像这样上吧～"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_45","textHome":"大家没事就好～"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":100}]}],"group_39":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100,"pos":1,"voice":"vo_char_4053_00_46","textHome":"大家的胜利！"}]}],"group_4":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405300,"motion":1,"pos":1,"voice":"vo_char_4053_00_04"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_63","textHome":"聚集在天空之下吧，白银之刃"}]},{"autoTurnFirst":1.5,"chara":[{"id":405300,"motion":200}]}],"group_41":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405300,"motion":100,"pos":1,"voice":"vo_char_4053_00_64","textHome":"击穿我的敌人！"}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405300,"motion":400,"pos":1,"voice":"vo_char_4053_00_65","textHome":"光之剑！"}]}],"group_43":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405300,"motion":200,"pos":1,"voice":"vo_char_4053_00_66","textHome":"……攻击！"}]}],"group_5":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100,"pos":1,"voice":"vo_char_4053_00_05"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":200,"pos":1,"voice":"vo_char_4053_00_13","textHome":"练习有效果了吗？真开心啊～"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300,"motion":100}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_14","textHome":"作为夜天之书的主人，也可以感到骄傲了吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":100}]}],"group_8":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405300,"motion":1,"pos":1,"voice":"vo_char_4053_00_15","textHome":"不管什么道路都要脚踏实地。不要着急一起走@下去吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405300}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405300,"motion":0,"pos":1,"voice":"vo_char_4053_00_16","textHome":"我的魔力虽然很高，但是我不擅长进行细微的@操纵和快速的运用。要是能补足这一方面就@好了。"}]},{"autoTurnFirst":4.5,"chara":[{"id":405300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":405300}]}]},"version":3}