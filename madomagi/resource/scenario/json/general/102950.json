{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":102900,"motion":0,"pos":1,"voice":"vo_char_1029_00_13","textHome":"就算像我一样弱小，也能着实地感觉到自己变@强了吗？"}]},{"autoTurnFirst":3.2,"chara":[{"id":102900,"motion":100}]}],"group_7":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":102900,"motion":200,"pos":1,"voice":"vo_char_1029_00_14","textHome":"我已经成长到连魔女也能打倒了，心情好激动@啊。"}]},{"autoTurnFirst":2.3,"chara":[{"eyeClose":1,"id":102900}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":102900,"motion":1,"pos":1,"voice":"vo_char_1029_00_15","textHome":"这些事，我不会跟其他人说。都是特别讲给你@听的，所以要保密哦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102900,"motion":100}]}],"group_9":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":102900,"motion":1,"pos":1,"voice":"vo_char_1029_00_16","textHome":"我喜欢做机器人。虽然也才刚刚起步……但是@，我会把从爷爷那里得到的电路板之类的材@料固定在丙烯酸树脂板上使用哦。"}]},{"autoTurnFirst":7.0,"chara":[{"id":102900,"motion":200}]}]},"version":3}