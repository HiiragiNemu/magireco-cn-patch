.exp.json","id":111700,"motion":1,"pos":1,"voice":"vo_char_1117_00_30","textHome":"去消灭魔女之前，先到调整屋坐坐吧。根据报@酬可以进行特别的强化哦，不来可就亏啦。"}]},{"autoTurnFirst":5.0,"chara":[{"id":111700,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":111700,"motion":100,"pos":1,"voice":"vo_char_1117_00_31","textHome":"哎呀，要去无尽镜界吗？那我也一起去吧。不@用担心，我只是在入口处等着而已♪"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":111700,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111700,"motion":0,"pos":1,"voice":"vo_char_1117_00_32","textHome":"这么多魔法少女聚在一起，调整屋里都没见过@几次呢！快去吧！手段高明的商人，可不会@错过这种机会！"}]},{"autoTurnFirst":3.0,"chara":[{"id":111700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":111700,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700}]}],"group_26":[{"autoTurnFirst":5.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":111700,"motion":300,"pos":1,"voice":"vo_char_1117_00_33","textHome":"初次参拜的时候，那可真是许了大堆愿望呢。@客人络绎不绝、生意繁荣昌盛、生活尽情享@受……还有很多呢，要听吗？"}]},{"autoTurnFirst":4.0,"chara":[{"id":111700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":111700,"motion":100}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":111700,"motion":0,"pos":1,"voice":"vo_char_1117_00_34","textHome":"在学习吗？了不起~诶，我没事，只要去参加@考试就能得分了。那你加油哦。"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":111700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":111700}]},{"autoTurnFirst":7.2,"c