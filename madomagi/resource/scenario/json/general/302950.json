{"story":{"group_1":[{"autoTurnFirst":10.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_01","textHome":"无论是达成了什么亦或是被他人所称赞，@我都不会放在心里，换做相反的事态也一样。@即使有人说我没有感情，我还是不为所动。@无论发生什么，我都心如止水。虽然这样的生活@非常平静，但也非常无趣。"}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"id":302900,"motion":200,"pos":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":302900,"motion":0,"pos":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":300,"pos":1}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_18","textHome":"不怎么看电视。因为觉得没有真实感，也不会@让人心动。我更偏爱能亲身体会的事情。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200}]}],"group_11":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_19","textHome":"感受到了……力量的涌动。现在的心情也……@好像有些兴奋的样子。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":200}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_20","textHome":"略微有点心动……这能让我的日常发生一些@变化吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_13":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_21","textHome":"仅仅是探寻自己，是找不到生存的意义的。@透过与他人的联系，才能在普世中找到喜悦。@这就是我目前的答案。"}]},{"autoTurnFirst":7.0,"chara":[{"id":302900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":200}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_22","textHome":"我曾经觉得死去，也只是我的命运而已。@而且，我的生死也是我自己的事情。……但是@如果我的死，会成为他人的伤痛的话，@那我就应该抗争到底。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_15":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_23","textHome":"无数次重复的早晨，刻在眼中那熟悉的景色…@因为一个小小的因素全都得以改变。虽然@只是一个站不住脚的假说，却这是我短暂@人生里最有兴趣的命题。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"id":302900,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200}]}],"group_16":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_50_24","textHome":"那，出发吧。去哪？海边。@穿着这身去海边……奇怪吗？@这种问题，我不太理解……"}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":300}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_50_25","textHome":"海水浴，虽然去过一次，但因为还小，@不太能记得了。除了泳装和毛巾，@还需要准备别的东西吗？"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":302900}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":302900}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":302900,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":302900,"motion":100}]}],"group_18":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_50_26","textHome":"下水之前，不要忘记做准备运动。@即使只是玩水，在水中发生的事故@也比想象当中还要危险。"}]},{"autoTurnFirst":7.0,"chara":[{"id":302900,"motion":300}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_50_27","textHome":"在海边度过一整天，在这之前从没想象过。@感觉度过了完全不一样的一天。@有一点，兴奋的感觉。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":100}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_03","textHome":"就算没有我，对她也没什么坏处才对。"}]}],"group_20":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_28","textHome":"在家仰望星空，和在海边仰望星空……@虽然都是同样的天空，@却因为环境和位置不同，能看到不同的星星。@人会因此而感受到不同的情绪吗？"}]},{"autoTurnFirst":5.5,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":100}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":400,"pos":1,"voice":"vo_char_3029_50_29","textHome":"在游泳部，一直都是这样穿的。@所以，对我来说日子还是一成不变。@你又如何呢？@看见这身泳装，反而觉得不平常吗？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":200}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100}]}],"group_22":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_50_30","textHome":"有魔女的气息……我去打探一下再回来。@不让吗？为什么？@没关系，不管穿什么衣服，变身之后都一样。@这样……也不行吗？"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":400}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":0}]}],"group_23":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_31","textHome":"午夜零时，试过用两面镜子相对。@当然，什么也没有。@无论是未来的自己，还是现在的自己。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302900,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":302900,"motion":200}]}],"group_24":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_32","textHome":"要去参加长距离游泳大会？那……加油吧。@问我要不要去？不知道心她去不去……@行，那我也出场吧。"}]},{"autoTurnFirst":4.2,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100}]}],"group_25":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_50_33","textHome":"仔细感受的话，海确实很大，气息也很强烈。@平时只习惯泳池规模的气味，@现在变得更加浓烈了。"}]},{"autoTurnFirst":4.2,"chara":[{"id":302900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":300}]}],"group_26":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_34","textHome":"想着能不能在沙滩光脚走路，@结果偶尔还会踩到玻璃片，@真是出乎意料的危险。@还好最后还是穿着拖鞋来了。"}]},{"autoTurnFirst":5.0,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":100}]}],"group_27":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_35","textHome":"暑假作业已经做完了。@自由研究……现在正在做。@这是之前爬过的那座山的立体地图。@看起来简单，做起来挺难的……"}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"id":302900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":302900}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_50_36","textHome":"用游泳圈游泳的人，是什么情况？@因为不会游泳所以用游泳圈？@那，不会游泳的话，为什么来海边？"}]},{"autoTurnFirst":3.7,"chara":[{"id":302900,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"id":302900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":100}]}],"group_29":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_50_37","textHome":"说好要去登山之后，我在查山的资料。@因为我也想知道，她究竟是因为什么而快乐。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":100}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_04","textHome":"只要和她在一起……我就会受伤，为什么会@变成这样？"}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_50_38","textHome":"到了夏天，调整屋里就有股奇怪的味道。@但是御魂坚持说“哪有什么怪味啦”。"}]},{"autoTurnFirst":2.0,"chara":[{"id":302900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":100}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_39","textHome":"在游泳部练习的时候，心来参观了。@好像是想看专心游泳的我，真奇怪啊……@不过，我倒是没什么意见。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":302900,"motion":100}]}],"group_32":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_50_40","textHome":"心帮忙选了适合我的泳装，但我已经有了，@所以最后没买。心看起来很不满意的样子……"}]},{"autoTurnFirst":5.7,"chara":[{"id":302900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":200}]}],"group_33":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_50_41","textHome":"都是一模一样的泳装和泳帽，@按说是很难分清游泳部的人的，@她却一下就找到我了。怎么做到的呢？"}]},{"autoTurnFirst":3.7,"chara":[{"id":302900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":300}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_42","textHome":"迎战，仅此而已。"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_43","textHome":"怎么样？胜利是否愉快呢？"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_44","textHome":"这种时候，感到高兴才是正确答案吧。"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_45","textHome":"好在守住了。"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_46","textHome":"现在的心情……要怎么表达出来呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_63","textHome":"不消灭你，誓不罢休。"}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_05","textHome":"第一次开始考虑未来了。虽然我也不明白@为什么会变成这样。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_64","textHome":"并非什么乐事。把它结束掉吧？"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_65","textHome":"总在重复同样的行动，很无趣吧？"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_66","textHome":"也许是改变场面的一击。"}]}],"group_43":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_02","textHome":"加贺见真良，十六岁，高中一年级。身高@162cm，是魔法少女。……除了这些客观@数据，我就没别的可说了。"}]},{"autoTurnFirst":6.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_13","textHome":"我想变的更强。因为前方说不定有能让我心动@的东西。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1}]}],"group_6":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":400,"pos":1,"voice":"vo_char_3029_00_14","textHome":"嗯，感到了充实。跟喜悦……可能还有一些@区别。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_15","textHome":"也许有意去寻找的时候，才更容易心动吧。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"id":302900,"motion":100}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_16","textHome":"虽然并没有像是“想打破记录”之类的热情…@…但我还是喜欢游泳。因为在只有气泡声的@水中，神秘且让人心情舒适。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_17","textHome":"举例自己擅长又喜欢的科目的话，现代文吧。@因为我觉得了解人的心理，有可能成为@改变日常的契机。"}]},{"autoTurnFirst":7.2,"chara":[{"id":302900,"motion":1}]}]},"version":3}