{"story":{"group_1":[{"autoTurnFirst":2.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_01","textHome":"我叫环忧，其实才刚刚成为魔法少女。@还有，因为一直住院，有很多事情不太懂。@可能会多麻烦你，希望你不要介意。@啊，其实我的姐姐也是魔法少女来着，@下次介绍给你哦。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":5.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_10":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_17","textHome":"虽然我看上去很开朗阳光，@但住院的时候还是哭了很多次……@但是，不要告诉姐姐哦。@总感觉她也会伤心的……"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":101500}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":100}]}],"group_11":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_18","textHome":"虽然只是些许，但我感受到了。@姐姐在学校，好像也有很多难事。@但我不说，这件事就藏在我心里吧。"}]},{"autoTurnFirst":5.0,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_19","textHome":"收到大家的力量……@我会把它合为一体发射出去！"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":101500}]}],"group_13":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_20","textHome":"先不说魔法少女，得先适应外面的生活才行。@"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]}],"group_14":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_21","textHome":"右左右，绿灯！嗯，我在学习交通规则！@但是，还是有点吓人。@城市里有好多车辆会朝人撞过来啊。"}]},{"autoTurnFirst":0.7,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"id":101500,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":300}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_22","textHome":"现在的目标是，帮上大家的忙。@不要吵架，好好相处，一起歌唱与欢笑。@虽说这话有点太理想了，但我真的想做到！@关于这一点，我就和姐姐一样的顽固了。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]}],"group_16":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_23","textHome":"认识了许多人，了解到人与人之间的差别。@人们要同心协力是一件非常困难的事情……@但是，就算明知如此，也不能放弃。@只要抱持希望，人与人就能携起手来。"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":101500,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_50_24","textHome":"太好了，差一点就迟到了，还好赶得上！@姐姐她们已经先走了，快点一起追上去吧。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]}],"group_18":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_50_25","textHome":"我回来啦。@哼哼，这些鱼是在防波堤上拿到的。@早起遇到了在钓鱼的人，分了一些给我哦。"}]},{"autoTurnFirst":1.5,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"id":101500,"motion":1}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_50_26","textHome":"锵锵！午饭是我和姐姐做的特制便当！@看嘛看嘛！@都是像梅渍藕片这样不容易变质的食物哦！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":1}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_02","textHome":"我叫环忧。诶……谢谢你选中我！我很开心！@为了大家的笑脸，我会努力战斗的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":3.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":101500,"motion":100}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_50_27","textHome":"怎么说呢，夏天沉入海面的夕阳虽然漂亮，@却也有点可怕……@太过漂亮和鲜艳，就好像要把人带走一样……"}]},{"autoTurnFirst":9.0,"chara":[{"id":101500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101500}]}],"group_21":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_50_28","textHome":"沙沙作响、叽叽喳喳……@夏天的声音混杂在一起，@就像音乐一样，听起来很放松。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":5.5,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":101500,"motion":300}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_50_29","textHome":"除了去海边游泳，夏天还有很多想玩的！@游泳池啦、远行啦、烟花大会，还有夏季合唱，@想都想不完！"}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":101500,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0}]}],"group_23":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_50_30","textHome":"这个……嗯，我认真学过所以能认出来。@是魔女的反应吧？@为了不败坏大家快乐的暑假，@快点打败它吧。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500}]},{"autoTurnFirst":3.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":101500,"motion":200}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_50_31","textHome":"去无尽镜界的时候，@偶尔会看见穿泳装的魔法少女。@虽然很好奇有谁，但窥探别人不好意思的事，@是不好的吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101500}]}],"group_25":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1015_50_32","textHome":"哇，在沙滩边聚集起来的人，@是来参加水球大会的吧？@一边要努力不沉下去，一边又要竞技，@好厉害啊……"}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]}],"group_26":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_041.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_50_33","textHome":"呼——休息一下，喝点茶吧。@放了很多冰，变得冰冰凉凉的，@肯定很好喝。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_50_34","textHome":"虽然宇宙才是无穷无尽的，@但海洋也相当没有尽头了……@在这压倒性的广阔面前……@我就像一粒沙子……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101500}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101500,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1015_50_35","textHome":"哇，这片贝壳超漂亮！@啊，再收集好多然后用来做装饰品吧。@可以做出可爱的发夹之类的，哼哼。"}]},{"autoTurnFirst":0.5,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":2.7,"chara":[{"id":101500,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_29":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_50_36","textHome":"那个，不知道我能不能鼓起勇气走进海里，@千万不要放手啊。@一点点……一点点地让我习惯一下……@拜托啦！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":101500,"motion":100}]}],"group_3":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_03","textHome":"我能做到什么呢？@我又想成为什么样的人呢……"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101500}]}],"group_30":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_50_37","textHome":"我跟你说，最近大家一起去吃流水素面了。@但是我想夹的时候，面就滑溜溜地躲开了……@下次的目标就是捉住它。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_50_38","textHome":"这香味，是我最喜欢的那个~@虽然说出来可能有点奇怪，@但蚊香的气味会让我放松的。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":1.5,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_32":[{"autoTurnFirst":1.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_50_39","textHome":"诶嘿，这件泳装，是和姐姐一起买的。@作为第一件泳装，是我的宝物哦！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1015_50_40","textHome":"这张是大家一起拍下的纪念照，@仔细看就发现，@八千代姐姐真是又高挑又漂亮啊！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_34":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_50_41","textHome":"呼——好舒服。淋浴把身上的沙子冲掉了。@总感觉到海里泡过之后，@头发就变得毛毛糙糙的不像自己的了。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101500,"motion":300}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_42","textHome":"全部吸收掉哦！"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_43","textHome":"姐姐，我也能打败敌人了！"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_44","textHome":"嗯，能力状态稳定！"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_45","textHome":"谢谢你，燕子！"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_46","textHome":"是不是能帮上忙了呢？"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_04","textHome":"太好啦。@这样三日月别墅的大家就都能友好相处啦。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_63","textHome":"大家，借与我力量！"}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_64","textHome":"变成照亮未来的光吧！"}]}],"group_42":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_65","textHome":"穿透天空。"}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_66","textHome":"Luce Speranza！"}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_05","textHome":"这就是我的未来。@从今天开始就要认真努力。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0}]}],"group_6":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_13","textHome":"虽然看上去没变……但其实有变化了。@感觉身体里暖洋洋的。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_7":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_14","textHome":"因为我还很弱，所以不能就此满足。@还要更加努力才行呢。"}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":1,"id":101500}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1015_00_15","textHome":"要说有意思的话，那我……@啊，想到一个了！"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]}],"group_9":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_16","textHome":"像是出院之后读哪所学校，@姐姐告诉我的事情，我都会记在本子上。@这件事有点害羞，要保守秘密哦？"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":200}]}]},"version":3}