{"story":{"group_1":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_00_01","textHome":"啊，那个……我是夏目佳子！很喜欢看书……@无论何时何地都会看书！只要是有趣的我都@会看！昨天看了本推理小说，标题是「 弗氏@飞鼠杀人事件」！我很推荐，还请你一定要@看看！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301150}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301150}]},{"autoTurnFirst":0.7,"chara":[{"cheek":1,"face":"mtn_ex_022.exp.json","id":301150}]},{"autoTurnFirst":1.6,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301150}]},{"autoTurnFirst":1.9,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":2.9,"chara":[{"id":301150,"motion":100}]},{"autoTurnFirst":4.9,"chara":[{"id":301150,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":301150,"motion":200}]}],"group_10":[{"autoTurnFirst":4.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_18","textHome":"……啊！这里是……现实对吧！？我，看书看得@太入迷了，感觉就像进入了故事中一样……@真的如同身临其境……"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"id":301150,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":301150,"motion":400}]}],"group_11":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_00_19","textHome":"真没想到我竟然能做到这一步……@我也吓了一跳！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301150,"motion":400}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_00_20","textHome":"说不定，我……可能领悟了什么！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301150}]},{"autoTurnFirst":2.0,"chara":[{"id":301150,"motion":400}]}],"group_13":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_00_21","textHome":"实际上我自己也在写小说。虽然只写了一半，@但一直没有停笔。不过读和写差距很大……"}]},{"autoTurnFirst":4.4,"chara":[{"id":301150,"motion":100}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301150}]},{"autoTurnFirst":1.4,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301150,"motion":200}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301150}]}],"group_14":[{"autoTurnFirst":3.2,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_22","textHome":"听我说！我写好了！小说！虽然只是短篇小@说，但是是完成了的！一开始写起来好苦恼，@后半段就一气呵成了。这就是所谓的「浑然@忘我」的状态吧？"}]},{"autoTurnFirst":1.4,"chara":[{"id":301150,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":301150,"motion":1}]},{"autoTurnFirst":1.8,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":1.3,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":301150}]},{"autoTurnFirst":3.4,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":301150,"motion":1}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":1,"pos":1,"voice":"vo_char_3011_00_23","textHome":"我将来的梦想，就是继承夏目书房，然后作为@作家出道！……要是能这样就好了……但哪会@这么顺利呢？这个梦要是能做下去就好了~！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301150,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":301150,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":301150,"motion":300}]}],"group_16":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":200,"pos":1,"voice":"vo_char_3011_50_24","textHome":"好巧，竟然会在这里遇见你！……那个，你在@看什么呢？……我、我的衣服!?有哪里…@…奇怪吗？"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301150,"motion":300}]}],"group_17":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":1,"pos":1,"voice":"vo_char_3011_50_25","textHome":"呼……呼……啊呜啊呜……啊？诶、诶……已@经早上了吗……没关系，妖怪们这个点都在@睡觉，所以不用起床……呼——"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":301150}]},{"autoTurnFirst":5.0,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":301150,"motion":100}]}],"group_18":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_26","textHome":"我和妈妈一起做了南瓜布丁……！上面还有用@南瓜皮雕刻的蝙蝠哦。你要不要作为午后甜@点来一个呢？"}]},{"autoTurnFirst":5.0,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":301150,"motion":1}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_50_27","textHome":"这个时间的商店街，真是不可思议啊。来买东@西的客人，还有来要糖果的妖怪。就像是梦@和现实的混合一样！"}]},{"autoTurnFirst":5.6,"chara":[{"id":301150,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":301150,"motion":200}]}],"group_2":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_00_03","textHome":"那个人到底是谁？我有种不好的预感……"}]},{"autoTurnFirst":3.0,"chara":[{"id":301150,"motion":300}]}],"group_20":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":200,"pos":1,"voice":"vo_char_3011_50_28","textHome":"要稍微通通风吗？我要开窗啦。……哈啊～虽@然有点冷，但风好舒服。……阿嚏！对、对@不起……"}]},{"autoTurnFirst":3.7,"chara":[{"id":301150,"motion":0}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301150}]},{"autoTurnFirst":1.4,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301150,"motion":200}]}],"group_21":[{"autoTurnFirst":0.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_50_29","textHome":"听了衣美里的提议，我们举行了万圣节派对。@我们穿的服装，也根据队伍作了区分。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":301150}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":4.1,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"id":301150,"motion":100}]}],"group_22":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_50_30","textHome":"到时间了……那么，出发吧！那个，请你好好@跟在我身后！我一个人到处要糖果的话，有@些不安……"}]},{"autoTurnFirst":3.2,"chara":[{"id":301150,"motion":0}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"id":301150,"motion":1}]}],"group_23":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":1,"pos":1,"voice":"vo_char_3011_50_31","textHome":"要去无尽境界？现在吗？明、明白了，我也要@去……！只不过……我能换件衣服吗？因为@这件衣服对我来说很珍贵……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":400}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301150}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":1,"pos":1,"voice":"vo_char_3011_50_32","textHome":"呀啊啊啊!?……诶诶？是魔法少女吗……？@哈啊……吓死我了……我还以为是一大群僵@尸，腿都吓软了……"}]},{"autoTurnFirst":3.0,"chara":[{"id":301150,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":301150,"motion":400}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_33","textHome":"万圣节的主题色也有着特殊意义哦。橘色代表@了「秋天的收获」，黑色代表着「冬日的长@夜」。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":301150,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":3.0,"chara":[{"id":301150,"motion":1}]}],"group_26":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":200,"pos":1,"voice":"vo_char_3011_50_34","textHome":"这附近的拉面店，似乎今天也推出了万圣节版@的。眼球一样的卤蛋，还有血液汤之类的…@…呜呜，光是想想就感觉好恐怖……"}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"id":301150,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301150,"motion":300}]}],"group_27":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_35","textHome":"……是这个吗？这是魔法帽形状的书签。把帽@子的前端，像这样……看！可以挂在书页的@一端哦。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150}]},{"autoTurnFirst":4.2,"chara":[{"id":301150,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":301150}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_36","textHome":"要说以万圣节为主题的书，那就是《南瓜派去@了哪里？》！对我来说派又是什么呢……读@完之后让我思考了好久……"}]},{"autoTurnFirst":3.0,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":301150,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":4.0,"chara":[{"id":301150,"motion":200}]}],"group_29":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":1,"pos":1,"voice":"vo_char_3011_50_37","textHome":"我来介绍一下大家的万圣节衣服吧……晶是巫@女，美雨是僵尸，七夏是吸血鬼，我还和大@家拍了照哦！"}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":301150,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":4.4,"chara":[{"id":301150,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":301150,"motion":400}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_00_04","textHome":"这这这这这是哪里！？谁来帮帮我！"}]},{"autoTurnFirst":0.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301150}]},{"autoTurnFirst":2.3,"chara":[{"id":301150,"motion":400}]}],"group_30":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_38","textHome":"我想把从枫那里拿到的南瓜做成杰克南瓜灯。@制作方法……我看过书了没问题！……大概@……"}]},{"autoTurnFirst":3.6,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":300}]}],"group_31":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_39","textHome":"在做这件衣服的时候，设计时的想法没办法整@合到一起，很让人苦恼……幸好有小圆她们@帮忙，真的很感谢她们！"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"id":301150,"motion":100}]}],"group_32":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_50_40","textHome":"哇啊!?菲莉希亚还有菖蒲冷静一点！那件衣@服再拉的话就要撕破了，牛先生会哞——哞@——哭的哦!?"}]},{"autoTurnFirst":3.3,"chara":[{"id":301150,"motion":400}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301150,"motion":200}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":0,"pos":1,"voice":"vo_char_3011_50_41","textHome":"不给糖就捣——乱！要是不给我糖果的话，我@可要恶作剧了。不过……我不太擅长恶作剧@……所以，给、给我糖果。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301150,"motion":400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301150}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301150,"motion":200}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301150,"motion":300}]},{"autoTurnFirst":0.9,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301150,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"id":301150,"motion":400}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_00_42","textHome":"鼓起勇气前进……！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_00_43","textHome":"……哈啊~！似乎胜利了……"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3011_00_44","textHome":"总算是画上了休止符……"}]}],"group_37":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_45","textHome":"下回待续……是这样的吧！"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_46","textHome":"可喜可贺可喜可贺！"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_63","textHome":"我要以我的方式竭尽全力！"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301150,"motion":400,"pos":1,"voice":"vo_char_3011_00_05","textHome":"……啊啾！呜呜，总感觉背后一凉……"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301150}]},{"autoTurnFirst":3.9,"chara":[{"id":301150,"motion":300}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":100,"pos":1,"voice":"vo_char_3011_00_64","textHome":"这招如何——！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301150,"motion":400}]}],"group_41":[{"autoTurnFirst":1.4,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":200,"pos":1,"voice":"vo_char_3011_00_65","textHome":"让我来为这一卷写上结尾吧！"}]},{"autoTurnFirst":1.6,"chara":[{"id":301150,"motion":400}]}],"group_42":[{"autoTurnFirst":1.7,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":301150,"motion":300,"pos":1,"voice":"vo_char_3