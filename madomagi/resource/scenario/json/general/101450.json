{"story":{"group_1":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_01","textHome":"柊音梦，平时仅仅是个编织故事的魔法少女。@只会和合得来的人在一起，也算是随缘吧。@试着聊聊天可能会合得来吧。@啊，但是我说的话题可能没什么有趣的。@因为最近都一直在住院。"}]},{"autoTurnFirst":4.5,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":4.7,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":100}]}],"group_10":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_17","textHome":"人生幸福的秘诀，乃是怀着喜悦接受变化。@有这句话在心里，出院之后突然变大的世界@我也能安然接受了。"}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":6.3,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":100}]}],"group_11":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_18","textHome":"有人说，幸存下来的种子，@并非最强也非最有智慧，而只是最适应变化。@但我要否定这句话。"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.7,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":200}]}],"group_12":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_19","textHome":"我的故事要浮出水面了。@比以往更加鲜明和热烈。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":400}]}],"group_13":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_20","textHome":"心如明镜。@感觉我能写出比平时更加优美的文字了。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":0}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_21","textHome":"嗯哼，有点飘飘然了。@可以写出点震惊读者的短篇来。@真想让读者能享受阅读啊。"}]},{"autoTurnFirst":6.4,"chara":[{"id":101400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":300}]}],"group_15":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_22","textHome":"就按这个步伐，把我的故事传播到全世界。@我想让全世界的人都认可我。@但就算拥有知识，我所走过的世界还是太小，@我还想往故事里塞进更多让人感兴趣的情节。"}]},{"autoTurnFirst":6.2,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":7.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]}],"group_16":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_23","textHome":"是否有面向世界的必要呢……@是否有被世界所知道的必要呢……@事到如今，我为自己曾经@说过这种幼稚的傻话而感到害羞。但好在，@我发现了真正重要的东西，心情也舒畅了。"}]},{"autoTurnFirst":8.2,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_24","textHome":"啊……抱歉，瞭望着大海，@不小心就失去表达能力了……@换做在海滨公园看到的海，@就完全不是这样的表情。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400}]},{"autoTurnFirst":7.5,"chara":[{"id":101400,"motion":1}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_25","textHome":"我回来了。@为了体验清晨的香气和海浪的声音才来的。@趁现在各种感觉还留有余韵，@就用文字表现一番吧。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":101400,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_26","textHome":"咸味的食物我比较喜欢朴素的。@特别是这家的海鲜拉面可以称之为无与伦比。@不过，可能是因为在这里吃才会觉得好吃吧。"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":101400,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_2":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_02","textHome":"我是柊音梦，来帮你了。萍水相逢前世缘，@偶尔也会觉得该做点奇妙的事情了。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_50_27","textHome":"爱情、友情、别离、誓言，@与夕阳下的海相称的场景太多了。@因为这里汇集着太多唤起感情的要素了。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":6.0,"chara":[{"id":101400,"motion":100}]}],"group_21":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"tear":1,"voice":"vo_char_1014_50_28","textHome":"呜啊啊……平时这个时间还不会困的，@今天好像已经累了。凉爽的风拂过温暖的身体，这@样就让人想睡了。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":8.0,"chara":[{"id":101400,"tear":0}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":0}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_50_29","textHome":"雄伟的山脉，广阔的大海，@以及照耀一切的太阳。@身处自然之中就会感受到自身的渺小。@我能理解过去的人们为什么将其崇拜。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_50_30","textHome":"哪里都有魔女啊……@嘛，既然我们来到这片海边，@找到魔女也是理所当然了。@首先，负起打扰我们兴致的责任吧。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":200}]}],"group_24":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_31","textHome":"穿着泳装去无尽镜界，@只能认为是脑子不对吧。@看到自己穿着泳装在镜界里徘徊这种事，@容我拒绝。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":100}]}],"group_25":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_50_32","textHome":"虽然在身边发生的争斗，@尤其是魔法少女同伴之间的争斗，@是我极力想回避的……@稍微换下衣服，能等我一下吗？"}]},{"autoTurnFirst":8.0,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":100}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_33","textHome":"嗯？只是一边休息一边在阴凉处读书而已。@玩了一会儿，感觉就满足了。@现在就远远地看着她们玩吧。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"id":101400,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":0}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_50_34","textHome":"像这样的海，少不了妖怪之类的怪谈吧。@不过我更偏好杀人事件。@这次谁会第一个成为牺牲品呢……呵呵。"}]},{"autoTurnFirst":5.5,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400}]}],"group_28":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_35","textHome":"和医院中见到的夏日景色完全不一样。@耀眼的明暗对比和过于鲜艳的颜色，@仿佛要把眼前的景色镌刻在我的视网膜上，@以及我的心中……"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":101400}]}],"group_29":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_50_36","textHome":"嗯~还是做不好。好像我没什么造型的灵感。@本来想堆个沙城堡的，@但是没法像漫画里堆得那么好。"}]},{"autoTurnFirst":8.0,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":101400,"motion":100}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_03","textHome":"要创造的话，首先就是大家的安身之地吧……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101400}]}],"group_30":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_50_37","textHome":"远远看着大家玩烟火的样子，@就如同暗夜中绽放的花朵，@溅起了点点光辉。"}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":3.2,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":400}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_38","textHome":"现在的我，看上去如何？@在涛声与虫鸣之间，@于稿纸上笔走龙蛇，@是否宛如一位文豪呢？有一点憧憬呢。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400}]}],"group_32":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_50_39","textHome":"嗯！嗯……吃刨冰……吃得头疼。@呼……感觉就好像头被夹了。@但是，炼乳和红小豆太好吃了，还要……@啊呜。嗯——"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]}],"group_33":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_50_40","textHome":"至少这个瞬间，是让我无所适从的幸福。@这是从深渊当中挣扎上岸的我们才能理解的，@身为人的幸福。"}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":0}]}],"group_34":[{"autoTurnFirst":7.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_50_41","textHome":"因、因为是第一次穿泳装，是妈妈帮我选的。@以前从没有一起去买过东西，@这件回忆本身就是宝物……@嗯，我是这样想的。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101400,"motion":300}]},{"autoTurnFirst":4.1,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":1.1,"chara":[{"eyeClose":1,"id":101400,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_42","textHome":"在这里，也留下我的足迹吧。"}]}],"group_36":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_43","textHome":"这样就完结了。"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101400}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_44","textHome":"结果是对面就此封笔了呢。"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":400,"pos":1,"voice":"vo_char_1014_00_45","textHome":"我的故事，可没有什么终结。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_46","textHome":"创造，是为了全体。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_04","textHome":"我希望人们，@能够知晓这些被献出的生命"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_63","textHome":"寄宿在我脑中的创造之子们。"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_64","textHome":"现在正是在广大的世界中留下脚印的机会。"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":400,"pos":1,"voice":"vo_char_1014_00_65","textHome":"来欣赏这场盛大的狂欢吧。"}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_66","textHome":"欢迎回来，位置留好了。"}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_05","textHome":"虽然很孤单，@但我绝不是不幸的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_6":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_13","textHome":"感受到自己的成长真是奇妙。@身体当中洋溢着温暖。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]}],"group_7":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_00_14","textHome":"我得到了足以用故事掩埋世界的能力。@当然这只是个比喻。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_8":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_15","textHome":"我的人生又翻开了一页。来看看吧。"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":101400,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101400,"motion":100}]}],"group_9":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_16","textHome":"对于人类，不幸、贫困、疾病是必要的。@否则人类就会马上骄傲自满起来。@住院时我想到了这句话，@于是把它认为是必要的考验了。"}]},{"autoTurnFirst":4.1,"chara":[{"id":101400,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":300}]}]},"version":3}