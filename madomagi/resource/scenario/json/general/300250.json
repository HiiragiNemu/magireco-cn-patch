{"story":{"group_1":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_00_01","textHome":"我是空穗夏希！啦啦队部和棒球部的部员！@当然了，我并不是棒球部的选手，而是经理。@我和棒球部的大家从小学起就认识了……@和最喜欢的大家打成一片，最幸福了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":5.0,"chara":[{"id":300250,"motion":100}]}],"group_10":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":200,"pos":1,"voice":"vo_char_3002_00_18","textHome":"我能抬头挺胸说出来了。@我靠着自己的努力……才来到了这里。@靠自己努力取胜，真的特别开心！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":300250,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":200,"pos":1,"voice":"vo_char_3002_00_19","textHome":"GO FOR IT！我还能变得更强！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_00_20","textHome":"试着踏出一步……@说不定就能遇见新的幸福了。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_13":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100,"pos":1,"voice":"vo_char_3002_00_21","textHome":"Let's Go！夏希！想快点试试@自己变强了多少呢！遇到不利的战斗@也不会胆怯！我会挺起胸膛上场！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]}],"group_14":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100,"pos":1,"voice":"vo_char_3002_00_22","textHome":"WE CAN DO IT！@就算是魔法少女的战斗，加油声也有着巨大的@能量，和棒球比赛不是一样嘛？所以，作为@魔法少女的时候，我也会全力为大家加油的！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300250,"motion":3}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":1,"pos":1,"voice":"vo_char_3002_00_23","textHome":"YES！VICTORY！！@感受到满满的能量了吗？如果魔法少女也有@世界大赛的话，我一定会赢的！我可不是只会@加油的魔法少女，也能作为选手大显身手！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":300250,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_16":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":200,"pos":1,"voice":"vo_char_3002_50_24","textHome":"不给糖就捣乱！嘿嘿——是不是吓了一跳？虽@然这跟平常的加油不一样，但我可是倾注了@感情，你要好好接下哦？"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_17":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":1,"pos":1,"voice":"vo_char_3002_50_25","textHome":"早上好！因为是万圣节，就稍微有些大意了吧@？没关系！我也和你一样，开心的忘乎所以@了呢！"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":300}]}],"group_18":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_50_26","textHome":"午餐到！今天的午饭，我做了土豆蛋糕。因为@就是把煮过的土豆捣烂了再烤，所以做起来@很简单！"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":0}]}],"group_19":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":400,"pos":1,"voice":"vo_char_3002_50_27","textHome":"啊，那边！看，是正好在到处要糖果的孩子们@。是小学生吧？不要害羞，加油！"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300250}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_2":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_00_03","textHome":"因为梦想已经实现了。所以我不会后悔哦？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]}],"group_20":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":300,"pos":1,"voice":"vo_char_3002_50_28","textHome":"夜深了呢～真正的妖怪也差不多该活跃起来了@吧？嗯，我？我当然要睡了！明天啦啦队还@有晨练。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300250,"motion":301}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":100}]}],"group_21":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":300250,"motion":300,"pos":1,"voice":"vo_char_3002_50_29","textHome":"那件万圣节服装看起来很难做……好，那我也@来帮忙吧!?我们两个人的力量加起来……@一定能做到！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250}]},{"autoTurnFirst":2.6,"chara":[{"id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_22":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_50_30","textHome":"噢，不知不觉该我击球了！……嗯，差不多该@领先到结束了！好，看我全垒打！"}]},{"autoTurnFirst":2.5,"chara":[{"id":300250,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":200}]}],"group_23":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":1,"pos":1,"voice":"vo_char_3002_50_31","textHome":"不管穿什么衣服，我都会全力应援的！上吧—@—大家！加油！战斗不要焦急！"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":100}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_char_3002_50_32","textHome":"让大家拿出气势，就是只有我才能做到的任务@。就让你见识一下啦啦队的真本事吧，要做@好觉悟哦!?"}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":300250,"motion":301}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":300250}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]}],"group_25":[{"autoTurnFirst":2.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":400,"pos":1,"voice":"vo_char_3002_50_33","textHome":"明晚的派对我一定会去！在比赛之前，有一场@解密活动，参与奖是糖果，优胜奖是棒球赛@内场券哦！"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250,"motion":200}]}],"group_26":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":400,"pos":1,"voice":"vo_char_3002_50_34","textHome":"啊！这个……好怀念。这张照片，是和哥哥一@起扮装时候拍的。哥哥扮成了面包，我扮成@了香肠！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":5.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":300250,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250}]}],"group_27":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300250,"motion":200,"pos":1,"voice":"vo_char_3002_50_35","textHome":"没问题吗？就算是节日，也不能吃那么多的糖@果！别看我这样，啦啦队也是很辛苦的运动@，控制体重可不能马虎！"}]},{"autoTurnFirst":4.3,"chara":[{"id":300250,"motion":0}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":1}]}],"group_28":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300250,"motion":301,"pos":1,"voice":"vo_char_3002_50_36","textHome":"啦啦队，也试着加入一些万圣节元素怎么样？@用南瓜一样的彩球，或者背后戴上蝙蝠翅膀@之类的，开玩笑的啦！"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":300250,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300250,"motion":300}]}],"group_29":[{"autoTurnFirst":2.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300250,"motion":100,"pos":1,"voice":"vo_char_3002_50_37","textHome":"……快看，快看！要上喽……咻……抓住！接@下来是旋转两圈！然后抓住！怎么样怎么样@？我的舞棒，很拿手吧？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300250,"motion":400}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300250,"motion":400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300250,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300250}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":300250,"motion":0,"pos":1,"voice":"vo_cha