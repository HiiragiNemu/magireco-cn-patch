{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_01","textHome":"我是天音月咲！嗯，要简洁地介绍清楚的话，@我是月夜的双胞胎妹妹，平时在工匠区的@一家竹工房，随父亲和学徒们生活。@且不说家里全是男性，把家务都丢给我是什么@意思啊！最近因为这个有些生气……诶嘿。"}]},{"autoTurnFirst":12.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_18","textHome":"太好了！终于有了新家伙……@心心念念的电动车到手了！@靠它就能从繁重的家务里稍微解放出来了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":101900,"motion":300}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_19","textHome":"我的笛声，还要传得更远！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101900,"motion":100}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_20","textHome":"这样我就能更好地支持月夜姐姐啦！"}]},{"autoTurnFirst":1.5,"chara":[{"id":101900,"motion":100}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_21","textHome":"爸爸挺可怕的……但是能靠笑容@让周围的人振作起来这点值得尊敬。@我也是靠笑来冲淡难过的哦。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_22","textHome":"月夜姐姐总是在忍受着各种事情吧？@所以我呢，会像这样笑着和她相处。@只要我这样充满活力的样子，@能让月夜姐姐的忍耐好受一些，@哪怕只有一点也好，我都会很开心。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_23","textHome":"只要微笑着面对，从这束缚中解脱出来，@就能变得幸福了。正因为相信着这些，@我才会这样朝着目标努力。因为，说过了吧？@笑门开幸福来……对吧。"}]},{"autoTurnFirst":5.5,"chara":[{"id":101900,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_51_24","textHome":"圣诞快乐！我家天音竹工房也摆着圣诞树形的@竹工艺品在庆祝呢！"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_51_25","textHome":"早！我要准备早餐，所以哪怕是圣诞节也要充@满精神地微笑着早起！圣诞老人当然要会笑@了。"}]},{"autoTurnFirst":6.0,"chara":[{"id":101900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":100}]}],"group_18":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_51_26","textHome":"啊，要一起吃便当吗？今天把黄瓜切成了圣诞@树的形状哦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]},{"autoTurnFirst":3.5,"chara":[{"id":101900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":200}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_51_27","textHome":"能顺利赶上今天的派对就好了……要是被工房@的学徒们发现了肯定要坏事，偷偷溜走才行@……"}]},{"autoTurnFirst":4.5,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":101900,"motion":200}]}],"group_2":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_03","textHome":"在肉店排队的是……七海八千代……"}]}],"group_20":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_51_28","textHome":"难得的圣诞节，我也有一个小愿望交给圣诞老@人……请让我明天还能再见到月夜姐姐吧…@…！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]}],"group_21":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_51_29","textHome":"圣诞节嘛。穿了和月夜姐姐组成一套的圣诞服@。真期待一起去派对的时候啊！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":101900,"motion":300}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":200,"pos":1,"voice":"vo_char_1019_51_30","textHome":"哎哎，该走去退治魔女了！诶，圣诞服有什么@问题吗？又不会就穿这样去战斗，当然没问@题啊！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_23":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_51_31","textHome":"连镜之魔女的结界，也有穿圣诞服的复制品了@。可是连泳装和万圣节的人都混进去了，一@点季节感也没有。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":101900,"motion":300}]}],"group_24":[{"autoTurnFirst":4.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_51_32","textHome":"呜……外面好冷啊……！比起面对另一队，还@是走出家门最需要勇气啊。"}]},{"autoTurnFirst":7.0,"chara":[{"id":101900,"motion":1}]}],"group_25":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_51_33","textHome":"啊，这件衣服？当然是我自己做的了。为了能@和月夜姐姐配成一对，可是想了很多才做好@的。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_51_34","textHome":"嗯……喜欢的派对食物的话，火鸡？平时没什@么机会吃，看到就忍不住动起手来了。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":101900}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_51_35","textHome":"经常去买肉的那条商业街，好像有张熟悉的脸@……那个穿着圣诞服卖蛋糕的……好像是环@彩羽吧？"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":0}]}],"group_28":[{"autoTurnFirst":6.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_51_36","textHome":"我在感受那绿色的花格子，柔软的皮毛和积雪@的圣诞树呢。而最有魅力的，就是绑着皮带@的雪人吧！"}]},{"autoTurnFirst":2.0,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":100}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_51_37","textHome":"嗯？问我冷不冷？没事，在你看不见的地方塞@满怀炉了。你试试，连手都不冷呢。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":101900,"motion":100}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_04","textHome":"爸爸如果能告诉我就好了……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":300}]}],"group_30":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_51_38","textHome":"朋友让我看了中学生画的漫画《死神少女Ch@ristmas·Death·Calib@ou》的复印本。还挺好看的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0}]}],"group_31":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_51_39","textHome":"诶嘿……美冬夸奖我这身衣服了。她在学校也@是月夜姐姐的前辈，好像有在挂念我们的样@子呢。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":200,"pos":1,"voice":"vo_char_1019_51_40","textHome":"应该不会在派对会场遇上十七夜吧……当初受@着她的照顾，要是现在遇上就尴尬了……"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":300}]}],"group_33":[{"autoTurnFirst":7.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":200,"pos":1,"voice":"vo_char_1019_51_41","textHome":"呜呜……还差一点点就能偷偷溜走了……结果@脖子上的铃铛响了，被阿贵发现了……"}]},{"autoTurnFirst":2.0,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":101900,"motion":300}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_42","textHome":"好，演奏开始了！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_43","textHome":"大家辛苦了！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_44","textHome":"这也是因为我充满了活力！"}]}],"group_37":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_45","textHome":"演奏结束，感谢！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_46","textHome":"就不用再来一曲了吧？"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_63","textHome":"我不喜欢争吵。所以，就用它结束掉吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":200}]}],"group_4":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_05","textHome":"我的同伴仅有月夜姐姐一人，@从今往后都要在一起。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_64","textHome":"为了梦想，牺牲在所难免……"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":200}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_65","textHome":"难道我不能渴望幸福吗!?"}]}],"group_42":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_66","textHome":"忍受至今的心情……就在这一击当中……！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":200}]}],"group_43":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_02","textHome":"我是天音月咲！虽然平时太忙，除了晚上以外@没什么时间，但还是想靠笛声我的笑脸@让大家精神起来，请多指教！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_13","textHome":"不可以辜负努力和活力，还有月夜姐姐！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_14","textHome":"这就是凭着一股锐气，没有被挫败的结果哦！"}]}],"group_7":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_15","textHome":"用笛声做背景音乐如何……@啊，吹笛子的时候说不了话呀。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_16","textHome":"好嘞，有了这自行车，采购就好办了！@前后左右都加上竹篓子，@十人份的食材也能买回来了！"}]},{"autoTurnFirst":6.0,"chara":[{"id":101900,"motion":1}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_17","textHome":"这就是十人份的食材！呼……@要一口气买够男人的食量真是体力活……@但是，我不会输的！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":200}]}]},"version":3}