{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_01","textHome":"我是，五十铃怜……嗯。我……特别@不擅长……说话。那个……不管想说什么……@总是说不好……大概也经常让对方很着急……@嗯。要是那样……真的很抱歉。提、提前说声@对不起…可能比较好……嗯……"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500}]},{"autoTurnFirst":14.5,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":9.0,"chara":[{"id":302500,"motion":1}]}],"group_10":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_18","textHome":"将来的梦想我已经想好了。@我想在文章里稍微放进一些插画……嗯，@这是叫做随笔作家吧？感觉会很好。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_19","textHome":"因为我这条命本该没有了才对……@所以总觉得有种不可思议的感觉……嗯。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":200,"pos":1,"voice":"vo_char_3025_00_20","textHome":"这样的成长……@也是活着的喜悦之一……嗯。"}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_21","textHome":"正因为受了许多人的影响，@我才能活到现在……嗯。@所以，我应该用这被拯救的生命……@去真诚地面对别人。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302500}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":200}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_22","textHome":"这样的我……真的能改变吗……@我还没有什么自信……嗯。@但是……我想成为……不去在意悲伤，@而是细数着喜悦和幸福前行的人，@现在的我真的是这样想的……嗯。"}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":100}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_23","textHome":"我希望能拥有一样可以给我的心@带来光芒的东西，哪怕只有一个也好……@这样，即便有时哭泣……有时后悔……@也能继续活下去。因为，无论是@多么渺小的光亮……也不会被黑暗所抹消。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":302500,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":100}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_24","textHome":"啊，早、早上好……！@嗯……我一直在等你。啊，不、不是的。@没有等很久的意思……嗯……"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":100}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_25","textHome":"我早上吃不了太多……嗯。@每天的早餐……基本都不会吃什么东西……@就算吃……也只吃一块苹果之类的……嗯……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":0}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_26","textHome":"怎么回事呢……？@一个人的时候……就算到了中午……@肚子也一点都不饿……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":1}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_27","textHome":"我喜欢……学习……嗯。@因为……喜欢记笔记。@……诶……但是……@这样不能算……喜欢学习吧……"}]},{"autoTurnFirst":3.7,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1}]}],"group_2":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_03","textHome":"对这个世界绝望了……@那个……这种事要怎么解释呢……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":100}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_28","textHome":"我喜欢……夜里行动。@可以稍微散散步……但是……@家人会训我，说这样很危险……嗯。"}]},{"autoTurnFirst":4.3,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":1}]}],"group_21":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_29","textHome":"学校里面……有一个多媒体教室……嗯。@那里的最后一排……窗边的座位……@是在学校里，最让我安心的地方。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_30","textHome":"是不是……应该出发了呢？@啊！呃……不是的！那个……@没有要逼你出门的意思……！@对……嗯……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500}]},{"autoTurnFirst":2.5,"chara":[{"id":302500,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":200}]}],"group_23":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_31","textHome":"我再也不会……害怕战斗了……嗯。@我……已经是死过一次的人了。@如果还觉得害怕……那就太可笑了……"}]},{"autoTurnFirst":5.5,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":1}]}],"group_24":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":300,"pos":1,"voice":"vo_char_3025_00_32","textHome":"我……很不安。@相比担心输掉……更担心@会拖大家的后腿……嗯……"}]},{"autoTurnFirst":9.0,"chara":[{"id":302500,"motion":1}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_33","textHome":"我喜欢……晴天，嗯。@特别是……春天……还有初夏。@闪耀的阳光……让人感觉到温暖……@也能稍微……打起精神来……"}]},{"autoTurnFirst":10.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":302500,"motion":200}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_34","textHome":"我喜欢……写点文字。@虽然……写不出什么厉害的东西……嗯。@也就是……日记之类的……"}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":100}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_35","textHome":"我……喜欢的就是写下文字的过程……嗯。@因为……你不觉得文字真的很神奇吗？@像是字如其人什么的……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"id":302500,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":1}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_36","textHome":"最近……我会在日记边上，稍微画些画。@所以……在收集彩铅……嗯……"}]},{"autoTurnFirst":4.5,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_37","textHome":"选择自尽的人……是软弱的人吗。@但就算是这样，我还是希望世界可以变成，@能让软弱的人也能活下去的世界……"}]},{"autoTurnFirst":6.5,"chara":[{"id":302500,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"id":302500,"motion":100}]}],"group_3":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_04","textHome":"我第一次……和这么多人说话……嗯。"}]},{"autoTurnFirst":4.2,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_38","textHome":"家人总是说我……脸色很差的样子……嗯。@害羞的时候……@倒是会变得像煮熟了一样红……"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_39","textHome":"我……看上去不太健康吗……？@但是……我身体很好……@很少感冒……平时还会喝姜汤……嗯……"}]},{"autoTurnFirst":9.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":200}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_40","textHome":"我……以前曾想要去死。@但是……却没有死成……@那就是我成为魔法少女的原因……嗯。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":300}]},{"autoTurnFirst":9.5,"chara":[{"id":302500,"motion":1}]}],"group_33":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_41","textHome":"我的魔法少女服……真是奇特呢。@有点和风……又有点像@幽灵的感觉……嗯。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":302500,"motion":1}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302500,"motion":200,"pos":1,"voice":"vo_char_3025_00_42","textHome":"首、首先……！深呼吸……！"}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":302500,"motion":400,"pos":1,"voice":"vo_char_3025_00_43","textHome":"我……！……赢了……嗯！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]}],"group_36":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_44","textHome":"心脏……还是跳得很快……嗯……"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_45","textHome":"因为我还活着……"}]}],"group_38":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_46","textHome":"对！这是……！喜悦的激动……！"}]},{"autoTurnFirst":4.5,"chara":[{"id":302500,"motion":100}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_63","textHome":"希望这个世界能一直温柔下去！"}]}],"group_4":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_05","textHome":"感觉……真的好久没看过……@这么美丽的夕阳了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":302500,"motion":100}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302500,"motion":200,"pos":1,"voice":"vo_char_3025_00_64","textHome":"我想和大家一起过幸福的生活……！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_65","textHome":"要笔直地注视着希望……！"}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_66","textHome":"无论受伤多少次……我都会相信希望……！"}]},{"autoTurnFirst":4.0,"chara":[{"id":302500,"motion":200}]}],"group_43":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":400,"pos":1,"voice":"vo_char_3025_00_02","textHome":"初、初次见面……！@我是……五十铃……怜……嗯。@……啊……对不起……！@我……遇到这种时候……@不知道应该说什么……嗯……。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":1}]},{"autoTurnFirst":7.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":302500,"motion":1}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_13","textHome":"哪怕只是一点点也不要紧，@我想要成长……嗯。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":302500,"motion":1}]}],"group_6":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_14","textHome":"因为激动……心跳也变快了。@我现在是活着的呢。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":302500,"motion":100}]}],"group_7":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":1,"pos":1,"voice":"vo_char_3025_00_15","textHome":"买了新的日记本……嗯。@希望能一直写下去。"}]},{"autoTurnFirst":5.0,"chara":[{"id":302500,"motion":100}]}],"group_8":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":0,"pos":1,"voice":"vo_char_3025_00_16","textHome":"最近，突然……开始考虑以后的事情了……@嗯。因为我本来想去死，@所以是第一次想这些。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302500,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500,"motion":100}]}],"group_9":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302500,"motion":100,"pos":1,"voice":"vo_char_3025_00_17","textHome":"以后……如果……@能找一份写文章的工作就好了……嗯。@……啊！但、但是……！@……还不能告诉别人哦……？"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":302500,"motion":400}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_001.exp.json","id":302500,"motion":1}]}]},"version":3}