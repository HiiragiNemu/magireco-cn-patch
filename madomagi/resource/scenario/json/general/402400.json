{"story":{"group_1":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":0,"pos":1,"voice":"vo_char_4024_00_01","textHome":"我是米诺……为了实现母亲大人的愿望，现在@正在帮忙参与一场战争。眼下烦恼的是，法@兰西的乡村中出现了一位被称为「圣女」的@魔法少女。如果不是她的话，现在法兰西已@经落入我们的手中了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":402400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":402400,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402400}]}],"group_10":[{"autoTurnFirst":8.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_17","textHome":"被国王所抛弃，继续着无谓的抵抗的身姿。挺@身而出帮助同伴的身姿……演员们美丽而又@愚蠢的样子，才是悲剧最棒的调味品。"}]},{"autoTurnFirst":2.8,"chara":[{"id":402400,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402400}]}],"group_11":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_18","textHome":"我有着很多想做成的事……要是说最想做的事@的话，答案就是和那个人永远在一起。"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":7.0,"chara":[{"id":402400,"motion":1}]}],"group_12":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_19","textHome":"这样，就能让舞台更加华丽了吧。"}]}],"group_13":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":100,"pos":1,"voice":"vo_char_4024_00_20","textHome":"哼哼……当一时的主角似乎也不错呢。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_21","textHome":"我的愿望，是献给伟大的母亲大人的。所以，@这得到的崭新力量，我也会为了母亲大人而@使用。"}]},{"autoTurnFirst":3.3,"chara":[{"id":402400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402400,"motion":300}]}],"group_15":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_22","textHome":"哎呀，我本来并不打算自己能够强到这种地步@的……支配这个国家，为母亲的梦想……尽@一份绵薄之力的同时，就让更戏剧的演出能@够上演吧。"}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":100}]}],"group_16":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_23","textHome":"如果管看到之前看不到的东西叫做“成长”的@话，那我现在就是这种状态。哼哼……为了@法兰西存亡而战斗的人做着无谓的努力，看@起来是多么愚蠢，多么的卑微……"}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402400,"motion":200}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_17":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_24","textHome":"新的一天又来临了。计划还在稳步的进行。那@位大人宣告了，“圣女”正朝着命运的那一@天前行……"}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":402400,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402400}]}],"group_18":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":0,"pos":1,"voice":"vo_char_4024_00_25","textHome":"早起祷告，祈求着稀松平常的一天……真是不@错的习惯。正因为有着值得被夺走的平静日@常，悲剧才会更加的精彩……"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":2.5,"chara":[{"id":402400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400,"motion":200}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_26","textHome":"你就好好回味这顿饭吧。这是你能够优雅享用@午餐的最后一天了……呵呵呵，开玩笑的。"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":402400}]}],"group_2":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_02","textHome":"我叫米诺。我有拉比努和可鲁波两位姐姐，是@三姐妹中最小的。而且……我还是“那个人@”的女儿哦？"}]},{"autoTurnFirst":3.0,"chara":[{"id":402400,"motion":200}]},{"autoTurnFirst":3.1,"chara":[{"id":402400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_27","textHome":"……那么，我差不多该告辞了。已经到洗澡的@时间了，在那之后，我也要到那位大人的卧@室里听候指示了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}]}],"group_21":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":0,"pos":1,"voice":"vo_char_4024_00_28","textHome":"夜深时刻，我会安心地在黑夜包围中入睡。然@后不断梦见这罪恶深重的国家被无尽的长夜@所笼罩。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":1}]},{"autoTurnFirst":8.0,"chara":[{"eyeClose":1,"id":402400}]}],"group_22":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_29","textHome":"只要你不采取反抗的态度，我就不会让你吃苦@头。当然你要是胆敢背叛的话，我就会用喜@欢的方式来拷问你。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]},{"autoTurnFirst":6.0,"chara":[{"id":402400,"motion":100}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402400,"motion":0,"pos":1,"voice":"vo_char_4024_00_30","textHome":"你说是消灭魔女的时间了？真有有趣……我们@的工作就是在法兰西散布悲伤之种，释放魔@女……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":200}]},{"autoTurnFirst":3.8,"chara":[{"id":402400,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_24":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":400,"pos":1,"voice":"vo_char_4024_00_31","textHome":"那个镜子延伸的洋馆，不用我亲自前去吧？交@给战斗的侍女们就行了。只要我下命令，那@些人就一定会服从的。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402400,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400}]}],"group_25":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_32","textHome":"就算魔法少女们不互相争斗，那也并不能友好@相处。因为她们早晚都会作为我的棋子，平@等地迎来与世长辞的命运……"}]},{"autoTurnFirst":2.4,"chara":[{"id":402400,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400}]}],"group_26":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_33","textHome":"我的任务就是布置名为战场的舞台。我是不会@胡乱地挥舞武器的。实在万不得已的时候，@就用顺手的拷问用具……鞭子之类的。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":0}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":402400,"motion":200}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400}]}],"group_27":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":100,"pos":1,"voice":"vo_char_4024_00_34","textHome":"……啊呀，你在害怕什么？我也不会吃了你。@我曾经也只不过是个弱小的少女哦？"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":402400,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}]}],"group_28":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_35","textHome":"有人称呼我们为英格兰军的魔法少女……但我@们原本是正宗的法兰西人。我们只不过是利@用他们的力量而已。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402400,"motion":300}]}],"group_29":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402400,"motion":300,"pos":1,"voice":"vo_char_4024_00_36","textHome":"在姐姐们陷入险境的时候，我就会使用空间移@动魔法来帮助她们。我能帮上忙的地方，也@就如此了……"}]},{"autoTurnFirst":4.8,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":7.0,"chara":[{"id":402400,"motion":1}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402400,"motion":100,"pos":1,"voice":"vo_char_4024_00_03","textHome":"本以为会是有趣的杂耍……"}]}],"group_30":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":300,"pos":1,"voice":"vo_char_4024_00_37","textHome":"战斗之后，和姐妹们一起去洗澡的约定……拉@皮努姐姐虽然是随口一说，我倒是很期待呢@。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"id":402400,"motion":200}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_38","textHome":"我的任务就是让“圣女”主演的悲剧装饰上美@丽的血和泪。这也是那位大人……母亲大人@的心愿。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":3.2,"chara":[{"id":402400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402400}]}],"group_32":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_39","textHome":"实现我们姐妹的愿望，让我们变成魔法少女，@都是靠着伟大的母亲大人的力量。这个完全@可以说是带来奇迹的力量了。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":6.0,"chara":[{"id":402400,"motion":100}]}],"group_33":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_40","textHome":"可鲁波姐姐十分爱我和拉皮努姐姐。不过……@她是怎么看母亲大人的呢……？"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402400,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":4.0,"chara":[{"id":402400,"motion":300}]}],"group_34":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":100,"pos":1,"voice":"vo_char_4024_00_41","textHome":"哎呀？真是性急的人呢。你要是这么急迫的话@，我就给你施上魔法的咒印，让你也变成魔@女了哦？"}]},{"autoTurnFirst":4.9,"chara":[{"eyeClose":1,"id":402400,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":6.0,"chara":[{"id":402400,"motion":200}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_42","textHome":"那么……结局该开始了。"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_43","textHome":"看起来是要闭幕了呢。"}]}],"group_37":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":100,"pos":1,"voice":"vo_char_4024_00_44","textHome":"那么就该贵安了……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402400}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_45","textHome":"真是不错的杂技啊。"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_46","textHome":"我想该让我告辞了吧。"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_04","textHome":"啊……真是不错。"}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_05","textHome":"看来还不够让你们快乐呢。"}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_13","textHome":"诶？不是主角的我也得到了力量吗？真是奇妙@的邂逅。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400}]}],"group_7":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1,"pos":1,"voice":"vo_char_4024_00_14","textHome":"我能够变得如此强大，都是拜伟大的母亲大人@所赐。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402400}]}],"group_8":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":200,"pos":1,"voice":"vo_char_4024_00_15","textHome":"请作为我的观众，把表演看到最后吧。"}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402400,"motion":300,"pos":1,"voice":"vo_char_4024_00_16","textHome":"不要给奥尔良有喘息的余地，用来给“圣女”@设下诱饵……这是那位大人直接给出的指示@。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":402400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402400,"motion":1}]}]},"version":3}