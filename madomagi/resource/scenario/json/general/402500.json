{"story":{"group_1":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_01","textHome":"啊？想知道我的事情？我是可鲁波。@是姐姐大人拉皮努的妹妹，米诺的姐姐。@当前的目标，就是抹杀掉法兰西突然出现的@「圣女大人」。那家伙，是我伟大计划的阻碍。@不用姐姐大人和米诺出手，我要解决掉她。"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":7.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402500}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402500,"motion":100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_17","textHome":"听到有个英格兰的将领在那说，@敌军中有绝不能输给的对手什么的……@即便是弱小的人类之间，@有这种对手在也不赖啊。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]}],"group_11":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_18","textHome":"就把我的杀手锏告诉你吧。@我使用的带来黑死病的魔法……@不论敌我，都会平等给予死亡，@是漂亮地将一切破坏，让人绝望的魔法。"}]},{"autoTurnFirst":6.0,"chara":[{"id":402500,"motion":1}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":402500}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_19","textHome":"呵呵…魔法要是强到这种地步，@就没法享受互相厮杀的快感了啊……"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":3.5,"chara":[{"id":402500,"motion":300}]}],"group_13":[{"autoTurnFirst":4.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_20","textHome":"好啊……力量涌了出来。@真想快点和人互相残杀啊。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402500,"motion":100}]}],"group_14":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_21","textHome":"呵呵……真期待这份力量@在下次实战中的表现啊！@拉比努姐姐和米诺就退到后面去，@让我也带着她们俩的份来战斗吧。"}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":4.0,"chara":[{"id":402500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":402500,"motion":200}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_22","textHome":"呵呵……我很开心。@我现在能够彻底守护我爱的人们了。@这下不管对手是谁，都会是单方面的蹂躏了。@可惜我想要的不分伯仲的厮杀啊。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1}]}],"group_16":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_23","textHome":"事到如今，就算是有成百上千的普通士兵，@也没办法成为我的对手。@我的敌人只有魔法少女。@人类就交给人类去解决就行了！"}]},{"autoTurnFirst":3.0,"chara":[{"id":402500,"motion":100}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":402500,"motion":200}]}],"group_17":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_24","textHome":"看来你成功的从昨天活过来了啊。@呵呵，我最喜欢命硬的家伙了。@毕竟要是死了的话，@不就没法愉快地搏杀了么？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":5.8,"chara":[{"eyeClose":1,"id":402500,"motion":300}]}],"group_18":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_25","textHome":"早上好，您贵安？@嘿嘿，你在这吃惊个什么劲？@我好歹也是王宫长大的。@打个招呼还是会的"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":200}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_26","textHome":"饿了的话，就找人做点什么吃的吧？@那位大人赏赐来的侍女们之中，@有擅长制作料理的人。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]}],"group_2":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_02","textHome":"Enchante……初次见面。一直期待着能见到你呢。@我是可鲁波，魔法少女。@简而言之……就是你们的敌人！"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":5.5,"chara":[{"id":402500,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":402500,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_27","textHome":"我差不多也该回要塞了。@毕竟我和拉皮努姐姐还有米诺，@约了要一起沐浴的！"}]},{"autoTurnFirst":5.5,"chara":[{"id":402500,"motion":200}]}],"group_21":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402500,"motion":300,"pos":1,"voice":"vo_char_4025_00_28","textHome":"……今天也够累了啊。@和米诺见面，向英格兰的军队传达指示，@光是战斗准备就花了一天。@真是怀念血的味道啊。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":10.0,"chara":[{"id":402500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402500,"motion":200}]}],"group_22":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_29","textHome":"与“圣女”一块儿的那个黑色玩影子的，@那家伙真是太棒了！@一想到下次能够和她尽情地来回厮杀……@啊啊……真是心跳不止……！"}]},{"autoTurnFirst":2.6,"chara":[{"id":402500,"motion":200}]},{"autoTurnFirst":5.2,"chara":[{"id":402500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"eyeClose":1,"id":402500,"motion":300}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_30","textHome":"差不多该出发了。@不管折腾别人是还是被折腾我都很喜欢。@这次的战斗，要是能遇见@能杀个你死我活的强敌就好了啊……！"}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":402500,"motion":300}]}],"group_24":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_31","textHome":"和魔法少女的复制体战斗的场所……有趣。@管他是真的还是假的，只要能互相厮杀就行。@尽情玩耍就可以了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500}]},{"autoTurnFirst":3.0,"chara":[{"id":402500,"motion":200}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_32","textHome":"虽说是集团战，但我会随自己的意战斗。@友方可别靠近我。@我可不管会不会把你们卷进来！"}]},{"autoTurnFirst":2.8,"chara":[{"id":402500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":402500,"motion":300}]}],"group_26":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_33","textHome":"你有什么事吗？抱歉，我很忙，@需要比试的话，就找那边的侍女吧。@我可先说好，她们都很强。@如果不是魔法少女的话是比不过她们的。"}]},{"autoTurnFirst":3.2,"chara":[{"id":402500,"motion":1}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_34","textHome":"法兰西的圣女大人……她真是不错。@原以为已经把她完全破坏了，@结果却还能复苏又再次阻挡住了我。@这让我想要更加激烈地对待她了啊。"}]},{"autoTurnFirst":2.0,"chara":[{"id":402500,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":402500,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"id":402500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402500}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":400,"pos":1,"voice":"vo_char_4025_00_35","textHome":"……那个白色的可疑的动物到底是什么？@丘卜？没听说过！@说起来圣女那家伙好像称其为天使大人……@哈，真是个有趣的笑话啊！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]}],"group_29":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_36","textHome":"米诺真的是个温柔的妹妹。@明明她不擅长战斗，却会在我危险的时候@用魔法赶来支援我。我总是在给她添麻烦呢。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402500,"motion":300}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_03","textHome":"我的灵魂宝石，从未有一丝浑浊。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]}],"group_30":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_37","textHome":"我虽然和拉比努姐姐还有米诺一样，@不讨厌单方面毁坏弱小的人类。@不过我还是最喜欢@和真正的强敌不留余力地厮杀。"}]},{"autoTurnFirst":1.5,"chara":[{"id":402500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":402500,"motion":200}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_38","textHome":"敌人是魔法少女的话，我不可能会输。@我有着特殊的能力。靠着这个能力，@我的灵魂宝石从没有浑浊过……一次也没有！"}]},{"autoTurnFirst":9.5,"chara":[{"id":402500,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200}]}],"group_32":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_39","textHome":"告诉你一个秘密。@侍女之中也有着能成为魔法少女的家伙。@通过她们的「愿望」，@我们就能得到自身资质以上的力量。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402500,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":200}]}],"group_33":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_40","textHome":"我渴求力量，@是为了保护心爱的拉比努姐姐还有米诺。@但是，要保护那个人……@从命运之中保护母亲大人的话，已经……"}]},{"autoTurnFirst":3.5,"chara":[{"id":402500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402500}]}],"group_34":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_41","textHome":"挑选出有魔法少女资质的侍女，@然后把她带到那个人的屋子时，@其他的侍女似乎都很羡慕呢……@不过，她们是不是搞错了什么？"}]},{"autoTurnFirst":4.8,"chara":[{"id":402500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":402500,"motion":0}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_42","textHome":"好了，开始派对吧！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_43","textHome":"有谁有意见吗？"}]}],"group_37":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_44","textHome":"已经结束了？真没劲。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100}]}],"group_38":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_45","textHome":"你，很有趣啊……我很享受！"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":300,"pos":1,"voice":"vo_char_4025_00_46","textHome":"这扫兴得也是恰到好处啊。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":1,"pos":1,"voice":"vo_char_4025_00_04","textHome":"我要用圣女大人来血祭。"}]},{"autoTurnFirst":2.5,"chara":[{"id":402500,"motion":200}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_63","textHome":"来吧，从此刻开始享受吧"}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":400,"pos":1,"voice":"vo_char_4025_00_64","textHome":"死亡的舞步，尽情起舞吧"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_65","textHome":"看着就好。"}]}],"group_43":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_66","textHome":"死亡之舞"}]}],"group_5":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_05","textHome":"约好了一起去沐浴，@就等我回来后……"}]},{"autoTurnFirst":3.0,"chara":[{"id":402500,"motion":300}]}],"group_6":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":100,"pos":1,"voice":"vo_char_4025_00_13","textHome":"呼呼，有了这份力量……@我就能守护我可爱的姐妹们了。"}]},{"autoTurnFirst":3.2,"chara":[{"id":402500,"motion":200}]}],"group_7":[{"autoTurnFirst":3.6,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":402500,"motion":300,"pos":1,"voice":"vo_char_4025_00_14","textHome":"啊……真是不错。@这样就能让我沉浸在@你死我活的愉悦之中了……"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402500}]},{"autoTurnFirst":6.0,"chara":[{"id":402500,"motion":200}]}],"group_8":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402500,"motion":200,"pos":1,"voice":"vo_char_4025_00_15","textHome":"我很中意你！@真想哪天和你厮杀一场呢"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":1}]}],"group_9":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402500,"motion":0,"pos":1,"voice":"vo_char_4025_00_16","textHome":"你问我擅长的武器是什么？@我不用看着像是武器的东西战斗。@但我可以让羽毛飞出去，@封住敌人的行动！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402500,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402500,"motion":200}]}]},"version":3}