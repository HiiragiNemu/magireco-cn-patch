{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_01","textHome":"呼……哈……冷静下来……得好好做自我介绍@才行……好！我是安积育梦。虽然不太擅长@同时做很多件事情，但我很喜欢做裁缝和编@制这种细致的工作。还有，我在戏剧社负责@服装和小道具的制作。……那个，从今以后@请多多关照……！"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":1.8,"chara":[{"id":103000,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":103000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103000,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":103000}]}],"group_10":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":100,"pos":1,"voice":"vo_char_1030_00_17","textHome":"那个，你平时会用遮盖胶带吗？因为我会不自@觉地买下来，所以总是会突然发现没地方放@了……如果可以的话，希望你能收下一些。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":400}]}],"group_11":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103000,"motion":1,"pos":1,"voice":"vo_char_1030_00_18","textHome":"诶嘿嘿，不自觉地买下来了。小猫和小老鼠的@便签纸。弹弹的样子好可爱……哎？这只小@猫稍微有点像时雨呢。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103000}]},{"autoTurnFirst":3.6,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103000,"motion":400}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":103000}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103000,"motion":300}]}],"group_12":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_19","textHome":"嗯！交给我吧。我会用这份力量打倒魔女的。"}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":100}]}],"group_13":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_20","textHome":"……我知道，不能止步不前的……稍微努力一@下吧。"}]},{"autoTurnFirst":6.0,"chara":[{"id":103000,"motion":1}]}],"group_14":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_21","textHome":"就算成为了魔法少女，我也还是很半吊子。明@明能打赢魔女，却无法守护自己的领地……@但是，我想稍微拿出点勇气努力一下。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":3.6,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":100}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":1,"pos":1,"voice":"vo_char_1030_00_22","textHome":"如果没有魔法少女之间的争斗，我是不是也会@作为“绝对能打倒魔女的人”受到尊敬呢…@…我有时也会靠这种空想逃避。但是，现在@的我应该说得出口……“就算对方是魔法少@女，也能稍微战斗一下”……"}]},{"autoTurnFirst":6.3,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":4.0,"chara":[{"id":103000,"motion":0}]},{"autoTurnFirst":4.2,"chara":[{"eyeClose":1,"id":103000,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103000,"motion":200}]}],"group_16":[{"autoTurnFirst":8.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_23","textHome":"灯花大人和音梦大人……还有姬，她们都是与@我生活在不同世界的人……不管如何期望，@我也无法与她们并肩站立。但是，我能为了@回应她们的期待而努力。那就是我能做到的@事情吧。"}]},{"autoTurnFirst":6.6,"chara":[{"id":103000,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":103000,"motion":400}]}],"group_17":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_24","textHome":"啊，找到了！太好了……找对碰头的地方了！@……我总是读错地图，所以稍微有点担心自@己是不是又迷路了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":400}]}],"group_18":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":400,"pos":1,"voice":"vo_char_1030_00_25","textHome":"啊哇哇……！班会课要迟到了！……明明我本@来只是打算在上课之前稍微整理一下服装的@，却把时间弄得这么紧张了……！"}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":200}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_26","textHome":"你问我要不要一起吃午饭？……嗯、嗯！如果@我可以的话，请务必！……诶嘿嘿，能被别@人邀请真开心啊。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103000,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"id":103000,"motion":300}]}],"group_2":[{"autoTurnFirst":1.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":400,"pos":1,"voice":"vo_char_1030_00_02","textHome":"啊！嗯……我是安积育梦！……那个……就算@你忽然让我做自我介绍也……怎么办啊……@呃，请、请多多关照……！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":4.2,"chara":[{"id":103000,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_041.exp.json","id":103000,"motion":400}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_27","textHome":"怎、怎么办啊！必须得做戏剧表演用的服装了@，但我还有魔法少女的活动……作业也还有@很多……啊，嗯，要从哪件事情做起呢……"}]},{"autoTurnFirst":2.7,"chara":[{"id":103000,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":2.0,"chara":[{"id":103000,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":103000,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":103000}]}],"group_21":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_28","textHome":"……嗯？……诶、诶？已经这么晚了吗！？…@…一开始编东西，我就会忘记时间……虽然@差不多必须要睡了，但是再编一层吧……"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103000}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_29","textHome":"我要说绕口令了！……“邻家竹篱立竹zh”@……啊呜，咬到舌头了。……为什么连幕后@人员也必须要做发声练习呢……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":103000}]}],"group_23":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_30","textHome":"如果不会给你添麻烦，巡视的话是不是可以一@起去呢？虽然对上魔法少女不行，但如果是@讨伐魔女，我觉得自己一定能派上用场！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":100}]}],"group_24":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":1,"pos":1,"voice":"vo_char_1030_00_31","textHome":"在这之前，我在无尽镜层发现了自己的复制品@……明明是我的复制品，却在被其他的复制@品们依赖……完全没法觉得那是我的复制品@啊。"}]},{"autoTurnFirst":6.5,"chara":[{"id":103000,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":103000}]}],"group_25":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_32","textHome":"呜呜……对不起。如果敌人是魔法少女，我就@完全派不上用场，所以我先道个歉吧……我@会尽量至少不拖大家后腿的……"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":4.8,"chara":[{"id":103000,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":6.0,"chara":[{"id":103000,"motion":100}]}],"group_26":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_33","textHome":"我有的时候也会被拉去参加大合唱哦。因为我@一和观众对上视线就会忘词，所以真的只有@在人数不够的时候就是了……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103000,"motion":400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":103000,"motion":300}]}],"group_27":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":100,"pos":1,"voice":"vo_char_1030_00_34","textHome":"我常去的手工店里，有个和我岁数相近的女孩@经常在挑选毛线。哈……如果有上前搭话的@勇气，是不是就能和她聊聊编织的话题了呢@……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":103000}]}],"group_28":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_35","textHome":"呵呵，诶嘿嘿……我买了台紫外线灯……我早@就想试一试使用树脂的手工了……哈，莫、@莫非我……刚才一直在傻笑吗？"}]},{"autoTurnFirst":4.8,"chara":[{"id":103000,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":103000,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":103000,"motion":400}]}],"group_29":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_36","textHome":"……嗯、嗯嗯？……哈……我想了解一下时雨@喜欢的东西，就买了本书，但编程什么的完@全看不懂啊……头好晕……"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":0}]},{"autoTurnFirst":5.6,"chara":[{"id":103000,"motion":300}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":103000,"motion":400}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_03","textHome":"为什么……我是这个样子呢。总是会陷入迷惘@……"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103000}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":1,"pos":1,"voice":"vo_char_1030_00_37","textHome":"我和十七夜住在同一个小区。所以，自从成为@黑羽之后，我就一直注意着尽量不要碰上她@……总感觉有点对不起她啊……"}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":5.0,"chara":[{"id":103000,"motion":300}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":100,"pos":1,"voice":"vo_char_1030_00_38","textHome":"我姑且也是有同为魔法少女的朋友的哦？只不@过，大家都去联盟了……所以，也有些不太@好说的事情……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":2.4,"chara":[{"id":103000,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":103000}]}],"group_32":[{"autoTurnFirst":4.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_39","textHome":"就算是我，也想要衷心认为自己也有能做到的@事情、有不同于他人的特别之处……但是，@我又没有像灯花大人和音梦大人那样的才能@……"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":103000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":1.2,"chara":[{"id":103000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":103000,"motion":300}]}],"group_33":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_40","textHome":"小时雨是特别的。挚友……比起这么说，嗯…@…虽然细微的差别会有点难把握……但是，@感觉她就像另一个我自己一样……"}]},{"autoTurnFirst":3.0,"chara":[{"id":103000,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103000}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":1}]}],"group_34":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":400,"pos":1,"voice":"vo_char_1030_00_41","textHome":"呀啊啊啊！？……白、白色的幽灵！？啊……@只是用来做服装的布被风吹动了而已……吗@……诶？但是，这阵风是从哪里吹来的呢…@…？"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":103000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103000,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":300}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103000}]},{"autoTurnFirst":4.0,"chara":[{"id":103000,"motion":200}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103000,"motion":0,"pos":1,"voice":"vo_char_1030_00_42","textHome":"战斗……虽然没有自信，但我会努力的。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":100}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":103000,"motion":200,"pos":1,"voice":"vo_char_1030_00_43","textHome":"哈……总算是做到了……吧？"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_44","textHome":"呼……能存活下来真是太好了……"}]}],"group_38":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":100,"pos":1,"voice":"vo_char_1030_00_45","textHome":"赢了……！说不定，我能稍微有点自信了。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103000}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_46","textHome":"就算是我，也是有相当的战斗能力的……！"}]}],"group_4":[{"autoTurnFirst":4.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_04","textHome":"就算没有人会给我玻璃鞋，也有一线可能……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":103000}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":103000,"motion":1,"pos":1,"voice":"vo_char_1030_00_05","textHome":"我什么也没有……嗯，我是知道的……"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103000}]},{"autoTurnFirst":4.0,"chara":[{"id":103000,"motion":0}]}],"group_6":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103000,"motion":300,"pos":1,"voice":"vo_char_1030_00_13","textHome":"哈……难得别人愿意帮我一次忙……我变强了@吗。"}]},{"autoTurnFirst":6.0,"chara":[{"id":103000,"motion":200}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010