{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_01","textHome":"自从成为魔法少女，我就一直在神滨市战斗。@拥有过快乐，但记住的却都是悲伤与心酸。@这是因为这类记忆更容易被记住吧……@但我一定要继续活下去。如果在这里放弃，@就等于否定了过往自己所坚持的这条路。"}]},{"autoTurnFirst":9.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":301}]}],"group_10":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":400,"pos":1,"voice":"vo_char_1002_00_18","textHome":"居然能做到这样……自己都有点吃惊。@比起所预想的，原来自己还能有更多潜力……"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":0}]}],"group_11":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_19","textHome":"了解了……我还能提升自己。"}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_20","textHome":"感觉还有上升的动力。挺不错。"}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":100}]}],"group_13":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_21","textHome":"对于当了很多年魔法少女的我来说，@也许“经验”才是最大的魔法。@今后要更善于在战斗中利用这份“经验”……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100200,"motion":301}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_22","textHome":"在思考之前身体就自然地行动了。@仿佛脑海中的记忆早已融入进骨血中一般。@这种感觉，虽然有些不可思议，@但除此以外我想不到其他更贴切的形容了。"}]},{"autoTurnFirst":8.5,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":201}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_23","textHome":"针对对手的一次攻击，最少也能想出十种反击@如今的我也拥有了这样广阔的眼界。@无论是现实中，还是精神上。@毫无疑问，这就是最佳的状态。"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100200,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_50_24","textHome":"恭贺新年。今年也请多关照。能这样和你@平安地共度新年，应该感恩才是。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100200}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":201}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_50_25","textHome":"早上好，昨晚睡得好吗？新年我也会在和往常@一样的时间起床。规律的生活，@是美容与健康的基础。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_50_26","textHome":"午饭做好了，你要吃吗？按照我自己的兴趣，@做了味道偏甜年糕小豆汤……"}]},{"autoTurnFirst":2.0,"chara":[{"id":100200,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":100200,"motion":301}]}],"group_19":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":300,"pos":1,"voice":"vo_char_1002_50_27","textHome":"难得的新年，从料理的准备当中解脱出来@也不错。偶尔上街，在外面吃个饭如何？"}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":100}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_03","textHome":"决斗少女，这件事太让人不安了……@会是什么样的人呢？"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":100}]}],"group_20":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_50_28","textHome":"睡前的这段时间也要学习。寒假结束后@就有考试了，大学的论文也要开始准备才行。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_50_29","textHome":"魔法少女虽然全年无休，但每天忧心忡忡@只会影响心情。在真的有问题出现之前，@好好地享受新年吧。"}]},{"autoTurnFirst":3.5,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":0}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_50_30","textHome":"差不多到了去街上巡视的时间了。就算大家都在@享受新年休假，魔女和传闻可不会@看时机跟着一起休息的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":200}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_50_31","textHome":"得去镜界露个面了。因为过年所以很久@不联系的话，御魂肯定又要絮絮不休了……@不，御魂会难过的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_50_32","textHome":"同一个队的伙伴相互竞争会有一种紧张感，@有时候也挺不错的。再穿着一身不同于平常的@盛装参与的话，精神上还会绷的更紧一些。"}]},{"autoTurnFirst":1.5,"chara":[{"id":100200,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":301}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_50_33","textHome":"身为模特也不表示就会经常穿和服呢。@拍照都是在新年、夏天的浴衣还有@毕业季……对不起，可能是挺经常穿的。"}]},{"autoTurnFirst":6.0,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":300}]}],"group_26":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_50_34","textHome":"年糕的话，我喜欢裹上黄豆粉吃。@诶，酱油……？抱歉，我不想谈论这个。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_052.exp.json","id":100200,"motion":201}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":200}]}],"group_27":[{"autoTurnFirst":2.8,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_50_35","textHome":"我不太喜欢抽签。要说原因就是……@总会抽到凶和大凶。听别人说大凶这种签@一辈子都抽不到一次的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_042.exp.json","id":100200}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_50_36","textHome":"新年里，感觉街上的空气比往常更加清新……@是因为和家人一起回乡探亲，或者是选择@独自度过这段时间的人增加了吗？"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":200}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_50_37","textHome":"祖母不在了之后，就没有压岁钱拿了呢……@等一下，我还没到要发压岁钱的年纪吧？"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":100200,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_04","textHome":"要是认真动起手来就太危险了……@我们的实力相差无几……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":300}]}],"group_30":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_50_38","textHome":"我很擅长打毽球的。桃子还说@「认真得一点都不像个大人」，但就算@和小学生对打，我也不会放水的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":201}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_50_39","textHome":"穿上长袖和服，突然就想吃抹茶雪糕了。@就算天气很冷，还下着雪也没关系……@倒不如说冬天正好。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100200,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":100200}]}],"group_32":[{"autoTurnFirst":6.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_50_40","textHome":"以前到了新年，就会和租公寓的学生们一起@唱百家诗……不，也不是很正规，@只是玩和歌纸牌而已。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":301}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200}]}],"group_33":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_50_41","textHome":"怎么了？缩在被炉里觉得没意思了吗……？@那到外面去堆雪人怎么样？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}]}],"group_34":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_42","textHome":"战斗是魔法少女的宿命……"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_43","textHome":"又活下来了呢……"}]}],"group_36":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_44","textHome":"就结果来说……不错。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":100200,"motion":301,"pos":1,"voice":"vo_char_1002_00_45","textHome":"我不能……在这倒下！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":400}]}],"group_38":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_46","textHome":"我一定会保护她们……"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_63","textHome":"在这里……做好觉悟吧……我会使出全力！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_05","textHome":"魔女也会耍各种手段啊……@今后得用心防备才行……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_40":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_64","textHome":"我不打算有所保留了！"}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_65","textHome":"不说坏话，就到这里结束吧！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_66","textHome":"……在我的时间里，用这一击……！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":400}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_02","textHome":"我是七海八千代。首先……请多关照。@在这神滨市生存下去，并不是件容易的事。@做好觉悟了吗？"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100200,"motion":201}]},{"autoTurnFirst":3.2,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":200}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_13","textHome":"最重要的，是脚踏实地……"}]},{"autoTurnFirst":6.0,"chara":[{"id":100200,"motion":200}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_14","textHome":"量变引起质变……就是这么回事。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}]}],"group_7":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_15","textHome":"要想生存下去，力量是必要的。"}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_16","textHome":"即使到了这个岁数，@通过锻炼也还有提升魔力的潜力。@不过，能有多少程度呢……@不，无论如何都要做下去。"}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":301}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_011.exp.json","id":100200,"motion":201}]}],"group_9":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_17","textHome":"……嗯，感觉到了。@能够运用相当强大的魔力了……@不过一定还能提升，把它磨练到底吧。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":201}]}]},"version":3}