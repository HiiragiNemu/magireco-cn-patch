{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_01","textHome":"我是塔鲁特……@因为聆听了主所派遣的天使大人的话语，@而获得了给法兰西带来光明的力量。@啊，不是……我并不是什么了不起的人！@我自己，只是一个来自乡村的少女而已。@叫我塔鲁特就可以了。"}]},{"autoTurnFirst":4.5,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_050.exp.json","id":402100,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_18","textHome":"我有时也会做着这样的梦，@我们的战争迎来结束，@上帝宽恕我们得以离开这个战场……"}]},{"autoTurnFirst":6.0,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":100}]}],"group_11":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_19","textHome":"怎么样？我也是能好好成长的吧！！"}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_20","textHome":"因为大家把力量借给了我，@所以我才能走到这里。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402100}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_21","textHome":"莉兹曾说我是能与她相匹的伙伴，@现在的我差不多有资格与她并肩作战了吧？@不行，光是这样还不能满足。"}]},{"autoTurnFirst":3.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_020.exp.json","id":402100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_14":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_22","textHome":"我想做的只是想拯救这个国家。@所以我不会把阻挡在我面前的人@都当作敌人来憎恨……@但是我不会原谅那些想要破坏一切的人。@我一定会挽救这一切的！"}]},{"autoTurnFirst":6.0,"chara":[{"id":402100,"motion":100}]},{"autoTurnFirst":7.5,"chara":[{"face":"mtn_ex_020.exp.json","id":402100,"motion":300}]},{"autoTurnLast":2.0,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":200}]}],"group_15":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_23","textHome":"「你在战场前线站立着的身姿……@你挥舞着的旗帜那就是『希望』本身」@那一天，莉兹对我说的话……@还有大家相信着的『希望』，我都深信不疑。@『希望』的旗帜就在这里……！"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":402100,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":402100}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":200}]}],"group_16":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402100,"motion":300,"pos":1,"voice":"vo_char_4021_00_24","textHome":"唔唔唔唔……啊！你来了呢！@你问我等很久了吗？没，没有！怎么会呢！"}]},{"autoTurnFirst":0.01,"chara":[{"eyeClose":0,"id":402100}]},{"autoTurnFirst":1.5,"chara":[{"face":"mtn_ex_050.exp.json","id":402100}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_030.exp.json","id":402100}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_050.exp.json","id":402100,"motion":100}]}],"group_17":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_25","textHome":"啊，早上好。我刚刚在做晨祷。@希望今天也是顺利的一天。"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402100}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_010.exp.json","id":402100}]},{"autoTurnFirst":4.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_26","textHome":"太阳挂得好高！@这样的日子，让我想起了在故乡的生活。@那是平静而又快乐的生活。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":402100,"motion":1}]}],"group_19":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_27","textHome":"晚饭时间到。梅丽莎准备的饭菜都很美味……@今天她做了什么呢？好期待啊！"}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100}]},{"autoTurnFirst":4.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]}],"group_2":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_03","textHome":"我发誓……我要拯救这个国家。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402100,"motion":100}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_28","textHome":"大家好像都喝得十分的尽兴，@但莉兹和梅丽莎却对我说@『就算给你倒错了也不准喝酒』……@这是为什么呢？"}]},{"autoTurnFirst":6.0,"chara":[{"face":"mtn_ex_030.exp.json","id":402100,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":402100,"motion":300}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_29","textHome":"剑柄不要握得太紧……啊，我在做剑术练习。@刚刚是莉兹一开始教给我的事。"}]},{"autoTurnFirst":1.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100,"motion":1}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_30","textHome":"那么，走吧。为了给法兰西带来光明。@在王子作为国王加冕之前，我不可以放弃。"}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":200}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_31","textHome":"我们要和一模一样的魔法少女战斗……@如果她们是我拯救国家的障碍……@那我就会战斗。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_020.exp.json","id":402100,"motion":1}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_32","textHome":"如果我站在前线的身姿就是希望的话，@我无论多少次都愿意挥舞这扇旗帜。@以上帝之圣名必定会取得胜利！！"}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":402100,"motion":201}]}],"group_25":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_33","textHome":"军旗的图案很奇怪……？是，是那样吗？@因为可以自由发挥，所以我就把天使大人@绣在了上面……"}]},{"autoTurnFirst":4.5,"chara":[{"face":"mtn_ex_030.exp.json","id":402100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":1}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_34","textHome":"这件衣服，是沃库勒尔的大家在前往希农时@送给我的。我竟然收到了这么好的礼物……@真是感激不尽。"}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_27":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_35","textHome":"如今，我把天使大人的话作为了使命来遵从。@就像那一天，我在凯瑟琳墓前发的誓一样。"}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":402100,"motion":1}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_36","textHome":"莉兹和我有一点不同。她成熟又帅气，@在刚遇见她的时候，我以为她比我年长很多。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_37","textHome":"灵魂宝石……看不见的灵魂竟被制成了宝石，@果然天使大人就是天使大人啊！！@这完全就如同神迹一样！"}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_010.exp.json","id":402100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":200}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_04","textHome":"总感觉街上的人都是慌慌张张的。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402100,"motion":100}]}],"group_30":[{"autoTurnFirst":5.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_38","textHome":"莉兹她，一直都很照顾我，@就像是姐姐一样的存在，是我的救命恩人。@是我感激不尽的，重要的朋友。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":402100}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":402100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_39","textHome":"我的剑术是莉兹教的。我还在村里的时候……@想要保护自己和妹妹……@所以我开始了学习剑术的道路。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":201}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402100,"motion":300,"pos":1,"voice":"vo_char_4021_00_40","textHome":"在村子被袭击的时候，我已经不想再有人受到@那样的痛苦，所以我成为了魔法少女。@为了给法兰西带来光明。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":402100,"motion":200}]}],"group_33":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_41","textHome":"这把「克洛维重剑」，是尘封在圣凯瑟琳教会@的武器。在作为妹妹名字由来的圣人的教会@找到它……总感觉有着莫名的缘分。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_42","textHome":"我一定要保护大家!!"}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":200}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_43","textHome":"呼……胜利了。"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":402100}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_44","textHome":"大家都没事吧!?"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_45","textHome":"那么，前进吧。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_46","textHome":"都是大家的功劳。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_63","textHome":"我要拯救这一切。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_05","textHome":"不管发生什么……我都要前进……"}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":201}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_64","textHome":"心坚无难事。"}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":200}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_65","textHome":"光辉万丈！"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_66","textHome":"这下就结束了。"}]}],"group_43":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_02","textHome":"初次见面，我叫塔鲁特。@啊，塔鲁特是天使大人赐给我的名字，@亲密的人都是这么叫我的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":100,"pos":1}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402100}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_13","textHome":"这样子，我对魔力的控制又得心应手了一些。"}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_14","textHome":"这样，我就能完美地控制魔力了！"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_15","textHome":"回想起来……已经……是很久远的事情了。"}]}],"group_8":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_16","textHome":"栋雷米……那里就是我的故乡。@要说在我成为魔法少女之前的愿望，@那就是希望家人和村庄的人们能够免于灾祸，@幸福地生活。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":6.1,"chara":[{"id":402100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_9":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_17","textHome":"凯瑟琳用命救了我，我才成为了魔法少女。@我已经……不想再有人@和我遭受同样的痛苦了……"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":402100,"motion":300}]}]},"version":3}