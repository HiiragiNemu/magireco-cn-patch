{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_01","textHome":"我是保澄雫，家里开了家茶店。不是时尚的@咖啡馆，只是以前就有的单纯喝茶的地方。@不过还是欢迎大家，我也会在店里的。感觉@变成店铺介绍了。抱歉，我没什么喜欢的东西。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":5.7,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700}]},{"autoTurnFirst":4.8,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300}]}],"group_10":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_18","textHome":"无论选择哪种道路，我对重要之人的思念@不会改变。只要这么想着……我似乎@就能看到些许未来了。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]}],"group_11":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_19","textHome":"嗯，我感受到了力量……@感觉我能走得更远了。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":3.0,"chara":[{"id":300700,"motion":100}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_20","textHome":"人们都是在重要的人中，@找寻自己归宿的吧……"}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":100}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_21","textHome":"如果有天……还有那么一个为我找寻归宿的人@就好了。就像这样的想象，也许也算是@未来的梦想吧。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":1.5,"chara":[{"id":300700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":3.0,"chara":[{"id":300700,"motion":300}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_22","textHome":"我的归宿就是这里……我能这么想吗……@至今我也放不下心中的不安……但是，@我想要待在这里。只要有重要的人在身边，@我就能坚定地踏出一步。"}]},{"autoTurnFirst":5.2,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]}],"group_15":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_23","textHome":"风哥，我找到了哦。就像你在我身上找寻到的@归宿一样，我也终于找到了自己的「归宿」。@我已经哪里都不会去了，也不需要再彷徨了。"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_24","textHome":"欢迎光临。今天是只喝茶吗？@还是说想吃点茶点呢？@……因为人很少，所以多待会儿也没关系。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":3.8,"chara":[{"id":300700,"motion":300}]}],"group_17":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_25","textHome":"早上好。@……一副没睡醒的样子呢，昨晚熬夜了吗？"}]},{"autoTurnFirst":3.0,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]}],"group_18":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_26","textHome":"我家的店，像是意大利面或是@三明治之类的料理……还是能做出来的。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":2.7,"chara":[{"id":300700,"motion":300}]}],"group_19":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_27","textHome":"离关门还有段时间……要喝杯咖啡吗？不加糖@只加牛奶。……这样对吧？嗯，我明白了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":3.4,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.6,"chara":[{"id":300700,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":300700,"motion":100}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_03","textHome":"明日与我没有约定。我……只能去寻找。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700,"motion":0}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_28","textHome":"还不睡吗？@……我也是，今天就一起熬会儿夜吧。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":1.0,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]}],"group_21":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_29","textHome":"啊……虽然并不时髦……但是，单纯喝茶的店@会使人平静下来对吧？我很喜欢。"}]},{"autoTurnFirst":4.0,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":0}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_30","textHome":"差不多该出门了？@只要你方便就可以，我随时都没问题。"}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":0}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_31","textHome":"与危险为邻的战斗确实很让人害怕，但是，@为了我的目标，我不能退缩。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"id":300700,"motion":100}]}],"group_24":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_32","textHome":"你能和我一起战斗吗？经常有人说，@有了想守护的东西，人就会变得软弱……@但我觉得，有了想守护的东西反倒会使人强大。"}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":1.0,"chara":[{"id":300700,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_33","textHome":"我试着做了法式火腿蛋三明治，你能试吃@一下吗？不知道能不能成为店里的新菜。@是不是有些太花哨了……"}]},{"autoTurnFirst":4.4,"chara":[{"id":300700,"motion":200}]},{"autoTurnFirst":4.1,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":0}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_34","textHome":"我看起来很无趣吧？能像这样一起聊天，@我觉得很开心，但是我不能很好地表达给你，@真是对不起。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":7.5,"chara":[{"id":300700,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":300700,"motion":100}]}],"group_27":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_35","textHome":"我有父母，也有朋友，明明受着大家的照顾，@为什么我还会是这样的心情呢，@可能只是我太任性了……"}]},{"autoTurnFirst":4.0,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":300700,"motion":300}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":200,"pos":1,"voice":"vo_char_3007_00_36","textHome":"奶昔虽然是咖啡店菜单上的经典……@但是我不太适应。喝生鸡蛋，@身体上总感觉有些抵抗."}]},{"autoTurnFirst":3.4,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.1,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700}]}],"group_29":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_37","textHome":"鹤乃……她像孩子般直爽，我很羡慕她。@我没有把她当傻瓜……是真的很羡慕。"}]},{"autoTurnFirst":4.8,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_04","textHome":"我一直在找的「归宿」……会是这里吗……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_38","textHome":"吵得越凶感情越深，来形容鹤乃和菲莉希亚@真是再合适不过了。她们俩差了4岁……@但确是很不错的组合。"}]},{"autoTurnFirst":1.0,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":3.5,"chara":[{"id":300700,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_39","textHome":"家族，就是大家共度相同的时光，从而@创造出来的产物吧……看着八千代她们，@我产生了这样的想法。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700}]},{"autoTurnFirst":3.5,"chara":[{"id":300700,"motion":100}]}],"group_32":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_40","textHome":"魔法少女们，是背负着同样的命运，@如同命运共同体般的存在。@不知道能不能一起聊更多的话题呢……"}]},{"autoTurnFirst":6.3,"chara":[{"id":300700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"id":300700}]}],"group_33":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_41","textHome":"把我带到风哥身边吧……那时我突然就许下了@这样的愿望。如果我许了不一样的愿望，@是不是就能拯救他了呢？"}]},{"autoTurnFirst":6.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300}]}],"group_34":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_42","textHome":"稍微有些紧张啊……"}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_43","textHome":"刚刚太忘我了……"}]}],"group_36":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_44","textHome":"嗯，我也很开心。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_45","textHome":"我，笑得很好看吗？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300700}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_46","textHome":"我可以留在这吗……"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_63","textHome":"请不要恨我。"}]},{"autoTurnFirst":1.5,"chara":[{"id":300700,"motion":200}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_05","textHome":"总有一天我也会找到的吧……@稳定的「归宿」。"}]},{"autoTurnFirst":2.0,"chara":[{"id":300700,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"face":"mtn_ex_000.exp.json","id":300700}]}],"group_40":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":200,"pos":1,"voice":"vo_char_3007_00_64","textHome":"到底能去到多远的地方呢，要试试看吗？"}]},{"autoTurnFirst":1.4,"chara":[{"id":300700,"motion":0}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_65","textHome":"我的意志不会轻易屈服……！"}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":100}]}],"group_42":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_66","textHome":"谁都没有夺走我们未来的权利……！"}]},{"autoTurnFirst":1.6,"chara":[{"id":300700,"motion":200}]}],"group_43":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_02","textHome":"我是保澄雫，抱歉看起来这么冷淡。不过，@我只是不擅长表达感情，所以不用担心。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300700,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":401}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_13","textHome":"为了到达我寻求的地方，我必须要变强。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300700}]},{"autoTurnFirst":2.5,"chara":[{"id":300700,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":100,"pos":1,"voice":"vo_char_3007_00_14","textHome":"无论去向何处我都不会恐惧。@因为，我找到了归处。"}]},{"autoTurnFirst":1.5,"chara":[{"id":300700,"motion":0}]}],"group_7":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":0,"pos":1,"voice":"vo_char_3007_00_15","textHome":"仿佛迷雾消散一般……@我想我看到了不一样的景色。"}]},{"autoTurnFirst":3.2,"chara":[{"id":300700,"motion":100}]}],"group_8":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":1,"pos":1,"voice":"vo_char_3007_00_16","textHome":"我必须赶快找到未来的我。在我踌躇的时候，@未来的我也是迷失的状态。"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300700,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":300700,"motion":300}]}],"group_9":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300700,"motion":300,"pos":1,"voice":"vo_char_3007_00_17","textHome":"就算不是什么能够热衷的事，但思念重要之人@的感情，也能成为我通往未来的路标吧。"}]},{"autoTurnFirst":2.3,"chara":[{"id":300700,"motion":100}]}]},"version":3}