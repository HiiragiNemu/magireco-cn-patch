{"story":{"group_1":[{"autoTurnFirst":7.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_01","textHome":"因为要去海边玩，所以我准备了泳装……@那个，原本想试着认真挑一件的……@结果还是好害羞……@我手上拿的？这是钓竿。@因为我还想试试钓鱼，所以就拿过来了。"}]},{"autoTurnFirst":6.5,"chara":[{"id":230000,"motion":300}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":230000}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":9.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]}],"group_10":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_18","textHome":"我也很想看看其他季节的大海。@一定和夏天是不同的吧。@这样的不同，好想和鹿目同学一起感受啊。"}]},{"autoTurnFirst":6.2,"chara":[{"id":230000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":230000,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":230000,"motion":100}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_19","textHome":"为了使起来更顺手，我改良了钓竿。"}]},{"autoTurnFirst":4.0,"chara":[{"id":230000,"motion":200}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":400,"pos":1,"voice":"vo_char_2300_00_20","textHome":"第、第一次靠自己钓上来了！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":230000}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_21","textHome":"我感觉越来越熟悉钓竿了。@嘿！嘿！怎么样？@是不是有模有样了？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":400}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":1,"id":230000,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":6.7,"chara":[{"id":230000}]}],"group_14":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":200,"pos":1,"voice":"vo_char_2300_00_22","textHome":"快看！我至今为止钓上来最大的一条鱼！@鹿目同学也夸我有钓鱼的天赋……@我今后也要努力钓更多的鱼。@啊！忘、忘记去讨伐魔女了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":230000,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":230000,"motion":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":4.9,"chara":[{"id":230000,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":300}]}],"group_15":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_23","textHome":"实际上，我以前从来没用过钓竿。@没想到，还能拿来作为对付魔女的武器。@不过现在的我就算是魔女也能钓上来，@大概……不，绝对！"}]},{"autoTurnFirst":10.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":300,"pos":1,"voice":"vo_char_2300_00_24","textHome":"还没来么还没来么。啊！我在这里！@对、对不起，我太兴奋了，有些坐立不安。@现在，我们一起享受大海吧！"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":230000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":2.0,"chara":[{"id":230000,"motion":400}]},{"autoTurnFirst":2.4,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":230000,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":5.0,"chara":[{"id":230000,"motion":100}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_25","textHome":"早上好。@因为担心会兴奋得睡不着，@所以昨天早早地就去睡了。@结果今天很早就醒了……@嘿嘿，好期待啊。"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":5.6,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0}]}],"group_18":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":230000,"motion":300,"pos":1,"voice":"vo_char_2300_00_26","textHome":"我，为什么这么迟钝呢……@刚刚还被海鹰抢走了午饭……@明明是大家分给我吃的。"}]},{"autoTurnFirst":5.8,"chara":[{"id":230000,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":100}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100,"pos":1,"voice":"vo_char_2300_00_27","textHome":"看着日落，就有了今天也结束了的感觉。@我要努力让这样和平的日子继续下去……"}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":230000}]}],"group_2":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":230000,"motion":300,"pos":1,"voice":"vo_char_2300_00_03","textHome":"唔……钓鱼好难……我钓不好鱼……"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":230000}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_28","textHome":"我还是第一次玩手持烟花。@这里也有满天星烟花呢。@在电视上看着好漂亮，@我一直亲手都想放一次试试。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":230000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":6.0,"chara":[{"id":230000}]}],"group_21":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_29","textHome":"这附近似乎有向日葵花田。@要是游泳游累了的话，就一起去看看吧？@好像开得正盛呢。"}]},{"autoTurnFirst":5.5,"chara":[{"id":230000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":230000,"motion":100}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":300,"pos":1,"voice":"vo_char_2300_00_30","textHome":"不能因为有很多快乐的事情，@就放弃了魔法少女的使命。@差不多该去巡视了。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]}],"group_23":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_31","textHome":"对面也是我穿着泳装的样子！@果然还是有些花哨了啊……@那个，这样再看一遍自己总感觉很害羞。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"id":230000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":230000,"motion":1}]}],"group_24":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_32","textHome":"这个时候，大家都是穿着泳装来的吧。@太好了……要是只有我穿着泳装就难办了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":6.0,"chara":[{"id":230000,"motion":1}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_33","textHome":"这个沙子城堡很厉害吧。装饰也很细致……@我也稍微帮了一下忙，@能够一起把它造出来真是太好了。"}]},{"autoTurnFirst":2.1,"chara":[{"id":230000,"motion":200}]},{"autoTurnFirst":2.7,"chara":[{"id":230000,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"id":230000,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":230000,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":2.0,"chara":[{"id":230000}]}],"group_26":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":230000,"motion":400,"pos":1,"voice":"vo_char_2300_00_34","textHome":"好、好冷！大脑被冻住了！@吃刨冰的时候，大脑真的感觉会被冰冻一下。@唔唔，不过葡萄味的真的很好吃呢。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":230000,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":230000}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"eyeClose":1,"id":230000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000}]},{"autoTurnFirst":5.0,"chara":[{"id":230000,"motion":100}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_35","textHome":"这个么？这个是海玻璃。@虽然只是在海上漂浮着的@像是磨砂玻璃的玻璃碎片，@不过却有着独特的感觉，很棒对吧。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]},{"autoTurnFirst":8.0,"chara":[{"id":230000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":230000,"motion":1}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_36","textHome":"这个风铃是我做的。@因为从吹玻璃到画花纹……@都是我在玻璃工坊的体验会上自己亲手做的，@所以感觉声音特别的好听。"}]},{"autoTurnFirst":7.7,"chara":[{"id":230000,"motion":1}]},{"autoTurnFirst":4.3,"chara":[{"id":230000,"motion":100}]},{"autoTurnFirst":4.2,"chara":[{"eyeClose":1,"id":230000}]}],"group_29":[{"autoTurnFirst":0.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":400,"pos":1,"voice":"vo_char_2300_00_37","textHome":"呀！难、难道说你看见了？@那个，要是转起来的话，@我身后的缎带也会跟着我转，很有趣……@所以就转了一下……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":230000}]},{"autoTurnFirst":6.7,"chara":[{"id":230000,"motion":1}]},{"autoTurnFirst":4.6,"chara":[{"id":230000,"motion":300}]}],"group_3":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_04","textHome":"嗯……我来真的没问题吗？"}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_38","textHome":"巴学姐和杏子好像是一起去买的泳装。@真好啊，明年我……要是有明年的话，@我也要和大家一起去买泳装。"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":230000,"motion":300}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":2.8,"chara":[{"id":230000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":230000}]}],"group_31":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_39","textHome":"美树同学的泳装很帅气对吧。@很有夏天的女孩子的感觉。@因为我不太适合，所以有些羡慕啊。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0}]}],"group_32":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_40","textHome":"鹿目同学虽然一直在夸我穿泳装好看……@但我觉得鹿目同学要比我可爱的多！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"cheek":2,"id":230000,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":230000,"motion":400}]}],"group_33":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_131.exp.json","id":230000,"motion":0,"pos":1,"tear":1,"voice":"vo_char_2300_00_41","textHome":"呜，咕……@不好意思，我不是在难过而是在开心。@我真是没有想到……@我竟然还能够像往常一样……@度过这么开心幸福的一天。"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":230000,"motion":100,"tear":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":230000,"tear":1}]},{"autoTurnFirst":5.8,"chara":[{"id":230000,"motion":1,"tear":1}]},{"autoTurnFirst":6.2,"chara":[{"id":230000,"motion":0,"tear":1}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":230000,"motion":300,"tear":1}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_42","textHome":"我一定要钓一条大鱼！"}]},{"autoTurnFirst":3.0,"chara":[{"id":230000,"motion":200}]}],"group_35":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":100,"pos":1,"voice":"vo_char_2300_00_43","textHome":"只带鱼饵的话会很奇怪吗……"}]}],"group_36":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":200,"pos":1,"voice":"vo_char_2300_00_44","textHome":"我不会输给炎热的！"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100,"pos":1,"voice":"vo_char_2300_00_45","textHome":"变得能够稳定钓上来了！"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":400,"pos":1,"voice":"vo_char_2300_00_46","textHome":"顺利钓上来一条大鱼了！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]}],"group_39":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_63","textHome":"现、现在就是展现修行成果的时候了……！"}]},{"autoTurnFirst":2.5,"chara":[{"id":230000,"motion":200}]}],"group_4":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_05","textHome":"虽然有些辛苦，但……很开心对吧？"}]},{"autoTurnFirst":2.2,"chara":[{"id":230000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":400,"pos":1,"voice":"vo_char_2300_00_64","textHome":"呀啊啊！"}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_65","textHome":"对不起……！"}]}],"group_42":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_66","textHome":"飞鱼冲击！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":400}]}],"group_43":[{"autoTurnFirst":4.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":230000,"motion":300,"pos":1,"voice":"vo_char_2300_00_02","textHome":"那、那个……我，没有什么奇怪的吧？@因为要和鹿目同学她们去海边，@所以就准备了泳装……"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"id":230000,"motion":100}]}],"group_5":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_13","textHome":"鱼饵被白吃的情况越来越少了！@是等级上升了吧。"}]},{"autoTurnFirst":5.5,"chara":[{"id":230000,"motion":100}]}],"group_6":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_14","textHome":"已经能习惯和鱼的博弈了。@现在的我什么都能钓上来！"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":230000,"motion":400}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_15","textHome":"夏天必不可少的节目就是恐怖故事了……@呜……可怕的东西有点……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":230000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":230000,"motion":300}]}],"group_8":[{"autoTurnFirst":8.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":1,"pos":1,"voice":"vo_char_2300_00_16","textHome":"虽然在海里游泳很有趣，@不过像这样眺望远方也不错。@在那边的尽头，只剩下了海与天，@仿佛是不同的世界。"}]},{"autoTurnFirst":4.4,"chara":[{"id":230000,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":230000}]}],"group_9":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":230000,"motion":0,"pos":1,"voice":"vo_char_2300_00_17","textHome":"海与天的分界线真是不可思议。@明明一样都是蓝色，但却能很好地分辨出来。@到这里是海，这一边是天空。"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":230000,"motion":100}]},{"autoTurnFirst":7.5,"chara":[{"id":230000,"motion":1}]}]},"version":3}