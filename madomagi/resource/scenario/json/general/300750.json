{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_01","textHome":"我是保澄雫，家里开了家茶店。不是时尚的@咖啡馆，只是以前就有的单纯喝茶的地方。@不过还是欢迎大家，我也会在店里的。感觉@变成店铺介绍了。抱歉，我没什么喜欢的东西。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750}]},{"autoTurnFirst":5.7,"chara":[{"id":300750,"motion":300}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300750}]},{"autoTurnFirst":4.8,"chara":[{"id":300750,"motion":100}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300}]}],"group_10":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_18","textHome":"无论选择哪种道路，我对重要之人的思念@不会改变。只要这么想着……我似乎@就能看到些许未来了。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0}]}],"group_11":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_19","textHome":"嗯，我感受到了力量……@感觉我能走得更远了。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750}]},{"autoTurnFirst":3.0,"chara":[{"id":300750,"motion":100}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_20","textHome":"人们都是在重要的人中，@找寻自己归宿的吧……"}]},{"autoTurnFirst":2.5,"chara":[{"id":300750,"motion":100}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_21","textHome":"如果有天……还有那么一个为我找寻归宿的人@就好了。就像这样的想象，也许也算是@未来的梦想吧。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750}]},{"autoTurnFirst":1.5,"chara":[{"id":300750,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750}]},{"autoTurnFirst":3.0,"chara":[{"id":300750,"motion":300}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_22","textHome":"我的归宿就是这里……我能这么想吗……@至今我也放不下心中的不安……但是，@我想要待在这里。只要有重要的人在身边，@我就能坚定地踏出一步。"}]},{"autoTurnFirst":5.2,"chara":[{"id":300750,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"id":300750,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750}]}],"group_15":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_23","textHome":"风哥，我找到了哦。就像你在我身上找寻到的@归宿一样，我也终于找到了自己的「归宿」。@我已经哪里都不会去了，也不需要再彷徨了。"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":300750,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750}]}],"group_16":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":1,"pos":1,"voice":"vo_char_3007_50_24"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300750}]},{"autoTurnFirst":5.5,"chara":[{"id":300750,"motion":101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300750,"motion":200}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_50_25"}]},{"autoTurnFirst":6.1,"chara":[{"id":300750,"motion":101}]},{"autoTurnFirst":4.5,"chara":[{"id":300750,"motion":300}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_50_26"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":401}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300750,"motion":300}]}],"group_19":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":300750,"motion":200,"pos":1,"voice":"vo_char_3007_50_27"}]},{"autoTurnFirst":4.0,"chara":[{"id":300750,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":300750,"motion":0}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_03","textHome":"明日与我没有约定。我……只能去寻找。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300750,"motion":0}]}],"group_20":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_50_28"}]},{"autoTurnFirst":3.2,"chara":[{"id":300750,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":300750,"motion":300}]},{"auto