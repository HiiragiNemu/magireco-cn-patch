exp.json","id":300750,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":300750,"motion":101}]}],"group_32":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":1,"pos":1,"voice":"vo_char_3007_50_40"}]},{"autoTurnFirst":4.2,"chara":[{"eyeClose":1,"id":300750}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":0,"id":300750}]},{"autoTurnFirst":2.3,"chara":[{"id":300750,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750,"motion":200}]}],"group_33":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_50_41"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":300750}]},{"autoTurnFirst":7.6,"chara":[{"eyeClose":0,"id":300750}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300750,"motion":300}]}],"group_34":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_42","textHome":"稍微有些紧张啊……"}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_43","textHome":"刚刚太忘我了……"}]}],"group_36":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_44","textHome":"嗯，我也很开心。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_45","textHome":"我，笑得很好看吗？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300750}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_46","textHome":"我可以留在这吗……"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_63","textHome":"请不要恨我。"}]},{"autoTurnFirst":1.5,"chara":[{"id":300750,"motion":200}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_05","textHome":"总有一天我也会找到的吧……@稳定的「归宿」。"}]},{"autoTurnFirst":2.0,"chara":[{"id":300750,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"face":"mtn_ex_000.exp.json","id":300750}]}],"group_40":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300750,"motion":200,"pos":1,"voice":"vo_char_3007_00_64","textHome":"到底能去到多远的地方呢，要试试看吗？"}]},{"autoTurnFirst":1.4,"chara":[{"id":300750,"motion":0}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_65","textHome":"我的意志不会轻易屈服……！"}]},{"autoTurnFirst":2.5,"chara":[{"id":300750,"motion":100}]}],"group_42":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_66","textHome":"谁都没有夺走我们未来的权利……！"}]},{"autoTurnFirst":1.6,"chara":[{"id":300750,"motion":200}]}],"group_43":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_02","textHome":"我是保澄雫，抱歉看起来这么冷淡。不过，@我只是不擅长表达感情，所以不用担心。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300750,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":401}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_13","textHome":"为了到达我寻求的地方，我必须要变强。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300750}]},{"autoTurnFirst":2.5,"chara":[{"id":300750,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":100,"pos":1,"voice":"vo_char_3007_00_14","textHome":"无论去向何处我都不会恐惧。@因为，我找到了归处。"}]},{"autoTurnFirst":1.5,"chara":[{"id":300750,"motion":0}]}],"group_7":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":0,"pos":1,"voice":"vo_char_3007_00_15","textHome":"仿佛迷雾消散一般……@我想我看到了不一样的景色。"}]},{"autoTurnFirst":3.2,"chara":[{"id":300750,"motion":100}]}],"group_8":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":1,"pos":1,"voice":"vo_char_3007_00_16","textHome":"我必须赶快找到未来的我。在我踌躇的时候，@未来的我也是迷失的状态。"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300750,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":300750,"motion":300}]}],"group_9":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":300750,"motion":300,"pos":1,"voice":"vo_char_3007_00_17","textHome":"就算不是什么能够热衷的事，但思念重要之人@的感情，也能成为我通往未来的路标吧。"}]},{"autoTurnFirst":2.3,"chara":[{"id":300750,"motion":100}]}]},"version":3}