{"story":{"group_1":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_01","textHome":"嗯！这朵花叫做风信子！小学时大概有很多人@种过！红橙黄紫……颜色也很丰富！…诶？@是、是问我的名字吗？抱歉！还以为是@问花的名字……我的名字是……春名木乃美…"}]},{"autoTurnFirst":5.0,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":2.1,"chara":[{"id":303000,"motion":100}]},{"autoTurnFirst":2.1,"chara":[{"id":303000,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000}]},{"autoTurnFirst":0.6,"chara":[{"cheek":1,"face":"mtn_ex_022.exp.json","id":303000}]},{"autoTurnFirst":2.1,"chara":[{"id":303000,"motion":0}]},{"autoTurnFirst":3.9,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303000,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":1}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_10":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_18","textHome":"努力得到承认，真是太高兴了。如果要用什么@办法表达的话……就好像能做出超棒的花束@一样！"}]},{"autoTurnFirst":0.5,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_11":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_19","textHome":"能够让更多美丽的花绽放了！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]},{"autoTurnFirst":2.5,"chara":[{"id":303000,"motion":400}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_20","textHome":"不会败给风雨哦？我的花是很坚强的。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":303000,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000}]},{"autoTurnFirst":1.0,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":400,"pos":1,"voice":"vo_char_3030_00_21","textHome":"不知不觉就变得这么强啦？以前的我……可是@个爱哭鬼啊。这都是身边的人的功劳。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]},{"autoTurnFirst":1.7,"chara":[{"id":303000,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":303000,"motion":100}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_22","textHome":"就算有痛苦的事情……也不能光是哭就算了。@通过自身的努力和设想，无论怎样的现实也@能改变。再说……就算失败了，也会有人@和我站在一起。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000}]},{"autoTurnFirst":1.5,"chara":[{"id":303000,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"id":303000}]},{"autoTurnFirst":2.5,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":0.3,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]}],"group_15":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_23","textHome":"花用它的生命装点了我们的人生，如果我也能@成为守护大家美好人生的存在……大概会@觉得美妙得难以置信吧。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":100}]}],"group_16":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_24","textHome":"欢迎。虽然是非卖品……但我家种的花开得@这么漂亮，想让大家都看看，所以在这里@等着呢。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]},{"autoTurnFirst":0.7,"chara":[{"cheek":1,"id":303000}]},{"autoTurnFirst":0.3,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]}],"group_17":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_25","textHome":"早晨一定要浇水！尤其是高温的季节……要是@气温高的白天不浇水的话，花是会热坏的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":303000,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":303000,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_18":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_26","textHome":"午饭后，想泡点洋甘菊茶来着……方便的话@一起喝吧？能安定心情哦。"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"id":303000,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]},{"autoTurnFirst":2.2,"chara":[{"id":303000,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"id":303000,"motion":1}]}],"group_19":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_27","textHome":"欢迎光临！今天呢，刚好有新的花到货了。@要不要去看看？"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":200}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303000,"motion":400,"pos":1,"voice":"vo_char_3030_00_03","textHome":"只要能守护阿姨和这家店……我很乐意成为@魔法少女……！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":200,"pos":1,"voice":"vo_char_3030_00_28","textHome":"因为夜间绽放所以名为月下美人……啊，@多美的名字啊。赋予它这个名字的人，一定也是@非常出色的人吧。"}]},{"autoTurnFirst":0.9,"chara":[{"cheek":1,"id":303000}]},{"autoTurnFirst":2.5,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":2.6,"chara":[{"id":303000,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":303000,"motion":1}]}],"group_21":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_29","textHome":"我觉得只是赠予重要的人花还不够。所以我要@更加努力……做出更漂亮的花束来。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"id":303000,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":303000,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":400,"pos":1,"voice":"vo_char_3030_00_30","textHome":"稍微等我一下好吗？马上就收拾好工作啦！@然后再一起出发吧？"}]},{"autoTurnFirst":2.0,"chara":[{"id":303000,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_31","textHome":"我呢，无论是花店的工作还是花束的设计，@都还想做下去。带着这个想法，无论怎样的@敌人我都感觉可以打倒。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"id":303000,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_24":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_32","textHome":"自以为是可不行哦。要照顾对方的心情……@只有团结一心，才能带着笑脸迎接胜利。"}]},{"autoTurnFirst":4.4,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":2.7,"chara":[{"id":303000,"motion":200}]}],"group_25":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303000,"motion":200,"pos":1,"voice":"vo_char_3030_00_33","textHome":"「鲜花易逝」这句话很常见呢……但是像是@保鲜花之类的，能让花长期保存的方法也@有很多哦？"}]},{"autoTurnFirst":0.9,"chara":[{"id":303000,"motion":0}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000}]},{"autoTurnFirst":1.9,"chara":[{"id":303000,"motion":400}]},{"autoTurnFirst":1.9,"chara":[{"id":303000,"motion":1}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_34","textHome":"不久前，收到了许久不见的人送的花。收到花@真是太令人开心啦……！"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"id":303000,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_27":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_35","textHome":"为了守护阿姨和花店……这是我成为魔法少女@的理由。所以，每当能和她一起工作，我就@会感到很开心。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":303000,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_28":[{"autoTurnFirst":0.9,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":400,"pos":1,"voice":"vo_char_3030_00_36","textHome":"呀！啊，我在想新肥料的事情……所以被@吓了一跳……！"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":2,"id":303000}]},{"autoTurnFirst":1.6,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":303000}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1}]}],"group_29":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_37","textHome":"枫和佳子应该差不多快到店里来了吧！有和@她们说过话吗？她们既温柔又可爱哦。"}]},{"autoTurnFirst":2.5,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000,"motion":400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_04","textHome":"为了能让大家更喜欢花，我们都这么努力了…"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303000}]}],"group_30":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":0,"pos":1,"voice":"vo_char_3030_00_38","textHome":"枫她对植物很熟悉啊，尤其是蔬菜来着？要是@用蔬菜花来做花束，不知道什么时候能有@成果呢……你怎么看？"}]},{"autoTurnFirst":2.7,"chara":[{"id":303000,"motion":100}]},{"autoTurnFirst":3.6,"chara":[{"id":303000,"motion":1}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303000,"motion":400}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303000,"motion":1,"pos":1,"voice":"vo_char_3030_00_39","textHome":"今天……读读佳子推荐的这本书吧。我喜欢一@边泡澡，一边悠闲地看书。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303000,"