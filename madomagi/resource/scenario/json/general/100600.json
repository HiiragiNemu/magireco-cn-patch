{"story":{"group_1":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_01","textHome":"我叫梓美冬。以前和小八在一个队伍，现在@因为个人原因独自生活，同时关照着其他人。@虽然经常被当作一个会照顾人的好姐姐，@其实家务全都不会做。@因为我并不成熟呢，呵呵。"}]},{"autoTurnFirst":6.1,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":7.9,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_18","textHome":"之所以玛吉斯有必要让我离开家工作，@是因为我做了七年的魔法少女，@语言很有说服力哦。"}]},{"autoTurnFirst":7.5,"chara":[{"id":100600,"motion":100}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_19","textHome":"这样就更加感到某种意义上的幸福了呢。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":100600,"motion":300}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_20","textHome":"不要悲观，再相信自己一点也不错的样子。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_13":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_21","textHome":"虽说力量已经衰退，@但是比起各位黑翼，也还是更强一些。@所以，我一定要守护她们。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]}],"group_14":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_22","textHome":"我不会屈服的，决不会被自己背负的罪压垮。@正因如此……哪怕把小八和羽翼们也卷进来@也要拯救她们。这种觉悟已经做好了。"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":5.3,"chara":[{"id":100600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"id":100600,"motion":1}]}],"group_15":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_23","textHome":"如果，没能解放他人，@没完成背负罪行的责任，那我只能以死谢罪。@如果那样也不能被原谅的话，@那就找到更多能拯救所有人的新路线……@以此来赎罪……"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":1}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_24","textHome":"怎么了吗？@感觉还是不要经常到我这里来比较好……@真没办法，喝个茶还是可以陪你的啦。"}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600}]},{"autoTurnFirst":3.0,"chara":[{"id":100600,"motion":1}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_17":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_25","textHome":"这个点还起不来哦……@有人能来叫醒我吗？@不然又要睡过去啦……"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]}],"group_18":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_26","textHome":"午饭后，稍微活动一下身体是我每天的习惯。@意外的是，好像也能算作是运动了？@虽然只是业余爱好啦。"}]},{"autoTurnFirst":4.9,"chara":[{"id":100600,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_19":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_27","textHome":"这下玛吉斯分配的任务就全部完成了。@之后就去便利店买下晚饭，@然后去看看黑翼们怎么样了吧。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_2":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_03","textHome":"我已经背负了太多，@无法离开玛吉斯之翼了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_20":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_28","textHome":"日本的房屋太明亮了，@睡前最好不要用直射光源。@我就看看书，等着自然困吧。"}]},{"autoTurnFirst":6.2,"chara":[{"id":100600,"motion":100}]}],"group_21":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_29","textHome":"作为年长者，@有时间的话就会想去组织内到处看看。@毕竟也有对玛吉斯抱有不满的白翼在……"}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]}],"group_22":[{"autoTurnFirst":8.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_30","textHome":"无论是普通的魔法少女，@还是追寻着解放的魔法少女，@都会收集悲叹之种。@我们一起去吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100600,"motion":400}]}],"group_23":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_31","textHome":"虽说只是复制品，但若是和认识的人战斗，@自然会有犹豫。这个魔女，一直都没有改变。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300}]}],"group_24":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_32","textHome":"团体作战的话就让我在后方支援吧。@诶，可不是想看戏啊，@这是扩大幻觉影响范围的策略哦？"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_33","textHome":"买了新衣服，就会期待起假期来，@想早点穿出门吧？@啊，但还是室内吧。弄脏就不好了。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":100600,"motion":1}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_34","textHome":"我喜欢在咖啡厅悠闲地读书。@我现在在读井原西鹤的《好色五人女》。@因为突然想读古典的纯爱文学啦。"}]},{"autoTurnFirst":6.1,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_27":[{"autoTurnFirst":6.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_35","textHome":"我的本家是水名区的绸缎店，经营得很不好。@所以我跟月夜有些共鸣。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":100600,"motion":100}]}],"group_28":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_36","textHome":"独自生活之后，感觉小八好厉害啊。@每天打扫那么大的房子，@感觉我做半小时就受不了了。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]},{"autoTurnFirst":8.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_37","textHome":"我在三日月别墅的时候，是被大家娇惯的对象，@但是小八常说“生气也能被人惯着，真好”。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600}]}],"group_3":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_04","textHome":"如果让小八加入的事已经没有希望的话，@我……"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_30":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_38","textHome":"有点怀念小八她奶奶了……@她是一个能温和地抚慰人心的人，@也好怀念加奈惠……"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.2,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100600}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_39","textHome":"回顾过去就会明白，我能找到喜欢的人，@其实是借了梅露占卜的契机吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":100600}]}],"group_32":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_40","textHome":"达成解放的话，我就能救到很多人。@不仅有我、小八还有黑翼们的心，@还有我作为一个女孩的幸福……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_33":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_41","textHome":"诶，啊，不要看我！@再不转过去我就要生气了！？@维持身材可是需要付出常人以上的关注的！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100600,"motion":400}]},{"autoTurnFirst":2.6,"chara":[{"id":100600,"motion":200}]},{"autoTurnFirst":5.8,"chara":[{"id":100600,"motion":100}]}],"group_34":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_42","textHome":"作为年长者，我站在前面的。"}]}],"group_35":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_43","textHome":"还好大家都没事。"}]}],"group_36":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_44","textHome":"如果是以前，还能再努力一点的。"}]}],"group_37":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_45","textHome":"但愿这胜利并不是我的幻觉。"}]}],"group_38":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_46","textHome":"也许我能更加自信了吧。"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_63","textHome":"偏执袭击！"}]}],"group_4":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_05","textHome":"拜托了……只要能完成这一切，@两人就都能被拯救了……"}]}],"group_40":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_64","textHome":"跨越现实与梦的界限，品味这幻觉的世界吧。"}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":3.8,"chara":[{"id":100600}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_65","textHome":"用溢出的血滋润这干枯的世界。"}]}],"group_42":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_66","textHome":"清醒是一种幸福哦。"}]}],"group_43":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_02","textHome":"我已经是魔力衰退的魔法少女了哦……@这样也不要紧的话，那就请多关照啦。@好的，我叫梓美冬。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":1}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_13","textHome":"哎呀，@感觉好像回到了像以前那样的水平呢。"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_6":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_14","textHome":"每天为了不退化而努力锻炼是很重要的哦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_7":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_15","textHome":"努力到这个程度，@还默不作声的话就说不过去了呢。"}]}],"group_8":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_16","textHome":"其实我一边独自生活，@一边也在以考取药学部为目标。@虽然这是获得奖学金的条件，@但还是很奇怪吧？"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_9":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_17","textHome":"我所获得的奖学金，@其实是某位玛吉斯为我做的项目。@但是，我也得认认真真去争取考上药学部。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]}]},"version":3}