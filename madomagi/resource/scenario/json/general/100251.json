{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_01","textHome":"自从成为魔法少女，我就一直在神滨市战斗。@拥有过快乐，但记住的却都是悲伤与心酸。@这是因为这类记忆更容易被记住吧……@但我一定要继续活下去。如果在这里放弃，@就等于否定了过往自己所坚持的这条路。"}]},{"autoTurnFirst":9.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":301}]}],"group_10":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":400,"pos":1,"voice":"vo_char_1002_00_18","textHome":"居然能做到这样……自己都有点吃惊。@比起所预想的，原来自己还能有更多潜力……"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":0}]}],"group_11":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_19","textHome":"了解了……我还能提升自己。"}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_20","textHome":"感觉还有上升的动力。挺不错。"}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":100}]}],"group_13":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_21","textHome":"对于当了很多年魔法少女的我来说，@也许“经验”才是最大的魔法。@今后要更善于在战斗中利用这份“经验”……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100200,"motion":301}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_22","textHome":"在思考之前身体就自然地行动了。@仿佛脑海中的记忆早已融入进骨血中一般。@这种感觉，虽然有些不可思议，@但除此以外我想不到其他更贴切的形容了。"}]},{"autoTurnFirst":8.5,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":201}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_23","textHome":"针对对手的一次攻击，最少也能想出十种反击@如今的我也拥有了这样广阔的眼界。@无论是现实中，还是精神上。@毫无疑问，这就是最佳的状态。"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100200,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_51_24","textHome":"去海边的准备已经做充分了。该期待的时候，@要好好期待，这是重点。……诶？我吗？@当然了，这是我今天最期待的一件事。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":201}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}]}],"group_17":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_51_25","textHome":"早上好。@虽然是暑假，但还是没有贪睡乖乖起床了啊。@虽然说起来也算是理所应当的，@但还是觉得挺厉害的呢。"}]},{"autoTurnFirst":5.3,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":100}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_51_26","textHome":"不能因为天热就拼命吃冷的东西哦。@所以午饭为大家准备的是咖喱，@还放了不少时蔬。"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":201}]},{"autoTurnFirst":2.7,"chara":[{"id":100200,"motion":100}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_51_27","textHome":"等到天黑，我们就在海边生起营火吧。@要在太阳落山之前做好准备，@你也来帮忙吧。"}]},{"autoTurnFirst":3.5,"chara":[{"id":100200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":200}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_03","textHome":"决斗少女，这件事太让人不安了……@会是什么样的人呢？"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":100}]}],"group_20":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_51_28","textHome":"能听见烟花升空的声音呢。@是哪里在开烟花大会呢？@不远的话说不定能看到，要去看看吗？"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100200}]}],"group_21":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":100,"pos":1,"voice":"vo_char_1002_51_29","textHome":"怎么样，玩得开心吗？@在夏天的海边想做的事情很多，@时间根本不够用的感觉。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":100200}]}],"group_22":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":300,"pos":1,"voice":"vo_char_1002_51_30","textHome":"很遗憾，看来不能一直玩下去了。@尽快退治魔女，然后回海边吧。"}]},{"autoTurnFirst":1.7,"chara":[{"id":100200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":201}]}],"group_23":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":300,"pos":1,"voice":"vo_char_1002_51_31","textHome":"镜之结界，即使在夏天也很凉爽呢……@但这次可不是来乘凉的，开始调查吧。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100200}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_51_32","textHome":"虽然这样的热天还在持续，@倒是意外地聚集了不少人呢。@为了不输给这天气，打起精神来吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":201}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_51_33","textHome":"好像有能跳水的地方。@虽然在游泳池跳过了，但在海里还是头一回。@你也要试试吗？"}]},{"autoTurnFirst":4.5,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"id":100200,"motion":100}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_51_34","textHome":"沙山平衡棒？可以。@我就擅长这种考验注意力的游戏。@不会输……你们准备的沙山可真够大的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"id":100200,"motion":201}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":100200}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":301}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_014.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_51_35","textHome":"一边喝着冰凉的波子汽水，@一边在沙滩伞下稍事休息，还真是有情调。@你的那一份汽水也准备了哦。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":100200}]},{"autoTurnFirst":1.5,"chara":[{"id":100200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":100}]}],"group_28":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_51_36","textHome":"游累了，来拾漂流物怎么样？@贝壳、海玻璃这些独一无二的东西有很多呢。"}]},{"autoTurnFirst":1.8,"chara":[{"id":100200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":201}]}],"group_29":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_51_37","textHome":"喂，等等，菲莉西亚！@就算说糖浆随便加，但也不能全都加下去啊！@啊，真是的！这刨冰都成什么颜色了。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":400}]},{"autoTurnFirst":4.5,"chara":[{"id":100200,"motion":300}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_04","textHome":"要是认真动起手来就太危险了……@我们的实力相差无几……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100200,"motion":300}]}],"group_30":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_51_38","textHome":"觉悟吧，鹤乃。@先动手的是你……若有怨的话，就怨自己吧。@啪！其实没有声音，因为是水枪。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100200,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"id":100200,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":100}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_51_39","textHome":"还好找到了冷门的海水浴场。@要是人太多，二叶就要被挤傻了。@难得的机会，要让大家都能好好享受才是。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100200,"motion":301}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100200,"motion":200}]}],"group_32":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_042.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_51_40","textHome":"奇怪……不合理啊。@人正常是会浮在海面上的……@但是为什么，无论尝试多少次，@彩羽总是会往下沉呢？"}]},{"autoTurnFirst":4.5,"chara":[{"id":100200,"motion":201}]},{"autoTurnFirst":2.5,"chara":[{"id":100200,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100200}]}],"group_33":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_51_41","textHome":"在海边拍性感写真？这个还是算了……@既没有做过，也没有这个想法。@不是我的风格……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100200}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":301}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"id":100200,"motion":300}]}],"group_34":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_42","textHome":"战斗是魔法少女的宿命……"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_43","textHome":"又活下来了呢……"}]}],"group_36":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_44","textHome":"就结果来说……不错。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":100200,"motion":301,"pos":1,"voice":"vo_char_1002_00_45","textHome":"我不能……在这倒下！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":400}]}],"group_38":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_46","textHome":"我一定会保护她们……"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_63","textHome":"在这里……做好觉悟吧……我会使出全力！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_05","textHome":"魔女也会耍各种手段啊……@今后得用心防备才行……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_40":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_64","textHome":"我不打算有所保留了！"}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_65","textHome":"不说坏话，就到这里结束吧！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":200}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":200,"pos":1,"voice":"vo_char_1002_00_66","textHome":"……在我的时间里，用这一击……！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":400}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":1,"pos":1,"voice":"vo_char_1002_00_02","textHome":"我是七海八千代。首先……请多关照。@在这神滨市生存下去，并不是件容易的事。@做好觉悟了吗？"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100200,"motion":201}]},{"autoTurnFirst":3.2,"chara":[{"cheek":-1,"face":"mtn_ex_021.exp.json","id":100200,"motion":200}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_13","textHome":"最重要的，是脚踏实地……"}]},{"autoTurnFirst":6.0,"chara":[{"id":100200,"motion":200}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_14","textHome":"量变引起质变……就是这么回事。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200,"motion":100}]}],"group_7":[{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":201,"pos":1,"voice":"vo_char_1002_00_15","textHome":"要想生存下去，力量是必要的。"}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_16","textHome":"即使到了这个岁数，@通过锻炼也还有提升魔力的潜力。@不过，能有多少程度呢……@不，无论如何都要做下去。"}]},{"autoTurnFirst":5.0,"chara":[{"id":100200,"motion":301}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_011.exp.json","id":100200,"motion":201}]}],"group_9":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100200,"motion":0,"pos":1,"voice":"vo_char_1002_00_17","textHome":"……嗯，感觉到了。@能够运用相当强大的魔力了……@不过一定还能提升，把它磨练到底吧。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100200}]},{"autoTurnFirst":4.0,"chara":[{"id":100200,"motion":201}]}]},"version":3}