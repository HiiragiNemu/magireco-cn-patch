{"story":{"group_1":[{"autoTurnFirst":10.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_01","textHome":"无论是达成了什么亦或是被他人所称赞，@我都不会放在心里，换做相反的事态也一样。@即使有人说我没有感情，我还是不为所动。@无论发生什么，我都心如止水。虽然这样的生活@非常平静，但也非常无趣。"}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"id":302900,"motion":200,"pos":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":302900,"motion":0,"pos":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":300,"pos":1}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_18","textHome":"不怎么看电视。因为觉得没有真实感，也不会@让人心动。我更偏爱能亲身体会的事情。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200}]}],"group_11":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_19","textHome":"感受到了……力量的涌动。现在的心情也……@好像有些兴奋的样子。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":200}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_20","textHome":"略微有点心动……这能让我的日常发生一些@变化吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_13":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_21","textHome":"仅仅是探寻自己，是找不到生存的意义的。@透过与他人的联系，才能在普世中找到喜悦。@这就是我目前的答案。"}]},{"autoTurnFirst":7.0,"chara":[{"id":302900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":200}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_22","textHome":"我曾经觉得死去，也只是我的命运而已。@而且，我的生死也是我自己的事情。……但是@如果我的死，会成为他人的伤痛的话，@那我就应该抗争到底。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_15":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_23","textHome":"无数次重复的早晨，刻在眼中那熟悉的景色…@因为一个小小的因素全都得以改变。虽然@只是一个站不住脚的假说，却这是我短暂@人生里最有兴趣的命题。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"id":302900,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200}]}],"group_16":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_24","textHome":"来了啊。没什么，并没有觉得心情压抑。@我……看起来很郁闷吗？可我其实既不郁闷，@也不开心。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":1}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_25","textHome":"有人说清爽的早晨……也有人说忧郁的早晨…@真是不可思议。明明就是重复了无数次的@相同的事情而已。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":302900,"motion":100,"pos":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_26","textHome":"午饭还没吃吧。不，没有在邀请你。和我一起@吃饭……只会很无聊的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":302900,"motion":200}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_27","textHome":"今天……有什么高兴的事吗？说来听听？也许@你所高兴的事情，可以成为帮我从这无聊@生活中的摆脱出来的救命稻草呢。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":302900,"motion":200}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_03","textHome":"就算没有我，对她也没什么坏处才对。"}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_28","textHome":"不睡觉吗？不，并没有打扰到我哦。如果我真的@那么想，就会用更直接的言语了。你请随意，@我也只是随便看看而已。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_29","textHome":"战斗很可怕吗？为什么？因为伴随着痛苦吗？@……也对，痛苦是会让人不愉快。但是，@不愉快和恐怖还是有区别的吧？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":302900,"motion":0}]}],"group_22":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_30","textHome":"差不多该动身了，还是要遵循指示的，因为@那就是魔法少女的使命。我既不觉得恐惧@也不觉得麻烦，那是理所应当的事情。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":302900,"motion":0}]}],"group_23":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_31","textHome":"就算身形与我们一致，也没有必要觉得@于心不安。敌人就是敌人，身份并不只在于外表。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302900,"motion":0}]}],"group_24":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_32","textHome":"这是和伙伴的对战。要留心展现出相应的热情@才行。即便是换做并肩作战的时候，这件事@也很重要。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":302900,"motion":200}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_33","textHome":"虽然是负面的东西……但魔女也是某种生命力@旺盛的存在。每次战斗时……都能感受到@压倒性的力量。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":300}]}],"group_26":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_34","textHome":"就我而言……是打算努力的。有时候会去尝试@发掘兴趣，但是并不顺利呢"}]},{"autoTurnFirst":6.0,"chara":[{"face":"mtn_ex_011.exp.json","id":302900,"motion":0}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":400,"pos":1,"voice":"vo_char_3029_00_35","textHome":"有喜欢的事情吗？如果有，具体是什么呢？@告诉我吧。还有是怎么发现它的？又为什么会@喜欢上它呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":302900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":302900,"motion":0}]}],"group_28":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_36","textHome":"不过分执着，就不会产生愤怒的情绪。对于@他人来说，我是一个极其无害的存在。@准确来说……也是极其无趣的。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_37","textHome":"游泳的话，有在游哦。所以泳池的气味对我@来说，就是平常的气味。既不令人安心的……@也不是令人厌烦的……平常的气味而已。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"id":302900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_04","textHome":"只要和她在一起……我就会受伤，为什么会@变成这样？"}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_38","textHome":"所见所闻……都无法触动我心弦。第一次@稍稍触动我的……是名为魔法少女的存在。"}]},{"autoTurnFirst":3.2,"chara":[{"face":"mtn_ex_030.exp.json","id":302900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1}]}],"group_31":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_39","textHome":"八云御魂，大概……是魔法少女当中，和我@交流第二多的人。因为她总能用平淡的语言@和我对话。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":100}]}],"group_32":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_40","textHome":"粟根心……她很不可思议。虽然不知道为什么@会和我扯上关系，但是……我不希望她受到@伤害。这一点我是确信的。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"id":302900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":0}]}],"group_33":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_41","textHome":"那时候，我并没有成为魔法少女以外的愿望。@所以我许愿要了钱，因为有钱也不会造成麻烦。"}]},{"autoTurnFirst":6.0,"chara":[{"id":302900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":302900,"motion":200}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_42","textHome":"迎战，仅此而已。"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_43","textHome":"怎么样？胜利是否愉快呢？"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_44","textHome":"这种时候，感到高兴才是正确答案吧。"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_45","textHome":"好在守住了。"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_46","textHome":"现在的心情……要怎么表达出来呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_63","textHome":"不消灭你，誓不罢休。"}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_05","textHome":"第一次开始考虑未来了。虽然我也不明白@为什么会变成这样。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302900,"motion":300}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_64","textHome":"并非什么乐事。把它结束掉吧？"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_65","textHome":"总在重复同样的行动，很无趣吧？"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":300,"pos":1,"voice":"vo_char_3029_00_66","textHome":"也许是改变场面的一击。"}]}],"group_43":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_02","textHome":"加贺见真良，十六岁，高中一年级。身高@162cm，是魔法少女。……除了这些客观@数据，我就没别的可说了。"}]},{"autoTurnFirst":6.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302900,"motion":0,"pos":1,"voice":"vo_char_3029_00_13","textHome":"我想变的更强。因为前方说不定有能让我心动@的东西。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":200,"pos":1}]}],"group_6":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":400,"pos":1,"voice":"vo_char_3029_00_14","textHome":"嗯，感到了充实。跟喜悦……可能还有一些@区别。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":100}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":1,"pos":1,"voice":"vo_char_3029_00_15","textHome":"也许有意去寻找的时候，才更容易心动吧。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"id":302900,"motion":100}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302900,"motion":100,"pos":1,"voice":"vo_char_3029_00_16","textHome":"虽然并没有像是“想打破记录”之类的热情…@…但我还是喜欢游泳。因为在只有气泡声的@水中，神秘且让人心情舒适。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302900,"motion":0,"pos":1}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302900,"motion":200,"pos":1,"voice":"vo_char_3029_00_17","textHome":"举例自己擅长又喜欢的科目的话，现代文吧。@因为我觉得了解人的心理，有可能成为@改变日常的契机。"}]},{"autoTurnFirst":7.2,"chara":[{"id":302900,"motion":1}]}]},"version":3}