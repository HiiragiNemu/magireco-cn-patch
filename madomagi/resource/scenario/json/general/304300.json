0,"face":"mtn_ex_050.exp.json","id":304300}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304300,"motion":100,"pos":1,"voice":"vo_char_3043_00_63","textHome":"自变化中获得，秘剑在此展现。"}],"deleteArmatureList":[1,2]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":304300,"motion":100,"pos":1,"voice":"vo_char_3043_00_64","textHome":"这一刀，是为了重要的人们。"}],"deleteArmatureList":[1,2]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304300,"motion":400,"pos":1,"voice":"vo_char_3043_00_65","textHome":"呀——！"}],"deleteArmatureList":[1,2]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304300,"motion":1,"pos":1,"voice":"vo_char_3043_00_66","textHome":"就这样在你身上刻下我的物语。"}],"deleteArmatureList":[1,2]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304300,"motion":300,"pos":1,"voice":"vo_char_3043_00_05","textHome":"｜那样的人，可以称之为朋友吗？｜"}],"deleteArmatureList":[1,2]}],"group_6":[{"autoTurnFirst":2.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304300,"motion":100,"pos":1,"voice":"vo_char_3043_00_13","textHome":"暖洋洋的。也许我的内心也有花在绽放吧。"}],"deleteArmatureList":[1,2]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":304300}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304300,"motion":1,"pos":1,"voice":"vo_char_3043_00_14","textHome":"初绽、盛开、樱花烂漫。我的心中充满了绽放@的花蕾。"}],"deleteArmatureList":[1,2]},{"autoTurnFirst":3.0,"chara":[{"id":304300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304300,"motion":100}]}],"group_8":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304300,"motion":1,"pos":1,"voice":"vo_char_3043_00_15","textHome":"我才刚诞生不久，从来没说过那么多话哦。"}],"deleteArmatureList":[1,2]}],"group_9":[{"autoTurnFirst":7.0,"ch