{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_01","textHome":"我是天音月咲！嗯，要简洁地介绍清楚的话，@我是月夜的双胞胎妹妹，平时在工匠区的@一家竹工房，随父亲和学徒们生活。@且不说家里全是男性，把家务都丢给我是什么@意思啊！最近因为这个有些生气……诶嘿。"}]},{"autoTurnFirst":12.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_18","textHome":"太好了！终于有了新家伙……@心心念念的电动车到手了！@靠它就能从繁重的家务里稍微解放出来了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":101900,"motion":300}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_19","textHome":"我的笛声，还要传得更远！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101900,"motion":100}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_20","textHome":"这样我就能更好地支持月夜姐姐啦！"}]},{"autoTurnFirst":1.5,"chara":[{"id":101900,"motion":100}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_21","textHome":"爸爸挺可怕的……但是能靠笑容@让周围的人振作起来这点值得尊敬。@我也是靠笑来冲淡难过的哦。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_22","textHome":"月夜姐姐总是在忍受着各种事情吧？@所以我呢，会像这样笑着和她相处。@只要我这样充满活力的样子，@能让月夜姐姐的忍耐好受一些，@哪怕只有一点也好，我都会很开心。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_23","textHome":"只要微笑着面对，从这束缚中解脱出来，@就能变得幸福了。正因为相信着这些，@我才会这样朝着目标努力。因为，说过了吧？@笑门开幸福来……对吧。"}]},{"autoTurnFirst":5.5,"chara":[{"id":101900,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_16":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_24","textHome":"啊，终于来了！对，这包东西我一个人拿@太重了，可以帮个忙吗？我家工房里，@大家都很能吃，光采购食材就很费工夫了。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300}]}],"group_17":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_25","textHome":"早上真是太要命了。要把报纸放在@爸爸的书桌上，准备好大家的早饭，@到点还得去叫大家起床，都快成老板娘了吧？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":300}]}],"group_18":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_26","textHome":"午饭的话……月夜姐姐今天又在医务室吃吗？@这样想来，有朋友真是一件好事啊。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101900}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_19":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_27","textHome":"好嘞，出发吧电动车初号机。@为了让学徒们吃上好吃的，@可不能错过傍晚的限时特卖呢。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":101900,"motion":200}]}],"group_2":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_03","textHome":"在肉店排队的是……七海八千代……"}]}],"group_20":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_28","textHome":"虽说从出生就一直在这间工房了，@但毕竟全是男人对吧？@到洗澡之类的时候，果然是会有点紧张……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101900,"motion":300}]}],"group_21":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_29","textHome":"这个，是木别针。@在稍微有空的时候一点一点做出来的。@诶嘿，发现啦？和月夜姐姐的是一对哦。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":101900,"motion":100}]}],"group_22":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_30","textHome":"差不多，该去打魔女了吧。@啊，不用在意我这边的时间。@家里的事情已经安排好了。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":101900,"motion":1}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_31","textHome":"就算是遇到了月夜姐姐的复制品，@我也能马上看穿。@因为我们已经通过愿望紧密联系在了一起。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900,"motion":1}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_32","textHome":"虽然有意给人留下爱笑又朝气蓬勃的印象，@但真正能信赖的人只有月夜姐姐。@无论变成怎样的混战，我都会相信她到最后。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_33","textHome":"买东西路上那家杂货铺，是我很喜欢的地方。@木制的小玩意很讨人喜欢，@我就稍微模仿着做出来了。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":101900,"motion":1}]}],"group_26":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_00_34","textHome":"不行，没有能像那样玩个够的时间啊！@虽然拿不出大段的时间很不好意思，@但因为是家里的事情，我也没办法啊。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":200}]}],"group_27":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_35","textHome":"总觉得，好像时不时地会在我偶尔去的那间@便宜又好吃的肉店看见七海八千代的样子……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_36","textHome":"其实，我也有向往的东西……@哪怕是一次也好，想睡在床上。@对，不是地铺而是在床上，美美地睡一觉。"}]},{"autoTurnFirst":1.5,"chara":[{"id":101900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101900}]},{"autoTurnFirst":6.0,"chara":[{"id":101900,"motion":100}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_37","textHome":"妈妈离开这个家的理由，我很理解。@我觉得她能在这个重男轻女的地方忍受这么久@已经很厉害了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_04","textHome":"爸爸如果能告诉我就好了……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":300}]}],"group_30":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_38","textHome":"我好像并不是独生女，@跟爸爸聊过之后就一直这么感觉……@没想到真的有一个姐姐……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":300}]}],"group_31":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_39","textHome":"藏着秘密的这支笛子，@对我、对月夜姐姐都是宝物。@所以首先还是要感谢爸爸的。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":200,"pos":1,"voice":"vo_char_1019_00_40","textHome":"为什么要问关于玛吉斯之翼的事情啊？@虽然让你知道真相之后会怎么样是另一回事，@但我们没有谈论它的权利，抱歉哦。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900}]}],"group_33":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300,"pos":1,"voice":"vo_char_1019_00_41","textHome":"啊——赶紧离开这个家，@做一个普通的女孩子，@跟月夜姐姐一起生活多好啊——"}]},{"autoTurnFirst":4.0,"chara":[{"id":101900,"motion":1}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_42","textHome":"好，演奏开始了！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_43","textHome":"大家辛苦了！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_44","textHome":"这也是因为我充满了活力！"}]}],"group_37":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_45","textHome":"演奏结束，感谢！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_46","textHome":"就不用再来一曲了吧？"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_63","textHome":"我不喜欢争吵。所以，就用它结束掉吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101900,"motion":200}]}],"group_4":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_05","textHome":"我的同伴仅有月夜姐姐一人，@从今往后都要在一起。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_64","textHome":"为了梦想，牺牲在所难免……"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":200}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_65","textHome":"难道我不能渴望幸福吗!?"}]}],"group_42":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_66","textHome":"忍受至今的心情……就在这一击当中……！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101900,"motion":200}]}],"group_43":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":0,"pos":1,"voice":"vo_char_1019_00_02","textHome":"我是天音月咲！虽然平时太忙，除了晚上以外@没什么时间，但还是想靠笛声我的笑脸@让大家精神起来，请多指教！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_13","textHome":"不可以辜负努力和活力，还有月夜姐姐！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101900,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_14","textHome":"这就是凭着一股锐气，没有被挫败的结果哦！"}]}],"group_7":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":1,"pos":1,"voice":"vo_char_1019_00_15","textHome":"用笛声做背景音乐如何……@啊，吹笛子的时候说不了话呀。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":0}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_16","textHome":"好嘞，有了这自行车，采购就好办了！@前后左右都加上竹篓子，@十人份的食材也能买回来了！"}]},{"autoTurnFirst":6.0,"chara":[{"id":101900,"motion":1}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":101900,"motion":100,"pos":1,"voice":"vo_char_1019_00_17","textHome":"这就是十人份的食材！呼……@要一口气买够男人的食量真是体力活……@但是，我不会输的！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101900,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101900,"motion":200}]}]},"version":3}