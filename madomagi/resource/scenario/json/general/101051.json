{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_00_01","textHome":"我是十咎桃子！十六岁，高中一年级。@估计是因为和兄弟一起混养着长大的……@所以不知道我该算做是假小子还是粗神经。@嘛，不过这样也有好处，就是很擅长运动了。@还有，喜欢……偶、偶像……"}]},{"autoTurnFirst":2.1,"chara":[{"id":101000,"motion":0}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":300}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"id":101000,"motion":100}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"id":101000}]},{"autoTurnFirst":2.4,"chara":[{"cheek":2,"id":101000}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_00_18","textHome":"依靠大家的帮助，我才能达到这个程度。@所以我会为了大家使用这个力量。@为了大家，一直战斗下去。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101000,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"id":101000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":101000,"motion":200}]}],"group_11":[{"autoTurnFirst":0.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_00_19","textHome":"才到这可不算完！我还能往前冲！"}]},{"autoTurnFirst":1.4,"chara":[{"id":101000,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000,"motion":0}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_00_20","textHome":"好嘞！早点去试试这力量吧！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":2.0,"chara":[{"id":101000,"motion":100}]}],"group_13":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":1,"pos":1,"voice":"vo_char_1010_00_21","textHome":"我已经不是一个人了。有大家的陪伴……@我一定要不断变强才行。@因为，我想要守护大家。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101000}]},{"autoTurnFirst":2.0,"chara":[{"id":101000,"motion":0}]}],"group_14":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_00_22","textHome":"为了守护重要的家人和朋友，@除了变强别无他法！@不仅仅是身为魔法少女的成长，@看这强健的腕力、能干的性格，@也挺不错的，对吧！"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101000,"motion":200}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":2.2,"chara":[{"id":101000,"motion":100}]}],"group_15":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_00_23","textHome":"可别说我是不凑巧的十咎桃子了哦？@就算是遇上不凑巧的战斗，也能出奇制胜！@在无敌的力量面前凑巧与否根本就没关系嘛！"}]},{"autoTurnFirst":2.0,"chara":[{"id":101000,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"id":101000,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"id":101000,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_51_24","textHome":"哦，来啦！呀~这大热天真是辛苦你了。@不用那么着急也没关系的。@首先补充下水和盐分吧！之后再说话！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_51_25","textHome":"今天准备玩点什么？@打西瓜、沙滩排球、堆沙堡……@海边能做的事情很多，太好玩了！@哦？长距离游泳我也欢迎！"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200}]}],"group_18":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_51_26","textHome":"嗨，久等啦！@炒面、什锦烧还有章鱼烧。还有炸鸡和烤串。@啊——虽然颜色比较单调，但好吃！"}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":100}]}],"group_19":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_51_27","textHome":"哦！看天空！@在海边看到的夕阳也很不错啊……@虽然和平时的夕阳是一样的，@但也算是特别的景色。"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":101000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":300}]}],"group_2":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":1,"pos":1,"voice":"vo_char_1010_00_03","textHome":"每次都这样，我总赶上坏时机。有点好笑。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000,"motion":300}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_51_28","textHome":"今天游了好远啊！呜……好疼！@哇，这里被晒伤了吗……@因为太得意忘形了吧？"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":101000,"motion":400}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101000}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101000,"motion":300}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_51_29","textHome":"下次还想和大家一起去夏季旅行！@在海边玩，吃烤肉，放烟花，然后睡觉！@满满都是暑假的感觉~"}]},{"autoTurnFirst":3.2,"chara":[{"id":101000,"motion":1}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]},{"autoTurnFirst":4.0,"chara":[{"id":101000,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_51_30","textHome":"出发吧！今天的目的地是神滨市营游泳池。@玲奈好像想挑战一下滑水道……@我……就不去了吧。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":101000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000,"motion":300}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":100,"pos":1,"voice":"vo_char_1010_51_31","textHome":"诶~大家都穿着可爱的泳装来了啊！@真不错，都特别合适。@还有熟悉的面孔，得去打个招呼。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":101000,"motion":200}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":1,"pos":1,"voice":"vo_char_1010_51_32","textHome":"哇——这么多人一通拥挤，会走散的吧。@还好吗？要紧紧跟着我哦！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":200}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_51_33","textHome":"啊，这个声音是……有了有了，是风铃摊位。@虽然可能有点让人意外，但我很喜欢这种。@样子又漂亮，声音又好听……很治愈的。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":101000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101000}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":0,"pos":1,"voice":"vo_char_1010_51_34","textHome":"好、好可爱！@啊，这……那边的小马游泳圈，好可爱啊……@算了，反正跟我不搭！"}]},{"autoTurnFirst":1.0,"chara":[{"id":101000,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101000}]},{"autoTurnFirst":5.5,"chara":[{"id":101000,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"id":101000,"motion":300}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":300,"pos":1,"voice":"vo_char_1010_51_35","textHome":"哈……突然下雨真是吓坏我了。@能躲雨的地方也没有，@这种地方发动“坏时机桃子”真的是……"}]},{"autoTurnFirst":3.5,"chara":[{"id":101000,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":101000,"motion":1}]}],"group_28":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":200,"pos":1,"voice":"vo_char_1010_51_36","textHome":"要吃冰棒吗？@嗨，这热天玲奈和枫都蔫了，我给她们买的。@你看，有这么多，选个喜欢的口味吧？"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101000,"motion":100,"pos":1,"voice":"vo_char_1010_51_37","textHome":"调整专家也去过海边吗？@那家伙怎么看都是个室内派，不像是去过。@好，下次邀请她一起去吧！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":200}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101000,"motion":400,"pos":1,"voice":"vo_char_1010_00_04","textHome":"诶!?她也是魔法少女吗!?@还有这种巧合!?"}]},{"autoTurnFirst":2.5,"chara":[{"id":101000,"motion":300}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1,"pos":1,"voice":"vo_char_1010_51_38","textHome":"枫送来了自家的西瓜，真的很好吃！@虽然挺大的，但是跟老弟们一起吃，@瞬间就吃完了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101000,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101000,"motion":300}]}],"group_31":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101000,"motion":1,"pos":1,"voice":"vo_char_1010_51_39","textHome":