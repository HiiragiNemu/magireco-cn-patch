.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":2.7,"chara":[{"id":130102,"lipSynch":1,"motion":0},{"id":130100,"lipSynch":0,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":130102,"motion":201}]}],"group_17":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":130102,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_1301_02_24","textHome":"欢迎。@彩羽和友爱3人组一起去万年樱那里了。@关系好是不错，但是偶尔也会有点嫉妒呢。"}]},{"autoTurnFirst":4.9,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130102}]},{"autoTurnFirst":2.0,"chara":[{"id":130102,"motion":301}]}],"group_18":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":130102,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_1301_02_25","textHome":"要在早上打扫卫生，@一天才能有一个心情愉快的开始。@啊，吸尘器又吸到什么东西……@十龙珠贴纸么……又不好好收拾……"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":130102,"motion":200}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130102}]},{"autoTurnFirst":4.0,"chara":[{"id":130102,"motion":300}]}],"group_19":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":1,"motion":301,"pos":1,"voice":"vo_char_1301_02_26","textHome":"午饭怎么办呢？@啊，这么说来彩羽有说过，@有昨天做好的筑前煮。@那我就不客气了。"}]},{"autoTurnFirst":0.6,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":130102,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]},{"autoTurnFirst":2.5,"chara":[{"id":130102,"motion":100}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":0,"motion":0,"pos":1,"voice":"vo_char_1301_00_02","textHome":"我们啊，现在要两个人一起去狩猎魔女了。@可以的话你也一起怎么样？@我想一定不会有什么坏处的。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130100,"lipSynch":1,"motion":100,"pos":0,"voice":"vo_char_1301_00_02","textHome":"我们啊，现在要两个人一起去狩猎魔女了。@可以的话你也一起怎么样？@我想一定不会有什么坏处的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":130102,"lipSynch":1,"motion":200},{"id":130100,"lipSynch":0,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]}],"group_20":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130102,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_1301_02_27","textHome":"哈……啊……真危险……@差一点就错过了限时大甩卖。@这个猫形的巧克力，就买给二叶好了。"}]},{"autoTurnFirst":1.1,"chara":[{"eyeClose":1,"id":130102}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"id":130102,"motion":200}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130102}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":1}]}],"group_21":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":130102,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_02_28","textHome":"灯还亮着……彩羽应该还在学习吧……@嗯，这种时候应该准备夜宵呢。@果然还是该做乌冬面吧？"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130102,"motion":301}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp.json","id":130102}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":130102}]}],"group_22":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":130102,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_1301_02_29","textHome":"啊，啊，抱歉。我不是在睡觉哦。@只是在闭上眼睛向梅露和加奈惠报告近况。@因为多亏了她们，@我才能有现在的幸福。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130102}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":130102,"motion":300}]}],"group_23":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130102,"lipSynch":1,"motion":201,"pos":1,"voice":"vo_char_1301_02_30","textHome":"好久没有一个人和魔女战斗了。最近感觉彩羽@的支援变得理所应当了，所以必须小心战斗"}]},{"autoTurnFirst":6.0,"chara":[{"id":130102,"motion":200}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":130102,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_1301_02_31","textHome":"无尽镜界里有时也会遇到有趣的复制品呢。@当然也看到过复制的彩羽。@至于是什么样的复制品，那就是秘密了。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130102,"motion":301}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":130102}]}],"group_25":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":201,"pos":1,"voice":"vo_char_1301_02_32","textHome":"真的，有时候我也不知道@鹤乃和菲莉希亚的关系是好是坏。@但是，这也可以说是三日月庄的乐趣吧？"}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130102,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":100}]}],"group_26":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":130102,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_1301_02_33","textHome":"哼哼，今天忧也在唱歌呢。@虽然她经常哼歌，@不过每次听起来都心情很好呢。@怎么说呢，姐妹都是治愈系的呢"}]},{"autoTurnFirst":0.7,"chara":[{"eyeClose":1,"id":130102}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":5.3,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":130102,"motion":200}]}],"group_27":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_1301_02_34","textHome":"唔……怎么办呢……@二叶说也想要像彩羽一样的直发，@但是带她去美容院有点难啊……"}]},{"autoTurnFirst":5.0,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":130102,"motion":301}]}],"group_28":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_02_35","textHome":"等下，可以尝尝这个吗……？@虽然是鹤乃参考了@彩羽的健康料理后推出的菜式……@但是感觉少放了油也就失去了味道呢。"}]},{"autoTurnFirst":4.5,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":130102,"motion":300}]}],"group_29":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_1301_02_36","textHome":"差不多该去工作了。@今天以街头一隅为舞台，@拍摄神滨市品牌服装特辑。@真希望什么时候，大家能一起上镜啊。"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130102,"motion":201}]}],"group_3":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_00_03","textHome":"也是，大概彩羽会帮我做的。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130100,"lipSynch":0,"motion":0,"pos":0,"voice":"vo_char_1301_00_03","textHome":"也是，大概彩羽会帮我做的。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]}],"group_30":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_1301_02_37","textHome":"一开始没打算去管菲莉希亚是真的。@也很烦恼能不能让她住在我家。@但是呢，最后还是越不省心的孩子越可爱啊。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":130102}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":2.9,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":130102,"motion":100}]}],"group_31":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":130102,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_1301_02_38","textHome":"啊，这个可能非常好。@这种不过分凸显的可爱，@感觉是彩羽喜欢的吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130102,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]}],"group_32":[{"autoTurnFirst":3.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_02_39","textHome":"这是我应该反省的事情……@我如果碰到感兴趣的东西就会忘乎所以对吧？@那个时候，就会忽视周围的事物呢……"}]},{"autoTurnFirst":4.0,"chara":[{"id":130102,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"id":130102}]}],"group_33":[{"autoTurnFirst":0.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130102,"lipSynch":1,"motion":301,"pos":1,"voice":"vo_char_1301_02_40","textHome":"虽然只是偶尔想象一下，@没有彩羽的我，一定会走到魔女那一步吧。@真是深切认识到遇到的人能左右人生的感觉。"}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":130102}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":2.9,"chara":[{"id":130102}]},{"autoTurnFirst":2.9,"chara":[{"id":130102,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":130102,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":130102}]}],"group_34":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":130102,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_1301_02_41","textHome":"啊！真是的，不要吓我了彩羽……@诶，啊，抱歉，没想到会认错人。@前段时间被吓过一次了，情急之下……"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":130102}]},{"autoTurnFirst":0.6,"chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":130102,"motion":0}]},{"autoTurnFirst":4.2,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":130102,"motion":301}]},{"autoTurnFirst":4.0,"chara":[{"id":130102,"motion":300}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130102,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_00_42","textHome":"无论怎样的污秽与诅咒，都在此刻扫清！@嗯，贯穿它们吧，八千代！"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130100,"lipSynch":0,"motion":0,"pos":0,"voice":"vo_