{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_01","textHome":"在下天音月夜。如此场合之下，不知应提起@何等话题……嗯，是天音月咲的双胞胎姐姐，@平日担任水名女子学园筝曲部部长之余，也练习@各种技艺。心爱之物……那便是月咲妹妹了。"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101800}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"id":101800,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"id":101800,"motion":100}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_18","textHome":"在外婆指示下，忙于各种技艺练习的我还有@最后一道槛。那就是在这鸟笼一般的家庭中@学会独立。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":200}]}],"group_11":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_19","textHome":"愿我演奏的音色，能响彻更远的地方。"}]},{"autoTurnFirst":4.2,"chara":[{"id":101800,"motion":100}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_20","textHome":"身为姐姐，这样就能守护月咲妹妹了吗？"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_13":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_21","textHome":"撒娇与哭喊是无意义的。此乃忍受万难，@为解放而尽力的结果。"}]},{"autoTurnFirst":4.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":100}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_22","textHome":"仅仅忍耐下去，终会摧残心灵，@人终究需要治愈与活力。而对我来说，@无需多言，那便是月咲妹妹了。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":200}]}],"group_15":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_23","textHome":"于忍耐中，饱含自尊的美丽精神，自制……！@得益于此，我也能堂堂正正做人。@今后我要为了解放自己和守护月咲妹妹，@成为顶天立地的人。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":200}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_24","textHome":"圣诞快乐！得遇圣诞姐姐的幸运儿啊，为你献@上开心一整天的魔法。"}]},{"autoTurnFirst":5.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"id":101800,"motion":100}]}],"group_17":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_25","textHome":"早上好。虽然门外尚冷，但还是早起了。因为@圣诞姐姐要作为孩子们的榜样才行。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"id":101800,"motion":100}]}],"group_18":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_26","textHome":"据说有可以接受委托制作圣诞风格菜式的中华@料理店……究竟会是什么样式呢？稍微有点@兴趣……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":100}]}],"group_19":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_27","textHome":"在等月咲妹妹来。月咲妹妹太忙了，也许会迟@到，但我相信她最后一定会来的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_03","textHome":"忍耐……乃是崇高的精神。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":100}]}],"group_20":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_28","textHome":"入睡之前，如果我也可以向圣诞老人祈愿的话@……希望明天还能和月咲妹妹相会。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_21":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_50_29","textHome":"这件衣服，自小就是我所向往的。因为圣诞姐@姐，能够使用给孩子们带来幸福的魔法……@！"}]},{"autoTurnFirst":7.0,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":200}]}],"group_22":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_30","textHome":"到和月咲妹妹一起出去制伏魔女了。为了保护@孩子们，就用圣诞姐姐的魔法击败敌人吧！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":101800,"motion":100}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_31","textHome":"在镜之魔女的结界，看见了穿着圣诞装的阿莉@娜……失礼，是阿莉娜的复制品才对……究@竟是怎么回事呢？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":300}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_32","textHome":"全员化装过的魔法少女组队战斗，偶尔如此似@乎也不坏。啊……但若变身，就又变为一如@既往的装束了呢。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_33","textHome":"以前迷路的时候，得到了圣诞姐姐的帮助……@那时候觉得，姐姐一定是用了魔法。"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1}]}],"group_26":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_34","textHome":"这身衣服，是为了和月咲妹妹一起去圣诞派对@而准备的。因为相当期待这场派对……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":101800,"motion":1}]}],"group_27":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_35","textHome":"参京屋总店的名点「凉抹茶蛋糕」的圣诞限定@版似乎发售了……真想和月咲妹妹一起吃呢@。"}]},{"autoTurnFirst":6.0,"chara":[{"id":101800,"motion":100}]}],"group_28":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_36","textHome":"魔法少女当中，也有年幼的在……所以作为圣@诞姐姐，希望能为她们带来快乐。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_29":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_37","textHome":"虽然我参加圣诞派对的事，并没有特意向家人@隐瞒，但和月咲妹妹相见的事自然是秘而不@宣了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":100}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_04","textHome":"由父亲手中所得的笛子，有着特殊的意义。"}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_38","textHome":"最合心意的地方，就是绑着铃铛的丝带了。因@为这是和月咲妹妹成对的丝带！"}]},{"autoTurnFirst":5.0,"chara":[{"id":101800,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"id":101800,"motion":100}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_50_39","textHome":"虽然并不感觉朋友少，但只和月咲妹妹互换了@礼物……啊……难道说，还是我朋友太少吗@？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101800}]},{"autoTurnFirst":3.0,"chara":[{"id":101800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":300}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_40","textHome":"突然意识到，美冬的魔法少女服也是带着蓬松@的毛的，换个颜色也变成圣诞姐姐了呢！"}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_50_41","textHome":"诶……是否合身呢？啊，一本正经地那样说…@…让人有点害羞了……"}]},{"autoTurnFirst":6.0,"chara":[{"id":101800,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":101800,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101800,"motion":300}]}],"group_34":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_42","textHome":"来，开始表演吧。"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_43","textHome":"做到了！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_44","textHome":"这也是忍耐的恩赐吧。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_45","textHome":"感谢聆听。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_46","textHome":"演出到此结束。"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_63","textHome":"请放心。凭这一击拉下帷幕。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_05","textHome":"相伴之人唯有彼此，@我与月咲妹妹将会一直在一起。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101800,"motion":100}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_64","textHome":"结束无用的战斗吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101800,"motion":200}]}],"group_41":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_65","textHome":"满载信念的一击，请收下吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":100}]}],"group_42":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101800,"motion":200,"pos":1,"voice":"vo_char_1018_00_66","textHome":"演出是否应该结束了呢？"}]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_02","textHome":"初次见面，在下天音月夜。虽说想奏出悦耳的@音色，但月咲妹妹在否呢？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101800,"motion":0}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101800,"motion":100}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_13","textHome":"唯努力、忍耐与月咲妹妹不可辜负。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101800,"motion":200}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":100,"pos":1,"voice":"vo_char_1018_00_14","textHome":"这也是耐心且努力的结果。"}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_15","textHome":"那么，就用这琴音来表达吧……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]}],"group_8":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":1,"pos":1,"voice":"vo_char_1018_00_16","textHome":"得益于外婆指示下的毛笔和硬笔书法练习，@在学校的活动中，老师也经常托付给我。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101800,"motion":100}]}],"group_9":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101800,"motion":0,"pos":1,"voice":"vo_char_1018_00_17","textHome":"得益于外婆指示下的器乐练习，@现在我担任了筝曲部的部长。@被周围的后辈们仰慕，@没有比这更让人高兴的了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101800,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":101800,"motion":100}]}]},"version":3}