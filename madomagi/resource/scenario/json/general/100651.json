,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100651,"motion":400}]},{"autoTurnFirst":4.8,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100651,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100651,"motion":300}]}],"group_32":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100651,"motion":1,"pos":1,"voice":"vo_char_1006_51_40"}]},{"autoTurnFirst":0.9,"chara":[{"eyeClose":1,"id":100651}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100651}]},{"autoTurnFirst":3.7},{"autoTurnFirst":1.0,"chara":[{"id":100651,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100651}]}],"group_33":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100651,"motion":0,"pos":1,"voice":"vo_char_1006_51_41"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100651,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100651}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100651,"motion":400}]}],"group_34":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_42","textHome":"作为年长者，我站在前面的。"}]}],"group_35":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_43","textHome":"还好大家都没事。"}]}],"group_36":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_44","textHome":"如果是以前，还能再努力一点的。"}]}],"group_37":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_45","textHome":"但愿这胜利并不是我的幻觉。"}]}],"group_38":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_46","textHome":"也许我能更加自信了吧。"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_63","textHome":"偏执袭击！"}]}],"group_4":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_05","textHome":"拜托了……只要能完成这一切，@两人就都能被拯救了……"}]}],"group_40":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_64","textHome":"跨越现实与梦的界限，品味这幻觉的世界吧。"}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":3.8,"chara":[{"id":100600}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_65","textHome":"用溢出的血滋润这干枯的世界。"}]}],"group_42":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_66","textHome":"清醒是一种幸福哦。"}]}],"group_43":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_02","textHome":"我已经是魔力衰退的魔法少女了哦……@这样也不要紧的话，那就请多关照啦。@好的，我叫梓美冬。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":1}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_13","textHome":"哎呀，@感觉好像回到了像以前那样的水平呢。"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_6":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_14","textHome":"每天为了不退化而努力锻炼是很重要的哦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_7":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_15","textHome":"努力到这个程度，@还默不作声的话就说不过去了呢。"}]}],"group_8":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_16","textHome":"其实我一边独自生活，@一边也在以考取药学部为目标。@虽然这是获得奖学金的条件，@但还是很奇怪吧？"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_9":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_17","textHome":"我所获得的奖学金，@其实是某位玛吉斯为我做的项目。@但是，我也得认认真真去争取考上药学部。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]}]},"version":3}