{"story":{"group_1":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_01","textHome":"我叫梓美冬。以前和小八在一个队伍，现在@因为个人原因独自生活，同时关照着其他人。@虽然经常被当作一个会照顾人的好姐姐，@其实家务全都不会做。@因为我并不成熟呢，呵呵。"}]},{"autoTurnFirst":6.1,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":7.9,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_18","textHome":"之所以玛吉斯有必要让我离开家工作，@是因为我做了七年的魔法少女，@语言很有说服力哦。"}]},{"autoTurnFirst":7.5,"chara":[{"id":100600,"motion":100}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_19","textHome":"这样就更加感到某种意义上的幸福了呢。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":100600,"motion":300}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_20","textHome":"不要悲观，再相信自己一点也不错的样子。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_13":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_21","textHome":"虽说力量已经衰退，@但是比起各位黑翼，也还是更强一些。@所以，我一定要守护她们。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]}],"group_14":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_22","textHome":"我不会屈服的，决不会被自己背负的罪压垮。@正因如此……哪怕把小八和羽翼们也卷进来@也要拯救她们。这种觉悟已经做好了。"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":5.3,"chara":[{"id":100600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"id":100600,"motion":1}]}],"group_15":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_23","textHome":"如果，没能解放他人，@没完成背负罪行的责任，那我只能以死谢罪。@如果那样也不能被原谅的话，@那就找到更多能拯救所有人的新路线……@以此来赎罪……"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":1}]}],"group_16":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100651,"motion":100,"pos":1,"voice":"vo_char_1006_51_24"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100651,"motion":200}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100651,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100651}]}],"group_17":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100651,"motion":1,"pos":1,"voice":"vo_char_1006_51_25"}]},{"autoTurnFirst":2.3,"chara":[{"id":100651,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":100651}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100651}]},{"autoTurnFirst":4.0,"chara":[{"id":100651,"motion":400}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100651,"motion":200,"pos":1,"voice":"vo_char_1006_51_26"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","