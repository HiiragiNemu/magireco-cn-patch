50,"motion":300,"pos":1,"voice":"vo_char_4022_50_37"}]},{"autoTurnFirst":2.5,"chara":[{"id":402250,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402250,"motion":100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_04","textHome":"我想要见证……真英雄的诞生。"}]}],"group_30":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":1,"pos":1,"voice":"vo_char_4022_50_38"}]},{"autoTurnFirst":4.3,"chara":[{"id":402250,"motion":300}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402250,"motion":100}]}],"group_31":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":1,"pos":1,"voice":"vo_char_4022_50_39"}]},{"autoTurnFirst":2.8,"chara":[{"id":402250,"motion":200}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402250,"motion":0}]}],"group_32":[{"autoTurnFirst":8.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":100,"pos":1,"voice":"vo_char_4022_50_40"}]},{"autoTurnFirst":5.3,"chara":[{"id":402250,"motion":300}]}],"group_33":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402250,"motion":300,"pos":1,"voice":"vo_char_4022_50_41"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402250,"motion":400}]},{"autoTurnFirst":0.9,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":402250,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":402250}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402250}]},{"autoTurnFirst":4.9,"chara":[{"id":402250,"motion":100}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_42","textHome":"看来不得不出手了。"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_43","textHome":"总之是胜利了。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":200,"pos":1,"voice":"vo_char_4022_00_44","textHome":"就这样吧。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_45","textHome":"不能骄傲哦。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_46","textHome":"我不会让你掩盖光明的。"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_63","textHome":"影子啊……"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_05","textHome":"塔鲁特就是我的……我们的希望之光。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":402200}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":200,"pos":1,"voice":"vo_char_4022_00_64","textHome":"才刚刚开始呢。"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_65","textHome":"我可不打算手下留情。"}]}],"group_42":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_66","textHome":"我绝对……不会有任何绝望！"}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":200}]}],"group_43":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_02","textHome":"我是莉兹。是来自意大利的佣兵。@姓氏……？嗯……是啊……@现在的话，只管叫我「莉兹」可以吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":402200,"motion":300}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_13","textHome":"谢谢……我确实感觉到了我的进步。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_14","textHome":"魔力来到了最高潮……@真想一直保持这个状态啊。"}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_7":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_15","textHome":"我们一起前进吧……@朝着太阳再次展现光辉的那一天。"}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_16","textHome":"我在塔鲁特的故乡度过的那段日子，@真是无法替代的回忆。大概是过得太开心了，@一下子就待了好长时间……"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402200,"motion":100}]}],"group_9":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300,"pos":1,"voice":"vo_char_4022_00_17","textHome":"塔鲁特拥有特别强大的力量，@但因此魔力的消耗也很巨大。@如果我的力量能增加的话，@她就可以不用战斗了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}]},"version":3}