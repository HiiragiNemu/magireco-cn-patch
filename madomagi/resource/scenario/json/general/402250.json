{"story":{"group_1":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_01","textHome":"我在寻求着给这个时代带来希望的「光」，@长期辗转于各地……同时也从事佣兵的工作。@在旅途尽头，我终于遇见了「光」，塔鲁特。@只要能保护她，怎样的危险我都不会厌弃。"}]},{"autoTurnFirst":6.2,"chara":[{"eyeClose":1,"id":402200,"motion":100}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":402200}]},{"autoTurnFirst":2.2,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":402200,"motion":200}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_18","textHome":"我的身体里，充满从未感受到过的力量。@上吧，和塔鲁特一起。@为了给法兰西带来光明……！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_19","textHome":"谢谢……感觉从外到内都变得强大了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_20","textHome":"重获新生，大概就是这样的感觉吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":402200,"motion":100}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_21","textHome":"我和丘卜认识很久了。@在遇见塔鲁特之前，我就和它一起踏上了，@寻找能成为英雄之人的旅程。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_22","textHome":"谢谢……有了这崭新的力量，@我就能守护希望……那名叫塔鲁特的光芒。@要在这个残忍的时代生存下去，@能顺利迎来每一天，真是一件值得感谢的事。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":402200}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":0,"id":402200}]},{"autoTurnFirst":7.5,"chara":[{"id":402200,"motion":1}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_23","textHome":"我是影子……伴随着光的影子。@我能够得到如此多的力量，@也是因为名叫塔鲁特的希望之光，@她的力量增长的关系。光凭我一个人，@是到达不了这个领域的。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402250,"motion":0,"pos":1,"voice":"vo_char_4022_50_24"}]},{"autoTurnFirst":5.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":1}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402250,"motion":100}]}],"group_17":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402250,"motion":100,"pos":1,"voice":"vo_char_4022_50_25"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":402250,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402250,"motion":300}]}],"group_18":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":0,"pos":1,"voice":"vo_char_4022_50_26"}]},{"autoTurnFirst":2.6,"chara":[{"id":402250,"motion":200}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402250,"motion":0}]},{"autoTurnFirst":0.9,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":402250}]},{"autoTurnFirst":5.5,"chara":[{"id":402250,"motion":300}]}],"group_19":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402250,"motion":0,"pos":1,"voice":"vo_char_4022_50_27"}]},{"autoTurnFirst":3.2,"chara":[{"id":402250,"motion":100}]},{"autoTurnF