{"story":{"group_1":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_01","textHome":"旅する調整屋の一人、篠目ヨヅルです。先生\nに誘われて調整屋となりました。魔法少女\nとしてはあまりに非力で、生きる力のなか\nった私に先生は生きる道を示してくれまし\nた。調整屋としての経験は、まだまだ浅い\nですが、誇りをもってあなたのソウルジェ\nムをお預かりします"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":8.5,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_17","textHome":"先生から誘いを受け、神浜で活動することに\nしました。神浜に興味があったとか、特に\nそういうことはありません。誘われたから\n来ました"}]},{"autoTurnFirst":4.5,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"id":104000,"motion":100}]}],"group_11":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_18","textHome":"先生は私を利用しているだけなのかもしれま\nせん。でも、それでいいのです。それを受\nけ入れて、私は先生のために尽力します"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":104000,"motion":100}]}],"group_12":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_19","textHome":"この力を使う機会は訪れないと願っています"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_20","textHome":"これが、生きるための力…"}]}],"group_14":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_00_21","textHome":"今まで限界だと思っていた力に、まだ上があ\nったのですね。この誤算はすごくうれしい\nです。私はまだ、死ぬわけにはいきません\nので。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000}]},{"autoTurnFirst":2.7,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000}]}],"group_15":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_22","textHome":"…また、力を得てしまいました…。嬉しいと\n思う反面、怖いという想いもあります。な\nぜなら私は…力に溺れてしまった人間なの\nで…。ですが、もう絶対に溺れません。私\nはもう孤独ではないので"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":5.8,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_23","textHome":"死ぬわけにはいかないと強く生きてきました\nが、かといって将来の目標があるわけでも\nないのです。でも、私は私の存在意義のた\nめに、日々精進していきます。なのでグリ\nーフシードはぜひ、ピュエラケアへ！"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100}]}],"group_17":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_24","textHome":"今日も来てくれたのですね。さ、こちらへど\nうぞ。部屋の温度は快適でしょうか？ご要\n望があればなんなりと申し付けください"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":2.3,"chara":[{"id":104000,"motion":400}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]}],"group_18":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_00_25","textHome":"ちょうど朝食の支度を終えたところです。せ\nっかくなので温かいうちにいかがですか？\nいいオレンジジュースも仕入れたんですよ"}]},{"autoTurnFirst":3.8,"chara":[{"id":104000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":104000,"motion":200}]}],"group_19":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_26","textHome":"お腹、空きましたよね。ふふ、私もです。…\nダイエット中でしたか。十分おキレイだと\n思いますが、サラダバーのあるお店を探し\nましょう"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]}],"group_2":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_02","textHome":"こんにちは、篠目ヨヅルと申します。中央区\nで調整屋を営んでおります。来店された暁\nには、おいしいスイーツでおもてなしさせ\nてください"}]},{"autoTurnFirst":3.3,"chara":[{"id":104000,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"id":104000,"motion":300}]}],"group_20":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_27","textHome":"幼い頃はこの時間、習い事で休む間もなかっ\nたですね。ピアノに水泳に絵画にダンスに\n…。結構、教養もあるんですよ"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0}]}],"group_21":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_28","textHome":"こんばんは。そろそろお休みのお時間ですか\n？お休みする前、最後のひとときを共にす\nごせて、大変光栄です。疲れは存分に癒し\nましょう"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":3.2,"chara":[{"id":104000,"motion":1}]}],"group_22":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_29","textHome":"今日は珍しく忙しいですね…。おっと、ダメ\nですね。笑顔笑顔。調整する私に元気がな\nければ、きっと魔法少女も不安です。そう\nメモにもあります"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":4.8,"chara":[{"id":104000,"motion":200}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100}]}],"group_23":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_00_30","textHome":"魔女がたくさん発生したようですね。頑張っ\nてください。グリーフシードを手に入れた\nら、ぜひ我々調整屋まで！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":5.4,"chara":[{"id":104000,"motion":100}]}],"group_24":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_00_31","textHome":"果てなしのミラーズ…。私がいた地域には、\nこんな現象は起きていなかった。神浜には\n不思議なことが多いですね"}]},{"autoTurnFirst":4.7,"chara":[{"id":104000,"motion":300}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":100}]}],"group_25":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_32","textHome":"おお…！お客様がこんなに…。え？違う？…\nこれからこの人数で戦う…？そうですか。\nでは死んでしまわれる前に、ぜひ調整を！"}]},{"autoTurnFirst":2.0,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":100}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_00_33","textHome":"私はいつでも中立ですよ。ええ、中立は中立\n。決して踏み込むこともありません。…幻\n滅しましたか？"}]},{"autoTurnFirst":3.2,"chara":[{"id":104000,"motion":1}]},{"autoTurnFirst":3.4,"chara":[{"id":104000,"motion":200}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300}]}],"group_27":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_34","textHome":"消えろ！この虫ケラ!!…ふぅ、まさか車内\nにあんな大きなハエが入ってくるとは…。\n野外で調整する際の、最大の欠点ですね"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000,"motion":100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}]}],"group_28":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_35","textHome":"いい映画でしたね…ええっ!?どうされたの\nですか!?…今の映画で…？なるほど、優\nしい人は今の映画で涙を流すのですね…。\nメモします"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":5.7,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100}]}],"group_29":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_00_36","textHome":"魔法少女になるとわかりにくいですが、実は\n元々の身体能力も結構高いのですよ。ほら\n、ここの筋肉、どうですか？触ってもいい\nですよ"}]},{"autoTurnFirst":4.6,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":200}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000}]}],"group_3":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_03","textHome":"安心してください、何があろうと中立です"}]},{"autoTurnFirst":3.0,"chara":[{"id":104000,"motion":400}]}],"group_30":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_37","textHome":"スー…、スー…。…おっと、失礼。居眠りを\nしてしまいました。…え？ふふ、私だって\n睡眠は取りますよ。…あの、人間ですよ？"}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":200}]}],"group_31":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_38","textHome":"みたまさんは…姉弟子にあたるのでしょうか\n。あまり面識はありませんが。調整屋は服\nを脱がすという風評被害を作られた方です\nね"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":200}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_39","textHome":"月出里は本当に元気ですよね。あと、とても\nおしゃべりです。…いやいや、本当におし\nゃべりなんですよ"}]},{"autoTurnFirst":3.0,"chara":[{"id":104000,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400}]}],"group_33":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_40","textHome":"先生は…、お店に立つ時はしっかりしてるの\nですが、裏では結構だらしなくて…。脱い\nだストッキングを放置するのは控えていた\nだきたいですね"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":5.1,"chara":[{"eyeClose":1,"id":104000}]}],"group_34":[{"autoTurnFirst":6.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_00_41","textHome":"息を吸って…大きく、味わうように吸って…\n。吐いて…。力を抜いて…。私にゆっくり\n、身を任せて…。…お疲れ様でした。調整\n終わりです"}]},{"autoTurnFirst":4.5,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000}]},{"autoTurnFirst":4.1,"chara":[{"id":104000,"motion":1}]}],"group_35":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_00_42","textHome":"さすがの私もガマンなりませんね"}]}],"group_36":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_43","textHome":"きょ、強敵でした…！"}]}],"group_37":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_44","textHome":"勝ちたければ、ぜひ調整屋に"}]}],"group_38":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_45","textHome":"今まで何やってきたんですか？"}]}],"group_39":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_46","textHome":"死んで詫びろ…!!"}]}],"group_4":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_04","textHome":"生きていくには邪魔なものが多すぎます"}]}],"group_5":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_05","textHome":"だから私は…生き続けます"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":0,"id":104000}]}],"group_6":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_13","textHome":"調整される側も悪くないですね"}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_14","textHome":"大変喜ばしいですが…これで満足してはいけ\nませんね"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_15","textHome":"私に探りを入れても…楽しくないですよ"}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_16","textHome":"先生に出会った時の私は、すべてを諦め、死@すら受け入れたところでした。先生は私に@、生きる手段と意義を与えてくれました"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":400}]}]},"version":3}