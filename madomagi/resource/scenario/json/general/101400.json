{"story":{"group_1":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_01","textHome":"柊音梦，平时仅仅是个编织故事的魔法少女。@只会和合得来的人在一起，也算是随缘吧。@试着聊聊天可能会合得来吧。@啊，但是我说的话题可能没什么有趣的。@因为最近都一直在住院。"}]},{"autoTurnFirst":4.5,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":4.7,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":100}]}],"group_10":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_17","textHome":"人生幸福的秘诀，乃是怀着喜悦接受变化。@有这句话在心里，出院之后突然变大的世界@我也能安然接受了。"}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":6.3,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":100}]}],"group_11":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_18","textHome":"有人说，幸存下来的种子，@并非最强也非最有智慧，而只是最适应变化。@但我要否定这句话。"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.7,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":200}]}],"group_12":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_19","textHome":"我的故事要浮出水面了。@比以往更加鲜明和热烈。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":400}]}],"group_13":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_20","textHome":"心如明镜。@感觉我能写出比平时更加优美的文字了。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":0}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_21","textHome":"嗯哼，有点飘飘然了。@可以写出点震惊读者的短篇来。@真想让读者能享受阅读啊。"}]},{"autoTurnFirst":6.4,"chara":[{"id":101400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":300}]}],"group_15":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_22","textHome":"就按这个步伐，把我的故事传播到全世界。@我想让全世界的人都认可我。@但就算拥有知识，我所走过的世界还是太小，@我还想往故事里塞进更多让人感兴趣的情节。"}]},{"autoTurnFirst":6.2,"chara":[{"id":101400,"motion":100}]},{"autoTurnFirst":7.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]}],"group_16":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_23","textHome":"是否有面向世界的必要呢……@是否有被世界所知道的必要呢……@事到如今，我为自己曾经@说过这种幼稚的傻话而感到害羞。但好在，@我发现了真正重要的东西，心情也舒畅了。"}]},{"autoTurnFirst":8.2,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_24","textHome":"啊，你来啦。@正好我把原稿写完了，是个好时机。@不介意的话我也能陪你说说话，@虽然可能没什么新鲜话题。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400}]},{"autoTurnFirst":7.5,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200}]}],"group_18":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_00_25","textHome":"嗯……嗯嗯……好，我喝。@诶？啊，抱歉，是想说牛奶的。@昨天熬夜了，现在还很困，脑子转不太动。"}]},{"autoTurnFirst":2.9,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":101400}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":101400,"motion":200}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":400}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300}]}],"group_19":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_26","textHome":"午饭一直是妈妈给我做的，经常吃的是便当。@工作本来就要早起，还日复一日做着这些，@我真的很感谢她。"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_2":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_02","textHome":"我是柊音梦，来帮你了。萍水相逢前世缘，@偶尔也会觉得该做点奇妙的事情了。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_27","textHome":"今天还有图书委员的工作，你就先走吧。@要是该做的时候不做，大家就都把这事忘了，@再说学校的藏书也很有趣呢。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":300}]}],"group_21":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_28","textHome":"呜啊……再醒一会儿吧。@因为去狩猎魔女，能读书的时间就少了。@就算熬夜，也要再读一些书才行。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":8.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]}],"group_22":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_29","textHome":"啊，能和我说会儿话吗？@浪费有限的光阴是不好的。@我们最好想想，@自己还有多少时间可以利用。"}]},{"autoTurnFirst":4.9,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":200}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_00_30","textHome":"日本自古就把黄昏称为@会遭遇危险魔物的逢魔之时。@魔女也正是如此，实在有趣。@那，话就说到这里，我们去狩猎吧。"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":400}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_31","textHome":"我个人不建议接近无尽镜界。@在没有破解的办法前就对它动手是很危险的。"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":200}]}],"group_25":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_32","textHome":"这个世界真是无情啊。@背负着同样宿命之人却要兵刃相向。@虽然能理解这其中的结构，@但真是空虚啊。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":101400}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":6.1,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.1,"chara":[{"id":101400,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101400}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_33","textHome":"嗯？嗯，刚刚耳朵不太好使。@自从出院，所见所闻都有种新鲜感。"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":5.9,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400}]}],"group_27":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_34","textHome":"你在那吧？嗯哼，正确。@写书的时候一直低着头，@结果气息的感知反而变强了。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":300}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_35","textHome":"学校生活，还没完全习惯的样子……@还需要点时间。@但是这并不是悲观哦，大体上还是积极的。"}]},{"autoTurnFirst":4.3,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_36","textHome":"虽然经常说我缺乏感情，但是不用担心。@我的心中可是装满了喜悦和惊奇，@绝不是冷淡的。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_03","textHome":"要创造的话，首先就是大家的安身之地吧……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101400}]}],"group_30":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_37","textHome":"虽然我不喜欢味道太重和油腻的食物，@但喜欢有嚼劲的东西。@之前第一次吃了红肉，那个相当不错。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"id":101400,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_31":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_38","textHome":"可以读看看我的小说吗？@虽然不是纸书，而是全都在网页上。@怎么样？要读的话我把网址告诉你。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400}]},{"autoTurnFirst":6.8,"chara":[{"id":101400,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":101400,"motion":0}]}],"group_32":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_39","textHome":"父母亲都太忙了，几乎没来看过我，@但我不恨他们。我知道他们都很努力的。"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":101400,"motion":300}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_40","textHome":"虽然对灯花很不爽，但不是讨厌。@具体来说就是讲话很现实，值得信赖，@也是我长期相处的室友了。"}]},{"autoTurnFirst":6.2,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":200}]}],"group_34":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_41","textHome":"下次假期好像爸爸妈妈都在在家……@啊，是父亲和母亲在家……@抱歉，一时忘记，说错了。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101400,"motion":300}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_42","textHome":"在这里，也留下我的足迹吧。"}]}],"group_36":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":200,"pos":1,"voice":"vo_char_1014_00_43","textHome":"这样就完结了。"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":101400}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_44","textHome":"结果是对面就此封笔了呢。"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":400,"pos":1,"voice":"vo_char_1014_00_45","textHome":"我的故事，可没有什么终结。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_46","textHome":"创造，是为了全体。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_04","textHome":"我希望人们，@能够知晓这些被献出的生命"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":200}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_63","textHome":"寄宿在我脑中的创造之子们。"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_64","textHome":"现在正是在广大的世界中留下脚印的机会。"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":400,"pos":1,"voice":"vo_char_1014_00_65","textHome":"来欣赏这场盛大的狂欢吧。"}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100,"pos":1,"voice":"vo_char_1014_00_66","textHome":"欢迎回来，位置留好了。"}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_05","textHome":"虽然很孤单，@但我绝不是不幸的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":100}]}],"group_6":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":300,"pos":1,"voice":"vo_char_1014_00_13","textHome":"感受到自己的成长真是奇妙。@身体当中洋溢着温暖。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0}]}],"group_7":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":1,"pos":1,"voice":"vo_char_1014_00_14","textHome":"我得到了足以用故事掩埋世界的能力。@当然这只是个比喻。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":100}]}],"group_8":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_15","textHome":"我的人生又翻开了一页。来看看吧。"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":101400,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101400,"motion":100}]}],"group_9":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":101400,"motion":0,"pos":1,"voice":"vo_char_1014_00_16","textHome":"对于人类，不幸、贫困、疾病是必要的。@否则人类就会马上骄傲自满起来。@住院时我想到了这句话，@于是把它认为是必要的考验了。"}]},{"autoTurnFirst":4.1,"chara":[{"id":101400,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":101400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101400,"motion":300}]}]},"version":3}