{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_01","textHome":"我是吉良手鞠。工匠学舍的二年级学生…啊，@是高中部的二年级。所有类别的文学我都喜@欢，时常会读书。陪儿时起的好友古町加入@了历史研究部…不过并没有在做历史的研究@呢"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":100}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304000}]},{"autoTurnFirst":4.5,"chara":[{"id":304000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":304000,"motion":300}]}],"group_10":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":1,"pos":1,"voice":"vo_char_3040_00_17","textHome":"我现在觉得有意思的是“随笔”。当你感觉这@像是日记时，突然间故事就会拉开序幕，有@着让人无法预测的乐趣。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304000}]},{"autoTurnFirst":4.3,"chara":[{"id":304000,"motion":100}]}],"group_11":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_18","textHome":"虽然有出于兴趣写过小说，但我并没有憧憬过@小说家这一职业。只是因为喜欢，所以就去@读，然后写一写而已。"}]},{"autoTurnFirst":1.0,"chara":[{"id":304000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":304000,"motion":400}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":200,"pos":1,"voice":"vo_char_3040_00_19","textHome":"呼…对魔力的用法，稍微有些明白了的感觉"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":304000}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_20","textHome":"我终于，获得了作为魔法少女前进下去的勇气"}]}],"group_14":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":1,"pos":1,"voice":"vo_char_3040_00_21","textHome":"原来如此，魔法少女是这样成长的啊。像是成@为了虚构小说的世界里的人物一样，非常有@意思。"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0}]}],"group_15":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_22","textHome":"哦哦——！让我感慨从前的自己是怎么回事啊@一般，思路变得清晰了起来。这就是，突然@意识到某件事物的前人们用“我发现了”或@者“神启的瞬间”等词汇来表现的经历吗？"}]},{"autoTurnFirst":5.8,"chara":[{"id":304000,"motion":300}]},{"autoTurnFirst":3.2,"chara":[{"id":304000,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"id":304000,"motion":200}]},{"autoTurnFirst":3.8,"chara":[{"id":304000,"motion":100}]}],"group_16":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_23","textHome":"内心变得澄澈，仿佛能感受到世人的因果的流@向一般。能将这种心境完整传达出来的表现@力，我是否终有一天可以获得呢…？"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":304000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304000,"motion":300}]}],"group_17":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_24","textHome":"我正实践着不经意间想到的“来到下一天后，@就立即写下当天的日记”的想法。这样一来@，就完全没有可以写的内容了…"}]},{"autoTurnFirst":5.9,"chara":[{"id":304000,"motion":100}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000,"motion":300}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":300,"pos":1,"voice":"vo_char_3040_00_25","textHome":"…欸？已经早上了？我什么时候睡着的来着？@…啊啊，一读起小说就停不下来了，好像天@快蒙蒙亮的时候就咣一下睡着了…"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"id":304000,"motion":200}]}],"group_19":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_26","textHome":"已经要吃午饭了？我想着读完这本书再吃的…@我现在不立刻吃饭，在地球的历史中来看不@是什么要紧的事吧？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000}]},{"autoTurnFirst":7.2,"chara":[{"id":304000,"motion":1}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":300,"pos":1,"voice":"vo_char_3040_00_02","textHome":"自我介绍吗？我喜欢所有类别文学…特别是近@代文学，只要有空就会读书。…啊，忘了说@名字了。我是吉良手鞠。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":1}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000}]}],"group_20":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_27","textHome":"抱歉，我稍微去一下书店可以吗？要在回家的@电车上读的书，忘在学校了…"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000,"motion":300}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":304000}]}],"group_21":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":1,"pos":1,"voice":"vo_char_3040_00_28","textHome":"学习的时间？我不怎么学习…上课的内容也全@是在书里读过的。不过没兴趣的领域就完全@不懂了。"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000}]},{"autoTurnFirst":4.0,"chara":[{"id":304000,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000}]}],"group_22":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":1,"pos":1,"voice":"vo_char_3040_00_29","textHome":"我经常被人说很奇怪，不过我觉得也没错…古@町和三穗野她们那样也算挺奇怪吧？"}]},{"autoTurnFirst":3.3,"chara":[{"id":304000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":304000,"motion":200}]}],"group_23":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_30","textHome":"差不多该去探寻魔女了。根据丘比所言，狩猎@魔女就是魔法少女的存在意义…Raiso@n d'être"}]},{"autoTurnFirst":2.6,"chara":[{"id":304000,"motion":100}]},{"autoTurnFirst":1.8,"chara":[{"eyeClose":1,"id":304000}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":304000}]}],"group_24":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_31","textHome":"居住在镜子的迷宫的深处的魔女…她到底是有@何考虑，才将魔法少女的复制放在身边的呢@…？"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":6.3,"chara":[{"id":304000,"motion":200}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_32","textHome":"看起来魔法少女的各位正在集结，我也过去比@较好吗？虽然我不是很喜欢人多的地方…"}]},{"autoTurnFirst":3.0,"chara":[{"id":304000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":304000,"motion":200}]}],"group_26":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":200,"pos":1,"voice":"vo_char_3040_00_33","textHome":"开始进行创作只是出于作为读者的兴趣。觉得@不切身去拥有创作的经验的话，作者的意图@和真正传达的意思也不会知道吧"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304000,"motion":300}]}],"group_27":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_34","textHome":"…欸？什么事？不是的，我是在构思一篇我读@完的书的批评。虽然不打算发表，但必须得@去写才行"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304000}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_35","textHome":"这本书吗？这是要带到学校去的，我打算在历@史研究部的活动室读。因为这样我就是在研@究文学史，而三穗野在研究电影史"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000}]},{"autoTurnFirst":5.5,"chara":[{"id":304000,"motion":1}]}],"group_29":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_36","textHome":"啊！我刚才脑海里浮现出一篇很棒的短歌。得@赶紧，拿出笔和砚来…欸，我一直都随身带@着这些啊？确实一般来讲不会随身带着它们@…"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304000,"motion":300}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304000,"motion":100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_03","textHome":"任何事物，若没有亲历过遍不会知道。"}]}],"group_30":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_37","textHome":"教科书上的日本文学的名作，都是译为了现代@语的。即便是明治时代的小说，也很少有人@一字一句地去读"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":304000,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":0,"id":304000}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_38","textHome":"“三穗野虽然会不经考虑地行动，却明白分寸@。吉良则是在清楚一切的情况下，做出难以@置信的笨事”…这是古町说过的话"}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":2.0,"chara":[{"id":304000,"motion":300}]}],"group_32":[{"autoTurnFirst":7.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_39","textHome":"最初读到柊音梦的作品时，我还以为这是一位@老写手假借其名写下的。作家的文笔，在年@少时便已成形呢"}]},{"autoTurnFirst":1.8,"chara":[{"id":304000,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"id":304000,"motion":400}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_40","textHome":"古町可是很胆小的哦。她几乎不敢以自己真实@的情绪面人。不过对我来说，她的这点让我@更容易和她相处了呢"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":304000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":1.1,"chara":[{"id":304000,"motion":200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304000}]}],"group_34":[{"autoTurnFirst":2.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304000,"motion":200,"pos":1,"voice":"vo_char_3040_00_41","textHome":"“啊啊，待你将这份可恨的因果斩断之时！”@…嗯，有什么事吗？不是的，好不容易读戏@曲，就想着出声读一读试试"}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":304000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":100}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_42","textHome":"这是故事的开始"}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_43","textHome":"那么我便退场了"}]}],"group_37":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":300,"pos":1,"voice":"vo_char_3040_00_44","textHome":"那么，将笔放下吧"}]}],"group_38":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":100,"pos":1,"voice":"vo_char_3040_00_45","textHome":"结局似乎是大团圆呢"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_46","textHome":"这便是语言的力量！"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":1,"pos":1,"voice":"vo_char_3040_00_04","textHome":"差不多该回去读书了呢…"}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":200,"pos":1,"voice":"vo_char_3040_00_05","textHome":"…现实比起小说还要奇幻，吗"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":304000}]}],"group_6":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":400,"pos":1,"voice":"vo_char_3040_00_13","textHome":"精神爽快…像是刚读完源氏物语时的感受"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304000}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":304000}]}],"group_7":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_14","textHome":"我的心情高涨到了极点。就像是面朝黎明的海@面，想要奔跑而出的感觉。"}]},{"autoTurnFirst":5.0,"chara":[{"id":304000,"motion":100}]}],"group_8":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_15","textHome":"感谢你一直以来的帮助。嗯…我向别人道谢会@很奇怪吗？"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304000}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000}]},{"autoTurnFirst":4.0,"chara":[{"id":304000,"motion":300}]}],"group_9":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304000,"motion":0,"pos":1,"voice":"vo_char_3040_00_16","textHome":"一时冲动买下毛笔套装后，就被古町问“现在@是近代文学模式？”…为什么她会知道呢…@？"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304000,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304000}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304000,"motion":1}]}]},"version":3}