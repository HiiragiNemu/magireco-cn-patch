{"story":{"group_1":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_01","textHome":"在醒来的时候，我除了姓名之外什么都@不记得了。不过海香和薰迎接了我，我们@一起住到了一个大房子里……之后，我就@不可思议的平静了下来！明明什么都@不记得了，真是奇怪的感觉啊~"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":401100,"motion":300}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_18","textHome":"我对于调味的方法似乎记得很清楚！@只要尝一口，就能完美地调出味道！@秘密的暗号就是……小小布丁！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_11":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_19","textHome":"我感受到了……这种兴奋感！我的魔力似乎@得到提升了！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_20","textHome":"嗯，好舒服！我的思路似乎更清晰了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]}],"group_13":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_21","textHome":"一开始是以耳朵上的灵魂宝石被魔女触碰为@契机而变身……不过，我还记得战斗的方式。@并不是脑子记得，而是身体记得！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_14":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_22","textHome":"我在和海香还有薰一起战斗的时候，我记住了@她们会怎么样行动。薰会封锁敌人的行动，@海香会用魔法来看穿敌人……！不过，@那个时候的我，还不能和她们配合默契。"}]},{"autoTurnFirst":6.0,"chara":[{"id":401100,"motion":100}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300,"pos":1,"voice":"vo_char_4011_00_23","textHome":"「以前的我会怎么做？……不对，是现在的我@该怎么做比较好？」这样想的话，我就能@很自然地把握住进攻的时机了！所以我和海香@还有薰的合作才会很成功！"}]},{"autoTurnFirst":5.0,"chara":[{"id":401100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":401100,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_16":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_24","textHome":"你好，你来啦！欢迎！……不过，@能稍等一会儿吗？那个……@我还在吃饭呢！要全部吃光才行！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_25","textHome":"你好！早饭吃什么好呢？诶，酸奶油肉？@早上吃这个有点腻……不过也可以！@我马上就去做！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100}]}],"group_18":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_26","textHome":"差不多该到午饭的时候了…我肚子也饿了呢。@今天吃什么好呢？桶装布丁？嗯……@也不错！那就去吃吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":300}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_27","textHome":"醒来之后第一次使用魔法后，我就一下子@就倒下睡着了……因为还没吃晚饭！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":401100,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":1,"id":401100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":401100,"motion":1}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_03","textHome":"肚子饿是战胜不了的呢……诶嘿。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300,"pos":1,"voice":"vo_char_4011_00_28","textHome":"呜呜……我，差不多该睡了吧……今天也吃得@饱饱的……嗯……这样就能睡个好觉了呢~"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":4.0,"chara":[{"id":401100,"motion":100}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_29","textHome":"我在肚子有点饿的时候，无论如何都想吃点@什么，所以我想要随身带点巧克力之类的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":401100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_22":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300,"pos":1,"voice":"vo_char_4011_00_30","textHome":"我，虽然还什么都没有回想起来……但是，@对我来说，时间就在当下不断流逝。所以，@我只能继续前进！"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":200}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_31","textHome":"我，还不太习惯使用魔法……没问题吗？……@不过，我必须要上的吧！嗯，我会加油的！"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":1}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_32","textHome":"嘛，魔法少女的话，别的街区也有很多吧……@我也要作为翌桧市的魔法少女而努力！@我是不会输的！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"id":401100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_33","textHome":"虽然有时我会被以前的自己所禁锢，但记忆@并不能决定一个人……因为人的足迹@是可以成为新的记忆的……@现在我就是这么认为的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_26":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_34","textHome":"看这个！送给你。里面放满了点心和食物！@是我最喜欢食物的精选……@取名就叫和美混拼！"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":8.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"id":401100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_35","textHome":"好的，我上喽？看好了……芝麻油开门！……@诶，不行吗……门完全没有开……@是咒语念错了吗？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":401100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":401100,"motion":1}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_36","textHome":"这个发型，是海香和薰帮我剪的。之前@似乎都没有人帮我剪过头发。所以，@现在这个样子我就很满意了……！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":401100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_37","textHome":"海香，在写小说遇到瓶颈的时候，头上……@就会长出角来！我和薰都看到了，@呼呼……真的很有趣！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_3":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_04","textHome":"做饭就是小事一桩！我，一定没问题！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":200}]}],"group_30":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_38","textHome":"薰，她战斗的时候就像是踢球一样！和海香的@行动也很有默契，真的很厉害呢！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_31":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":401100,"motion":300,"pos":1,"voice":"vo_char_4011_00_39","textHome":"我以前的记忆，似乎深深地刻在了身体之中…@然后，如今的我，又刻下了新的记忆……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_40","textHome":"我还能想起，之前的事情吗……如果回想起来@的话，那时的我又是什么样子的呢……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":401100,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"id":401100,"motion":300}]}],"group_33":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_41","textHome":"在故事里，不好好对待饭菜的家伙都是不能@活到结局的大坏蛋！……所以，@饭菜可不能剩下哦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":401100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_42","textHome":"不能容许你再继续撒野了！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":401100,"motion":200}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_43","textHome":"哈啊~肚子饿了……"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":100,"pos":1,"voice":"vo_char_4011_00_44","textHome":"好的！接下来，去吃点什么吧！"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":1,"pos":1,"voice":"vo_char_4011_00_45","textHome":"很合拍呢！"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_46","textHome":"我……可以战斗！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":200}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_63","textHome":"明白了……现在，开始行动！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":200}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":401100,"motion":300,"pos":1,"voice":"vo_char_4011_00_05","textHome":"还好找到了！我得赶紧去那两个人身边！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":401100,"motion":200}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":401100,"motion":0,"pos":1,"voice":"vo_char_4011_00_64","textHome":"就让这一击……让你醒醒吧！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":40