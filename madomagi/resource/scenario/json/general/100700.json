{"story":{"group_1":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_01","textHome":"嗯？诶？一定要和我说才行吗？@天才的时间很宝贵的，这次就算特别待遇哦。@我是里见灯花。在宇宙相关的领域相当有名，@还写了书哦。另外，家里是医疗相关的团体，@对人体也很了解。有什么想知道的尽管问吧。"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":7.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"id":100700,"motion":200}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]}],"group_10":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_17","textHome":"了解宇宙会使人类进化哦？@某种意义上，就像逐渐解开阿卡西纪录一样。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_11":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_18","textHome":"在魔法少女的历和人类的进化当中，@牺牲如影随形哦。@所以了解宇宙也是需要牺牲的。"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":100}]}],"group_12":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_19","textHome":"465亿光年的彼岸，又近了一步！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_20","textHome":"我成长了喵？因为本来就太厉害了，@所以我也不清楚喵——"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400}]}],"group_14":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_21","textHome":"叔父大人说，希望我把才能用来造福所有人。@虽然稍微有点那种感觉了，但是好难啊。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":300}]}],"group_15":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_22","textHome":"爸爸说过，才能是有限的，@所以要最大限度地发挥它的效用。@所以我每当到了不得不取舍时，就会这样想。@毕竟我有着这么强大的力量嘛。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":100700,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]}],"group_16":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_23","textHome":"人与人之间连接着看不见的细丝，@所以只考虑效率是不行的。@叔父大人正因为知晓如此，@才说要救所有的人……@嗯，我也决定了，为了大家去运用我的才能。"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":300}]},{"autoTurnFirst":8.5,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":201}]}],"group_17":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_24","textHome":"真是的，好慢啊。@比我晚到的话，知道后果吧？@作为今天的惩罚，东西就全由你来背了。"}]},{"autoTurnFirst":2.1,"chara":[{"id":100700,"motion":201}]},{"autoTurnFirst":4.7,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":100700,"motion":200}]}],"group_18":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_25","textHome":"每天都会早早醒来哦。@离出门还有点时间，@嗯……去看看天文台采集到的数据吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":300}]},{"autoTurnFirst":4.2,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]}],"group_19":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_26","textHome":"嗯？午饭是一个人吃哦。@和别人说话太没意思了。@现在是我的读书时间，不要说话哦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":100700}]}],"group_2":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_02","textHome":"两个人可以相遇的概率是很——低的。@所以这大概是命运的相逢吧。@我是里见灯花，请指教！"}]},{"autoTurnFirst":3.3,"chara":[{"id":100700,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_20":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_27","textHome":"天色已晚，到了魔女的时间，总会想起丘比。@虽然想问问它关于宇宙的事情，@但还是忍一忍喵。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":300}]}],"group_21":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_28","textHome":"嗯啊……之所以会困，都怪脑内的蛋白质啦。@嗯……不行了，睡了。@抱着小熊睡了……呼……呼……"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":8.0,"chara":[{"id":100700}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100700,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":5.0,"chara":[{"id":100700,"motion":300}]}],"group_22":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_29","textHome":"知道真相的话，@是不是谁也不会去当魔法少女了喵？@拥有比起普通人更加健康的身体，@我反而觉得赚到了呢。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]}],"group_23":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_30","textHome":"一起狩猎魔女吗？@嗯……啊，那这么办吧！@因为我是头脑派，负责考虑作战方案就好！@这叫人尽其才，完美吧？"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200}]}],"group_24":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_31","textHome":"无尽镜界，我不太想去呢。@去了会被复制，一想到会有两个我，@还挺不舒服的。"}]},{"autoTurnFirst":4.1,"chara":[{"id":100700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":200}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_32","textHome":"这、这么多人聚集起来很难战斗啦！@我的攻击这么华丽，@说不定咚地就把人卷进去了哦！？"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":201}]}],"group_26":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_33","textHome":"爸爸是里见医疗集团的社长哦！@所以有很多钱，@住院也是住自家的医院哦——"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":1}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_34","textHome":"手机出问题了的话让我帮你修吧。@虽然我还不懂编程，@不过稍微学一下马上就能学会了吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_35","textHome":"呜，我在考虑事情，别吵我哦。@打扰到天才的思考，@一秒罚款一万可是世界规则哦。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100700}]},{"autoTurnFirst":5.0,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":100700,"motion":100}]}],"group_29":[{"autoTurnFirst":0.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_36","textHome":"诶！？没有没有！绝对没有！@玩偶里怎么会有人呢！@不准再说这种事！真是的！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":100700,"motion":201}]},{"autoTurnFirst":4.3,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"id":100700,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100700}]}],"group_3":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_03","textHome":"这样就完美了！能集合多少人喵？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_30":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_37","textHome":"住院的饭菜味道都好淡啊……@外面的东西就全是咸的……@这当中有好吃的东西吗？"}]},{"autoTurnFirst":4.8,"chara":[{"id":100700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":100}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_38","textHome":"嘿嘿，这一次要和市内的大学教授座谈了哦！@虽然不会上电视，但会在杂志上发表，@可以的话买来看看哦！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_39","textHome":"其实叔父大人已经失踪了，不知道去了哪儿。@只留下了出版前的原稿……@到底去哪儿了呢？"}]},{"autoTurnFirst":3.5,"chara":[{"id":100700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":100700}]}],"group_33":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_40","textHome":"音梦总说些空想得来的毫无根据的话，@但她也能好好看清现实，比我要冷静。@所以总是能很放心依赖她。"}]},{"autoTurnFirst":4.3,"chara":[{"id":100700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100700,"motion":400}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_41","textHome":"规则是猜拳输了就要回答问题！@那么，我会先出剪刀再出布。@好，剪刀石头布！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201}]}],"group_35":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_42","textHome":"出发吧，和全宇宙的能量一起！"}]}],"group_36":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_43","textHome":"不愧是我，诶嘿！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_44","textHome":"嗯嗯，分泌了不少肾上腺素！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_38":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_45","textHome":"我觉得你很努力哦？辛苦啦——"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100700}]}],"group_39":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100700,"motion":0,"pos":1,"voice":"vo_char_1007_00_46","textHome":"绝不允许关上人类进化的道路！"}]},{"autoTurnFirst":1.5,"chara":[{"id":100700,"motion":201}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100700,"motion":1,"pos":1,"voice":"vo_char_1007_00_04","textHome":"小学就教过的问题，没错吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_63","textHome":"宇宙的能量倾泻而下！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_64","textHome":"收缩吧，大坍缩开始——"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":201,"pos":1,"voice":"vo_char_1007_00_65","textHome":"宇宙大爆炸——!!"}]}],"group_43":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":100,"pos":1,"voice":"vo_char_1007_00_66","textHome":"嗯哼，这就是宇宙的诞生哦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_05","textHome":"姐姐大人好温柔！@我像喜欢忧一样喜欢姐姐大人！"}]}],"group_6":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100700,"motion":400,"pos":1,"voice":"vo_char_1007_00_13","textHome":"哇，魔法少女成长也会分泌荷尔蒙之类的吗？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":100}]}],"group_7":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100700,"motion":200,"pos":1,"voice":"vo_char_1007_00_14","textHome":"我作为魔法少女，已经是大人了哦！@因为很强啊！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.e