{"story":{"group_1":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_01","textHome":"和家人的回忆？记得最清楚的，是小时候全家@一起去登山的事情吧。最近呢…怎么说呢？@基本上就没和家人一起出去过了……啊，@抱歉。气氛有点尴尬。你和家人的回忆@又是什么样的呢？"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_18","textHome":"最近开始编织毛衣了。想做成稍微复杂一点的@北欧风格……大概会成为至今为止@最好的作品吧。"}]},{"autoTurnFirst":6.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnLast":4.0,"chara":[{"id":301600,"motion":100}]}],"group_11":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_19","textHome":"拿山做比喻的话～现在是爬了几层呢？呵呵，@目前的行程算是告一段落了呢。"}]},{"autoTurnFirst":3.5,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_20","textHome":"有种焕然一新的感觉。从现在开始……@再次启程吧。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":0}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_21","textHome":"我为了守护家庭，而背负起了全部的责任，@听起来是一件很了不起的事情。@因为那不是我一个人能做到的。"}]},{"autoTurnFirst":4.5,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":301600,"motion":300}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_22","textHome":"我真的希望……能够有一个幸福的家庭。@但是……那不是我一个人能建立起来的。@因为是家庭嘛。爸爸、妈妈，还有我。@不是三个人共同建立的话就没有意义了。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnLast":1.5,"chara":[{"eyeClose":0,"id":301600}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":0,"id":301600,"motion":200}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_23","textHome":"为了再次拥有幸福的家庭，我尽我所能。@但是……既不能勉强，也不能独自承受。@如果要牺牲谁才能拥有幸福的家庭，@那样的家庭已经失去了原有的意义了"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":301600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_24","textHome":"呀吼。嗯，我在等哦。啊，没事没事！@我是一边读着杂志一边等的！诶？没有没有，@不是时尚杂志……是关于手工的杂志。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":300}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_25","textHome":"大概因为平时经常登山？早起对我来说@并不难。原来也是这个样子的……因为@想要趁早慢慢的整理一天的事情。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_26","textHome":"不饿吗？该吃饭了吧。那……日式还是西式？@意面还是拉面？……选哪个好呢？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1}]}],"group_19":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":1,"pos":1,"voice":"vo_char_3016_00_27","textHome":"回家路上去趟手工店好吗？虽然家里还有@很多……但是听说出了新的毛线，@就又想买了。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_2":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_03","textHome":"离开的人……是无法理解理解@被丢下一方的感受的……！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_28","textHome":"一天当中……我最喜欢这段时间。事情全都@做完了……就可以悠闲地织点东西。@在一片宁静中编织，会让人非常的安心。"}]},{"autoTurnLast":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":1,"id":301600}]},{"autoTurnLast":0.5,"chara":[{"eyeClose":0,"id":301600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_21":[{"autoTurnFirst":5.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_29","textHome":"说到编织物，经常给人留下一种过时的印象。@但是，其实也是可以用现代的风格配色……@织出很时尚的东西的哦。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301600,"motion":200}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_30","textHome":"哎……我们是不是该出去退治魔女了？……@毕竟是用愿望交换而来的使命，是自己的@选择……不好好完成可不行。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":301600,"motion":0}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_31","textHome":"要同和我们魔法少女一模一样的敌人战斗啊。@这是敌人——虽然脑子里很清楚，@但还是会感觉不太舒服。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"id":301600,"motion":300}]}],"group_24":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_32","textHome":"好了！到出发去战斗的时间了。比起想赢……@对我来说不想因为输掉而让伙伴难过的心情@更多一些。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":1}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_33","textHome":"运动当中最喜欢的是长跑。很艰难……@但是也要加油！像这样，@挑战自己的感觉真好。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0}]}],"group_26":[{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_34","textHome":"在大自然中漫步，非常的治愈身心呢。……@但是，啊……还是最喜欢@登顶时的那种快感了。"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":200}]},{"autoTurnFirst":4.2,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_35","textHome":"诶～爬山……就是不以登顶为目的的登山啦！@你听说过吗？"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_36","textHome":"编织和登山，虽然室内和户外活动是相反的…@但却有着积少成多的共通点，对吧？"}]},{"autoTurnFirst":4.5,"chara":[{"id":301600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301600,"motion":100}]}],"group_29":[{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_37","textHome":"说到登山，我就会想到全家人一起去野餐。@那是我最好的回忆…我也因此喜欢上了登山。"}]},{"autoTurnFirst":5.0,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_04","textHome":"这是靠我的愿望……才取回的东西。@我一定……要保护好……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":301600}]}],"group_30":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_38","textHome":"说是为了别人，但当那个人为此而高兴时，@自己也会快乐起来。到底是为了自己，@还是为了别人……真是道不清呢。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":301600}]},{"autoTurnLast":0.5,"chara":[{"eyeClose":0,"id":301600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0}]}],"group_31":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_39","textHome":"现在啊，我在给爸爸和妈妈编织东西。@给妈妈织披肩……给爸爸织手包。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_40","textHome":"真良是个很厉害的人，我很敬佩她。@无论何时，无论对谁……都能秉持坦率，@这真的很难做到。"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]},{"autoTurnFirst":5.0,"chara":[{"id":301600,"motion":0}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_41","textHome":"那个，要是想要什么编织物就告诉我吧？……@啊，如果有的话，一定要说哦？@要是变成硬送的礼物就不好了……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301600,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301600,"motion":300}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_42","textHome":"为了大家，我要全力以赴！"}]}],"group_35":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_43","textHome":"大家没受伤吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_44","textHome":"啊，真刺激！嗯哼。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":300,"pos":1,"voice":"vo_char_3016_00_45","textHome":"放心下来就有种脱力感了。"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_46","textHome":"没问题。我会保护你的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_63","textHome":"现在正是大举进攻的时机!"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_05","textHome":"我不会再忽视自己的内心了。为了我自己，@我会陪在你身边的。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":100}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_64","textHome":"别小看了这份守护的心意！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":1}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":200,"pos":1,"voice":"vo_char_3016_00_65","textHome":"不会让你轻易击垮的!"}]}],"group_42":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":100,"pos":1,"voice":"vo_char_3016_00_66","textHome":"这一发……是最后的一击!"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":400}]}],"group_43":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_02","textHome":"初次见面，我是粟根心。需要帮忙的话@随时来找我吧。同样身为魔法少女的伙伴，@如果有困难我会帮忙的。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"id":301600,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":301600,"motion":100}]}],"group_5":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_13","textHome":"只要努力，就有回报，挺不错的呢。"}]},{"autoTurnFirst":3.0,"chara":[{"id":301600,"motion":100}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_14","textHome":"成功登顶！……嗯哼，开个玩笑。@但是那种的爽快感是可以真实感受到的呢。"}]},{"autoTurnFirst":2.0,"chara":[{"id":301600,"motion":1}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600}]},{"autoTurnLast":1.5,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_7":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_15","textHome":"虽然只是小小进步，但是积少成多@总有一天会取得更大的成功。"}]},{"autoTurnFirst":5.0,"chara":[{"id":301600,"motion":100}]}],"group_8":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_16","textHome":"最近热衷于制作杯垫哦。因为编起来很快，@就会开始思考转换设计风格和颜色之类的了。"}]},{"autoTurnFirst":3.8,"chara":[{"id":301600,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]}],"group_9":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301600,"motion":0,"pos":1,"voice":"vo_char_3016_00_17","textHome":"正在编织毯子。把注意力放在针眼上，@乍一看感觉简单，其实仔细看就感觉很厉害！@所以我就想试试看！"}]},{"autoTurnFirst":4.5,"chara":[{"id":301600,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301600}]}]},"version":3}