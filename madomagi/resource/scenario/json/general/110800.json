{"story":{"group_1":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":1,"pos":1,"voice":"vo_char_1108_00_01","textHome":"东西南北……受寒的人到处都有。那么阿莉娜@就依据传闻，披着这华丽的驯鹿毛皮为你们@带来温暖。但是做好觉悟吧，代价是你的寿@命。啊哈。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":110800,"motion":200}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":110800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":110800,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":110800}]}],"group_10":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_17","textHome":"周围漂浮的死相面具，是以自己的寿命作为代@价，逃离了寒冷之人的所有物。也就是生命@的标识，OK？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":110800,"motion":100}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_18","textHome":"啊哈，知晓这一切的你也感到寒冷了。那么阿@莉娜来温暖你。作为代价，就请……你明白@的吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":110800,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":110800}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_19","textHome":"阿莉娜心中又有东西冒出来了……和至今未曾@见过的快感一起……"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":200}]}],"group_13":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_20","textHome":"这姿态就是阿莉娜的答案，当然会很熟悉了。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110800,"motion":100}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_21","textHome":"阿莉娜的传闻是音梦做的，对阿莉娜来说就像@自己的孩子一样。和它共同成长又如何不感@到喜悦呢？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110800,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":200}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_22","textHome":"啊……来了……深入骨髓……每个细胞都和传@言融合了……啊哈哈，啊哈哈哈哈!!和传@言共鸣乃至完全操控的感觉，麻美又怎么会@知道呢！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":110800}]},{"autoTurnFirst":2.8,"chara":[{"id":110800,"motion":100}]},{"autoTurnFirst":4.7,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":4.5,"chara":[{"id":110800,"motion":200}]}],"group_16":[{"autoTurnFirst":7.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_23","textHome":"哈啊……感觉结合又变强了。真是超出了新境@界，仿佛来到天国一般的舒服。直到我们一@起做出最棒的作品，不会让别人来拿掉它的@。"}]},{"autoTurnFirst":8.0,"chara":[{"id":110800,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":2.8,"chara":[{"id":110800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":110800,"motion":200}]}],"group_17":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":200,"pos":1,"voice":"vo_char_1108_00_24","textHome":"又到阿莉娜这里来了，也没有什么事。现在也@没什么温暖别人的心情，去别处吧。拜拜。"}]},{"autoTurnFirst":6.5,"chara":[{"id":110800,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":400}]}],"group_18":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_060.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_25","textHome":"呜哇!!阳光好刺眼！好刺眼！赶紧把窗帘拉@上！阿莉娜还想睡的！"}]},{"autoTurnFirst":0.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":110800}]},{"autoTurnFirst":2.8,"chara":[{"id":110800,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":110800,"motion":100}]}],"group_19":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_26","textHome":"啊哈，就算是这种时候，阿莉娜的天线也能探@测到受寒的人。反正也不想睡觉，去找一找@也行吧。"}]},{"autoTurnFirst":6.0,"chara":[{"id":110800,"motion":1}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_02","textHome":"阿莉娜为了实现自己的美，披上了专用的传闻@。所以不用担心，静静地等着那个时刻的到@来即可。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110800,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":110800,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":110800,"motion":200}]}],"group_20":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":400,"pos":1,"voice":"vo_char_1108_00_27","textHome":"嘘，去别处吧。平时都是半夜干活，现在因为@传闻的原因会犯困，只能现在集中精力作画@了。"}]},{"autoTurnFirst":5.5,"chara":[{"id":110800,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":100}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110800,"motion":1,"pos":1,"voice":"vo_char_1108_00_28","textHome":"夜行性的阿莉娜，抵抗不了昼行性的驯鹿传闻@……呼啊~看什么啊？阿莉娜睡了，晚安。"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":110800}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110800,"motion":300}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":200,"pos":1,"voice":"vo_char_1108_00_29","textHome":"倒不是一整天都穿着这样的。就算是自己原来@的模样，阿莉娜也是能操控的。不然的话总@有股野兽的怪味似的……"}]},{"autoTurnFirst":5.0,"chara":[{"id":110800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110800,"motion":300}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_30","textHome":"魔女最棒的地方在于它是能生出佳作的存在。@也就是说，阿莉娜必须收集更多魔女的饵食@才行。"}]},{"autoTurnFirst":3.5,"chara":[{"id":110800,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":110800,"motion":100}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":200,"pos":1,"voice":"vo_char_1108_00_31","textHome":"和复制的阿莉娜战斗，完美地燃尽它的生命也@罢。嘛，把烧剩下的炭捡回去回收利用也不@错。"}]},{"autoTurnFirst":6.5,"chara":[{"id":110800,"motion":100}]}],"group_25":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_32","textHome":"无论是人类还是魔法少女，为什么总不理解争@斗是无休止的呢？这不该没人想到啊。不管@是阿莉娜还是别人，从出生开始就……"}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":110800,"motion":300}]}],"group_26":[{"autoTurnFirst":6.3,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_33","textHome":"哈……不再浑身难受了，感觉很清爽。阿莉娜@从小就努力着的目标终于找到了。之后就是@把它完成而已。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":4.8,"chara":[{"id":110800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":200}]}],"group_27":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":1,"pos":1,"voice":"vo_char_1108_00_34","textHome":"绝叫罗汉，活的单色，死者复生系列，阿莉娜@所创作的生死主题是没有错的。大家也能仔@细思考一下就好了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":110800,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":300}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_35","textHome":"看什么？这身衣服是阿莉娜专用的，怎么可能@会给你。抱歉但你还是自己定做去吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":3.3,"chara":[{"id":110800,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":100}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_36","textHome":"你会来参加阿莉娜创作的装置艺术吧？那个，@现在没有标题，到了最后一天才会加上。名@为「人类的报酬」。"}]},{"autoTurnFirst":6.0,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":0}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_03","textHome":"感觉好像稍微看清了……阿莉娜的主题……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_37","textHome":"虽然美冬的感想帮不上什么忙，但和灯花、音@梦不同，有着平易近人的感觉，倒是可爱。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110800,"motion":100}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_38","textHome":"在人的集体无意识中存在的东西……那就是阿@莉娜的美的根源。所以阿莉娜创作出的东西@能使人兴奋……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"id":110800,"motion":300}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_39","textHome":"阿莉娜真是不可思议啊。没想到竟然会从笨女@孩的漫画里获得灵感。"}]},{"autoTurnFirst":4.5,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":110800}]}],"group_33":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_40","textHome":"哈……有个审查员竟然说「没有改变世界的想@法就别创作了」这种话，弄得我真打算去改@变世界了……"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":200}]}],"group_34":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110800,"motion":400,"pos":1,"voice":"vo_char_1108_00_41","textHome":"行了，毛皮而已就别那么羡慕地看着了。再说@这东西穿起来也没那么舒服……内脏之类的@还在里面呢……"}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110800,"motion":300}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_42","textHome":"阿莉娜来包裹你吧！啊哈哈哈！"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":200,"pos":1,"voice":"vo_char_1108_00_43","textHome":"作为代价，就拿走你的寿命了。"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_44","textHome":"哈，光想想就兴奋了……"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_45","textHome":"为了做出最棒的作品，总有一天要把一切都包@进去。"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":1,"pos":1,"voice":"vo_char_1108_00_46","textHome":"请你想象一下毁灭的世界。"}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_04","textHome":"人类总在循环着到达的，共通的极限……"}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":100,"pos":1,"voice":"vo_char_1108_00_63","textHome":"为你们献上最美好的自灭。"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":400,"pos":1,"voice":"vo_char_1108_00_64","textHome":"还差一点，烙印在眼睛里吧。"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":200,"pos":1,"voice":"vo_char_1108_00_65","textHome":"啊哈……啊哈哈哈哈哈哈!!"}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_66","textHome":"人类的快乐啊。"}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":110800,"motion":0,"pos":1,"voice":"vo_char_1108_00_05","textHome":"啊哈哈！毫无疑问！阿莉娜的理想遍及一切！"}]},{"autoTurnFirst":4.0,"chara":[{"id":110800,"motion":100}]}],"group_6":[{"autoTurnFirst":3.4,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":110800,"motion":300,"pos":1,"voice":"vo_char_1108_00_13","textHome":"哈，又有魔力和阿莉娜一起发烧了。"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":110800}]},{"autoTurnFirst":5.5,"cha