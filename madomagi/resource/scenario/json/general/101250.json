{"story":{"group_1":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_01","textHome":"我乃生于万圣节的魔法少女，魔法花凛。给我@糖果的话我就会说Treat and Trick !然后恶作剧！哎？嗯，不是@or而是and的说。得到糖果就@会进行打败魔女的恶作剧，@是这样设定的说！很帅气吧？"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_18","textHome":"《怪盗少女魔法希凛第30话：Trick @and Treat奇迹的恶魔驱除》，@对我来说这就是魔法少女的根基的说！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_19","textHome":"哼哼哼，吾之红莲南瓜，寄宿着全新的@炼狱之炎的说！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_20","textHome":"因为有大家，我才能变强，所以现在我要去@帮助大家的说。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":200}]}],"group_13":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300,"pos":1,"voice":"vo_char_1012_00_21","textHome":"那时的我，只是个冒牌的主角的说。但是，@现在的我不一样。我能自信地说出，我是@为了大家在战斗。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":101200,"motion":200}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_22","textHome":"我已超越了魔法花凛，成为了魔法花凛满月！@获得了万圣节和满月之力，魔界的@魔法少女！用这白银的大镰刀，将魔女的@灵魂收割殆尽的说！太好了，全都念出来了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101200,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_23","textHome":"之前一直拿来耍小手段的，偷走任何东西的@力量，现在真心希望能用它帮助别人。@因为我终于能赶上怪盗少女希凛，变得比以前@更自信了的说。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":2.5,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_16":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_50_24","textHome":"太阳即热，热即火炎……!!@换言之，夏天即是魔法花凛的季节的说！@来吧，与我同行！@去苍蓝的海边游玩！"}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":400,"pos":1,"voice":"vo_char_1012_50_25","textHome":"哈，天亮了……？好奇怪……不困了……！@在学校的时候每天都很困的，@到了出来玩的时候就精神了！@好神奇！"}]},{"autoTurnFirst":4.5,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":6.5,"chara":[{"id":101200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]}],"group_18":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_50_26","textHome":"因为想多玩一会，午饭本来想吃点香蕉就好，@结果买成了芒果棒，还被大家笑话了……"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":101200}]}],"group_19":[{"autoTurnFirst":11.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_50_27","textHome":"嗯……沉入夏天海面的夕阳。@好像大家都说它特别，但是我没感觉。@夕阳就是夕阳。还是晚上的鱼更让人期待！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]}],"group_2":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_03","textHome":"陷入危机的魔法花凛……结局会如何！的说…"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101201}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":400,"pos":1,"voice":"vo_char_1012_50_28","textHome":"哇，好棒！夜空有好多星星！@有这么多光点，好像可以连成画！@哎？……原来这就是星座!?"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":100}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_50_29","textHome":"玩的时候，再热流再多汗也不要紧。@但是，不喜欢一出门就满身大汗……@想快点去凉爽的地方看漫画！"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":200}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_50_30","textHome":"难得的好心情就这么被搅了，干得好啊魔女！@就用我超越太阳般灼热的炼狱之炎，@将你烧得灰飞烟灭吧！"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":2.5,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":5.3,"chara":[{"id":101200,"motion":1}]},{"autoTurnFirst":4.2,"chara":[{"id":101200,"motion":400}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_50_31","textHome":"要对付这酷暑，去无尽镜界也不错！@那里一定很凉快，如果穿着泳装去@就更舒服了的说！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":200}]}],"group_24":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101200,"motion":300,"pos":1,"voice":"vo_char_1012_50_32","textHome":"魔法花凛再厉害，@也难以在酷暑中长时间混战的说。@就用我真实的力量，立即结束这边的争斗吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_50_33","textHome":"快看我的包里都装了什么！@感觉海边会有很多有趣的事情发生，@所以带来了画漫画用的东西！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_50_34","textHome":"《怪盗少女魔法希凛》里，@有着以海边为舞台的故事，@这里就可以称为圣地的说！@兴奋得难以自制也是当然的!!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":400}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_50_35","textHome":"蚊子为什么要在人耳边嗡嗡嗡啊？@弄得我睡不着……@但要是想打它，妈妈又会怪我太吵……"}]},{"autoTurnFirst":4.5,"chara":[{"id":101200,"motion":300}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":101200,"motion":100}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_50_36","textHome":"就是它的说！！下一篇漫画的舞台是海！@是主人公渔夫钓到人鱼，和她相爱，@最后和她的未婚夫大王乌贼侯爵@比试用网捕鱼的故事的说！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101200,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_50_37","textHome":"啊——讨厌，又疼又痒……！@呜……被晒伤不方便活动，只好看漫画了……@还很担心会不会变黑的说……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101200}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":101200,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":1}]}],"group_3":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_04","textHome":"给自己找了借口，这样是不行的……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":101200,"motion":300}]}],"group_30":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_50_38","textHome":"阿莉娜学姐，有时候让人看不懂在想什么。@前阵子试穿了好多泳装，@结果最后还是自己做了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_50_39","textHome":"嗯……像女仆一样轻便……@容易活动又凉快的……干脆穿学校泳装好了！@嗯，果然小十七穿什么都合适的说！"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":101200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_50_40","textHome":"真是的！@租游泳圈的时候，居然被人说付儿童价就行！@我可是中学生，而且还是二年级，@已经是大人了的说！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":101200,"motion":400}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_50_41","textHome":"嗯……这件泳装很孩子气吗？@可是我觉得作为夏天的魔法花凛很合适……@哪怕是强行夸夸我也好！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":101200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":300}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_42","textHome":"魔法花凛，到达现场！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":200}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_43","textHome":"这就是欢乐万圣节。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_44","textHome":"没有这把镰刀无法猎取之物。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_45","textHome":"下次带上糖果就放过你。"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_46","textHome":"此乃由另一个世界而来的魔物之力。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_63","textHome":"潜藏在隔离的世界里那古老的灵魂哟。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_05","textHome":"魔法少女当中，有着这么多闪光的人啊……"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":100}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_64","textHome":"赋予我彷徨炼狱的力量！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":100,"pos":1,"voice":"vo_char_1012_00_65","textHome":"去吧，这是我全部魔力的结晶！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_66","textHome":"这就是生于万圣节的力量的说！"}]}],"group_43":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_02","textHome":"我乃魔法花凛…生于万圣节的魔法少女！@带着这样的设定战斗，我叫御园花凛@的说！今后请多关照！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":101200,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":0,"pos":1,"voice":"vo_char_1012_00_13","textHome":"之前被学姐当成笑话的画，感觉现在稍微@进步一些了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101200,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_14","textHome":"学姐快来看！我的画，是不是有长进了！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":100}]}],"group_7":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_022.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_15","textHome":"此乃连接着我与他人的故事中的一页……"}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101200,"motion":200,"pos":1,"voice":"vo_char_1012_00_16","textHome":"那个，有个叫做《怪盗少女魔法希凛》的@漫画。那是连接着我和奶奶的，充满回忆的@漫画的说！"}]},{"autoTurnFirst":3.5,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101200,"motion":1,"pos":1,"voice":"vo_char_1012_00_17","textHome":"为了取回被盗走的圣物而驱除恶魔，敌方头目@却是意中的男孩子，《怪盗少女魔法希凛》@真是太刺激了的说！"}]},{"autoTurnFirst":3.0,"chara":[{"id":101200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":101200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101200,"motion":200}]}]},"version":3}