{"story":{"group_1":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_01","textHome":"我的名字是土岐沙绪。尽管不至于像时女村落@那个程度，但我也是出身于乡下，对城市不@太熟悉。你能为我解答很多我感到困惑的地@方的话，就帮大忙了。不过，我没有什么能@拿来回谢的呢…。啊，可以的话请享用乡村@菜哦！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":102700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":102700}]},{"autoTurnFirst":3.0,"chara":[{"id":102700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":300}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_10":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_17","textHome":"祖父母过世地时候我还很小所以什么都做不到@…。也或许因此，我感到帮着村里做各种各@样的事情是有意义的"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":100}]}],"group_11":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_18","textHome":"为了别的谁而帮忙其实也是为了自己。因为，@大家能被治愈而得到幸福，就是对我的欣慰@了"}]},{"autoTurnFirst":2.8,"chara":[{"id":102700,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_19","textHome":"我不去看未来…我会回首过去，将其化为我的@力量!!"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":102700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":102700}]},{"autoTurnFirst":4.5,"chara":[{"id":102700,"motion":200}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_20","textHome":"如果我的成长，能够促成时女罪恶的旧习的革@除，我会非常开心的"}]},{"autoTurnFirst":2.7,"chara":[{"id":102700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_21","textHome":"千儿和静香都接纳了罪孽深重的我。所以我想@为了她们二人贡献自己的力量的心情，可以@说更甚于为了村里"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":102700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102700}]}],"group_15":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_22","textHome":"在参与进时女村落的黑暗之后，我绝无可能被@原谅了。但是…所以，我会为了不让历史重@演而努力！为了不让和我一样的人出现，实@现一个健全地魔法少女村落而努力！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700}]},{"autoTurnFirst":2.0,"chara":[{"id":102700,"motion":0}]},{"autoTurnFirst":6.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":102700,"motion":100}]}],"group_16":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_23","textHome":"我们所决心要实现的魔法少女的和平与为了日@出之国战国即便出现了动摇，我也会为了拯@救大家，继续使用这份力量。小的沟壑不去@填补，就会随着时间就会扩大，变得无法修@复了啊…"}]},{"autoTurnFirst":5.5,"chara":[{"id":102700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":102700}]}],"group_17":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_24","textHome":"以前听说大都市的人都很冷漠，所以我没想到@你真的会过来。抱歉，说了些失礼的话呢"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":400}]}],"group_18":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_25","textHome":"早上好。那个，吃鱼没有关系吧？今早做了盐@烤鲇鱼。村里的米很美味，请多吃一些哦"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":102700,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"id":102700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_19":[{"autoTurnFirst":3.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_26","textHome":"那个大福饼，看起来好好吃…。哈，午、午饭@虽然是吃了，甜食还没有呢…当然是属于另@一个肚子，所以…！对吧"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":400}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102700}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_2":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_02","textHome":"初次见面。我叫土岐沙绪。我没有什么值得拿@出来说道的特点…啊，我喜欢帮人做各种各@样的忙"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":300}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_20":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_27","textHome":"山里的夕阳，很短暂，很快就会凉下去，而都@市里则会仍带着热量慢慢地落下，美丽的时@间会延续下去呢"}]},{"autoTurnFirst":4.0,"chara":[{"id":102700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":102700}]}],"group_21":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":200,"pos":1,"voice":"vo_char_1027_00_28","textHome":"村落的人们，有没有好好喝下夜里份的药呢…@。我把药分成了小包的，真担心他们有没有@忘…"}]},{"autoTurnFirst":1.8,"chara":[{"eyeClose":1,"id":102700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":102700}]},{"autoTurnFirst":4.0,"chara":[{"id":102700,"motion":300}]}],"group_22":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_29","textHome":"一个人独处的时候，你会去考虑朋友的事吗？@我最近经常会去考虑千春和静香的事。我真@是爱操心呢"}]},{"autoTurnFirst":5.2,"chara":[{"id":102700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":200}]}],"group_23":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_30","textHome":"想必和时女村一样，这个魔女也是在一无所知@的情况下变成这样的…。在她向日出之国散@布诅咒之前，我们必须给予她安息才行…"}]},{"autoTurnFirst":5.2,"chara":[{"id":102700,"motion":300}]},{"autoTurnFirst":3.4,"chara":[{"id":102700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":102700}]}],"group_24":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_31","textHome":"会产生另一个自己的结界…。稍微有点不想见@到实物呢…。总感觉会隐藏着一副让人讨厌@的脸，有些害怕…"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":102700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":102700}]}],"group_25":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_32","textHome":"本来光是人数就已经很多了，竟然还要这么多@人去进行争斗…。要是静香的话估计会气绝@了吧…"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700}]},{"autoTurnFirst":6.0,"chara":[{"id":102700,"motion":300}]}],"group_26":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_33","textHome":"你不觉得倾听别人的经历很有意思吗？我特别@喜欢听年长的人讲述他们过去的故事"}]},{"autoTurnFirst":3.3,"chara":[{"id":102700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_27":[{"autoTurnFirst":2.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_34","textHome":"哇，大都市不管是商店里还是车站里都有卡通@角色呢！都好可爱的。目光游荡在各种各样@的地方"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102700}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700,"motion":200}]}],"group_28":[{"autoTurnFirst":8.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_35","textHome":"千儿和静香都说我的头发散发一种很好的香味@，但我没有特别去做什么啊。有那么大区别@吗？"}]},{"autoTurnFirst":4.0,"chara":[{"id":102700,"motion":100}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_36","textHome":"梦想…吗…。其实我的梦想是成为一名护士。@不仅是为了爸爸和妈妈，也是想给照顾了我@这么多的村里的人们报恩"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102700,"motion":1}]}],"group_3":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_03","textHome":"我只是怕爸爸和妈妈会担心而已…"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":102700}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_37","textHome":"快看这个！说是“汉堡包的霍伯军曹”！“越@用手掌去拍越好吃哦！”，好可爱啊！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102700,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102700,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_31":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_38","textHome":"啊，静香她现在，似乎因为晕人了在休息。因@为她从人烟稀少的村落出来，还没有习惯"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":102700,"motion":200}]}],"group_32":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":200,"pos":1,"voice":"vo_char_1027_00_39","textHome":"千儿很喜欢看以前的刑警电视剧一类的，不过@我喜欢看恋爱类的电视剧。不觉得会有一些@憧憬吗…？啊，刚才的当我没说！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":102700}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":102700,"motion":100}]},{"autoTurnFirst":0.8,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":102700,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":102700}]}],"group_33":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_40","textHome":"我真的只是想让爸爸和妈妈安心而已。可没想@到，会招致那样的后果…。当时的我完全没@有去想过…"}]},{"autoTurnFirst":4.7,"chara":[{"id":102700,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":102700}]}],"group_34":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":300,"pos":1,"voice":"vo_char_1027_00_41","textHome":"唔…好像，稍微长了些肉呢…。啊…没、没什@么！绝不是垃圾食品太好吃了之类的，不是@这样的…！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":102700,"motion":400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":102700}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_42","textHome":"战斗的时候要去注视自己的过去…"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_43","textHome":"为了我们的目的，对不起了…！"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":200,"pos":1,"voice":"vo_char_1027_00_44","textHome":"希望这能成为抹除过去的一小步"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_45","textHome":"未来变得稍微明朗一些了！"}]}],"group_39":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":400,"pos":1,"voice":"vo_char_1027_00_46","textHome":"啊，得赶紧了！都到了该去帮忙的时间了！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":102700}]}],"group_4":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":102700,"motion":0,"pos":1,"voice":"vo_char_1027_00_04","textHome":"和我许了类似的愿望的人是有的吧…？"}]},{"autoTurnFirst":3.0,"chara":[{"id":102700,"motion":200}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_05","textHome":"遇到了这么多能友好交往的人真是太好了"}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":100,"pos":1,"voice":"vo_char_1027_00_13","textHome":"感觉现在，能给大家帮到更多的忙了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":102700}]}],"group_7":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":200,"pos":1,"voice":"vo_char_1027_00_14","textHome":"我不能满足于此，因为赎罪是没有终结的"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":102700}]}],"group_8":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_15","textHome":"村子里面什么都没有，也没什么好玩的事情，@你也要听吗？"}]},{"autoTurnFirst":4.0,"chara":[{"id":102700,"motion":100}]}],"group_9":[{"autoTurnFirst":5.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":102700,"motion":1,"pos":1,"voice":"vo_char_1027_00_16","textHome":"尽管村里的人常说我温柔啊会照顾人啊，但我@其实不是打算这样…。那个，请不要很奇怪@地表扬我"}]},{"autoTurnFirst":2.5,"chara":[{"id":102700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":102700,"motion":100}]}]},"version":3}