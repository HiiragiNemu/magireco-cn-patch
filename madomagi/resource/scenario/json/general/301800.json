{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_01","textHome":"被问到自己是什么人……@嘛，硬要说的话，我谁也不是。@也就是，我任何人都不是。明白吗？@啊哈！说得还算明白吧！@诶？想知道真正的我？@嘛……硬要说的话……只是个幻觉？啊哈！"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":301800,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200,"pos":1,"voice":"vo_char_3018_00_17","textHome":"随便打扫我的房间的话我会生气的哦！@我也是经过思考才把它们丢的到处都是的！@……啊，没这回事吗？啊哈哈！"}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":301800}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301800}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]}],"group_11":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_18","textHome":"把房间弄乱之后，下次就把它再收拾干净。@然后，再弄乱……呵呵……@就这样不断重复……呵呵呵！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800,"motion":100}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_19","textHome":"啊，啊哈……啊哈……变强的感觉……真棒！"}]},{"autoTurnFirst":4.5,"chara":[{"id":301800,"motion":100}]}],"group_13":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_20","textHome":"嗯！嗯！脑子里乱七八糟的感觉最棒了！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":200}]}],"group_14":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_21","textHome":"成为魔法少女的时候，真是让我吓了一跳呢～@不过也很让人兴奋……@因为发现了新的世界！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_22","textHome":"一开始我很不擅长使用魔法。@和魔女的战斗更是如此。@不过，在不断适应的过程中，@这些逐渐变成了快感……@啊啊，好厉害！这个世界最棒了！"}]},{"autoTurnFirst":2.9,"chara":[{"eyeClose":1,"id":301800}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800}]},{"autoTurnFirst":5.0,"chara":[{"id":301800,"motion":100}]}],"group_16":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_23","textHome":"我一直都在思考。@像魔法这么强的力量，我应该怎么使用。@和魔女战斗的时候自然不用说了！@但我还期待着更多！@那就是把魔法少女自身……啊哈哈哈哈！"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800}]},{"autoTurnFirst":2.4,"chara":[{"id":301800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":301800,"motion":1}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_24","textHome":"那么，又要开始了呢……诶～今天做什么呢？@事先说好了，无聊的事情就别找我了。@必须要有趣才行……啊哈！"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":301800}]}],"group_18":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_25","textHome":"呼……呼……呼……骗你的啦！我早就起了！@啊哈哈！……别做出那样的表情啊！@为了这么做，我可是提早了一小时等你啊！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":4.5,"chara":[{"id":301800,"motion":300}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_26","textHome":"午饭，这个我不要吃！还有这个！@还有……这个也是！还有这个，这个，这个！@……诶？那我不是没有饭能吃了吗？"}]},{"autoTurnFirst":1.5,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400}]}],"group_2":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_02","textHome":"嗯？……啊哈！你是谁？@我？诶？名字？不能不说吗？@……告诉你也行。啊哈哈！@……更纱帆奈……记住了吗？"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":200}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_27","textHome":"傍晚的时候……啊哈……@我知道一个最美的地方。@呵呵……呵呵呵……那里……@看起来真的很美哦……"}]},{"autoTurnFirst":5.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800}]},{"autoTurnFirst":2.8,"chara":[{"id":301800,"motion":1}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":301800}]}],"group_21":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200,"pos":1,"voice":"vo_char_3018_00_28","textHome":"好了好了，不要盯着黑的地方看比较好噗。@要是看久了……可是会被吸进黑暗深处哦……@啊哈哈哈！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":200}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_29","textHome":"不管好坏，只管有不有趣就行了！@无聊的东西怎么样都很无聊吧？@所以一整天都去找乐子吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]}],"group_23":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_30","textHome":"哼……还挺有趣的嘛。@那么，走吧。赶紧的。@不然的话……我可能就改主意了。啊哈！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_31","textHome":"对手是谁都行……不过我讨厌无聊的事情～@不管什么事，只要有趣就不用考虑后果，@做到最后就行了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400,"pos":1,"voice":"vo_char_3018_00_32","textHome":"嘛～居然聚集了这么多人。@大家都很空吗？……我、我也是。@啊哈哈哈！行吧行吧，就大家一起开心吧！"}]},{"autoTurnFirst":1.5,"chara":[{"id":301800,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_33","textHome":"动物真可爱啊，我很喜欢。@动物和人类不一样。@诶？人也是动物？@那么，人就是我唯一讨厌的动物了。啊哈！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":301800}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":100,"pos":1,"voice":"vo_char_3018_00_34","textHome":"不要跑，乖乖地被打烂就行了！@像这样去敲……最后，就变得乱七八糟了！@啊哈！这也算是一个结束吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800,"motion":1}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_35","textHome":"尽情使用魔法打倒魔女的快感……@就和从大楼上跳下去一样爽呢！@让人兴奋不已！"}]},{"autoTurnFirst":5.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":300}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_36","textHome":"还要分狗派和猫派吗……哪边都很可爱啊！@我？……想知道吗？@我的话是……狗派。@嘛，都有喜好嘛！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301800}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":1}]}],"group_3":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_03","textHome":"……哈哈……已经无所谓了，@真的……各方各面……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301800}]}],"group_30":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":200,"pos":1,"voice":"vo_char_3018_00_37","textHome":"在意别人的目光就是在浪费时间。@要是因此错过了有趣的事情，@那真就是蠢到家了～"}]},{"autoTurnFirst":2.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300}]}],"group_31":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_38","textHome":"和动物接触的诀窍，就是用眼睛看。@一直盯着看，然后趁机……@也有可能被咬到。@不过由此开始你们的关系不也挺好的吗？"}]},{"autoTurnFirst":5.0,"chara":[{"id":301800,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":301800,"motion":1}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301800,"motion":100,"pos":1,"voice":"vo_char_3018_00_39","textHome":"我已经什么都不想去在意了！@只要做自己想做的事情，@自己会变成什么样子都无所谓吧？"}]},{"autoTurnFirst":3.5,"chara":[{"id":301800,"motion":200}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":400,"pos":1,"voice":"vo_char_3018_00_40","textHome":"除我之外的魔法少女？啊啊～我有兴趣呀！@要是遇见的话，会和我做朋友吗？@啊哈……啊哈哈哈哈！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301800}]},{"autoTurnFirst":7.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":301800,"motion":1}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_41","textHome":"啊，没有，不用那样子……也没问题的……@嗯……请不要再在意我了……对不起……@以前的我差不多就是这样的！啊哈！"}]},{"autoTurnFirst":4.5,"chara":[{"id":301800,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":100}]}],"group_35":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_42","textHome":"从那里过来就行了哦？"}]}],"group_36":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":301800,"motion":200,"pos":1,"voice":"vo_char_3018_00_43","textHome":"诶？已经结束了吗？"}]}],"group_37":[{"autoTurnFirst":4.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":100,"pos":1,"voice":"vo_char_3018_00_44","textHome":"嗯～很不错！"}]}],"group_38":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_45","textHome":"很期待下次！"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_46","textHome":"这个感觉……啊哈！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301800,"motion":100}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_04","textHome":"这个世界总是对我那么残酷……@我已经习惯了……"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301800}]}],"group_40":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":100,"pos":1,"voice":"vo_char_3018_00_63","textHome":"啊哈！"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_64","textHome":"给你看个好东西……"}]}],"group_42":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":100,"pos":1,"voice":"vo_char_3018_00_65","textHome":"我特意准备的哦……？"}]}],"group_43":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_66","textHome":"希望你能开心！"}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_05","textHome":"忘了我就行了……我也想随心所欲一点……"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":301800}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":0,"pos":1,"voice":"vo_char_3018_00_13","textHome":"啊，嗯，感觉不～错！不错不错！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301800,"motion":100}]}],"group_7":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_14","textHome":"诶……会变成这样啊……啊哈！有趣！"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":100}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301800,"motion":1,"pos":1,"voice":"vo_char_3018_00_15","textHome":"这样顺其自然，不是挺好的吗？"}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301800,"motion":300,"pos":1,"voice":"vo_char_3018_00_16","textHome":"干净的屋子总让我安不下心……@所以……我会把房间搞得乱七八糟！@啊哈！终于安心下来了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":301800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":301800,"motion":1}]}]},"version":3}