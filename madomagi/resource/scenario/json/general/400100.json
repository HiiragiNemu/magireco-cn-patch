{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_01","textHome":"我叫美国织莉子。你认识我吗？在魔法少女@中，她们似乎叫我白色的魔法少女……@你如果知道真相的话，我想你也一定会赞同@我的。可以的话一起喝杯红茶聊聊怎么样？"}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100}]},{"autoTurnFirst":2.3,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.4,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_18","textHome":"无法接受绝望的你，是不可能成为我的@对手的。放弃吧，晓美焰。我和只会逃到@别的道路的你不一样。"}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":300}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_19","textHome":"无论什么样的绝望在等待着我……我都会接受@并继续前进……！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_20","textHome":"路暗了就自己点灯。我不会逃开自己的命运。"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":300}]}],"group_13":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_21","textHome":"这份力量是为了被指示的道路而使用的。因为@我是想知道自己活着的意义……才成为@魔法少女的。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_22","textHome":"拯救世界……父亲大人没能实现的梦想，就由@我和纪里香来实现。请父亲保佑我们前进的@道路……并注视着我们吧！"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":0}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_23","textHome":"还剩一点就能完成救世了……纪里香……@请为了我来使用那份力量吧……我们一起@背负这份罪孽……今后，也请为我效力。我们@一起保护这个世界。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":5.3,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":2.2,"chara":[{"id":400100,"motion":400}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_24","textHome":"不错的时机呢。正好纪里香刚出门。如果她在@的话……要是看到我总是管你的事，就会@生气了吧！"}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100,"motion":400}]}],"group_17":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_25","textHome":"已经多少次了……又做噩梦了……不，并不是@预知未来的梦。是失去了活下去意义的……@可怜女孩的梦……"}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"id":400100,"motion":200}]}],"group_18":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100,"motion":400,"pos":1,"voice":"vo_char_4001_00_26","textHome":"呼呼，快到时间了……那个孩子就要边喊着@「我饿啦！」边冲过来了。虽然有些孩子气，@不过她并不是坏孩子哦？"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":0.4,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":1.5,"chara":[{"id":400100,"motion":0}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_27","textHome":"我虽然泡了红茶……不过有点浓哦？没关系，@没必要冲淡。加上牛奶，做成一杯浓厚的@奶茶就行了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":400100,"motion":300}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_03","textHome":"神滨……那里有着什么能扰乱我预知的东西@存在吗……？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":300}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":200,"pos":1,"voice":"vo_char_4001_00_28","textHome":"明天……傍晚开始就会下雨了。要出门的话，@最好带把伞。怎么样？我的能力，还是@挺有用的吧？"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":1}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_29","textHome":"如果这就是我的命运……无论多大的威胁到来@我都会阻止这一切。"}]},{"autoTurnFirst":5.0,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]}],"group_22":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_30","textHome":"那么，我们也出门吧。最后的结局已经注定了@所以还是赶快行动为好。"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":1}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_31","textHome":"害怕战斗？为了不被任何威胁所挫伤……@就不得不拥有一颗坚强的心。只要有想守护@的东西存在……是吧？"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]}],"group_24":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_32","textHome":"为了完成广大的救济，微小的牺牲在所难免。@为了拯救世界……就只好抛开琐碎的感情。"}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":200}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":400100,"motion":400,"pos":1,"voice":"vo_char_4001_00_33","textHome":"太棒了！做成了！……我还是第一次把@海绵蛋糕烤的这么好！松松软软的哦？哼哼！@必须要感谢蛋糕之神才行呢！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":400100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":400100,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":0.7,"chara":[{"id":400100,"motion":100}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":400100}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":400100,"motion":1}]}],"group_26":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_34","textHome":"一不小心……发个呆就被烫伤了……果然在@做菜的时候想事情是不行的啊。呼……@要是赶紧松手就好了……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100}]},{"autoTurnFirst":3.8,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":1}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_35","textHome":"纪里香这家伙……到底跑哪去了？……已经把@她的存在当作习惯了……突然这么安静还@真有些不适应了。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":300}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_36","textHome":"孩子就应该像个孩子……任性一点就行了……@无论什么都能听明白的孩子……一定不会@被大人喜欢的。"}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":200}]}],"group_29":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_37","textHome":"“丘比”……把那个生物当做宠物是想做@什么？那个生物就是才是一切的元凶。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":400100,"motion":300}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_04","textHome":"竟然把自己投身于危险之中。人的想法真是@不可思议。"}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":200}]}],"group_30":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_38","textHome":"想要抛开一些琐碎的感情……但如果她出了@什么事的话……我恐怕也会动摇吧。"}]},{"autoTurnFirst":5.5,"chara":[{"id":400100,"motion":300}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_39","textHome":"为了不被沉重的罪孽击垮……我的心不得不@变得坚硬……感觉有些意外吗？我竟然会说出@这些话……"}]},{"autoTurnFirst":5.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":400100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":1}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_40","textHome":"对纪里香来说，我就是她唯一重要的人。@你呢？你是否也有这样的人呢？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":300}]}],"group_33":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_41","textHome":"我已经……走到了没有退路的地方……然而…@有时我也会想……我的道路是否正确呢……"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":0}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":400,"pos":1,"voice":"vo_char_4001_00_42","textHome":"我不会退缩的……！"}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_43","textHome":"胜负已定。"}]}],"group_36":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":200,"pos":1,"voice":"vo_char_4001_00_44","textHome":"不想抵抗了吗？"}]}],"group_37":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_45","textHome":"好好悔过吧！"}]}],"group_38":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_46","textHome":"你也要成为我的棋子？"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_63","textHome":"就赌在这一击了……神谕光束!"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":400}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_05","textHome":"如果没有你，我估计早就坏掉了吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":1}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1,"pos":1,"voice":"vo_char_4001_00_64","textHome":"别小看我。我也是有能力战斗的哦？"}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":300}]}],"group_41":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_65","textHome":"你会输给我的……这就是我预知的未来……@！"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":1}]}],"group_42":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_66","textHome":"还差一点……这场战斗，就要结束了。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":400}]}],"group_43":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_02","textHome":"我是美国织莉子。我会把魔法少女的秘密@告诉你，而你有足够强大的内心去接受这个@事实吗？"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":1}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"id":400100,"motion":300}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":300,"pos":1,"voice":"vo_char_4001_00_13","textHome":"我的道路已经被指示了出来……只要笔直前进@就够了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":1}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":200,"pos":1,"voice":"vo_char_4001_00_14","textHome":"我已经看破这一切了。带着这份力量……@继续前进吧！"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":300}]}],"group_7":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_15","textHome":"那是谁都无法阻止的。所以……就在它出现@之前消灭它。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":300}]}],"group_8":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":400,"pos":1,"voice":"vo_char_4001_00_16","textHome":"我找到你了……守护者。你在世界迎来终结的@那个地方……却还想着阻止我。你应该@接受现实才是。"}]},{"autoTurnFirst":3.5,"chara":[{"id":400100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":400100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":400100,"motion":1}]}],"group_9":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400100,"motion":0,"pos":1,"voice":"vo_char_4001_00_17","textHome":"让我来结束这一切吧，晓美焰。继续成为@鹿目圆的守护者是愚蠢的选择，总有一天@你会明白的。"}]},{"autoTurnFirst":4.5,"chara":[{"id":400100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"id":400100,"motion":1}]}]},"version":2}