{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_01","textHome":"事到如今，好像也用不着自我介绍了……@我是佐仓杏子。@至于这个泳装……背后发生了很多事。@不过，就算是这幅样子，我也不会输给敌人。@因为我还是我自己，这一点并没有变。@而且，这样子我就能游泳了。@好不容易有了泳装，这次就去海边看看吧。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":260000}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]},{"autoTurnFirst":3.5,"chara":[{"id":260000,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":260000,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000}]},{"autoTurnFirst":5.0,"chara":[{"id":260000,"motion":100}]}],"group_10":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_17","textHome":"噗！哈哈！@原来如此，在海边确实玩不到这个！@我还头一次见这么长的水滑梯。@我要再去玩一次！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":260000}]},{"autoTurnFirst":1.5,"chara":[{"id":260000,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":260000}]},{"autoTurnFirst":3.5,"chara":[{"id":260000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":260000,"motion":200}]}],"group_11":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_18","textHome":"嗯~坐在泳圈上漂流的感觉也不差啊……@冲浪池原来是这样玩的啊……@比起海中的波浪要更有安心感……"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_051.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":260000,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_19","textHome":"嗯？特训什么的好像见效了啊。@姑且还是起到作用了吗……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":300}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_20","textHome":"没想到，沙滩排球也能拿来战斗啊……@比预想中的威力要大得多呢。"}]},{"autoTurnFirst":3.0,"chara":[{"id":260000,"motion":300}]}],"group_14":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_21","textHome":"我提了下用球把敌人打飞的事儿，@麻美那家伙，突然就兴致满满地说@「我们去特训吧！」@但沙滩排球和战斗没有关系吧？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":260000,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":260000}]},{"autoTurnFirst":4.0,"chara":[{"id":260000,"motion":300}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_22","textHome":"我本以为就算进行沙滩排球特训，@也只是玩球地手感会更好而已……@没想到，敌人的动作比以前看得更清楚了。@在这世上，所做的事情会带来什么影响，@还真是难以预料呢。"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":260000,"motion":100}]}],"group_16":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_23","textHome":"先不论沙滩排球和战斗有没有关系，@沙滩排球我是玩的越来越好了。@之前，沙耶香邀请我参加了个什么大会……@结果当然是优胜啦。@你看，这就是奖品，一整个夏天份的西瓜！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":4.5,"chara":[{"id":260000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":260000,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"id":260000,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_24","textHome":"嘿！你也来游泳的吗？我也正好来游泳。@毕竟是好不容易穿的泳装，@想着趁现在好好游一游。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_25","textHome":"从早上开始就很热啊……@好了，今天要干什么呢？@可以去海边游泳，去河边抓鱼也不错。@……决定了，盐烧河鱼！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000}]},{"autoTurnFirst":6.5,"chara":[{"eyeClose":1,"id":260000,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000}]}],"group_19":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_26","textHome":"还没有到中午吗？@那，我分给你个好东西。@我把今天早上小圆「刚从地里采的」野菜@给冰镇了一会儿。超好吃的哦！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]},{"autoTurnFirst":4.5,"chara":[{"id":260000,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000,"motion":400}]}],"group_2":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_02","textHome":"我是佐仓杏子。@因为许多缘由以泳装的姿态在战斗……@不过，也没关系吧？别管是不是我的风格，@总之是有了夏天的感觉。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":260000,"motion":100}]}],"group_20":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_27","textHome":"雷阵雨吗……这雨停了后会稍微凉快一些吧？@呼……这雨声听了有点想睡觉了……@稍作休息好了……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":4.0,"chara":[{"id":260000,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_28","textHome":"差点忘了！蚊香没有点……@就算是我，也受不了被蚊子咬啊。@又痒又很烦……真不想见到它啊。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":260000,"motion":200}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_29","textHome":"阳光果然还是热的要命啊……@还是去麻美那边，要杯麦茶来喝好了。@我记得，她应该常备着冰镇的饮料。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":260000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":200,"pos":1,"voice":"vo_char_2600_00_30","textHome":"这一身就是我现在的战斗服。@别因为穿着泳装拿着沙滩排球就小瞧我哦。@打中了就等着被弹飞吧，做好心理准备！"}]},{"autoTurnFirst":2.0,"chara":[{"id":260000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":260000,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_31","textHome":"听说有魔法少女姿态的我的复制品。@尽管并不是完全一样的，@不过试着和原本的魔法少女姿态的我战斗，@感觉会很有趣啊！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]}],"group_25":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_32","textHome":"要是因为我穿着泳装就把我看扁了，@可是要遭罪的哦。@不论是本来的姿态，还是现在这个姿态，@我都不打算输给任何人！"}]},{"autoTurnFirst":5.5,"chara":[{"id":260000,"motion":200}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_33","textHome":"要是有办法舒适地度过酷热难眠的夜晚的话，@请务必告诉我。昨天我又半夜醒了……@哈……有些睡眠不足"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":260000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":3.0,"chara":[{"id":260000,"motion":0}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_34","textHome":"嗯？你也找到了这片树荫啊。@这里很不错吧。很凉快。@我注意到有不少猫在往这边凑，@就好奇地跟着它们，于是发现了这里。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":260000,"motion":1}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_35","textHome":"有太鼓的声音。附近在办夏日祭吗？@好嘞，过去看一眼吧。@说不定会有很特别的小吃摊呢。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":260000,"motion":200}]}],"group_29":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":260000,"motion":200,"pos":1,"voice":"vo_char_2600_00_36","textHome":"在海礁也能捡到贝壳呢。@贻贝、龟足、钟螺、松叶笠螺……@简单地用盐煮煮就会很好吃。@分一点给你也行哦。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":260000,"motion":100}]}],"group_3":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_03","textHome":"想要学会游泳、吗……@嗯，心情我倒是明白。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_37","textHome":"打西瓜这活动，我是反对的。@魔法少女用全力砸下去的话，@西瓜要变成粉了吧？@怎么能去做这么浪费的事情啊！"}]},{"autoTurnFirst":5.5,"chara":[{"id":260000,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":200}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_38","textHome":"御魂那家伙……老做些多余的事情……@嘛，虽说多亏了这个，我能够自由地游泳了。@感谢……是不可能说的……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":260000,"motion":400}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_39","textHome":"哼。虽说这身泳装看上去就游得很快……@实际也确实好快。@接下来，去和十七夜比赛好了。@现在的我，是不会输的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]},{"autoTurnFirst":3.0,"chara":[{"id":260000,"motion":200}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_40","textHome":"要从小焰那里借根鱼竿来吗……@还是直接潜水去抓呢……@这样能抓到的鱼也会有所不同，不好决定啊。@到底哪种方法抓得更快呢？"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":260000}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":260000,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":200}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":260000,"motion":200,"pos":1,"voice":"vo_char_2600_00_41","textHome":"1、2……1、2……哇啊！？@什、什么啊。我在做准备运动很奇怪吗？@要是抽筋了不就像个傻瓜了嘛，以防万一啦。"}]},{"autoTurnFirst":1.3,"chara":[{"id":260000,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_051.exp.json","id":260000,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":260000,"motion":300}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_42","textHome":"比赛……不对，战斗开始！"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":260000}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":200}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_43","textHome":"连准备运动都算不上。"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_44","textHome":"我的攻击，很完美对吧？"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_45","textHome":"我可不是会被夏天热倒的类型。"}]}],"group_39":[{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_46","textHome":"呼！真想喝一瓶冰汽水呢。"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":260000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_04","textHome":"比起最开始已经好多了。@期待明天到来吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":400,"pos":1,"voice":"vo_char_2600_00_63","textHome":"就让你看看我特训的成果！"}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_64","textHome":"要上了！沙耶香！"}]}],"group_42":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_65","textHome":"盛夏的…火焰冲击！"}]},{"autoTurnFirst":2.5,"chara":[{"id":260000,"motion":200}]}],"group_43":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_66","textHome":"好！不错的垫球！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":260000,"motion":0,"pos":1,"voice":"vo_char_2600_00_05","textHome":"毕竟，可不能输给忧啊！@我认真也是能做到的！"}]},{"autoTurnFirst":2.5,"chara":[{"id":260000,"motion":200}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1,"pos":1,"voice":"vo_char_2600_00_13","textHome":"渐渐习惯了沙滩排球的手感。@感觉不错。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_14","textHome":"现在的我，感觉不会输给任何人。@你想试试接我的球吗？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":260000,"motion":200}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":260000,"motion":100,"pos":1,"voice":"vo_char_2600_00_15","textHome":"要聊一些关于夏日的话题吗？@鬼故事之类的"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":260000,"motion":300}]}],"group_9":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":260000,"motion":300,"pos":1,"voice":"vo_char_2600_00_16","textHome":"虽然沙耶香她们也邀请我去泳池过，@但那种地方有必要专门花钱去吗？@要是游泳的话，@我觉得来海边就可以了。"}]},{"autoTurnFirst":3.5,"chara":[{"id":260000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":260000,"motion":1}]}]},"version":3}