{"story":{"group_1":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_01","textHome":"在我记事前，双亲就因病离世了。他们似乎@是受到了事业失败的打击，再加上积劳成疾，@所以就……无依无靠的我来到了孤儿院@「杜鹃之家」。在那里，我认识了游佐叶月@和三栗菖蒲，之后就一直和她们在一起。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600,"motion":300}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_10":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_18","textHome":"叶月、菖蒲还有我。@我们三个的性格完全不同，@正因为如此我们才能成为彼此的支柱。@因为我们知道，我们三人是一条心的……"}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":302600,"motion":100}]}],"group_11":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_19","textHome":"我感觉到了……@魔力的波动……从我的体内涌出来了……"}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":200}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_20","textHome":"我的感觉更加敏锐了……@视野也比以前更广阔了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_21","textHome":"在被托付给孤儿院的时候，@我的心里充满了不安。@但是，这份不安的前方却有着崭新的人生。@所以我必须要跨越这道阻碍，继续前进。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":200}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_22","textHome":"杜鹃之家的老师@是个对大家一视同仁的温柔的人，@我对老师感到由衷的尊敬……@能够遇见像阳光一样温暖的人，@我想这就是所谓的「救赎」吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":100}]}],"group_15":[{"autoTurnFirst":8.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600,"motion":300,"pos":1,"voice":"vo_char_3026_00_23","textHome":"老师不惜牺牲自己来养育我们，@守护我们到最后……@我们绝对不会浪费这样延续下来的生命，@今后也不会放弃活着的希望……！"}]},{"autoTurnFirst":3.2,"chara":[{"id":302600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":200}]}],"group_16":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_24","textHome":"今天也见到你了呢。@你不觉得这是很珍贵的一件事吗？@因为，没有任何一天是理所当然会到来的。"}]},{"autoTurnFirst":4.2,"chara":[{"id":302600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600}]}],"group_17":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_25","textHome":"我早上会尽量起早一些。@因为我想在白天多一些时间活动。@这样子很合算，不是吗？"}]},{"autoTurnFirst":4.5,"chara":[{"id":302600,"motion":100}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_26","textHome":"我有很多身份，学生就是其中之一。@所以我要好好学习，@因为我希望自己的身份足够好看。"}]},{"autoTurnFirst":6.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":302600,"motion":100}]}],"group_19":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_27","textHome":"差不多从这个时间段开始，@我就要作为魔法少女行动了。@定期的探索是不可欠缺的。@这已经算是日常的一环了……"}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_03","textHome":"调味料的用法？嗯……无可奉告。"}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":100}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_28","textHome":"在找不到猎物的时候，@就不要再拖拖拉拉地继续寻找了。@为明天积攒力量也是很重要的。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"id":302600,"motion":100}]}],"group_21":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_29","textHome":"我平常会写日记。@看着日记一页页增加，@我就能真实感受到自己又活了一天。@听起来很奇怪，就像是确认自己的生存一样。"}]},{"autoTurnFirst":7.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302600,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_30","textHome":"总之对我们来说，生存下去比什么都重要……@所以，不用害怕……迈出那一步吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":100}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_31","textHome":"虽然不能肯定我一定会赢。不过，别误会了。@这不代表我就觉得自己会输。@那么，开始吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"id":302600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":200}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_32","textHome":"人越多，交流就越困难。@重要的是不要分散注意力。@只要把视线集中在胜利上就可以了。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_33","textHome":"在战斗中紧张感也是必要的。@就算是一直在一起的同伴也不可以太过亲近。@因为这之间产生的松懈，有可能会断送一切。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":302600,"motion":100}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_34","textHome":"需要达成的目标只有一个，@那就是「活下去」。@而且，并不是我一个人活下去。@而是和叶月还有菖蒲，三个人一起……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":100}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_35","textHome":"我倒也……不是讨厌人多的地方，@只不过喜欢安静的场所。@可能是无意识中，@就和世界保持距离了吧……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302600,"motion":100}]}],"group_28":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_36","textHome":"物美价廉就是我买东西的基本原则。@不调查家周围的价格情报就下手，@就如同没有作战计划的突击战一样鲁莽。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"id":302600,"motion":100}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_37","textHome":"在家里我主要负责事务性的手续和资产管理。@在财务方面，光是管理是不够的，@还要学会合理运用起来获得收益。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":302600,"motion":100}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_04","textHome":"我最大的敌人，可能就是做饭吧……"}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":100}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_38","textHome":"是人当然就会有自己不擅长的方面啦。@所以，我要堂堂正正，正大光明地学习做饭……@只不过，对叶月和菖蒲还是暂时保密吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":300}]}],"group_31":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_39","textHome":"嗯……是啊……真是好吃到令人昏迷……@不行……我得正视现实……@不过话说回来，到底是怎么回事呢……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302600,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600}]},{"autoTurnFirst":5.0,"chara":[{"id":302600,"motion":1}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_40","textHome":"我，的确没有和真正的家人在一起生活过。@但是，我遇到了把我作为家人来看待的人……@那个时候的记忆，我是绝不会忘记的……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":302600,"motion":100}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_41","textHome":"我很喜欢积分卡，@数上面的积分的时候也……很……@噗……呵呵呵……哈！@……糟糕……不小心笑出声来了……"}]},{"autoTurnFirst":5.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":302600,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":302600,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":302600}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_42","textHome":"乖乖成为我的猎物吧……"}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_43","textHome":"我一定会活下去……"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_44","textHome":"我的眼睛一直看着前方。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_45","textHome":"是啊……就是这么回事吧。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":200,"pos":1,"voice":"vo_char_3026_00_46","textHome":"向前进……就这么简单。"}]}],"group_39":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_63","textHome":"就算是为了肯定过去……也要抓住未来……！"}]},{"autoTurnFirst":2.0,"chara":[{"id":302600,"motion":200}]}],"group_4":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_05","textHome":"总之，最重要的就是经验。@那么，接下来该做什么好呢？"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_40":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_64","textHome":"差不多该从我的视线里消失了吧。"}]},{"autoTurnFirst":3.2,"chara":[{"id":302600,"motion":100}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_65","textHome":"是时候结束了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":100}]}],"group_42":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_66","textHome":"乖乖闭嘴的话，我就放你一马……！"}]},{"autoTurnFirst":2.5,"chara":[{"id":302600,"motion":200}]}],"group_43":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_02","textHome":"我是静海木叶。@我和叶月还有菖蒲过着四处辗转的生活，@现在住在神滨。@这里似乎是个十分有趣的地方。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"id":302600,"motion":1}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_13","textHome":"嗯……这样子，我就能变得更强了。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":1,"pos":1,"voice":"vo_char_3026_00_14","textHome":"不变得强大就无法活下去。@所以，我才来到了这里。"}]},{"autoTurnFirst":2.5,"chara":[{"id":302600,"motion":200}]}],"group_7":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_15","textHome":"我们是不能停下脚步的……@今后也会一直跑下去……"}]},{"autoTurnFirst":3.0,"chara":[{"id":302600,"motion":200}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":0,"pos":1,"voice":"vo_char_3026_00_16","textHome":"和什么人都能率直地搭话，@很容易被人当成是举止轻浮的人，@然而在做事之前却会深思熟虑……@她就是叶月。"}]},{"autoTurnFirst":3.5,"chara":[{"id":302600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":100}]}],"group_9":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":302600,"motion":100,"pos":1,"voice":"vo_char_3026_00_17","textHome":"菖蒲是想到什么就做什么的人。@她性格外向，除了我们没人能让她消停一点，@但也证明她是个心口如一的人。"}]},{"autoTurnFirst":3.2,"chara":[{"id":302600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302600,"motion":1}]}]},"version":3}