{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_01","textHome":"我叫安名梅露！是以100%命中率为傲的@最强占卜师！来吧，想占卜点什么！？@不管是今日的运势、明日的运势，@还是现在正困扰着你的问题，都可以问我！@啊，顺带一提，不接受投诉哦！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":400}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":1}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_18","textHome":"想逃脱我的塔罗牌所揭示的命运，@简直是难如登天！这下就如占卜所得，@我会越来越强的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303700}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100}]}],"group_11":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":400,"pos":1,"voice":"vo_char_3037_00_19","textHome":"哈，离献上漆黑命运之时，又稍微近了一些！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_20","textHome":"这魔力的提升，说明占卜的精度又上升了！"}]},{"autoTurnFirst":4.0,"chara":[{"id":303700,"motion":200}]}],"group_13":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_21","textHome":"我的占卜结果，今天晚饭是讨厌的纳豆才对，@结果却是最喜欢的炖菜！@啊，原来看到的牌是逆向的来着！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200}]}],"group_14":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_22","textHome":"占卜禁止令出来的时候，@感觉就好像整个人都被否定了一样。@但是，如果我的能力是诱导出占卜结果的话，@我也接受。我会加油去占卜出更好的结果的！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303700,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303700,"motion":100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_23","textHome":"我否定了自己。@因为太过依赖占卜能力，实力才会停滞不前。@所以今后我要先锻炼自己，再去使用占卜。@然后把力量和技术都练到极致！"}]},{"autoTurnFirst":6.5,"chara":[{"id":303700,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":303700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_24","textHome":"嗯哼，今天你也来啦？@我的占卜总能命中，沉迷其中也没办法嘛。@那么，想问点什么？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":1}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_25","textHome":"早晨我很紧张……@今天的运势就全寄托在这张塔罗牌上了……@结果是好是坏？翻牌！"}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":303700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":303700}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":303700,"motion":200}]}],"group_18":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_26","textHome":"午间的下课铃响了，早点去教学楼后院吧。@就算学校也有占卜禁止令，我也不会气馁的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303700}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":200}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":400,"pos":1,"voice":"vo_char_3037_00_27","textHome":"啊，你也是客人吗！？@啊并不是！@放学后想占卜的人蜂拥而至，@想回去也不容易呢！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":303700,"motion":200}]}],"group_2":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_03","textHome":"都说过了啊！我的占卜是绝对准确的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_20":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":1,"pos":1,"voice":"vo_char_3037_00_28","textHome":"呜——呜——说到夜晚就想到猫头鹰。@我太想养一只了，忍不住就开始学起来了。@请忘了这件事吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":303700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":303700,"motion":300}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":400,"pos":1,"voice":"vo_char_3037_00_29","textHome":"呜啊，不要吓我啊！@要是这张牌再放歪一公分，地球就要毁灭了！@骗你的啦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":303700,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":303700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_30","textHome":"不知道从哪里传来微妙的魔力……@我的占卜结果是魔女！@走吧，快点过去！@去看看我的占卜准不准吧！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303700}]},{"autoTurnFirst":3.5,"chara":[{"id":303700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":100}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_31","textHome":"也许就在不远的未来，@这座城市将会出现形如我们的复制品的存在。"}]},{"autoTurnFirst":8.0,"chara":[{"id":303700,"motion":200}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_32","textHome":"非上前线不可吗？@在这边……我也能像孔明借东风一样，@用我的占卜来引发奇迹……"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":303700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":303700}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303700}]}],"group_25":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_33","textHome":"不管是考砸了，还是体育课上摔倒了，@都是占卜的错！不是我的问题！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":100}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303700,"motion":300,"pos":1,"voice":"vo_char_3037_00_34","textHome":"嗯～嗯～嗯！@好想养啊……好想养猫头鹰啊！@像这样，站在占卜师的肩上，@绝对超帅气哦！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":303700}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":303700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":100}]}],"group_27":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_35","textHome":"但是命中率100%也很麻烦啊。@至少我想在遇到坏结果的时候，@帮别人回避一下的……"}]},{"autoTurnFirst":6.5,"chara":[{"id":303700,"motion":300}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":1,"pos":1,"voice":"vo_char_3037_00_36","textHome":"第一次去向调查的时候，写了想当占卜师。@但是不知道哪里看不顺眼，老师生气了……"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"id":303700,"motion":200}]}],"group_29":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_37","textHome":"再不认真可不行了……@现在鹤乃、桃子还有我，@争夺起能和七海学姐说话的地位了。"}]},{"autoTurnFirst":4.5,"chara":[{"id":303700,"motion":100}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_04","textHome":"命运不可推翻……只能接受它了！"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":303700,"motion":200}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_38","textHome":"对七海学姐而言，我的地位？@嗯——鹤乃是徒弟，桃子是跟班，@美冬是伙伴，我的话是妹妹吧！"}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303700,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":303700,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_39","textHome":"美冬虽然年龄较长，家务活却全都不太会。@说好听点叫大大咧咧，难听点就是粗枝大叶。@身为旁观者是这么觉得的。"}]},{"autoTurnFirst":4.0,"chara":[{"id":303700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":303700,"motion":100}]}],"group_32":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_40","textHome":"七海学姐简直是魔鬼教官。@但她并不是蛮不讲理，也是会关心朋友的，@我很喜欢！"}]},{"autoTurnFirst":5.0,"chara":[{"id":303700,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100}]}],"group_33":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_41","textHome":"快看！我们的相性史无前例的好！@好像光是这样，亲近感就按捺不住了！"}]},{"autoTurnFirst":3.0,"chara":[{"id":303700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":400,"pos":1,"voice":"vo_char_3037_00_42","textHome":"卡牌展开！引导我吧！"}]},{"autoTurnFirst":2.5,"chara":[{"id":303700,"motion":200}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_43","textHome":"不靠占卜，我也能凭实力取胜！"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_44","textHome":"我早已看到这个结果了哦！"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_45","textHome":"搞不好我一个人也没问题呢。"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_46","textHome":"这个结果连敌人也会吃惊吧！"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_63","textHome":"到各位塔罗牌出动了！"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":1,"pos":1,"voice":"vo_char_3037_00_05","textHome":"虽然以前也很热闹，@但现在依然可以热闹下去真是太好了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_64","textHome":"给它最最最坏的结果！"}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":400,"pos":1,"voice":"vo_char_3037_00_65","textHome":"魅惑众生吧，漆黑的阿卡纳！"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_66","textHome":"这就是命运！"}]}],"group_43":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_02","textHome":"是来求取我的占卜的吗！？啊，不是吗？@只是想一起战斗吗！那也没问题！@我是安名梅露！今后请多关照！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303700,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":303700,"motion":200}]}],"group_5":[{"autoTurnFirst":4.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_13","textHome":"这不就和我占卜的结果一模一样嘛！"}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":100,"pos":1,"voice":"vo_char_3037_00_14","textHome":"这门占卜已经精通了，去挑战下一门技术吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700}]}],"group_7":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":0,"pos":1,"voice":"vo_char_3037_00_15","textHome":"很好，想了解我的话，现在就是机会了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":200,"pos":1,"voice":"vo_char_3037_00_16","textHome":"我最常用的是塔罗牌！@虽然塔罗牌已经有了很多的排列法，@但我有着自己原创的排列和解读！"}]},{"autoTurnFirst":4.5,"chara":[{"id":303700,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":303700,"motion":100}]}],"group_9":[{"autoTurnFirst":9.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303700,"motion":1,"pos":1,"voice":"vo_char_3037_00_17","textHome":"我的塔罗牌，在查看过去、现在的状况、@灵魂的状态、未来的可能四张牌后，@通过查看第五张牌就能知道今天的综合运势！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303700,"motion":100}]}]},"version":3}