{"story":{"group_1":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_01","textHome":"最好……别跟我扯上关系……若被人被当作是@雪野加奈惠的朋友……你也会陷入麻烦。@深陷其中的话，争斗只会带来更多争斗。@无谓的暴力事件与日俱增……@等意识到时……自己已经处在事件中心了。@在变得只能和音乐作伴之前……离开我吧……"}]},{"autoTurnFirst":7.0,"chara":[{"id":304900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":304900,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":100}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_18","textHome":"我放弃做主唱了……实在是不会说话。但试着唱的时候……心里的话能脱口而出……@感觉真好……"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":304900}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":200}]}],"group_11":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_19","textHome":"身体变轻盈了……@感觉能更敏捷地击溃目标。"}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":200}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_20","textHome":"无所畏惧……@我已经有了……一个人也能活下去的力量……"}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":200}]}],"group_13":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_21","textHome":"难得的力量……所以我会把它用在自己身上。@其中一件是……@哪怕燃烧自己的生命也要报答的恩情……@不要说出去。"}]},{"autoTurnFirst":2.5,"chara":[{"id":304900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0}]}],"group_14":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_22","textHome":"拥有不输别人的力量，一个人也能活下去……@我曾这样想过，但实际并非如此。@有了美冬、八千代、还有她的奶奶之后……@我终于打破了外壳，变得更成熟了……@不要说出去。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0}]}],"group_15":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_23","textHome":"魔法少女的世界……很危险……@一步走错就有性命之忧。@但在理解彼此之后……就结下了深深的羁绊。@对于像我这样的人……@即使难过也能相互支持的当下是很幸福的……@不要说出去。"}]},{"autoTurnFirst":3.7,"chara":[{"id":304900,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"id":304900,"motion":100}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":304900,"motion":0}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304900,"motion":400,"pos":1,"voice":"vo_char_3049_00_24","textHome":"嗯……不再来也没关系的。@不是……来也没关系，只是因为有危险……@所以没必要来我身边……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":304900,"motion":300}]}],"group_17":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_25","textHome":"今天的睡眠是3小时……并不困……@从没觉得困过。这对我来说很平常……@大概我是短睡者吧……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":0}]}],"group_18":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_26","textHome":"我喜欢学校的屋顶，不会有人进入我的视线。@就像来到了只有我一个人的世界。@所以，现在也是一个人……不说了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":304900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":304900,"motion":300}]}],"group_19":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304900,"motion":400,"pos":1,"voice":"vo_char_3049_00_27","textHome":"嗯？抱歉……我在听歌。@现在正在听的是蓝调……"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":1}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_03","textHome":"甘苦参半……总感觉……很怀念……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":304900,"motion":300}]}],"group_20":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_28","textHome":"我睡得少……你还是去睡吧。@一会我去练习吉他的指法……@再看看音乐视频……"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":100}]}],"group_21":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_29","textHome":"我擅长独处……无论何时。@但是……自从遇到了八千代……@好像有所改变。呼……有点……羞愧。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]},{"autoTurnFirst":5.0,"chara":[{"id":304900,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"id":304900,"motion":1}]}],"group_22":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_30","textHome":"嗯……该走了。@我所见到的恶人……@也许是受了魔女的诅咒所影响吧……"}]},{"autoTurnFirst":3.0,"chara":[{"id":304900,"motion":200}]}],"group_23":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_31","textHome":"只是万一……@如果要和魔法少女大战一场……我有些担心。@我总和人争斗……战法也过于粗暴。@如果是假货……倒也无妨……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]},{"autoTurnFirst":4.7,"chara":[{"id":304900,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":304900,"motion":0}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":200,"pos":1,"voice":"vo_char_3049_00_32","textHome":"无论有多少敌人……我都会独自面对。@我向来是这种风格……因为无拘无束……"}]},{"autoTurnFirst":3.5,"chara":[{"id":304900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]}],"group_25":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_33","textHome":"自小学以来……就一直打架斗殴。@但是，我不会主动挑事，@反而总因为这张脸就被人盯上，@然后事情就找上门来了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":300}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":400,"pos":1,"voice":"vo_char_3049_00_34","textHome":"哈……谁！？唉，抱歉……@别人从背后过来，我会神经过敏。@以前……有过突然袭击的人……我怎么也……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304900}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900}]},{"autoTurnFirst":4.0,"chara":[{"id":304900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":304900,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":304900}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_35","textHome":"喜欢的音乐流派么……不拘一格。@我喜欢那种直击人心的感觉……@虽然这样说起来像是喜欢朋克或者重金属……@但其实没有关系。"}]},{"autoTurnFirst":9.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":1}]}],"group_28":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_36","textHome":"嗯……喜欢茶和蜜柑。@倒不如说……是最近才开始喜欢的。@都是能让我放松下来的东西……"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":1,"id":304900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":304900,"motion":1}]}],"group_29":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":300,"pos":1,"voice":"vo_char_3049_00_37","textHome":"如果换个许愿的时间和地点……@我大概会选择改变自己的面容吧。@但，因为能帮到朋友，我也并不后悔。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":304900,"motion":1}]}],"group_3":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_04","textHome":"又夺走了……我的朋友……"}]},{"autoTurnFirst":2.5,"chara":[{"id":304900,"motion":300}]}],"group_30":[{"autoTurnFirst":9.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_38","textHome":"我觉得美冬……还在做着身为女孩子的梦。@喜欢着漫画和戏剧中的恋爱……@向着那样的空想……投出羡慕的眼神……"}]},{"autoTurnFirst":4.5,"chara":[{"id":304900,"motion":200}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_39","textHome":"我能变得如此温和……全靠八千代的奶奶。@不可思议地……滋润了我原已干枯的部分……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":1,"id":304900,"motion":300}]}],"group_32":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_40","textHome":"回顾起来……还有很多想报答的恩情。@从最初得到的帮助到现在……@一定要报答八千代才行……"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304900,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":304900}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":0}]}],"group_33":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_41","textHome":"话说得差不多了。@还是说……难道你想……和我做朋友？@真难办……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"id":304900,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":304900,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":304900,"motion":300}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_42","textHome":"嗯……也就是，碾碎对方吧……"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_43","textHome":"因为打架……已经打出经验了……"}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_44","textHome":"能够交出身后的安心感……让人放心……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304900}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_45","textHome":"合作演奏……可以这样认为吗？"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_46","textHome":"能和大家共同战斗的现在……我很感恩……"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":300,"pos":1,"voice":"vo_char_3049_00_63","textHome":"这……还能忍受吗!!"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_05","textHome":"能打起精神来太好了……八千代……"}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":400,"pos":1,"voice":"vo_char_3049_00_64","textHome":"限制器——解除——!!"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":200,"pos":1,"voice":"vo_char_3049_00_65","textHome":"消失吧垃圾！"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":300,"pos":1,"voice":"vo_char_3049_00_66","textHome":"抱歉……要弄得一团乱了……"}]}],"group_43":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_02","textHome":"雪野加奈惠……@觉得是因为不良而出名的话，那也无妨。@本来也没想……去跟人拉帮结派……"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"id":304900,"motion":0}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_13","textHome":"嗯……感觉是这样没错……"}]}],"group_6":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304900,"motion":0,"pos":1,"voice":"vo_char_3049_00_14","textHome":"可能是骄傲……@但是……感觉我变强了。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":200}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":100,"pos":1,"voice":"vo_char_3049_00_15","textHome":"虽然……没怎么说过……@但是，能听听吗？"}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":200,"pos":1,"voice":"vo_char_3049_00_16","textHome":"有朝一日，我也想试试唱歌……@和朋友一起在小型舞台上……@虽然不知道能否实现……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":300}]}],"group_9":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":304900,"motion":1,"pos":1,"voice":"vo_char_3049_00_17","textHome":"会从吐露心声的歌曲中感受到魅力……@是不是因为自己也压抑着什么……@八千代这样说。@大概……是吧……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304900,"motion":300}]}]},"version":3}