urnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200,"motion":400}]}],"group_15":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405200,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4052_00_22","textHome":"为了重要的人而拼命……不知不觉中伤到了其@他的人……我想要为了帮助陷入那种境遇的@人而变强。我的力量也是为此而生的。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":405200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":405200}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":405200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":405200,"motion":200}]}],"group_16":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_23","textHome":"为了喜欢我的人们，我要以我的方式变得更加@强大！所以……就好好看着我吧。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200}]},{"autoTurnFirst":3.2,"chara":[{"id":405200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200,"motion":100}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_24","textHome":"你今天也来看我了呢。嗯，一起加油吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":405200,"motion":400}]}],"group_18":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_25","textHome":"早上好。你好像有些困……没问题吧？"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200}]},{"autoTurnFirst":2.7,"chara":[{"id":405200,"motion":300}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_26","textHome":"差不多该吃午饭了。我们一起吃吧？"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200}]},{"autoTurnFirst":2.2,"chara":[{"id":405200,"motion":100}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_02","textHome":"初次见面。我是时空管理局委托魔导师，菲特@·泰斯特罗莎·哈拉温。我们同心协力，一@起加油吧！"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200,"motion":200}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_27","textHome":"这个点经常是和奈叶练习魔法的。有时练得太@集中了会忘记吃晚饭……稍微有些害羞。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":405200}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_28","textHome":"呼呼……诶……啊……有什么事吗？不好意思@，我有些困了。我不太能够熬夜。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":405200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":405200,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":405200}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4052_00_29","textHome":"我很喜欢……像这样平静的聊天时间。啊，当@然我也喜欢和大家一起热闹的时间。真的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200,"motion":400}]}],"group_23":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_30","textHome":"我和雷光战斧都已经准备万全了。要出发的话@，随时打个招呼就行了。"}]},{"autoTurnFirst":1.8,"chara":[{"id":405200,"motion":200}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200,"motion":100}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4052_00_31","textHome":"在模拟战中可以确认自己训练的成果，找寻自@己的课题。有机会的话就一起试试吧。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200,"motion":400}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4052_00_32","textHome":"团体战重要的是配合。不断训练然后商讨配合@，准备好了就去挑战吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":405200,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200}]},{"autoTurnFirst":3.0,"chara":[{"id":405200,"motion":400}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405200,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4052_00_33","textHome":"嗯……怎么啦？如果有时间的话，就陪我聊一@会儿吧。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200,"motion":100}]}],"group_27":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4052_00_34","textHome":"我的防护装有着适应机动战的性能。轻便能够@使我快速敏捷的行动。不过与之相对的……@装甲薄弱就是它的弱点。"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200}]},{"autoTurnFirst":3.5,"chara":[{"id":405200,"motion":300}]}],"group_28":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_35","textHome":"我使用的魔法是米德切尔达式。在我们的世界@是很受欢迎的种类。不过雷电的变换天赋是@我特有的啦。诶嘿。"}]},{"autoTurnFirst":5.5,"chara":[{"id":405200,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"id":405200,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405200}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":405200,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4052_00_36","textHome":"最近，我好像长高了好多。也有了好像叫「生@长痛」的症状，我得好好留意以才行……"}]},{"autoTurnFirst":4.5,"chara":[{"id":405200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":405200,"motion":300}]}],"group_3":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_03"}]},{"autoTurnFirst":1.5,"chara":[{"id":405200,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"id":405200,"lipSynch":0}]}],"group_30":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4052_00_37","textHome":"奈叶和疾风，她们俩都是我重要的朋友。我们@一起上学，一起在管理局工作。总感觉一直@都在一起。"}]},{"autoTurnFirst":5.0,"chara":[{"id":405200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405200,"motion":400}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405200,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4052_00_38","textHome":"我的装备，雷光战斧。是从养育我的人那里得@到的礼物。从小就和我一起……今后一定也@是。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":4052