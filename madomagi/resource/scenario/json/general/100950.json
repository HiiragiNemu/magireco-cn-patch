{"story":{"group_1":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_01","textHome":"我叫水波玲奈，完毕。什么？没有。@别的也没什么可介绍的了。我知道啦，@自我介绍嘛，我做就是了。年龄15岁，完毕。@哈？还得多说点？那，你先做个示范吧。@我会认真听的，你的自我介绍。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":100900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_18","textHome":"顺利极了！要是继续保持的话，@咱们小队搞不好就要成为@魔法少女界有名的最强小队了。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_19","textHome":"要是觉得玲奈的极限就到这里了，那可不成。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":1.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_20","textHome":"努力和自信息息相关对吧？@忘了是谁说的，但我会努力的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_21","textHome":"很高兴变强了。@因为这份力量呢，对于玲奈来说……@也是用来守护队友桃子和枫的。"}]},{"autoTurnFirst":6.5,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_22","textHome":"对自己……应该更加爱护才行。@因为啊，要是说出最讨厌自己这种话来，@那喜欢着玲奈的人们该怎么办呢？"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_15":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_23","textHome":"总觉得……身为水波玲奈也意外地不错呢。@虽然曾经说着最讨厌自己，@想拥有能变成别人的能力而成为了魔法少女。@但现在不仅仅是力量……@而是连心灵也成长了吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_24","textHome":"喂，要让人等到什么时候啊。想想穿着这身@衣服傻站着的玲奈啊，罚你去买糖果来。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":100}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_50_25","textHome":"啊，冷……不说圣诞节，快想想办法解决@这寒冷啊……停下，快停下……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900,"motion":300}]}],"group_18":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_50_26","textHome":"买好了给桃子她们的礼物，就等着@活动开始了，没有别的事情……@能陪玲奈消磨下时间吗？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_50_27","textHome":"啊……肚子饿了……都怪圣诞节，@害得我这么难熬……烤鸡、派、蛋糕@这些好吃的都摆在一起，真的太坏了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":201}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_03","textHome":"不是的……这就是真正的玲奈……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":100900}]}],"group_20":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_28","textHome":"行了，赶紧睡吧。哈？玲奈？玲奈就算了。@马上还有别的事情要做了，@跟你没什么关系啦。"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"id":100900,"motion":200}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_50_29","textHome":"总觉得虽然因为太冷不喜欢冬天，但是@一旦习惯了的话，这冰凉的空气@还挺让人心情舒畅的。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100}]}],"group_22":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_50_30","textHome":"敢在别人心情正好的时候来捣乱，@现在哭着求饶也没有用了。我绝对要逮住你。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":201}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_50_31","textHome":"枫是不是去镜界了啊，不去帮忙没问题吗……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":100}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_32","textHome":"一大群人聚起来搞些吵吵嚷嚷的事情，@玲奈可不喜欢。总觉得看着吵闹至极的人，@自己莫名其妙的就冷静下来了……"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":3.3,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":100}]}],"group_25":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_50_33","textHome":"大概你会觉得意外，但是玲奈现在要去扮演@给弟弟送礼物的圣诞老人，以前就做过这个。"}]},{"autoTurnFirst":4.7,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":200}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_50_34","textHome":"糟透了啊……圣诞节当然要去看演出了，@为什么偏偏这个时候没有抽中!?明明@之前都是连胜的……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"tear":1}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":100900,"motion":201,"pos":1,"voice":"vo_char_1009_50_35","textHome":"跟魔法少女什么的没关系，单纯是玲奈穿着@这件衣服而已，虽然感觉并不是那么的合身。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_060.exp.json","id":100900,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":5.0,"chara":[{"id":100900,"motion":100}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_36","textHome":"蛋糕的话，比起水果，还是奶油的好！@如果不光是普通的蛋糕底，而是法式栗子蛋糕@的话，那就更棒了！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900,"motion":201}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_37","textHome":"给蛇绑上缎带做装饰，枫脑子里到底在@想什么啊……完全无法理解。@不过，她本人乐在其中就好。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":100}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_04","textHome":"这样的自己……水波玲奈真是没用……"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]}],"group_30":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":400,"pos":1,"voice":"vo_char_1009_50_38","textHome":"诶，有兴趣吗？这是玲奈整理的偶像圣诞歌曲@精选集！而且为了振作精神，@把最喜欢的歌都放在了后面！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_50_39","textHome":"别自顾自地觉得玲奈就不喜欢扮演@圣诞老人好吗？虽然确实是很麻烦，@但也没说过不喜欢啊。说到底，@还是帮上忙了的吧？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_50_40","textHome":"我家附近的公园，是第一次同桃子和枫一起@度过圣诞节的充满回忆的地方。@这个，是我的秘密……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_33":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_50_41","textHome":"虽然以前不太喜欢……但是看到这@闪闪发亮的景色……啊！你怎么在这!?@我只是在自言自语啦！话说不要偷听啊！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":1009