up_41":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_65","textHome":"真是烦透了……！吃我这一招！"}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":400}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_66","textHome":"不拿出撒手锏来，就没完没了了!?"}]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_02","textHome":"水波玲奈，请多关照。哈？@玲奈不喜欢自我介绍……因为又长又无聊。@有问题的话我会回答的哦。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"id":100900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":100900,"motion":200}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_13","textHome":"变强了是么？那让我打一下试试？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_00_14","textHome":"嘛，是一种眼前的目标达成了的感觉。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":100}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_15","textHome":"玲奈的性格总被人找茬。不变强可不行。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":100900,"motion":200}]}],"group_8":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_00_16","textHome":"不管找上门来的是什么敌人，@都痛快地打一顿不就好了。@越是强的敌人，赢的时候也就越发爽快嘛。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":100}]}],"group_9":[{"autoTurnFirst":6