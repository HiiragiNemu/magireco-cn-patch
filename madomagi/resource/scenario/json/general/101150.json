{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_00_01","textHome":"那个……我叫秋野枫！喜欢动物、植物……@还有大自然……在学校当饲育委员……@种了菜……啊！家里也种、种了菜！@我还养了好多宠物！像蛇啦……蜘蛛啦……@啊，什么？不喜欢……虫子吗……？"}]},{"autoTurnFirst":3.5,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":9.0,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"id":101100,"motion":400}]},{"autoTurnFirst":3.1,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":2.6,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"id":101100,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]}],"group_10":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_18","textHome":"害怕的事物只要逃避就行了……@以前的我总是这么想。……@但是，原来努力克服困难之后，@会是这样的心情呀……！"}]},{"autoTurnFirst":2.8,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101100}]}],"group_11":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_19","textHome":"还能……变得更强吗……？@我也想……像别人那样……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_20","textHome":"就好像刚睡醒一样……！@没、没有啊？我没在打瞌睡啊……！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101100,"motion":1}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_21","textHome":"我……想要变得更强！虽然还差得远……@要是什么时候能帮得上玲奈和桃子就好了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_14":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_22","textHome":"成为桃子和玲奈的队员……是我最自豪的事。@虽然我一点自信也没有，但每当感到不安的时候，@只要想到这个，紧张的心情也能平静下来。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]}],"group_15":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_23","textHome":"就算我又粗心做错事，只要想到有支持着我的@伙伴在，就能毫不恐慌地前进。这和撒娇有点@不一样，应该就是所谓的信赖吧。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"id":101100,"motion":1}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":101100}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":400,"pos":1,"voice":"vo_char_1011_50_24","textHome":"啊……那个……我在等你！一起去吧。@玲奈安排我去买炒面和雪糕那些的，@不去不行……我需要帮忙的人手。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":101100,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1011_50_25","textHome":"呜！？门突然打开吓到我了。@诶……早上好~@吃完早饭就一起出发吧。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]}],"group_18":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_26","textHome":"海边的阳光好强烈，好热啊～@要再涂一遍防晒霜吗？我放在包里带来了哦！@啊，但是包在更衣室的柜子里诶……"}]},{"autoTurnFirst":3.0,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":300}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_27","textHome":"从海水浴场回来，看到玲奈的脖子被晒伤了，@稍微摸了一下，结果挨了顿骂……"}]},{"autoTurnFirst":3.5,"chara":[{"id":101100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101100,"motion":300}]}],"group_2":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_03","textHome":"我夹了13次都没夹到……玲奈好厉害！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":100}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":200,"pos":1,"voice":"vo_char_1011_50_28","textHome":"我想去看看晚上的沙滩！@要是能亲眼看见一次海龟产卵就好啦！"}]},{"autoTurnFirst":3.4,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100,"motion":100}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_29","textHome":"最近和家人一起去了海边，爸爸钓到了河豚。@那河豚像气球一样鼓起来了，@就跟玲奈生气的样子一模一样～"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":0.6,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101100}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101100,"motion":200,"pos":1,"voice":"vo_char_1011_50_30","textHome":"难、难得来一次，今天就想挑战一下！@浴衣版的特大摩卡兔！@但是夹一次要1000日元，好紧张！"}]},{"autoTurnFirst":4.0,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":300}]}],"group_23":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":101100,"motion":400,"pos":1,"tear":1,"voice":"vo_char_1011_50_31","textHome":"呼呜呜！？出、出现了！镜界里闹鬼了！@快逃啊……诶？看错了？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101100,"tear":1}]},{"autoTurnFirst":2.5,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":101100,"tear":1}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_50_32","textHome":"虽然还是不太习惯人多的地方……@但还是要慢慢地去习惯才行。@一点点地克服弱点，就能改变自己了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101100,"motion":300}]},{"autoTurnFirst":3.3,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_25":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":200,"pos":1,"voice":"vo_char_1011_50_33","textHome":"最近夹娃娃机里的奖品也是夏季版的啊～@有套着游泳圈的，还有拿着海星的。@海星……慢悠悠地动起来的样子真可爱啊！"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":4.5,"chara":[{"id":101100,"motion":100}]}],"group_26":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_34","textHome":"佩罗是没法调节自己的体温的。@夏天的向阳处，是绝对不能待的。@所以就在家休息吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":101100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_50_35","textHome":"用自家采的黄瓜和西红柿做了中华凉面！@啊，是妈妈做的，我只是在一旁帮忙。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":300}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_50_36","textHome":"啊，快看，是烟花！好漂亮啊……@哇！声音隔了一会才传来～@是离这里很远的烟花大会吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":101100,"motion":1}]}],"group_29":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_37","textHome":"小八的食量大，很麻烦的。@但是，夏天有很多蟋蟀，喂食不成问题。@今天也多捉点吧！"}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100,"motion":200}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_04","textHome":"是我的错……！都是我太迟钝了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":1}]}],"group_30":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_50_38","textHome":"和玲奈她们一起去