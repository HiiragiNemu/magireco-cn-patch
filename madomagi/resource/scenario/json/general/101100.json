{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_00_01","textHome":"那个……我叫秋野枫！喜欢动物、植物……@还有大自然……在学校当饲育委员……@种了菜……啊！家里也种、种了菜！@我还养了好多宠物！像蛇啦……蜘蛛啦……@啊，什么？不喜欢……虫子吗……？"}]},{"autoTurnFirst":3.5,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":9.0,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"id":101100,"motion":400}]},{"autoTurnFirst":3.1,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":2.6,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"id":101100,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]}],"group_10":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_18","textHome":"害怕的事物只要逃避就行了……@以前的我总是这么想。……@但是，原来努力克服困难之后，@会是这样的心情呀……！"}]},{"autoTurnFirst":2.8,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101100}]}],"group_11":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_19","textHome":"还能……变得更强吗……？@我也想……像别人那样……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_20","textHome":"就好像刚睡醒一样……！@没、没有啊？我没在打瞌睡啊……！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101100,"motion":1}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_21","textHome":"我……想要变得更强！虽然还差得远……@要是什么时候能帮得上玲奈和桃子就好了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_14":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_22","textHome":"成为桃子和玲奈的队员……是我最自豪的事。@虽然我一点自信也没有，但每当感到不安的时候，@只要想到这个，紧张的心情也能平静下来。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]}],"group_15":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_23","textHome":"就算我又粗心做错事，只要想到有支持着我的@伙伴在，就能毫不恐慌地前进。这和撒娇有点@不一样，应该就是所谓的信赖吧。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"id":101100,"motion":1}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"id":101100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":101100}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_00_24","textHome":"早、早上好！啊呜……本、本来想今天由我先@打招呼的……等着等着……就莫名其妙紧张@起来了……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":101100}]},{"autoTurnFirst":4.9,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.1,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":101100,"motion":300}]}],"group_17":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_25","textHome":"早上好！差不多该给佩罗喂食了。@佩罗的早饭不解冻可不行。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":1.6,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":101100,"motion":100}]}],"group_18":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_26","textHome":"佩罗的鳞片摸起来凉凉的，很舒服！@今天它心情也不错的样子。@不介意的话你也抱看看吧？"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_19":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_27","textHome":"放学路上顺便去了杂货商场，@买了蔬菜种子哦！@还是没见过的新品种~"}]},{"autoTurnFirst":1.7,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":1.6,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]}],"group_2":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_03","textHome":"我夹了13次都没夹到……玲奈好厉害！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":100}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_28","textHome":"得去给小八喂晚饭了。虽然可以不用解冻……@但是小八总是把饭弄洒呢。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101100}]}],"group_21":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_29","textHome":"因为早上要打扫饲养室……所以我一直睡得@比较早。学校的小兔子们，很可爱的哦。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":400,"pos":1,"voice":"vo_char_1011_00_30","textHome":"啊……马上就到了必须要出发的时间吧？@可、可是我还什么也没准备！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":101100,"motion":200}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101100,"motion":100,"pos":1,"voice":"vo_char_1011_00_31","textHome":"必、必须战斗才行吧……？@啊呜……好、好奇怪啊……！@我明明是魔法少女……@还说这种话……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101100,"motion":300}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_32","textHome":"到、到要战斗的时间了……对吧……@一定不要拖大家的后腿才行……@一定不要麻烦别人……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":101100}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_33","textHome":"夹娃娃又失败了……明明花了好多钱……@结果还是没拿到奖品……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":1}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0,"pos":1,"voice":"vo_char_1011_00_34","textHome":"听说下周末，会有移动的爬虫园@在学校附近展览！@虽然偶尔有听说移动动物园……@但是爬虫园就很新鲜了呢！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100,"motion":100}]}],"group_27":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_35","textHome":"要是哪天可以只用自家种的菜来做晚饭@就好了！自家种的菜，味道可不是一般的好！"}]},{"autoTurnFirst":2.3,"chara":[{"id":101100,"motion":0}]},{"autoTurnFirst":0.7,"chara":[{"id":101100,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101100}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_36","textHome":"因为我许的愿望，建造公寓的计划被取消了。@这样可能有点自私……@但是我真的好喜欢被日光照亮的家……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":101100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101100}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100,"motion":1,"pos":1,"voice":"vo_char_1011_00_37","textHome":"这是妈妈在卖的红茶哦……不介意的话一起@喝喝看吧！无任何添加哦。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101100,"motion":300,"pos":1,"voice":"vo_char_1011_00_04","textHome":"是我的错……！都是我太迟钝了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"fa