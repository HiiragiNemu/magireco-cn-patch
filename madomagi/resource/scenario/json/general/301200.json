{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_01","textHome":"纯美雨，苍海帮的一员。伤害我同伴的人@绝不饶恕。我一定会打倒出手的家伙。@所以，我必须变强。所以我无论是现在或是@将来，都要积累功夫。修炼的道路不会停止。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"id":301200,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_18","textHome":"无论我多强大，也有战胜不了的对手。@那就是……杏仁豆腐！面对那份美味，@我就只能缴械投降了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":300}]}],"group_11":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_19","textHome":"不断修行，必定能发现新的拳法！"}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":200}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_20","textHome":"我隐约看到了，苍海帮要前往的未来……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200}]}],"group_13":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_001.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_21","textHome":"苍海帮，现在虽然是正经的帮派，但还是会@遭到世间的冷眼。所以总有一天，@我要把苍海帮变成公司。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_22","textHome":"苍海帮，目标是成为神滨市风险投资界的领导者。然后进行创新，协同，分享……大概是这样的感觉？这样的话我感觉能赚跟多钱吧？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":8.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":400}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_23","textHome":"我想到了苍海帮的新商机，那就是……健身！@使用拳法来健身！一定会空前繁荣的。@计划就是先做1000个俯卧撑！@嗯？这是谁都能做到的吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":400}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_24","textHome":"今天也来了啊，我在等你。那就开始继续@修行吧。首先是松鼠猴的姿势……嗯？不是@来修行的吗？那还真是抱歉了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0}]}],"group_17":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_25","textHome":"早上深呼吸，把新鲜气体吸入体内，这就是我@的每日任务。一起来试试吧。吸气~，呼气~"}]},{"autoTurnFirst":2.5,"chara":[{"id":301200,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":400}]}],"group_18":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_26","textHome":"今天的午饭是，麻婆豆腐、饺子、小笼包还有@炒饭。胃口好的时候，还会加上青椒肉丝@和棒棒鸡。"}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":100}]}],"group_19":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_001.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_27","textHome":"放学路上，我都会顺道去看看商店街的大家，@之后也会喝杯茶。普洱茶，对身体也很好。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":400}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_03","textHome":"沟通已经无法解决问题了，真是粗鲁的家伙。"}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":200}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_28","textHome":"这个时间，是积累功夫的时间。师父说过，@修行是没有终点的。所以每天都要不断重复。@哈啊——！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":100}]}],"group_21":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_001.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_29","textHome":"现在的我虽然看起来什么都没做，但其实是修@行中。哼哼哼……因为我现在，在踮着脚呢！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_001.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_30","textHome":"一切都是为了苍海帮。所以我要积累功夫……@所以我，不管是什么战斗都不会害怕！"}]},{"autoTurnFirst":4.5,"chara":[{"id":301200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_31","textHome":"不管是谁、什么时候、从哪里来，我都不会@逃避任何对手。从什么地方过来都可以。@真是期待啊……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_32","textHome":"总之要先找到自己的战场。找不到战场，@就不能称之为战士。因为是大型战斗，@所以不能迷失自己。"}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"id":301200,"motion":400}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_33","textHome":"如果可以的话我想避免战斗。和大家快乐地@生活比什么都重要。但是，我也绝对会抵抗@对这一点造成威胁的人。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":200}]}],"group_26":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":400,"pos":1,"voice":"vo_char_3012_00_34","textHome":"天津饭原本并不是中国的料理。而是日本人@做的中华料理。但芙蓉蛋是有的。芙蓉蛋就是@中国风的煎蛋卷。"}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":200}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_35","textHome":"我最喜欢玩偶了，可爱又软绵绵的。@而且小时候，它也是我修行的练习对象。"}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":100}]}],"group_28":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_36","textHome":"「哈！那、那不是传说中不碰到人就可以把人@打倒的招式吗！你，怎么会……」要是这么想@的话，那你恐怕是看错了。"}]},{"autoTurnFirst":8.0,"chara":[{"id":301200,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_37","textHome":"苍海帮是绝对不会欺负弱小的。@我们一直嫉恶如仇，这是不能打破的帮规。"}]},{"autoTurnFirst":4.5,"chara":[{"id":301200,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"id":301200,"motion":100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_04","textHome":"苍海帮里竟然有叛徒……真是难以置信。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":300}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_38","textHome":"成为魔法少女时许下的愿望，是没有什么值得@后悔的。把苍海帮从危机中拯救出来，是最重@要的事情。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":301200,"motion":100}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_39","textHome":"我的父亲也是苍海帮的。他过去非常强大，@只靠气势就能打倒5个人。这是从他本人那里@听到的故事，所以不会有错。"}]},{"autoTurnFirst":3.5,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100}]}],"group_32":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_40","textHome":"常盘七香，她确实是有才干的人。那个人，外@表很漂亮，却心怀猛虎。真是个麻烦的对手。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":301200,"motion":300}]}],"group_33":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_41","textHome":"传说中的拳法家曾说过战斗的秘诀，现在我来@告诉你……Don't think.Feeeeel……你就牢牢@刻在心里吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":301200,"motion":200}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_42","textHome":"我随时都可以。"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_010.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_43","textHome":"没问题。"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_44","textHome":"胜于易胜者也。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_45","textHome":"用拳头打出的胜利。"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_46","textHome":"守护苍海帮。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_63","textHome":"快到结束的时间了！"}]}],"group_4":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":301200,"motion":0,"pos":1,"voice":"vo_char_3012_00_05","textHome":"呼——事件姑且是告一段落了……姑且啊……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":100,"pos":1,"voice":"vo_char_3012_00_64","textHome":"你就在这里倒下吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301200,"motion":200}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":301200,"motion":200,"pos":1,"voice":"vo_char_3012_00_65","textHome":"我的真气已经充满全身！"}]},{"autoTurnFirst":3.5,"chara":[{"id":301200,"motion":1