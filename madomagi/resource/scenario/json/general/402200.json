{"story":{"group_1":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_01","textHome":"我在寻求着给这个时代带来希望的「光」，@长期辗转于各地……同时也从事佣兵的工作。@在旅途尽头，我终于遇见了「光」，塔鲁特。@只要能保护她，怎样的危险我都不会厌弃。"}]},{"autoTurnFirst":6.2,"chara":[{"eyeClose":1,"id":402200,"motion":100}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":402200}]},{"autoTurnFirst":2.2,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":402200,"motion":200}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_18","textHome":"我的身体里，充满从未感受到过的力量。@上吧，和塔鲁特一起。@为了给法兰西带来光明……！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_19","textHome":"谢谢……感觉从外到内都变得强大了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_20","textHome":"重获新生，大概就是这样的感觉吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":402200,"motion":100}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_21","textHome":"我和丘卜认识很久了。@在遇见塔鲁特之前，我就和它一起踏上了，@寻找能成为英雄之人的旅程。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_22","textHome":"谢谢……有了这崭新的力量，@我就能守护希望……那名叫塔鲁特的光芒。@要在这个残忍的时代生存下去，@能顺利迎来每一天，真是一件值得感谢的事。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":402200}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":0,"id":402200}]},{"autoTurnFirst":7.5,"chara":[{"id":402200,"motion":1}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_23","textHome":"我是影子……伴随着光的影子。@我能够得到如此多的力量，@也是因为名叫塔鲁特的希望之光，@她的力量增长的关系。光凭我一个人，@是到达不了这个领域的。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300}]}],"group_16":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_24","textHome":"我在等你哦。今天也迎来了新的一天呢。@那么，为了不让身体变迟钝，@做些简单的热身怎么样？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":402200,"motion":200}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_25","textHome":"你醒了么？习惯不错啊。@不知道敌人什么时候会发起袭击，@所以发困是不行的吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_26","textHome":"有时间的话，一起吃个饭怎么样？@有时间吃饭的时候不抓紧吃的话，@一旦打起来就没那个功夫了。"}]},{"autoTurnFirst":6.0,"chara":[{"id":402200,"motion":1}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_27","textHome":"我所操纵的是影子……@但影子是存在于强大光辉之下的。@光芒黯淡的话，我也会变得不安。"}]},{"autoTurnFirst":6.0,"chara":[{"id":402200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":300,"pos":1,"voice":"vo_char_4022_00_03","textHome":"竟然盯上了我不在的时候……"}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_28","textHome":"我马上就去睡了。虽说是魔法少女，@肉体受到损耗的话回复也是要花费魔力的。@所以我不太喜欢熬夜。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200}]},{"autoTurnFirst":3.5,"chara":[{"id":402200,"motion":300}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_29","textHome":"现在虽然被称作圣女大人，@塔鲁特还是那一副呆呆的样子，@和我初次遇见她时相比，@感觉并没有什么变化。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402200}]},{"autoTurnFirst":6.0,"chara":[{"id":402200,"motion":100}]}],"group_22":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_30","textHome":"怎么啦，比平常来的都要晚？@没有，我并不是在生气。@只不过在担心你出了什么事而已。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_31","textHome":"差不多该到出发的时间了吧？@你问就算对手是魔法少女也没关系么？@真是遗憾，只能说我已经习惯了战斗。"}]},{"autoTurnFirst":5.5,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300}]}],"group_24":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_32","textHome":"队伍同伴并肩作战，在我作为佣兵时，@已经在实战中数不清经历过多少次了。@正因为那时没有输过，所以才能活下来。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_33","textHome":"「莉兹」，像这样直呼我的名字就行了。@只要并肩战斗，你我就是平等的战友。"}]},{"autoTurnFirst":5.5,"chara":[{"id":402200,"motion":1}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_34","textHome":"塔鲁特是有着非同寻常资质的魔法少女。@也就是说，她身上背负的因果，@是多得惊人的。"}]},{"autoTurnFirst":5.0,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300}]}],"group_27":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_35","textHome":"丘比……？啊，就是丘卜吧。@因为地点和时代的不同所以称呼也不同吧？@塔鲁特则深信它就是「天使大人」。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402200}]},{"autoTurnFirst":6.5,"chara":[{"id":402200,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"id":402200,"motion":100}]}],"group_28":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_36","textHome":"传闻法兰西会毁于一个女人，@又被一位少女所拯救。@塔鲁特就是那位少女吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0}]}],"group_29":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_37","textHome":"梅丽莎虽说是塔鲁特的随从，@但我觉得她们更像是年龄相近的朋友。@丘卜也看中了她，@似乎她也有成为魔法少女的资质。"}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_04","textHome":"我想要见证……真英雄的诞生。"}]}],"group_30":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_38","textHome":"塔鲁特她，有个叫凯瑟琳的妹妹。@我没能保护住那孩子……@这是我心中无法挽回的伤痛。"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":402200}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":402200,"motion":300}]}],"group_31":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_39","textHome":"我生于意大利的维斯孔蒂家族。@因为祖父是异国来的佣兵，@所以我也成了有名的军人……@算是有好也有坏吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":0}]}],"group_32":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_40","textHome":"塔鲁特是希望之光……@我就选择当与光明相伴的影子。@就算是拼上这条性命，@我也要保护塔鲁特。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402200}]}],"group_33":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402200,"motion":400,"pos":1,"voice":"vo_char_4022_00_41","textHome":"嗯……你怎么了？你和塔鲁特一样，@也是喝醉了到处抱人的狂魔吗？@虽然允许狂欢，但也得把握好程度才行。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":402200,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402200,"motion":1}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_42","textHome":"看来不得不出手了。"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_43","textHome":"总之是胜利了。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":200,"pos":1,"voice":"vo_char_4022_00_44","textHome":"就这样吧。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_45","textHome":"不能骄傲哦。"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_46","textHome":"我不会让你掩盖光明的。"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_63","textHome":"影子啊……"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_05","textHome":"塔鲁特就是我的……我们的希望之光。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":402200}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":200,"pos":1,"voice":"vo_char_4022_00_64","textHome":"才刚刚开始呢。"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_65","textHome":"我可不打算手下留情。"}]}],"group_42":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_66","textHome":"我绝对……不会有任何绝望！"}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":200}]}],"group_43":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_02","textHome":"我是莉兹。是来自意大利的佣兵。@姓氏……？嗯……是啊……@现在的话，只管叫我「莉兹」可以吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":402200,"motion":300}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":0}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_13","textHome":"谢谢……我确实感觉到了我的进步。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402200,"motion":100}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":0,"pos":1,"voice":"vo_char_4022_00_14","textHome":"魔力来到了最高潮……@真想一直保持这个状态啊。"}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}],"group_7":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":402200,"motion":100,"pos":1,"voice":"vo_char_4022_00_15","textHome":"我们一起前进吧……@朝着太阳再次展现光辉的那一天。"}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402200,"motion":1,"pos":1,"voice":"vo_char_4022_00_16","textHome":"我在塔鲁特的故乡度过的那段日子，@真是无法替代的回忆。大概是过得太开心了，@一下子就待了好长时间……"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402200,"motion":100}]}],"group_9":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402200,"motion":300,"pos":1,"voice":"vo_char_4022_00_17","textHome":"塔鲁特拥有特别强大的力量，@但因此魔力的消耗也很巨大。@如果我的力量能增加的话，@她就可以不用战斗了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":402200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402200,"motion":100}]}]},"version":3}