{"story":{"group_1":[{"autoTurnFirst":11.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_01","textHome":"我是那种吊车尾的……一无是处，什么都@做不好，经常弄得一团糟……就好像@我一点都没有随着周围的世界动起来一样……@所以总是一事无成，眼泪掉下来了…呜呜…"}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":9.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100400,"motion":300,"tear":1}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_18","textHome":"我在图鉴上看到的，有种叫灰雀的鸟。@不是骗人啦，真的叫做灰雀！@……诶？不是啊，真的叫灰雀的！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":200}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_19","textHome":"…虽然不太明白…我是不是变得更好了呢？"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]}],"group_12":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_00_20","textHome":"现在，我的心中非常平静……很舒服……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100400,"motion":1}]}],"group_13":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_21","textHome":"我，确实存在感很低吧……这就是天生的吗…@要改变自己才行……！"}]},{"autoTurnFirst":4.5,"chara":[{"id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]}],"group_14":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_22","textHome":"那，那我开始了……嘿！……怎、怎么样？@有爽快地搭话的感觉了吗？呜呜……@第一次这么做……但还差得远吧……@我、我会继续努力的！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_23","textHome":"……耶！怎么样？状、状态如何？今天也要@好好……不、不行了！虽然好不容易@练到这种程度，还是得拼命地……@不过，好像更自信了一点……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_51_24","textHome":"啊，太好了……正在想要是没人来怎么办……@里面已经穿好泳装了……@唔，我是不是兴奋过头了呢？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100400}]},{"autoTurnFirst":1.5,"chara":[{"id":100400,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100400}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":400,"pos":1,"voice":"vo_char_1004_51_25","textHome":"鹤、鹤乃体操第一节！一二三四……@啊，是因为……鹤乃教我说，@这样做早上就能很有精神……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_18":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":400,"pos":1,"voice":"vo_char_1004_51_26","textHome":"找到猫咪了……@猫真的很擅长找凉爽的地方呢……@这里就算是正午，也能轻松地度过……"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":300,"pos":1,"voice":"vo_char_1004_51_27","textHome":"菲莉希亚没问题吧……@到傍晚就玩累了，家务和作业都不做……@会被八千代骂的吧……"}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_03","textHome":"在家里要是不乖乖的，就好像会被抛弃一样@让人害怕……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_20":[{"autoTurnFirst":14.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_51_28","textHome":"凉爽的风……叮叮的风铃声……@叽叽喳喳的虫鸣……云层间能看到的明月……@在这样的环境里大家一起入睡，真幸福……"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":0,"id":100400,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":100}]}],"group_21":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300,"pos":1,"voice":"vo_char_1004_51_29","textHome":"和家人一起旅行，感觉拘束得让人窒息……@但是，现在不一样了。@和重要的人一起欢笑，真的很开心！"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100400,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_51_30","textHome":"退治魔女的话……我随时都行！@啊，还是等一下吧！@变身回来时还是泳装……@这样没关系吗……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":100400,"motion":100}]}],"group_23":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_51_31","textHome":"原来如此……穿着泳装去的话，@无尽镜界里穿泳装的我就会变多诶……@要是穿着各种衣服过去……@感觉会很不得了……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":200}]}],"group_24":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200,"pos":1,"voice":"vo_char_1004_51_32","textHome":"要、要战斗的话就得换个心情了……@其实，我一直……以为这群人是来参加@海猫抢答大赛的……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_51_33","textHome":"哼……哼哼……@像这样，踩进海浪里，让浪花冲走沙子，@脚就会一点点地沉下去……@看起来很好玩……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400}]},{"autoTurnFirst":6.4,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":100}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_51_34","textHome":"淋上蜜瓜味糖浆的刨冰，看起来很好玩吧？@就像从顶上开始融雪的山一样，@只不过正好颠倒过来了……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]}],"group_27":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_51_35","textHome":"其实小猫咕噜咕噜里，也有去海边的故事……@乌鸦老黑飞在空中，把小海豹送回那里……@然后……然后……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"id":100400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":100400,"motion":300}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":100400,"motion":400,"pos":1,"voice":"vo_char_1004_51_36","textHome":"啊，好害羞……从没和别人一起来过海边……@也没让别人看过泳装……要冷静下来……"}]},{"autoTurnFirst":4.7,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":4.3,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":100400,"motion":300}]}],"group_29":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_51_37","textHome":"彩羽说她不会游泳……@要不要邀请她一起去泳池……@然后一起练习……@但是，她会来吗……"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_04","textHome":"找了好几天……但是，再也没见到咕噜了……"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":2,"id":100400,"motion":300,"tear":1}]}],"group_30":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_51_38","textHome":"眨眼间肚子就咻地被砸到了……@鹤乃和菲莉希亚她们@真的是尽全力在扣球啊……"}]},{"autoTurnFirst":3.3,"chara":[{"id":100400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":10