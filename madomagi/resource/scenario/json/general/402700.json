{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_01","textHome":"我是拉皮努。魔法少女。咳咳！@我也是可鲁波和米诺的姐姐哦。@平时总是交给可鲁波战斗，@本以为没有我出场的机会……@啊，我是怎么样成为魔法少女的……@哼哼哼！保密！"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":402700,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402700}]},{"autoTurnFirst":7.3,"chara":[{"id":402700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":400}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":402700,"motion":100}]}],"group_10":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_17","textHome":"米诺虽然很少生气，但生气起来超级恐怖！@只要是牵扯到母亲大人的事，@就算是我和可鲁波也没办法阻止她！"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1}]}],"group_11":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_18","textHome":"如果，可鲁波和米诺出了什么事的话，@我可不会忍气吞声的哦！@我会把那家伙找出来，@直到把他变得不成人形！"}]},{"autoTurnFirst":4.2,"chara":[{"id":402700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"id":402700,"motion":200}]}],"group_12":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_19","textHome":"唔嘿嘿♪这样我的魔法也完美了！@我已经等不及想要用它了！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":1}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_20","textHome":"怎么样？我很厉害吧——！？@快夸我快夸我！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_21","textHome":"太好了！感觉到力量好像在疯狂涌出？@这样我就能破坏更多的人类了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1}]}],"group_15":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_22","textHome":"噢噢！所谓的不会输，就是这样的感觉吧！@嗯，现在就算一群「圣女」冲过来也没关系！@嘛，反正我就算死了也能复活，@死亡也不会有任何疼痛哦～！？"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":402700,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":4.2,"chara":[{"id":402700,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":402700,"motion":1}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_23","textHome":"就算不用这么强，@我想也没有能打倒我的魔法少女。@不过，变强也是一件好事呢！@只要我们变得更强，@离实现母亲的梦想就能更近一步！"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400}]},{"autoTurnFirst":2.9,"chara":[{"id":402700,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100}]}],"group_17":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_24","textHome":"找～到你啦！！今天，也一起玩吧？@附近好像有敌军哦！@我去问问米诺，能不能和他们一起玩！"}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]},{"autoTurnFirst":7.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":402700,"motion":100}]}],"group_18":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_25","textHome":"早上好！诶？我的面具去哪了？@啊，难道说我已经带上了吗！？@诶，没有带上呀！？诶？@怎么回事？诶？"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":400}]},{"autoTurnFirst":2.6,"chara":[{"id":402700,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":1}]}],"group_19":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_26","textHome":"喂，该吃午饭了哦！快点一起来吃嘛！@吃午饭啦！午饭！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"id":402700,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":402700,"motion":400}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_02","textHome":"拉皮努哟！唔嘿嘿嘿～♪@今天玩些什么呢？啊好多玩具在走呢！@那个——我可以弄坏那些人吗？@可以吗？"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":1}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":1.5,"chara":[{"id":402700,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"id":402700,"motion":200}]}],"group_20":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_27","textHome":"差不多是洗澡的时间了吗？@玩得都出了一身汗了，该去了吧？@可以吗！？怎么样怎么样！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_21":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402700,"motion":300,"pos":1,"voice":"vo_char_4027_00_28","textHome":"嗯……啊……诶？嗯，已经要睡了吗？@啊——！？因为是小孩子所以要早睡？@才没有这种事呢！"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402700}]},{"autoTurnFirst":2.0,"chara":[{"id":402700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":200}]}],"group_22":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_29","textHome":"诶～可鲁波好像又一个人跑去战斗了。@真是的——也留点玩具给姐姐我嘛！！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":402700,"motion":200}]}],"group_23":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_30","textHome":"那个！快点去战场嘛！@我想要把敌人们都当做玩具，@弄得七零八落，乱七八糟的！@快点嘛！快点！"}]},{"autoTurnFirst":2.5,"chara":[{"id":402700,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400}]}],"group_24":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_31","textHome":"魔法少女的赝品馆？那不是很有趣嘛！@反正不管是赝品还是真品@破坏起来都是一样的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"id":402700,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402700,"motion":1}]}],"group_25":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_32","textHome":"你说有聚集了很多魔法少女的战争？@唔嘿嘿……好呀！@那么我就能尽情大闹一场了！"}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":200}]}],"group_26":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_33","textHome":"三姐妹中个子最高的是可鲁波，@中间的是米诺，我是最小的。@不过要是这样就把我当成妹妹的话，@我可是会生气的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":200}]}],"group_27":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":200,"pos":1,"voice":"vo_char_4027_00_34","textHome":"我很强哦？因为只要使用我的魔眼，@不管是敌人还是队友，@大家都会无法使用武器。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100}]}],"group_28":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_35","textHome":"传闻中的圣女？……那家伙妨碍了母亲大人，@这次就把她大卸八块吧……！"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":200}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_36","textHome":"为什么要总是戴着面具？@嗯～因为米诺是这么要求的……@还有，习惯了的话，戴着也能冷静下来吧？"}]},{"autoTurnFirst":4.3,"chara":[{"id":402700,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402700,"motion":100}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_03","textHome":"约定好了哦！一起去泡澡！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_30":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_37","textHome":"我喜欢可鲁波的温柔。@她对我总是使用敬语，@为了不让我们陷入危险的魔法之中，@她总是一个人在战斗！"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":2.7,"chara":[{"id":402700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_38","textHome":"米诺明明是最小的那个，@但她有时会唠叨个不停。@没办法，一切都是为母亲大人！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":300}]}],"group_32":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_39","textHome":"……诶，死亡很可怕吗？@不可怕哦！因为我死了之后就会立即复活！@真的哦！我说真的啦！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]}],"group_33":[{"autoTurnFirst":7.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_40","textHome":"我们姐妹成为魔法少女，@都是为了母亲大人，付出了各自的愿望。@我的愿望是希望母亲大人……@算了，还是保密吧！"}]},{"autoTurnFirst":2.3,"chara":[{"id":402700,"motion":400}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402700}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100}]}],"group_34":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":0,"pos":1,"voice":"vo_char_4027_00_41","textHome":"……诶，啊，什么？……想被我蹂躏吗？@没问题哦！我正好没玩够呢♪@……想从哪里开始被破坏呢？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_42","textHome":"会死得很凄惨哦♪"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":200,"pos":1,"voice":"vo_char_4027_00_43","textHome":"真是一点意思都没有！"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_44","textHome":"诶诶——已经结束了～!?"}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_45","textHome":"之后帮我洗个澡吧——♪"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_46","textHome":"辛苦啦！"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":200,"pos":1,"voice":"vo_char_4027_00_04","textHome":"下次我一定要去玩！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_05","textHome":"过来，过来，快过来♪"}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":100,"pos":1,"voice":"vo_char_4027_00_13","textHome":"这样就能弄坏更多的人了♪"}]}],"group_7":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402700,"motion":400,"pos":1,"voice":"vo_char_4027_00_14","textHome":"噢——好多的魔力！？@有了这些，又能尽情地破坏了呢♪"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":200}]}],"group_8":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_15","textHome":"下次一起去洗澡吧——♪"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700}]}],"group_9":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402700,"motion":1,"pos":1,"voice":"vo_char_4027_00_16","textHome":"可鲁波好像有了比「圣女」更想战斗的对象。@其他的人都只不过那两个人的背景而已，@成为不了我们的对手。"}]},{"autoTurnFirst":3.2,"chara":[{"id":402700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402700,"motion":400}]}]},"version":3}