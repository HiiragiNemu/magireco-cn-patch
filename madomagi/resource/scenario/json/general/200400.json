{"story":{"group_1":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_01","textHome":"呼～一路追着麻美学姐，一不留神我也来到了@神滨……这里确实很奇怪。不仅能撞见魔女@和使魔，而且……那是什么？传闻？@那些家伙真是出乎意料的可怕！@嘛，麻美学姐倒是不会输给那些家伙就是……"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400}]},{"autoTurnFirst":4.5,"chara":[{"id":200400,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":100}]}],"group_10":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_18","textHome":"我已经不再是过去的我了。@如今站在这里的我，@只靠自己一个人是绝对无法成就的。@那么现在，就让我勇往直前吧！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":200400,"motion":200}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_19","textHome":"感觉超棒……！@现在的我，开心得快飞起来了哦！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200400,"motion":100}]}],"group_12":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_20","textHome":"呜哇……我感觉，世界看起来都不一样了。"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_21","textHome":"嗯，我似乎变强了一些……@就算是之前一筹莫展的对手，@现在我也觉得能赢了。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200400,"motion":1}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":300,"pos":1,"voice":"vo_char_2004_00_22","textHome":"我的愿望是治好青梅竹马的伤病。@不仅如此……我还想获得力量，@能一直保护好重要的人。@所以我不后悔成为魔法少女。我不能后悔。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":200400}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":200400,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":200400,"motion":1}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_23","textHome":"我很开心自己能够变强。@那样就能不依靠别人，保护自己想保护的人了@对吧？我讨厌和那些见死不救，利用他人的@家伙们一起行动。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200400,"motion":1}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0}]}],"group_16":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_24","textHome":"好，今天也好好努力吧！@虽然每天有着各种各样的事情，@但一个劲地烦恼解决不了任何问题，对吧！"}]},{"autoTurnFirst":7.0,"chara":[{"id":200400,"motion":1}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_25","textHome":"早上好！我的闹钟没响，差点就睡过头了，@还好还好！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":1}]}],"group_18":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_26","textHome":"好，午饭时间到！那么，快点快点！@要我别走那么快？@不行不行，再怎么说我也还在成长期嘛！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":100}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_27","textHome":"我差不多该出门了。@是的，去搜寻邪恶的魔女。@麻美学姐说，这是正义的伙伴应尽的义务！@"}]},{"autoTurnFirst":4.0,"chara":[{"id":200400,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":200}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_03","textHome":"交给魔法侦探沙耶香！有问题都来问我吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":200400,"motion":1}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200400,"motion":400,"pos":1,"voice":"vo_char_2004_00_28","textHome":"呜哇，都已经是这个时间点了吗！？@我还计划这时候已经做完作业，钻进被窝了呢！@咕——看来我还是太天真了！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":200400,"motion":300}]}],"group_21":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_29","textHome":"大家都似乎觉得我和古典音乐沾不到边。@所以，我偶尔说中了曲名，就会震惊四座。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400}]},{"autoTurnFirst":4.0,"chara":[{"id":200400,"motion":100}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":400,"pos":1,"voice":"vo_char_2004_00_30","textHome":"太～慢～了！我早就做好巡逻的准备了！@快点，不要磨磨蹭蹭了，赶紧出发吧！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":200}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":300,"pos":1,"voice":"vo_char_2004_00_31","textHome":"我啊，是为了保护重要的人才期望这份力量。@如果存在有比魔女更可恶的人的话，@我也会去战斗。即使同是魔法少女。"}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":0}]}],"group_24":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200400,"motion":300,"pos":1,"voice":"vo_char_2004_00_32","textHome":"看，我的手一直在颤抖……@从刚刚开始就停不下来。不过不用担心。@只要有同伴一起，我就会精神百倍！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":200400,"motion":200}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_33","textHome":"小圆的妈妈，真的很帅气啊。@长的很漂亮，又是职场强人。@到底该怎么做，才能像她一样呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200400,"motion":100}]}],"group_26":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_34","textHome":"我的朋友仁美，每天都在忙着练习的样子，@不是练钢琴就是是练日本舞。@幸好我只是平常人家的孩子……"}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":100}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_35","textHome":"我开始喜欢逛音像店，@也是因为我青梅竹马的缘故……@不知道为什么，@我总能在流动货架上发现超稀有的CD。"}]},{"autoTurnFirst":6.0,"chara":[{"id":200400,"motion":100}]}],"group_28":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_36","textHome":"成为魔法少女最让我惊讶的是，@能够使用心灵感应！@虽然不知道是什么原理，但有时真的很方便！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_37","textHome":"小圆这家伙，戴着可爱的缎带@来吸引男孩子注意什么的，我可不会原谅！@小圆可是要成为我老婆的！"}]},{"autoTurnFirst":1.8,"chara":[{"id":200400,"motion":400}]},{"autoTurnFirst":4.7,"chara":[{"id":200400,"motion":200}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_04","textHome":"所以，我都说了才不是去约会呢……！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":100}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_38","textHome":"那个叫晓美焰的转校生……@有着眼镜、麻花辫再加上冒失的属性。@这是萌吧？这就是所谓的萌吧！？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200400}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":400}]}],"group_31":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_39","textHome":"真是幸运，能在同一个中学遇见麻美学姐。@她不会为了自己而使用魔法，@是正义的魔法少女。"}]},{"autoTurnFirst":1.7,"chara":[{"id":200400,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":200400}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":200400,"motion":200}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_40","textHome":"杏子她啊，一边喊着麻美学姐泡的茶好酸，@一边流着眼泪喝了下去。@她的口味真像个小孩子啊！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":200400,"motion":100}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_41","textHome":"我是为了他才使用了祈求奇迹的权利……@我不想把这份感情当作谎言。@所以我是不会后悔的，绝对不会！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200400}]},{"autoTurnFirst":5.5,"chara":[{"id":200400,"motion":0}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_42","textHome":"让我来打飞它吧！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_43","textHome":"算是告一段落了。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_44","textHome":"真是千钧一发呀。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_45","textHome":"我都忍不住夸自己了哦？"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_46","textHome":"太无聊了我都快睡着了！"}]}],"group_39":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_63","textHome":"我不会输……我怎么可能会输！"}]},{"autoTurnFirst":3.7,"chara":[{"id":200400,"motion":400}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_05","textHome":"这里有这么多的魔法少女，真是吓了我一跳。"}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_64","textHome":"呀啊！"}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_65","textHome":"还有还有，还不止这样！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200400,"motion":200}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200400,"motion":200,"pos":1,"voice":"vo_char_2004_00_66","textHome":"看到了吗，我真正的实力！"}]}],"group_43":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":201,"pos":1,"voice":"vo_char_2004_00_02","textHome":"久等啦！正义的魔法少女——美树沙耶香，前@来造访！嗯嗯，因为我很强，所以有什么事@尽管交给我就行了……开玩笑的啦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200400,"motion":201}]}],"group_5":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200400,"motion":400,"pos":1,"voice":"vo_char_2004_00_13","textHome":"噢噢!?我感觉全身充满了魔法的力量……！"}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_14","textHome":"嗯，好久没有这么舒服了！爽快爽快！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400}]},{"autoTurnFirst":2.7,"chara":[{"id":200400,"motion":100}]}],"group_7":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1,"pos":1,"voice":"vo_char_2004_00_15","textHome":"谢谢你一直和我在一起。让我总能放下心。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200400}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200400,"motion":0,"pos":1,"voice":"vo_char_2004_00_16","textHome":"身经百战后，我也算是个合格的魔法少女了，@不过我依然是我。@魔法少女沙耶香，之后也请多指教！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200400,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"id":200400,"motion":200}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200400,"motion":100,"pos":1,"voice":"vo_char_2004_00_17","textHome":"我这个人并没有什么特别的天赋和才能。@但即便如此，我也变得这么强了……@可以稍微骄傲一下吗？"}]},{"autoTurnFirst":5.0,"chara":[{"id":200400,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200400}]}]},"version":3}