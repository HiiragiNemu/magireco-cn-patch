_4002_00_63","textHome":"就让这结束吧……！吸血鬼之牙!"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":200}]}],"group_4":[{"autoTurnFirst":2.6,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":200,"pos":1,"voice":"vo_char_4002_00_05","textHome":"为了你，就算是去地球的背面买红茶也完全@没问题的！"}]},{"autoTurnFirst":2.4,"chara":[{"id":400200,"motion":300}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400200,"motion":200,"pos":1,"voice":"vo_char_4002_00_64","textHome":"你没有拒绝权！被干掉吧……！"}]},{"autoTurnFirst":1.0,"chara":[{"id":400200,"motion":0}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_65","textHome":"别东张西望！一瞬间就了结你！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400200,"motion":100}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":300,"pos":1,"voice":"vo_char_4002_00_66","textHome":"还有人在等着我……！差不多该让我回去了！"}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":1}]}],"group_43":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_02","textHome":"我是吴纪里香。黑色的魔法少女……这样的@称呼似乎更贴切吧？你要是想对抗织莉子的话@我就会毫不犹豫地击垮你。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":100}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":400200,"motion":1}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_13","textHome":"啊……我感受到了织莉子的爱……！@织莉子的爱，就是我的力量！"}]},{"autoTurnFirst":4.5,"chara":[{"id":400200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":200}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo