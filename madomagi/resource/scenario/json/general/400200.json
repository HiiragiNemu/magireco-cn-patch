{"story":{"group_1":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_01","textHome":"我是吴纪里香。这样啊……那我就告诉你@织莉子是个多么出色的人吧。她拯救了被@黑暗侵蚀的我……！她是充满爱心……如同@圣母一样的人。不，这就是我的自我介绍了。@因为我的一切都是她。"}]},{"autoTurnFirst":4.3,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"id":400200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200,"motion":1}]},{"autoTurnFirst":2.4,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":1.9,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":0}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":2.6,"chara":[{"cheek":1,"id":400200,"motion":200}]}],"group_10":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":100,"pos":1,"voice":"vo_char_4002_00_18","textHome":"没问题……。放心吧，织莉子。就算在终点@等待着我的是绝望……无论变成什么样子……@我都不会伤害你。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400200,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]}],"group_11":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"pos":1,"voice":"vo_char_4002_00_19","textHome":"怎么可能存在什么极限？因为我对她爱的极限@就是无限！"}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":300}]}],"group_12":[{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200,"motion":100,"pos":1,"voice":"vo_char_4002_00_20","textHome":"啊，织莉子…！我变成了与你般配的人哦…！"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200}]}],"group_13":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_21","textHome":"我的「全部」「重要」，在这个世界上只有你@一个！所以我的目的地不会动摇。织莉子，@一起前进吧……！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":300}]}],"group_14":[{"autoTurnFirst":1.9,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_22","textHome":"织莉子，要怎么使用我再次变强的力量呢？@啊，我等你的命令好久了……！这份力量，@好想快点为你所用……！我一定会…把你的@命令彻底完成的。"}]},{"autoTurnFirst":3.6,"chara":[{"id":400200,"motion":300}]},{"autoTurnFirst":1.1,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":2.7,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":0.8,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":400200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":3.1,"chara":[{"id":400200,"motion":300}]}],"group_15":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_23","textHome":"我可以向天发誓。不管发生什么……无论变成@什么样子……我都会永远追随着你……所以@在你安息的那一天到来之前……我绝不会@离开你。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":400200,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_24","textHome":"你在干嘛。……哈啊，织莉子不在我好无聊。@你，知道织莉子去哪了吗？"}]},{"autoTurnFirst":5.0,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":400200,"motion":200}]}],"group_17":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":400200,"motion":100,"pos":1,"tear":1,"voice":"vo_char_4002_00_25","textHome":"呜哇，呜……啊……总感觉今天有点睡不醒…@喝杯加满果酱的红茶，也许就精神了吧！"}]},{"autoTurnFirst":1.5,"chara":[{"id":400200,"motion":0,"tear":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":0}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200,"motion":100,"pos":1,"voice":"vo_char_4002_00_26","textHome":"啊，我饿了！真的饿啦！那么！这样的话，@今天就和织莉子吃宇宙第一美味的帕菲吧！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":400200,"motion":300}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_27","textHome":"废话就免了吧。我不需要和织莉子无关的@情报。我的大脑也是如此。我的全部身体…@都是为了织莉子而存在的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"id":400200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_012.exp.json","id":400200,"motion":300}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_03","textHome":"织莉子，神滨这里有什么阻挡你的东西吗？"}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":100}]}],"group_20":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_28","textHome":"看到丘比了吗？不，不是我要找它。我怎么样@都无所谓，是织莉子在找它。"}]},{"autoTurnFirst":3.5,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":0}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":200,"pos":1,"voice":"vo_char_4002_00_29","textHome":"用单位来衡量爱的人是不会知道爱的本质的。@我对织莉子的爱怎么能用世间一般的定量@来表示呢？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":300}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_30","textHome":"你不会要说还没做好准备什么的吧？我得赶紧@把事情做完，然后去找织莉子了。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":400200,"motion":200}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_31","textHome":"差不多是表演战斗的时间了……我什么也不@害怕哦！如果是为了织莉子的话……我甚至会@感到兴奋呢……！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":300}]}],"group_24":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":100,"pos":1,"voice":"vo_char_4002_00_32","textHome":"不管是魔法少女还是魔女……我都不关心。@只要是阻碍织莉子的人，我就会立即把它@打趴下。"}]},{"autoTurnFirst":3.5,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":400200,"motion":0}]}],"group_25":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_33","textHome":"织莉子做的薄饼真是比什么甜点都美味！只要@我拜托她的话，她什么时候都会请我吃。@羡慕吧？"}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"id":400200,"motion":300}]},{"autoTurnFirst":1.8,"chara":[{"id":400200,"motion":100}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_34","textHome":"甜党有什么错？喜欢甜食，与大人小孩无关@的吧？因为喜欢甜食就被当作是小孩子看待@是错误的。"}]},{"autoTurnFirst":3.6,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":1.4,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":100}]}],"group_27":[{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":400200,"motion":0,"pos":1,"voice":"vo_char_4002_00_35","textHome":"你不知道织莉子送我的玩偶吗!?是兔子玩偶@哦！啊，真是的，我把它放哪去了呢……？"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":1.0,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":300}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":400200,"motion":400,"pos":1,"voice":"vo_char_4002_00_36","textHome":"呜哇哇！你突然干嘛！我可说好了，我是不会@让你碰织莉子一根手指的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":400200,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"id":400200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":0}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_37","textHome":"无论和我说什么都是没用的哦？转眼间我就会@全部忘掉。我对织莉子以外的东西一点兴趣@都没有。"}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200}]},{"autoTurnFirst":2.0,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":200}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":300,"pos":1,"voice":"vo_char_4002_00_04","textHome":"危险危险……我差点就干掉你了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":200}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":400200,"motion":100,"pos":1,"voice":"vo_char_4002_00_38","textHome":"我喝不了不加糖的红茶，太苦了……3块砂糖@和3杯果酱……是必须的。织莉子……@她又要把我当作小孩子对待了……"}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":400200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"id":400200,"motion":200}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_012.exp.json","id":400200,"motion":1,"pos":1,"voice":"vo_char_4002_00_39","textHome":"我是为了在织莉子身边才成为的魔法少女。@只要织莉子在，无论看到什么样的绝望，@我都不会后悔。"}]},{"autoTurnFirst":3.0,"chara":[{"id":400200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":400200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"id":400200,"motion":300}]}],"group_32":[{"autoTurnFi