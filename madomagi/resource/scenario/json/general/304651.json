":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304600,"motion":300,"pos":1,"voice":"vo_char_3046_00_66","textHome":"一枚都不要浪费啊。"}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304600,"motion":300,"pos":1,"voice":"vo_char_3046_00_05","textHome":"我成为棋子就只有这一刻而已。"}]}],"group_6":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304600,"motion":1,"pos":1,"voice":"vo_char_3046_00_13","textHome":"最近的照片景深都很棒。@不过我还要继续积累才行。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":304600,"motion":300}]}],"group_7":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304600,"motion":400,"pos":1,"voice":"vo_char_3046_00_14","textHome":"光圈值和快门速度都没问题！@现在我就能把一切都清楚地拍下来了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304600,"motion":200}]}],"group_8":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":304600,"motion":1,"pos":1,"voice":"vo_char_3046_00_15","textHome":"哈哈，想听我拍照的故事吗？@那我就告诉你吧。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304600}]},{"autoTurnFirst":4.0,"chara":[{"id":304600,"motion":200}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304600,"motion":1,"pos":1,"voice":"vo_char_3046_00_16","textHome":"这和事情好坏无关。@只要有成为八卦的机会，我就会立即拍下来。@这就是我的能力。"}]},{"autoTurnFirst":2.0,"chara":[{"id":304600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":304600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":304600}]},{"autoTurnFirst":4.0,"chara":[{"id":304600,"motion":400}]}]},"version":3}