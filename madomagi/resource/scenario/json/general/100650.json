{"story":{"group_1":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_01","textHome":"我叫梓美冬。以前和小八在一个队伍，现在@因为个人原因独自生活，同时关照着其他人。@虽然经常被当作一个会照顾人的好姐姐，@其实家务全都不会做。@因为我并不成熟呢，呵呵。"}]},{"autoTurnFirst":6.1,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":7.9,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_00_18","textHome":"之所以玛吉斯有必要让我离开家工作，@是因为我做了七年的魔法少女，@语言很有说服力哦。"}]},{"autoTurnFirst":7.5,"chara":[{"id":100600,"motion":100}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_19","textHome":"这样就更加感到某种意义上的幸福了呢。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":100600,"motion":300}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_20","textHome":"不要悲观，再相信自己一点也不错的样子。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_13":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_21","textHome":"虽说力量已经衰退，@但是比起各位黑翼，也还是更强一些。@所以，我一定要守护她们。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]}],"group_14":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_22","textHome":"我不会屈服的，决不会被自己背负的罪压垮。@正因如此……哪怕把小八和羽翼们也卷进来@也要拯救她们。这种觉悟已经做好了。"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":5.3,"chara":[{"id":100600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"id":100600,"motion":1}]}],"group_15":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_00_23","textHome":"如果，没能解放他人，@没完成背负罪行的责任，那我只能以死谢罪。@如果那样也不能被原谅的话，@那就找到更多能拯救所有人的新路线……@以此来赎罪……"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":1}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_50_24","textHome":"在这边！快点快点！@呵呵……不管来几次，都让人兴致高涨！@来吧，好好享受这片海吧！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]},{"autoTurnFirst":2.5,"chara":[{"id":100600,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_17":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_50_25","textHome":"嗯，清晨在海岸边散步吗？@真是美妙的邀请……但是抱歉……@昨天闹得太晚了……还很困……呼呼……"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":2.0,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_18":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_50_26","textHome":"嗯？午饭时间了吗？@海浪声听起来太舒服了，@没想到过了这么长时间啊。"}]},{"autoTurnFirst":4.5,"chara":[{"id":100600,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":100600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_19":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_50_27","textHome":"午饭好像是流水素面哦！@很有夏天的感觉，真好啊。@嗯？我当然是负责吃啦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":200}]}],"group_2":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_03","textHome":"我已经背负了太多，@无法离开玛吉斯之翼了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_20":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_50_28","textHome":"烟花大会后会莫名感到冷清吗？@正因太过美丽……消散后才会睹物伤情……@要是明年还能看就好了……"}]},{"autoTurnFirst":6.5,"chara":[{"eyeClose":1,"id":100600,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0}]}],"group_21":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_50_29","textHome":"好热啊……热得一点做事的动力也没有了……@在树下睡到太阳落山，凉快起来吧。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_22":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_50_30","textHome":"难得的放松时间……不得不中断了。@好像有魔女出现了，赶紧收拾掉然后回来吧。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_50_31","textHome":"连我的复制品也穿着泳装……@客观来说是这样的……@嗯嗯嗯……赶紧打倒她们吧！@看上去好羞耻！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":1.7,"chara":[{"cheek":2,"face":"mtn_ex_001.exp.json","id":100600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":100600,"motion":400}]}],"group_24":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_50_32","textHome":"大家都穿着泳装来了呢。@是刚从海水浴场回来吗？@不，只是开个玩笑。@看上去完全不是带着玩的心态来的。"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100600,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":100600}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_50_33","textHome":"虽然看起来是这样，但完全可以穿去游泳哦。@只是比起下水，@还是在沙滩边悠闲地晒日光浴更合我口味些。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":100600,"motion":400}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_50_34","textHome":"啊！那碗刨冰是什么味道的啊？@能跟我交换一口吗！@我想试试各种口味，嗯哼。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_50_35","textHome":"放眼望去都是广阔的海洋，让人感觉很自由。@就好像什么都能做到一样……虽然并没有。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_50_36","textHome":"恐怖的事吗？@嗯……本来想一天吃一个的馒头，@反应过来的时候已经吃光了……@这个好像不算吧？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":100600,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100600,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_50_37","textHome":"灯花和音梦，好像是第一次看海……@因为一直在住院嘛。@幸亏赶上了个好天气，@一定会留下珍贵的回忆吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]},{"autoTurnFirst":4.0,"chara":[{"id":100600,"motion":400}]}],"group_3":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_04","textHome":"如果让小八加入的事已经没有希望的话，@我……"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":100600}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":1,"pos":1,"voice":"vo_char_1006_50_38","textHome":"让月夜和月咲把我埋进沙里了。@之前就很想试试……@呵呵，沙子里面好温暖啊……@舒服得想睡觉……呼……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100600,"motion":0}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100600,"motion":300}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_50_39","textHome":"要是不擅长游泳的话就别勉强了吧。@来我这边一起放松吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_50_40","textHome":"这件泳装，真漂亮啊。@因为看过小八在杂志上穿过，所以就选它了。@有点让人害羞，别告诉小八哦。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_33":[{"autoTurnFirst":4.5,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100600,"motion":0,"pos":1,"voice":"vo_char_1006_50_41","textHome":"摇摇晃晃……摇摇晃晃……@嗯哼，像这样坐在救生圈上随波漂流@真是太棒啦~"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"id":100600,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":4.7,"chara":[{"id":100600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":100600,"motion":100}]}],"group_34":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_42","textHome":"作为年长者，我站在前面的。"}]}],"group_35":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_43","textHome":"还好大家都没事。"}]}],"group_36":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_44","textHome":"如果是以前，还能再努力一点的。"}]}],"group_37":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_45","textHome":"但愿这胜利并不是我的幻觉。"}]}],"group_38":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_46","textHome":"也许我能更加自信了吧。"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_63","textHome":"偏执袭击！"}]}],"group_4":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":400,"pos":1,"voice":"vo_char_1006_00_05","textHome":"拜托了……只要能完成这一切，@两人就都能被拯救了……"}]}],"group_40":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_64","textHome":"跨越现实与梦的界限，品味这幻觉的世界吧。"}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":100600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":100600}]},{"autoTurnFirst":3.8,"chara":[{"id":100600}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_65","textHome":"用溢出的血滋润这干枯的世界。"}]}],"group_42":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_66","textHome":"清醒是一种幸福哦。"}]}],"group_43":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_02","textHome":"我已经是魔力衰退的魔法少女了哦……@这样也不要紧的话，那就请多关照啦。@好的，我叫梓美冬。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600,"motion":1}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100600,"motion":100,"pos":1,"voice":"vo_char_1006_00_13","textHome":"哎呀，@感觉好像回到了像以前那样的水平呢。"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100600}]}],"group_6":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100600,"motion":200,"pos":1,"voice":"vo_char_1006_00_14","textHome":"每天为了不退化而努力锻炼是很重要的哦。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100600}]}],"group_7":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":100600,"motion":300,"pos":1,"voice":"vo_char_1006_00_15","textHome":"努力到这个程度，@还默不作声的话就说不过去了呢。"}]}],"group_8":[{"a