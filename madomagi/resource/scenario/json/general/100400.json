{"story":{"group_1":[{"autoTurnFirst":11.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_01","textHome":"我是那种吊车尾的……一无是处，什么都@做不好，经常弄得一团糟……就好像@我一点都没有随着周围的世界动起来一样……@所以总是一事无成，眼泪掉下来了…呜呜…"}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":9.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":100400,"motion":300,"tear":1}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_18","textHome":"我在图鉴上看到的，有种叫灰雀的鸟。@不是骗人啦，真的叫做灰雀！@……诶？不是啊，真的叫灰雀的！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":200}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_19","textHome":"…虽然不太明白…我是不是变得更好了呢？"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]}],"group_12":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_00_20","textHome":"现在，我的心中非常平静……很舒服……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100400,"motion":1}]}],"group_13":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_21","textHome":"我，确实存在感很低吧……这就是天生的吗…@要改变自己才行……！"}]},{"autoTurnFirst":4.5,"chara":[{"id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]}],"group_14":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_22","textHome":"那，那我开始了……嘿！……怎、怎么样？@有爽快地搭话的感觉了吗？呜呜……@第一次这么做……但还差得远吧……@我、我会继续努力的！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_23","textHome":"……耶！怎么样？状、状态如何？今天也要@好好……不、不行了！虽然好不容易@练到这种程度，还是得拼命地……@不过，好像更自信了一点……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]}],"group_16":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_24","textHome":"啊！你来了……！嗯……谢谢你……每次都来@找我……我很开心！……呜呜……"}]},{"autoTurnFirst":2.3,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100400}]}],"group_17":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_25","textHome":"早起的话，能感受到到还没开始活动，感受@这宛如风景一样的静谧的街道真的很舒畅，@只是很快就会热闹起来……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_26","textHome":"午饭的话，是呢，凉粉……嗯，还有粉条……@春卷也不错……啊？好像都是些@可以透过去看食物……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":400}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_27","textHome":"虽然每天都有，但是夕阳真的百看不厌……@怎么说呢……尤其是太阳刚好落山的@那个时候……（抽泣）……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_03","textHome":"在家里要是不乖乖的，就好像会被抛弃一样@让人害怕……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_20":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_28","textHome":"睡觉的时候很幸福。迷迷糊糊的，然后就@睡过去了，能做个美梦就更好啦……@噩、噩梦就不要啦！"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":400}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_29","textHome":"太阳升起落下，今日成为昨天，明日又变作@今日……为什么时间会流动呢？仔细想想@真是不可思议……"}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1}]}],"group_22":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_30","textHome":"在这个世界，我真的有存在的必要吗……@我曾这样想过。也许从出生开始，我就一直在@寻找存在的意义了吧……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":100}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_31","textHome":"啊，那个……我基本上不懂怎么跟人争斗……@但是，必须要去做对吗……哈啊……@怎么办……能行吗……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":1}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_32","textHome":"诶，我就在后面好好看着，不要碍事就好吧…@不行？不行的吗……呜，那希望@不会被针对……！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"id":100400,"motion":300,"tear":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":100400,"tear":1}]}],"group_25":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_33","textHome":"天热就会没有精神……天冷也不太行……@还有因为花粉过敏春天也会不舒服……啊，@最近秋天也开始有花粉了……@就是说，我一年到头都不太行……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_34","textHome":"风扇和空调的风力都有「微风」这个选项吧？@看着遥控器上的字，会感觉说的就是自己……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_35","textHome":"不太能大声说话……虽然自己也很努力。但是@声音完全出不来……要听看看吗？那……@喂……怎么样？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":100400,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]}],"group_28":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200,"pos":1,"voice":"vo_char_1004_00_36","textHome":"就算别人突然冲过来，我也能轻描淡写地@岔开话题就好了。感觉这样@才是最适合我这种类型……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]}],"group_29":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_37","textHome":"感觉走路摇摇晃晃的。但是，我总算还活着…@可以的话今后我也想继续走下去……@哪怕是摇摇晃晃的……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_04","textHome":"找了好几天……但是，再也没见到咕噜了……"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":2,"id":100400,"motion":300,"tear":1}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_38","textHome":"还记得小猫咕噜的朋友们吗？有小狗妙妙，@乌鸦老黑……还有狮子立鬃！"}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100400,"motion":100}]}],"group_31":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_39","textHome":"猫高兴的时候会把尾巴立起来。但要是平着@摇尾巴就要小心了，似乎是生气了才会这样。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1}]}],"group_32":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_40","textHome":"彩羽，以后也请和我好好相处吧。这是约定！@好吗？……诶，有些沉重吗？……对不起……@但是，拜托你了！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":100400,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400}]},{"autoTurnFirst":3.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100400,"motion":100,"tear":1}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_41","textHome":"那我开始了……“看我把手伸你嘴里，@吓得你牙根发软”……怎么样？@吓人吗？在电视上学的……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_00_42","textHome":"不战斗不行吗!?"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_00_43","textHome":"太好了……得救了……"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":100400,"motion":400,"pos":1,"voice":"vo_char_1004_00_44","textHome":"诶？真的吗？赢了吗？"}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_45","textHome":"哈……运气太好了，赢了……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100400,"motion":200}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_46","textHome":"……那个，我……很强吗？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100400,"motion":100,"pos":1,"voice":"vo_char_1004_00_63","textHome":"拜托了，要打过啊……我、我上了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":100400,"motion":400}]}],"