40.exp.json","id":100400,"motion":1}]}],"group_7":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_15","textHome":"能一点点地进步就好了吧。一点点地……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":0,"pos":1,"voice":"vo_char_1004_00_16","textHome":"鸟能在天空中自由翱翔，真让人羡慕。我从小@就喜欢鸟，也看过很多图鉴。要是我也有@翅膀就好了……"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100400,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100400,"motion":300}]}],"group_9":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100400,"motion":1,"pos":1,"voice":"vo_char_1004_00_17","textHome":"鸟的叫声也很好呢。像是知更鸟、云雀还有@黄莺。伴随着风声，非常治愈人心……"}]},{"autoTurnFirst":6.0,"chara":[{"id":100400,"motion":100}]}]},"version":3}