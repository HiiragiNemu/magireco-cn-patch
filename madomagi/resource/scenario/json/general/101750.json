{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_00_01","textHome":"我是大家的伙伴，调整专家八云御魂哟。@即使如此，我也是水灵灵的17岁女高中生，@那种会被人叽叽喳喳议论的年轻女孩哦。@平时借助各种道具强化魔力，@也会出售手工制作的物品，记得来光顾哦～"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":7.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":300}]}],"group_10":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_18","textHome":"能接触他人魔力的原理？@嗯，就像磁铁一样吧？@如果大家都是N极的魔力，@那我就是S极的魔力。所以能够接触哦～"}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":101700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":2.9,"chara":[{"id":101700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_19","textHome":"这样一来，@是不是就能更深入地触碰大家了呢？@呵呵～"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_12":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_20","textHome":"感觉仿佛觉醒了一般，@今后还能更加努力呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_21","textHome":"无法战斗的我也变强了，真让人欣慰。@就算桃子她们不在，我也想保护好调整屋。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101700}]}],"group_14":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_22","textHome":"对于没有战斗力的我，经商就是我的生存术。@绝对不是榨取大家的悲叹之种啦……@啊，我想到了一桩好生意～"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_15":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_23","textHome":"为大家进行强化的时候，@自然地就会看到记忆的片段……@真让我觉得魔法少女们纯粹而美丽。@所以我，也要为了美丽的大家而使出全力哦。"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":101700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":6.5,"chara":[{"id":101700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}]}],"group_16":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_50_24","textHome":"哎呀，突然来邀请我真让人吃惊。@就那么想看穿泳装的调整专家吗？@那样的话早点说好不就好了吗。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101700,"motion":1,"pos":1,"voice":"vo_char_1017_50_25","textHome":"海边的早餐，无论是什么都新鲜又好吃。@特别是旅店的饭菜，@有着无论谁都会吃得津津有味的自信呢~"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":101700,"motion":300}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_50_26","textHome":"调整专家主办！@中午的刨冰大会♪@时间限制内吃的最多的人胜利。@但是要小心里面混入了超辣草莓味的哦♪"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":101700,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_19":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_50_27","textHome":"感觉这个场景，莫名地像青春偶像剧不是吗？@背对夕阳，带着悲伤的笑脸，@在都市里送走恋人那样的。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"id":101700,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":101700}]}],"group_2":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_03","textHome":"这样的城市，我讨厌……讨厌极了。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":101700}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_50_28","textHome":"玉屋！键屋！@嗯哼，这些是真实存在的烟花老字号哦。@前阵子在网上查资料看见的！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"id":101700,"motion":200}]}],"group_21":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_50_29","textHome":"呼……呼……哎？@对不起啊，在遮阳伞下面看书太舒服了，@不知不觉就……哈啊~"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":400}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":101700,"motion":0}]}],"group_22":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_50_30","textHome":"打扰我长假的坏魔女……有必要惩罚一下了。@好哇，你等着。@我现在就找别的魔法少女来打倒你！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101700}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":101700,"motion":0}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_23":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1,"pos":1,"voice":"vo_char_1017_50_31","textHome":"那么问题来了，@在无尽镜界穿着泳装出现的是谁？@哒啦啦啦啦，铛！@正确答案是！自己去看吧，嗯哼。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":3.0,"chara":[{"id":101700,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_24":[{"autoTurnFirst":7.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_50_32","textHome":"天气这么热，@大家居然还能不停和自己人打架……@要是被卷进去就要满身大汗了，@还是躲开吧。"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":101700,"motion":300}]}],"group_25":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_50_33","textHome":"被蚊子吵得睡不着的晚上就靠它！@电蚊拍♪很方便哦？@只要这样挥动，你看蚊子就掉下来了！"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":101700,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":200}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_50_34","textHome":"海边的抓拍就交给「海滨鹰眼」八云御魂吧。@不留神的话，可是会被偷偷拍下黑照的哦♪"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]}],"group_27":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_50_35","textHome":"不会游泳的话，@就让调整专家稍微给你处理一下吧？@变成海边模式就可以轻松地游泳了。@不信的话来试试吧？"}]},{"autoTurnFirst":4.8,"chara":[{"id":101700,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]}],"group_28":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_50_36","textHome":"海鲜炖饭……味噌汤……咖喱……@嗯，这样美味的海产就齐了，都想试试呢……@啊，全部混在一起就好了吧！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_50_37","textHome":"明天不能再玩了，得去补习才行。@平日里没去的份，要在暑假里补回来才好。@人也不多，是个好主意吧？"}]},{"autoTurnFirst":6.5,"chara":[{"id":101700,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":101700}]}],"group_3":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_04","textHome":"即使后悔，也不能逃离自己的愿望了。"}]}],"group_30":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_50_38","textHome":"哎呀，游泳课我当然都是在旁边观看的。@因为根本没有好的回忆嘛……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101700}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_50_39","textHome":"哎呀……好难受……？@等一下，这件泳装又……嗯……嗯！！@呼……终于穿进去了！@唉，刚刚胸前难受得我人都紧绷起来了。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":1,"id":101700,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":1.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101700}