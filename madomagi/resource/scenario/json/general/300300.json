{"story":{"group_1":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300,"motion":100,"pos":1,"voice":"vo_char_3003_00_01","textHome":"哼！哼哼…！好…！太好了…！下次活动的梗@就决定是这个了……啊！干嘛？不要跑到别人@的城堡，还偷听别人自言自语啊！还有那表情@也太失礼了！我叫都雏乃，姑且算是部长吧。@哈？化学部啦，这里是化学部的活动室。"}]},{"autoTurnFirst":2.3,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":0.7,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":2.4,"chara":[{"id":300300,"motion":200}]},{"autoTurnFirst":0.6,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300}]},{"autoTurnFirst":1.4,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300,"motion":400}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300}]},{"autoTurnFirst":2.2,"chara":[{"id":300300,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":0}]}],"group_10":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_18","textHome":"攀登？爆破？无论多么高的墙壁，@都有跨越的方法。墙那头的景色，@就是对努力过的人最高的褒奖。"}]},{"autoTurnFirst":2.2,"chara":[{"id":300300,"motion":400}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":2.1,"chara":[{"id":300300,"motion":400}]}],"group_11":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_19","textHome":"化学和人……都有无限可能！未来是光明的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":300300,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":0}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_20","textHome":"这、这样一来……我也能变成@适合穿白衣的性感理科女生了吗！？"}]},{"autoTurnFirst":0.8,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"id":300300,"motion":200}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_21","textHome":"我要是示弱了，后辈们也会不安吧。@所以我，要一直保持帅气的前辈形象才行。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"id":300300,"motion":400}]}],"group_14":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_22","textHome":"我想要长大！变成伟大的都前辈！但是我，@并不是想要被人尊敬。我想成为能接受大家@所有的不安和悲伤的——那样巨大的前辈！"}]},{"autoTurnFirst":3.4,"chara":[{"id":300300,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":300}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":400}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":200,"pos":1,"voice":"vo_char_3003_00_23","textHome":"浓缩就是精华！拥有庞大的知识储备和熟练@精湛的技能，就不得不接受个子小这种短板。@不过话说回来，小小的身体却饱含无限能量，@这样的反差萌不是最棒了吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":300300,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":300300,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300,"motion":1}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_24","textHome":"太慢了！你去做什么了啊！@让满怀期待的客人久等可不行！@好了，快把那边的一套仪器搬过来！"}]},{"autoTurnFirst":4.0,"chara":[{"id":300300,"motion":1}]},{"autoTurnFirst":1.1,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"id":300300,"motion":200}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_25","textHome":"哦，早上好。真是个清爽的早晨啊……！@是适合做实验的好天气呢……！@嗯？你也是这么觉得的吧？"}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":400}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300,"motion":200}]},{"autoTurnFirst":0.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":1}]}],"group_18":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_26","textHome":"我要饿死了……挨饿可是会影响发育的……@就用烧杯……来煮拉面吧。@不知道能行吗……？"}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":300300,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":1}]}],"group_19":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_27","textHome":"啊～城堡真是最棒了！就是这里啦，这里。@化学部的活动室，通称「城堡」！@顺便一提图书室叫「别墅」哦！"}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"id":300300,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":1}]}],"group_2":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_03","textHome":"并不是我的威严不够，是那家伙太狂妄了！"}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":200}]}],"group_20":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_28","textHome":"不好！想着下次活动的梗，都这个时间了！@要赶紧去睡了……能睡的孩子长得高！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300300,"motion":400}]},{"autoTurnFirst":3.2,"chara":[{"id":300300,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":300}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_29","textHome":"不！不是物理，而是通过化学来让自己长高！@我对化学的进步很有信心！@未来肯定会有这么一天的！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":300300,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":200}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_30","textHome":"什么嘛，还没准备好吗？@真是的，一直都是一副懒洋洋的样子……@再不快点太阳都要下山啦。"}]},{"autoTurnFirst":4.0,"chara":[{"id":300300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":0}]}],"group_23":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_31","textHome":"看起来无论如何都想和我们战斗啊……！@我的假设……应该99%是没错的！@那就赶紧用实验来证明吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":1}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":200}]}],"group_24":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_32","textHome":"好好考察，然后改善……@这里也聚集了不少优秀的研究员呢。@那么，接下来就到演出时间了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":1}]},{"autoTurnFirst":1.7,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":300300,"motion":200}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_33","textHome":"过去我也做过很多荒唐的实验。@说起来……我成为魔法少女，@也是因为做了那样危险的事。"}]},{"autoTurnFirst":3.5,"chara":[{"id":300300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":300}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_34","textHome":"烧瓶、试管、培养皿……不觉得玻璃很棒吗？@关于玻璃的魅力，说上5个小时也没问题！"}]},{"autoTurnFirst":3.4,"chara":[{"id":300300,"motion":400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300300,"motion":100}]}],"group_27":[{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_35","textHome":"所——以——说！让你不要低头看了！@从上面来的视线让人很不爽啊！"}]},{"autoTurnFirst":3.3,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"id":300300,"motion":200}]}],"group_28":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_36","textHome":"我是手写报告派的。能够画出漂亮的构造图，@我想也是科学家的一项技能吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":4.0,"chara":[{"id":300300,"motion":400}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_37","textHome":"化学虽然有趣但也伴随着危险。@这一点，还请好好记住，@稍微疏忽大意就可能引起重大事故。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":1}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_04","textHome":"居然利用化学来夺人性命……不可饶恕！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":200}]}],"group_30":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_38","textHome":"虽然我并不讨厌和年纪比我小的人交流……@但像衣美里这样的，还是饶了我吧……@这么闹腾的一个就够了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"id":300300,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":0}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_39","textHome":"虽然自己恐怕已经不会再长高了……@但在守护可爱后辈这件事上，@我还是能够成长的……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":0}]}],"group_32":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_40","textHome":"资料收集方面，我也是比较传统老派的作风。@嘛～确实是因为不擅长电脑……@而且常用的书籍也比电脑要方便。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":1}]}],"group_33":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_41","textHome":"怎么说衣美里呢……总是让人很担心……@完全不明白那家伙在做什么对吧？@所以，我没办法放她一个人。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":1}]}],"group_34":[{"autoTurnFirst":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_42","textHome":"现在就来验证假设吧……！"}]},{"autoTurnFirst":2.8,"chara":[{"id":300300,"motion":200}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":100,"pos":1,"voice":"vo_char_3003_00_43","textHome":"嗯，满足了！"}]}],"group_36":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":200,"pos":1,"voice":"vo_char_3003_00_44","textHome":"假设成立！"}]}],"group_37":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_45","textHome":"看来能写出不错的报告了！"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":200,"pos":1,"voice":"vo_char_3003_00_46","textHome":"实验成功了！"}]}],"group_39":[{"autoTurnFirst":1.9,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_63","textHome":"注意这边！接下来就是重点了！！"}]},{"autoTurnFirst":2.1,"chara":[{"id":300300,"motion":200}]}],"group_4":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_05","textHome":"真是的，突然说这么奇怪的话。@是不是有点太得意忘形了……"}]},{"autoTurnFirst":2.5,"chara":[{"id":300300,"motion":400}]}],"group_40":[{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":400,"pos":1,"voice":"vo_char_3003_00_64","textHome":"睁大眼睛看清楚哦!?"}]},{"autoTurnFirst":2.2,"chara":[{"id":300300,"motion":200}]}],"group_41":[{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_65","textHome":"给别人添麻烦的观众……谢绝入内！！"}]},{"autoTurnFirst":2.6,"chara":[{"id":300300,"motion":200}]}],"group_42":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":300300,"motion":100,"pos":1,"voice":"vo_char_3003_00_66","textHome":"到达沸点！！原子暴怒！！"}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":200}]}],"group_43":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":300300,"motion":0,"pos":1,"voice":"vo_char_3003_00_02","textHome":"我叫都雏乃。别看我这样……不对不对！@就是你看到的这样！我在魔法少女当中@也算是老资格了。叫我都前辈没问题吧？"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300300}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"id":300300,"motion":1}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300300,"motion":300}]}],"group_5":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_13","textHome":"怎么样！？不知道是不是心理作用，@感觉个子好像也长高了……！"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":2,"id":300300,"motion":200}]}],"group_6":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_000.exp.json","id":300300,"motion":1,"pos":1,"voice":"vo_char_3003_00_14","textHome":"脚踏实地努力的成果，@才有回味无穷的成就感。"}]},{"autoTurnFirst":3.0,"chara":[{"id":300300,"motion":400}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300300,"motion":300,"pos":1,"voice":"vo_char_3003_00_15","textHome":"要是用上这个定律的话……！@哼哼……我又想到新梗了！"}]},{"autoTurnFirst":0.5,"chara":[{"id":300300,"motion":100}]},{"autoTurnFirst":1.9,"chara":[{"face":"mtn_ex_010.exp.json","id":300300}]},{"autoTurnFirst":2.1,"chara":[{"id":300300,"motion":200}]}],"group_8":[{"autoTurnFirst":0.7,"chara