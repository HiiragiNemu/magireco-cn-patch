{"story":{"group_1":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_00_01","textHome":"我是大家的伙伴，调整专家八云御魂哟。@即使如此，我也是水灵灵的17岁女高中生，@那种会被人叽叽喳喳议论的年轻女孩哦。@平时借助各种道具强化魔力，@也会出售手工制作的物品，记得来光顾哦～"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":7.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":300}]}],"group_10":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_18","textHome":"能接触他人魔力的原理？@嗯，就像磁铁一样吧？@如果大家都是N极的魔力，@那我就是S极的魔力。所以能够接触哦～"}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":101700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":2.9,"chara":[{"id":101700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_19","textHome":"这样一来，@是不是就能更深入地触碰大家了呢？@呵呵～"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_12":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_20","textHome":"感觉仿佛觉醒了一般，@今后还能更加努力呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_21","textHome":"无法战斗的我也变强了，真让人欣慰。@就算桃子她们不在，我也想保护好调整屋。"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101700}]}],"group_14":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_22","textHome":"对于没有战斗力的我，经商就是我的生存术。@绝对不是榨取大家的悲叹之种啦……@啊，我想到了一桩好生意～"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_15":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_23","textHome":"为大家进行强化的时候，@自然地就会看到记忆的片段……@真让我觉得魔法少女们纯粹而美丽。@所以我，也要为了美丽的大家而使出全力哦。"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":101700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":6.5,"chara":[{"id":101700,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}]}],"group_16":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":1,"pos":1,"voice":"vo_char_1017_00_24","textHome":"欢迎光临，让调整专家等你可真是心大呢。@今天就让你陪我到天黑吧～"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_25","textHome":"为了能精神地过一整天……@要是能吃到谁亲手做的早饭就好了……@哈……八千代，彩羽和桃子，都不帮忙吗……"}]},{"autoTurnFirst":3.7,"chara":[{"eyeClose":1,"id":101700,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":101700,"motion":200}]}],"group_18":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_26","textHome":"白天是学生模式哦！？@呵呵，即使出席率低，学习也总是名列前茅。@被嫉妒也没办法啦。"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_19":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_27","textHome":"这段时间，会有很多魔法少女过来，@特别的忙哦？啊，不要随意触摸@那边架子上的东西啦。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]}],"group_2":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_03","textHome":"这样的城市，我讨厌……讨厌极了。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":101700}]}],"group_20":[{"autoTurnFirst":0.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_28","textHome":"哈啊～啊……呜……今天困得好早啊……@打烊算啦。这种时候，不固定营业时间真好～"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":101700,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":4.0,"chara":[{"id":101700,"motion":200}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101700,"motion":300}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_29","textHome":"傍晚后忙起来倒不是问题，@但是客人走后突然感觉就很冷清了。@能陪我一会儿吗？"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_30","textHome":"今天大家也要加油打倒魔女，@获得悲叹之种哦～@实在不行引到菲莉希亚附近去就好咯。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_31","textHome":"没错，大家一定要解开无尽镜界的谜团。@我会准备好各种补给，大家要平安回来哦。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_24":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_32","textHome":"哎呀，好大一场战斗开始了！？@大家快过来，带上值钱的东西！@我可以就地进行调整的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]},{"autoTurnFirst":5.0,"chara":[{"id":101700,"motion":1}]}],"group_25":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":1,"pos":1,"voice":"vo_char_1017_00_33","textHome":"最近在学校露面慢慢多了起来。@因为不得不和调整屋两手抓，@升学的事也只能勉勉强强呢。"}]},{"autoTurnFirst":2.7,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":5.2,"chara":[{"id":101700,"motion":300}]}],"group_26":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_34","textHome":"想调整一下哪个地方？@十秒内不回答的话，@调整专家可要随便下手了哦？"}]},{"autoTurnFirst":4.0,"chara":[{"id":101700,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]}],"group_27":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_35","textHome":"很遗憾～抓到了顺手牵羊的坏人呢。@啊，对了！虽然算不上惩罚，@就由你来试吃我的料理吧。"}]},{"autoTurnFirst":3.7,"chara":[{"id":101700,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":200}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_36","textHome":"我啊，最喜欢被炉了。只要进去就出不来了，@除非去洗手间和泡澡。实在是太暖和啦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_29":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_37","textHome":"因为我持有中立的立场，可以为任何人调整，@所以这里也是禁止战斗的安全地带。@呵呵，是个很好的避难所吧？"}]},{"autoTurnFirst":4.0,"chara":[{"id":101700,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700}]}],"group_3":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":200,"pos":1,"voice":"vo_char_1017_00_04","textHome":"即使后悔，也不能逃离自己的愿望了。"}]}],"group_30":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101700,"motion":300,"pos":1,"voice":"vo_char_1017_00_38","textHome":"其实我也很不好意思哦？@一直都让桃子帮我击退魔女和使魔。@但是，桃子人那么好，忍不住就会依靠她。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":101700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]}],"group_31":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_39","textHome":"十七夜真是神出鬼没，很让我头疼的。@但是，了解我过去的只有她，@我也只能和她提起，所以没法对她生气哦。"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":101700,"motion":200}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":0}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":101700,"motion":100,"pos":1,"voice":"vo_char_1017_00_40","textHome":"收集那么多悲叹之种做什么……@嗯，毕竟是做这种工作的，@只能说是自己净化用啦。"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":101700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101700}]},{"autoTurnFirst":7.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101700,"motion":300}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101700,"motion":0,"pos":1,"voice":"vo_char_1017_00_41","textHome":"真是的！嘿～嘿～嘿！@对付烦人的孩子要戳会让魔力下降的穴位哦！@哼哼，骗你的啦～"}]},{"autoTurnFirst":0.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101700,"motion":100}]},{"autoTurnFirst":0.7,"chara":[{"id":101700,"motion":100}]},{"autoTurnFirst":1.4,"chara":[{"id":101700,"motion":100}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.ex