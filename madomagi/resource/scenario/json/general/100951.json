{"story":{"group_1":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_01","textHome":"我叫水波玲奈，完毕。什么？没有。@别的也没什么可介绍的了。我知道啦，@自我介绍嘛，我做就是了。年龄15岁，完毕。@哈？还得多说点？那，你先做个示范吧。@我会认真听的，你的自我介绍。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":100900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_18","textHome":"顺利极了！要是继续保持的话，@咱们小队搞不好就要成为@魔法少女界有名的最强小队了。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_19","textHome":"要是觉得玲奈的极限就到这里了，那可不成。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":1.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_20","textHome":"努力和自信息息相关对吧？@忘了是谁说的，但我会努力的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_21","textHome":"很高兴变强了。@因为这份力量呢，对于玲奈来说……@也是用来守护队友桃子和枫的。"}]},{"autoTurnFirst":6.5,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_22","textHome":"对自己……应该更加爱护才行。@因为啊，要是说出最讨厌自己这种话来，@那喜欢着玲奈的人们该怎么办呢？"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_15":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_23","textHome":"总觉得……身为水波玲奈也意外地不错呢。@虽然曾经说着最讨厌自己，@想拥有能变成别人的能力而成为了魔法少女。@但现在不仅仅是力量……@而是连心灵也成长了吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":201,"pos":1,"voice":"vo_char_1009_51_24","textHome":"可算来了！有点事拜托你。@帮玲奈买炒面来……不是光要你跑腿啦！？@玲奈也跟着去的……"}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]}],"group_17":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_51_25","textHome":"这个时间就换好泳装，是不是太着急了？@啊，虽然玲奈也一样迫不及待了。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":1}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_51_26","textHome":"好热啊！肚子又饿！@不行了！快买雪糕和刨冰来。@啊啊啊啊，别磨蹭了啊笨蛋！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900}]},{"autoTurnFirst":3.5,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":201}]}],"group_19":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_51_27","textHome":"终于凉下来了啊……那就……西瓜！@玲奈，现在想吃西瓜。@枫家的菜园里肯定有，去采来吧。"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":100900}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":201}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_03","textHome":"不是的……这就是真正的玲奈……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":100900}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_51_28","textHome":"哼哼哼……走啦！@还问哪里，除了试胆大会还有哪里？@先说好，你来扮鬼。不接受其他意见。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":201}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]}],"group_21":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_51_29","textHome":"把玲奈过夏天的方法教给你吧。@先把空调开到最大，吹得屋子里凉飕飕的，@然后吃雪糕吃到喊冷！是不是超级棒！？"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100}]}],"group_22":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_51_30","textHome":"出发前记得好好涂防晒霜啊。@之后要是被晒伤了喊疼，玲奈可不管。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":200}]}],"group_23":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_51_31","textHome":"要是现在的玲奈被镜界拓模了的话，那泳装玲奈不就要大量增加了……@你、你傻啊！谁会穿着泳装去镜界啊！？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":100900,"motion":201}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_51_32","textHome":"好像在打沙滩排球，人都聚集起来了，@玲奈该怎么办才好……@要是桃子她们想去，那玲奈也跟着去好了……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":100}]}],"group_25":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_51_33","textHome":"说到夏天就会想到蚊香猪！@圆滚滚的，看起来天真可爱，@玲奈喜欢这样的。你也喜欢吗？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]}],"group_26":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_51_34","textHome":"烟花棒啊，一支只能点燃小小的火球，@但如果聚在一起，就会变成大火球了……@就好像玲奈的小队一样。"}]},{"autoTurnFirst":1.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100}]}],"group_27":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_51_35","textHome":"啊，必须做作业了……@又是习题册又是自选题，都是些烦人的东西！@嗯……今天事情这么多，明天再做吧。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":100}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_51_36","textHome":"以前玲奈和弟弟玩水枪的时候，@被脚边用来补充水的桶给绊倒了……@现在想起来，大概是弟弟设下的巧妙陷阱吧。"}]},{"autoTurnFirst":5.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100900,"motion":200}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_51_37","textHome":"和枫她们商量过买泳装的事，@桃子还真是在意自己的尺寸呢。@想不到桃子还有这么女孩子的一面。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":100900,"motion":200}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_04","textHome":"这样的自己……水波玲奈真是没用……"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_51_38","textHome":"玲奈的泳装……怎么样？没问题吧？@买到可爱的泳装，再和朋友一起去看海……@这种事，以前根本没法想象。@所以……玲奈很开心。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100