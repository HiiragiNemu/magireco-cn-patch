k":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210200,"motion":200,"pos":1,"voice":"vo_char_2102_00_64","textHome":"唔唔唔唔……砰！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200,"motion":400}]}],"group_41":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210200,"motion":200,"pos":1,"voice":"vo_char_2102_00_65","textHome":"要上喽……呀啊啊啊啊……好痛。"}]},{"autoTurnFirst":1.1,"chara":[{"id":210200,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210200}]}],"group_42":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_66","textHome":"……馒头飞踢。"}]}],"group_43":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_02","textHome":"我是从魔法报告世界中，@不知怎么就过来了的小圆前辈哦。@梦想是用我自己塞满所有助战栏。@请多指教。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210200,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":200}]}],"group_5":[{"autoTurnFirst":0.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_13","textHome":"啊，升级！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200}]}],"group_6":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_14","textHome":"彩羽，看到了吗？我成长到这么厉害了哦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":100}]}],"group_7":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_15","textHome":"居然问这种问题……彩羽真是色羽呢。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":210200,"motion":100}]}]