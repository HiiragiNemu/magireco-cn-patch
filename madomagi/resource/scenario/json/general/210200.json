{"story":{"group_1":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_01","textHome":"我是魔法报告界的明星，小圆前辈哦。@你见到了魔法纪录中的我了吗？@不过彩羽没能抽到我，伤心地嚎啕大哭呢。@不是这个世界的彩羽而是那个世界的……@一会这边一会那边真是好麻烦。@总之，我虽然少了一颗星，@但我也是魔法报告世界的明星——小圆前辈！@请多指教。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":101}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210200}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":400}]}],"group_10":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_18","textHome":"和馒头加农炮进行沟通可是很难的哟。@情绪兴奋的时候，不自觉地就会发射炮弹，@别忘了躲一下哦。"}]},{"autoTurnFirst":3.5,"chara":[{"id":210200,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":101}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_19","textHome":"也就是说，我踢人的力量增强了？"}]},{"autoTurnFirst":2.0,"chara":[{"id":210200,"motion":101}]}],"group_12":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_20","textHome":"已经有两个我被实装了哦。"}]}],"group_13":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_21","textHome":"其他的我都是四星，@所以从三星进化成四星是属于我的特权。@很开心哟？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200}]}],"group_14":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_22","textHome":"普通的我，穿着盛装的我，@加上已经实装了的魔法报告的我，@差不多该组一个只有我的队伍了吧。@当然，助战借来的，也是魔法报告的我对吧？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":400}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":200}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_23","textHome":"我下次再实装又是什么时候呢？@这次的我，实装了馒头加农炮和馒头巨蟹，@让我看上去就很强……@真期待下次的我是什么样的啊。"}]},{"autoTurnFirst":5.0,"chara":[{"id":210200,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":210200,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":100}]}],"group_16":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":400,"pos":1,"voice":"vo_char_2102_00_24","textHome":"谢谢来信！你的烦恼就由我来解答！@诶，你不是来找我吐露烦恼的吗？"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200}]},{"autoTurnFirst":4.0,"chara":[{"id":210200,"motion":1}]}],"group_17":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_25","textHome":"早上好……难道说你熬夜了吗？@魔法纪录肝太久了之类……@啊，是其他的游戏啊……这样啊……"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":100}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210200,"motion":0}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_26","textHome":"是魔法纪录本篇的神滨市啊！@有能让我赞叹不已的拉面店吗？@这个世界的彩羽，你有什么推荐吗？"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":101}]}],"group_19":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_27","textHome":"看，那天边最闪耀的一颗星……@小圆前辈之所以只有三星呀，@是因为有一颗星星已经飞向那边的天空了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210200,"motion":300}]},{"autoTurnFirst":5.5,"chara":[{"id":210200,"motion":1}]}],"group_2":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_03","textHome":"为了解决魔法少女的烦恼，FM神滨开始咯！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":200}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_28","textHome":"因为魔法纪录好玩就熬到深夜可是不行的哦☆@因为不掉素材？这种事情……也确实是有啊。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210200,"motion":300}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":100,"pos":1,"voice":"vo_char_2102_00_29","textHome":"我听到了魔法报告世界的彩羽的嚎哭声哦。@又输给了百分之一的概率了吗……"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":210200,"motion":300}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":101,"pos":1,"voice":"vo_char_2102_00_30","textHome":"卡关了吗？@这种时候，就交给助战角色吧！@对吧，彩羽。"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":200}]}],"group_23":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":101,"pos":1,"voice":"vo_char_2102_00_31","textHome":"这些纸相扑一样的人偶，是在镜界用的哦。@诶……魔法纪录的世界不用纸相扑来战斗吗？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200,"motion":400}]}],"group_24":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_32","textHome":"好多魔法少女……光是看着就很壮观啊。@和这么多的少女签订了契约，@真是不能小看丘比啊。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":100}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_33","textHome":"通过预约就能见到小焰真是开心啊。@我就说一定会见到她的嘛……@怎么啦？难道说，你没有预约吗？"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200}]}],"group_26":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_34","textHome":"这个世界的麻美好像也陷入了奇怪的宗教啊。@这边的我们还找我商量说，@要想办法把她带回来呢。"}]},{"autoTurnFirst":3.1,"chara":[{"id":210200,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"id":210200,"motion":0}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_35","textHome":"杏子好像在用麻美的手机玩魔法纪录呢。@好像还下载了不少其他的游戏。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":100}]}],"group_28":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_36","textHome":"沙耶香她……啊，这个是不能提的吧？@真想她快点实装……啊不，是快点和她见……@诶，我已经能见到她了吗？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200,"motion":400}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200,"motion":0}]}],"group_29":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_37","textHome":"这个电台，是我和彩羽……@诶？怎么感觉彩羽的气质变了？@硬要说的话，是画风变了吧？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210200,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210200,"motion":101}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_04","textHome":"看来大家都有着不同的烦恼呢。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210200,"motion":300}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":101,"pos":1,"voice":"vo_char_2102_00_38","textHome":"下一封信是……「请教我抽出四星的方法」。@嗯……嗯……有三星的小圆前辈在哦！"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":300}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":200}]}],"group_31":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0,"pos":1,"voice":"vo_char_2102_00_39","textHome":"日美香的“野汁”虽然很苦，@但喝起来还挺上瘾。@不过，要是御魂拿去用的话……@还是别聊这个话题了。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":1}]},{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210200,"motion":300}]}],"group_32":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210200,"motion":200,"pos":1,"voice":"vo_char_2102_00_40","textHome":"呀嚯——魔法报告世界的彩羽在看吗？@是终于魔法纪录里实装了的，小圆前辈哟。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210200,"motion":400}]}],"group_33":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":1,"pos":1,"voice":"vo_char_2102_00_41","textHome":"既然你这么诚恳地一直戳我， @我也只能聊些劲爆的话题了呀……@说说小西红柿的事情怎么样？"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":200}]}],"group_34":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210200,"motion":200,"pos":1,"voice":"vo_char_2102_00_42","textHome":"到底能不能赢过这个武装小圆呢？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.js