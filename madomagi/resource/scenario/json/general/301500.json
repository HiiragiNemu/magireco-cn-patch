{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_01","textHome":"我，最喜欢大自然了。@花鸟鱼虫都喜欢，还有玩耍，我也最喜欢了！@不管是在外面，还是在家里！@学习？学习也……喜欢哦！@真的真的！我说真的啦！@不过要是可以的话……我想一直玩耍下去！@诶，不行吗？"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":1}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":4.7,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301500,"motion":400}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":300}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":100}]}],"group_10":[{"autoTurnFirst":6.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_18","textHome":"我喜欢喝茶，所以想有一天能挑战一下茶道！@虽然周围的人会说我不太适合，@但才没有这种事呢！"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301500}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301500,"motion":400,"pos":1,"voice":"vo_char_3015_00_19","textHome":"哈！……等一下……难道说我……变强了！？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500,"motion":200}]}],"group_12":[{"autoTurnFirst":4.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_20","textHome":"我也感觉到了！@刚刚……发生了什么好事对吧？"}]},{"autoTurnFirst":2.0,"chara":[{"id":301500,"motion":200}]}],"group_13":[{"autoTurnFirst":5.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_21","textHome":"家附近有一片树林，我一直在那里尽情玩耍。@不管是和丽良还有其他朋友一起玩，@还是自己一个人玩，都非常有趣！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]}],"group_14":[{"autoTurnFirst":5.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":400,"pos":1,"voice":"vo_char_3015_00_22","textHome":"自己一个人的时候，我会在树林里建造别墅。@用大树旁捡到的树枝和家里的瓦楞纸之类的，@来制作墙壁和天花板，然后再拿本书钻进去！"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"id":301500,"motion":200}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_23","textHome":"过去，我在树林里建造过一座自己的别墅！@然后我把它进一步扩建，@最终建成了「未都庄园」！@用来玩的道具都是自己制作的！@还和丽良她们一起玩过哦！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"id":301500,"motion":1}]}],"group_16":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_24","textHome":"唔……咚！打中你了呢～未都攻击！@嘿嘿，我在等你哦！@那么今天也打起精神地出发吧！"}]},{"autoTurnFirst":1.8,"chara":[{"id":301500,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_25","textHome":"早上好！再来……早上好！@嘿嘿，双倍的早安问候哦！@诶？一大早太精神了吗？@诶～因为是早上所以要拿出活力来哦！"}]},{"autoTurnFirst":2.5,"chara":[{"id":301500,"motion":200}]},{"autoTurnFirst":4.6,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":400}]}],"group_18":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_26","textHome":"我虽然经常被说人很精神……@但上课的时候就好困！@不过，我也想努力学习，@所以只好用手撑着眼皮了！"}]},{"autoTurnFirst":2.0,"chara":[{"id":301500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500,"motion":400}]}],"group_19":[{"autoTurnFirst":4.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_27","textHome":"回家的路，要是总走同一条不就很无聊嘛。@所以有时我也会绕远路回家，@之前有一次整整花了三小时呢！"}]},{"autoTurnFirst":4.5,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":301500,"motion":100}]}],"group_2":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_03","textHome":"只要每天能欢笑，那就是幸福了吧！啊哈！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":400}]}],"group_20":[{"autoTurnFirst":5.1,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_28","textHome":"呼……呼……嗯啊？@啊啊，不好意思我睡着了……@不管怎么样——都好困啊……@所以，晚安……"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301500}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":301500}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":301500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":1}]}],"group_21":[{"autoTurnFirst":1.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_29","textHome":"有时发个呆，时间就一眨眼过去了。@也有时并不是这样，为什么对时间的感觉@会有如此的不同呢？"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]}],"group_22":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":300,"pos":1,"voice":"vo_char_3015_00_30","textHome":"总感觉，有些兴奋，有些激动，有些紧张……@到底会发生什么呢……！？@嗯……差不多该行动了！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]}],"group_23":[{"autoTurnFirst":4.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_31","textHome":"这里……真是不可思议啊……看起来好有趣！@那个那个！我可以在那边散会儿步吗？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":200}]}],"group_24":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301500,"motion":400,"pos":1,"voice":"vo_char_3015_00_32","textHome":"哇！这里所有人都是魔法少女吗？好厉害……@居然有这么多人！我又有干劲了哦！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":0}]}],"group_25":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_33","textHome":"我，对自己的嗅觉很自信！@住宅区里每户人家的晚饭，我都能猜中！@首先……邻居家是咖喱！@诶？太简单了吧？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301500}]}],"group_26":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_34","textHome":"和动物说话很快乐哦！你问在说什么？@我完全听不懂！但是，也没问题！@感觉，去感觉！去感觉就行了吧？"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":301500,"motion":100}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500}]},{"autoTurnFirst":4.1,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":400}]}],"group_27":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_35","textHome":"过去，我很擅长爬树的。@不过……现在已经完全不行了……@因为……爬到顶要花三十秒了！@过去明明只要十秒的～"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301500,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":100}]}],"group_28":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":300,"pos":1,"voice":"vo_char_3015_00_36","textHome":"我最喜欢在小区的屋顶上午睡了！@吹着风，听着树叶和人们生活的声音……@那种感觉舒服极了。"}]},{"autoTurnFirst":7.5,"chara":[{"eyeClose":1,"id":301500,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]}],"group_29":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_37","textHome":"以前我还认真地收集过橡果，@然后还藏到了小区各处！@实际上……现在也被好好的藏着！"}]},{"autoTurnFirst":1.8,"chara":[{"id":301500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":400}]}],"group_3":[{"autoTurnFirst":2.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":1,"pos":1,"voice":"vo_char_3015_00_04","textHome":"很多小事，也能让生活变得有趣起来对吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":200}]}],"group_30":[{"autoTurnFirst":3.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_38","textHome":"你有玩过跳圆圈吗？@我过去做过围绕整个小区的圆圈！@虽然跳到最后的人都已经气喘吁吁了！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":100}]}],"group_31":[{"autoTurnFirst":4.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_39","textHome":"虽然有时我会去帮丽良做点心，但做的时候，@我总是忍不住想偷吃！对不起呢，丽良！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":301500,"motion":200}]}],"group_32":[{"autoTurnFirst":4.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_40","textHome":"清佳她十分文静，和我恰恰相反，@不过我们在一起却不会难受……@反而会十分安心～"}]},{"autoTurnFirst":3.5,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]}],"group_33":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_41","textHome":"喵喵喵！喵喵喵！喵喵喵！喵喵喵！@啊，我刚刚在和附近的猫对话呢！"}]},{"autoTurnFirst":2.8,"chara":[{"id":301500,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":301500,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"id":301500,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":0}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_42","textHome":"只能上了吗！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301500,"motion":400,"pos":1,"voice":"vo_char_3015_00_43","textHome":"嗯？我好像赢了？"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":300,"pos":1,"voice":"vo_char_3015_00_44","textHome":"哈啊……安然无恙了～"}]}],"group_37":[{"autoTurnFirst":1.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_45","textHome":"赢了！还不错吧？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301500,"motion":300,"pos":1,"voice":"vo_char_3015_00_46","textHome":"好累……想喝杯茶……"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_63","textHome":"我的心情依旧不变……"}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_05","textHome":"虽然烦心事很让人烦恼，@但一直闷闷不乐也是不行的！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":400}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_64","textHome":"下决心拉开弓弦……之后就是……"}]},{"autoTurnFirst":1.5,"chara":[{"id":301500,"motion":200}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_65","textHome":"让箭矢乘上我的感情……"}]}],"group_42":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_66","textHome":"这一招……如何——！？"}]},{"autoTurnFirst":1.5,"chara":[{"id":301500,"motion":400}]}],"group_43":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":0,"pos":1,"voice":"vo_char_3015_00_02","textHome":"一开始是「相」，然后是「野」，@再接下来是「未」，最后是「都」！@连起来就是「相野未都」！请多指教！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":400,"pos":1}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":1}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500,"motion":100}]}],"group_5":[{"autoTurnFirst":2.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301500,"motion":300,"pos":1,"voice":"vo_char_3015_00_13","textHome":"野草是越踩越强大的！就是这种感觉吧？"}]},{"autoTurnFirst":4.5,"chara":[{"id":301500,"motion":400}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_14","textHome":"嗯嗯……这样子我也算是变强了……对吧？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301500,"motion":400}]}],"group_7":[{"autoTurnFirst":2.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301500,"motion":200,"pos":1,"voice":"vo_char_3015_00_15","textHome":"我又有提升了！这样就能走得更远了吧！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.j