{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_01","textHome":"我的双亲被魔女所杀，街坊们都以为是失踪了@可那是一份虚假的记忆，@是由我缔结契约时所许下的「愿望」形成的。@但是！我会永远记住真实的记忆！@之后我就边当佣兵边杀魔女，今后也会如此！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":300}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_18","textHome":"话说啊，要是想和我干架就尽管来！@看我一个个给你们揍趴下，@让你们晓得啥是超强佣兵！"}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_19","textHome":"哦哦——这感觉！@……毫无疑问是有突破了！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_20","textHome":"嗯，心情不错！还能往上走~！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_21","textHome":"要说让人开心的时候，@那就是没有麻烦的时候。@烦心事儿一概没有！可以随心所欲的时候！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_14":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_22","textHome":"做饭、扫除……这不就是家务活？超麻烦啊！@我完全不爱做这些，会做也不爱做。@啊——不管了不管了！@垃圾再多忍忍就完事了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":400}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_23","textHome":"我想象中最赞的生活嘛，首先是饭来张口，@然后想去哪都有人接送。@总之就是自己什么也不用做！就是这样！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_03_24","textHome":"嘿——这件衣服怎么样!?咱觉得是又帅@又可爱嘞！你看，耳朵也可以动哦!?"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_03_25","textHome":"嗯……咱不想起来……绝对不会起来的。@小动物啊，就是自由啦，在大自然里嗯……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":100500}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_050.exp.json","id":100500}]}],"group_18":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_03_26","textHome":"嘿呀！午饭之前练习一下万圣节的话剧吧！@还是要肚子饿扁的时候，饭才会更好吃呐！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_03_27","textHome":"哦，再不去练习，花凛就要生气了。别看@我一直是一副懒散的样子，@委托可都是会好好完成的！因为是佣兵嘛！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_2":[{"autoTurnFirst":3.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_03","textHome":"七香那家伙！@从初次见面的时候就觉得与她合不来！"}]},{"autoTurnFirst":4.3,"chara":[{"id":100500,"motion":200}]}],"group_20":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_03_28","textHome":"好累，好困，好疲惫……也没有魔女的反应，@还是睡觉算了……啊，还要去收糖果才行！@Trick or Treat的那个！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_21":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_03_29","textHome":"嗯啊？哦，抱歉，现在佣兵不接单。@万圣节可是很重要的。啊什么？有魔女出现了!?@那就是另一回事了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_03_30","textHome":"衣服和包包都准备好啦！快点上台吧！@咱虽然是第一次当演员，但是一定会成功的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_03_31","textHome":"镜界如果把咱复制了的话，就是两头牛。@再复制的话就是四头。啊，@怎么感觉好像成了牧场一样。"}]},{"autoTurnFirst":1.5,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":3.6,"chara":[{"id":100500,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_03_32","textHome":"不管有多少变装的家伙，咱可不会输的。@咱还要赢过红头发的姐姐然后独占所有零食！"}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_03_33","textHome":"快看这个包包！装着超大量的糖果!?@八千代是大人所以用不着，@就只留一个给她吧。嘻嘻！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":300}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_03_34","textHome":"和鹤乃一起做了土豆泥哦！啊，是一个叫做@马铃薯卷心菜泥的东西。万圣节经常吃的！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":3.1,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_03_35","textHome":"什么嘛这剧本。写满了注音，都没法读了！@谁搞的啊！……嗯？啊，是咱自己干的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]}],"group_28":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_03_36","textHome":"衣服就很厉害了，这个铃铛更是！好像是@鹿乃子用黄铜加工出来的!?"}]},{"autoTurnFirst":1.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnLast":2.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":300,"pos":1,"voice":"vo_char_1005_03_37","textHome":"说来还好没被明日香抢走扮演牛的机会。@能拿到这身衣服，真是不容易啊——"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_04","textHome":"可恶！被人给骗了！@这不是只有我一个人去战斗了吗！"}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_03_38","textHome":"在演出里有自己的台词，对咱来说还是@头一回呢。以前总被老师说捣乱，@然后就被赶到幕后去了呢。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":300}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":300,"pos":1,"voice":"vo_char_1005_03_39","textHome":"虽然演出用的糖果都送出去了，但小朋友们@都很开心，这样也好吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_32":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_03_40","textHome":"爸爸来自不列颠那类讲英语的国家，@一家人在一起的时候，过了很多次万圣节哦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":300,"pos":1,"voice":"vo_char_1005_03_41","textHome":"南瓜汤啊。妈妈会把南瓜挖空，@而咱负责的就是在上面画鬼脸了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":100}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_42","textHome":"哦哟！赶紧战斗吧！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_43","textHome":"耶——！是咱赢了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_36":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_44","textHome":"哈！那就给我认输吧！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_45","textHome":"这个结果是当然啦！"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_46","textHome":"想不到能怎么输！"}]}],"group_39":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_63","textHome":"好嘞！就用它了！"}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":200}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_05","textHome":"我要把魔女通通收拾掉……绝对不会输的！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":200}]}],"group_40":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_64","textHome":"很好！再吃我这招！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_41":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_65","textHome":"看好，用这个把它打得说不出话！"}]},{"autoTurnFirst":4.3,"chara":[{"id":100500,"motion":200}]}],"group_42":[{"autoTurnFirst":0.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_66","textHome":"大招！给你打得稀里哗啦！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_43":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_02","textHome":"听说有人找我！要说到狩猎魔女，@当然是我深月菲莉希亚的事了！@那就赶紧的干活去吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]}],"group_5":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_13","textHome":"好！心情特别爽！干啥都杠杠的！"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_14","textHome":"哦，感觉好像特别顺手？这不是挺好的嘛！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"