,{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":350101,"motion":200}]}],"group_25":[{"autoTurnFirst":1.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":0,"pos":1,"voice":"vo_char_3501_01_32","textHome":"圣诞派对上，有美食，有卡拉OK，有互换礼@物……总之是很盛大的活动！要期待哦！"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"id":350101,"motion":400}]},{"autoTurnFirst":1.9,"chara":[{"id":350101,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":201}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":350101,"motion":400,"pos":1,"voice":"vo_char_3501_01_33","textHome":"不好！一看到圣诞用的化妆品就来兴致了！总@之一个个试一遍吧？可以的话……就挑一个@买下吧？"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":350101,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":350101}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":350101}]}],"group_27":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":100,"pos":1,"voice":"vo_char_3501_01_34","textHome":"雪橇啊，意外地有不少种设计呢！怜会喜欢哪@种呢？会是圣诞老人款式的吗？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":350101}]},{"autoTurnFirst":2.6,"chara":[{"id":350101,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":1}]}],"group_28":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":350101,"motion":100,"pos":1,"voice":"vo_char_3501_01_35","textHome":"等一会！这家店在做圣诞特惠呀！种草很久的@香水，还有没有呀～嗯……果然卖完了啊。@……哎，没办法啦！下次吧下次！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":350101}]},{"autoTurnFirst":3.7,"chara":[{"id":350101,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":350101,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":350101,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":350101}]}],"group_29":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":0,"pos":1,"voice":"vo_char_3501_01_36","textHome":"怎样选礼物？我呢，会暗中弄清楚对方想要的@东西再决定。这样对方才会高兴嘛。"}]},{"autoTurnFirst":2.0,"chara":[{"id":350101,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"id":350101,"motion":1}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":350101}]},{"autoTurnFirst":1.8,"chara":[{"eyeClose":0,"id":350101}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":350101,"motion":400}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":0,"pos":1,"voice":"vo_char_3501_00_03","textHome":"这样就准备完成了……是吗？"}]}],"group_30":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":350101,"motion":1,"pos":1,"voice":"vo_char_3501_01_37","textHome":"刚刚还跟艾米莉说，女孩子真是太棒了呢。圣@诞节可以光明正大地穿出这样可爱的衣服，@还会被大家夸奖哦！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":0}]},{"autoTurnFirst":2.2,"chara":[{"id":350101,"motion":201}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":350101,"motion":100}]}],"group_31":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350101,"motion":100,"pos":1,"voice":"vo_char_3501_01_38","textHome":"怜好像每年都会和家人一起过圣诞节，所以她@说很久没和朋友一起了。真想让她开心一点@呀。"}]},{"autoTurnFirst":4.0,"chara":[{"id":350101,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":350101}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":350101,"motion":1,"pos":1,"voice":"vo_char_3501_01_39","textHome":"之前，和我在一起的女孩子，连圣诞节都没到@就走了……啊，不是被甩了哦？总之是我不@好……"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":350101}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":350101}]},{"autoTurnFirst":3.5,"chara":[{"id":350101,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"id":350101,"motion":300}]}],"group_33":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":350101,"motion":100,"pos":1,"voice":"vo_char_3501_01_40","textHome":"在圣诞节告白的孩子不少呢～我也能明白啦。@想要告白成功，首先当然是从气氛做起啦！"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":350101}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":350101}]},{"autoTurnFirst":1.8,"chara":[{"id":350101,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":350101,"motion":200}]}],"group_34":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":350101,"motion":1,"pos":1,"voice":"vo_char_3501_01_41","textHome":"在我身边，有着好多闪闪发光的好东西哦！诶@，不是说圣诞彩灯啦！是说我的好宝贝！"}]},{"autoTurnFirst":2.3,"chara":[{"id":350101,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":350101,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":350101,"motion":400}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":0,"pos":1,"voice":"vo_char_3501_00_42","textHome":"怜，加油啊！嗯……梨花！"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":0,"pos":1,"voice":"vo_char_3501_00_43","textHome":"这就是带来圣诞奇迹的魔法！"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":350100,"motion":0,"pos":1,"voice":"vo_char_3501_00_44","textHome":"大家都变得幸福了吗？"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":