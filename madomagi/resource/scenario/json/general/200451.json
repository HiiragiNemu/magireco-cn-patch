{"story":{"group_1":[{"autoTurnFirst":7.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_01","textHome":"呼～一路追着麻美学姐，一不留神我也来到了@神滨……这里确实很奇怪。不仅能撞见魔女@和使魔，而且……那是什么？传闻？@那些家伙真是出乎意料的可怕！@嘛，麻美学姐倒是不会输给那些家伙就是……"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200451,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200451}]},{"autoTurnFirst":4.5,"chara":[{"id":200451,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200451}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":100}]}],"group_10":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_00_18","textHome":"我已经不再是过去的我了。@如今站在这里的我，@只靠自己一个人是绝对无法成就的。@那么现在，就让我勇往直前吧！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":200451,"motion":200}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":200,"pos":1,"voice":"vo_char_2004_00_19","textHome":"感觉超棒……！@现在的我，开心得快飞起来了哦！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200451,"motion":100}]}],"group_12":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_00_20","textHome":"呜哇……我感觉，世界看起来都不一样了。"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_00_21","textHome":"嗯，我似乎变强了一些……@就算是之前一筹莫展的对手，@现在我也觉得能赢了。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200451,"motion":1}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":300,"pos":1,"voice":"vo_char_2004_00_22","textHome":"我的愿望是治好青梅竹马的伤病。@不仅如此……我还想获得力量，@能一直保护好重要的人。@所以我不后悔成为魔法少女。我不能后悔。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":200451}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":200451,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":200451,"motion":1}]}],"group_15":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_23","textHome":"我很开心自己能够变强。@那样就能不依靠别人，保护自己想保护的人了@对吧？我讨厌和那些见死不救，利用他人的@家伙们一起行动。"}]},{"autoTurnFirst":7.0,"chara":[{"id":200451,"motion":1}]},{"autoTurnFirst":10.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":0}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_51_24","textHome":"欢迎光临。这里是我亲戚开的旅店。@怎么样，有好好享受这个夏天的感觉吧？"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":200}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_25","textHome":"早上好！@因为起得早，我就去海滩边散了会儿步。@现在还不热，海风吹起来很舒服。@要不要陪我再去一次？"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":4.3,"chara":[{"id":200451,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"id":200451,"motion":1}]}],"group_18":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":300,"pos":1,"voice":"vo_char_2004_51_26","textHome":"哈啊～吃完饭就想休息一下。@是去游泳，还是去海滩边玩呢，@在海之家里看在外面的人玩耍也不错啊～"}]},{"autoTurnFirst":3.9,"chara":[{"eyeClose":1,"id":200451}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":200451}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":0}]},{"autoTurnFirst":7.5,"chara":[{"id":200451,"motion":1}]}],"group_19":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":201,"pos":1,"voice":"vo_char_2004_51_27","textHome":"接下来，晚饭该吃什么呢！@难得来一趟，就吃海鲜吧。@游累了之后，饭也会变得更好吃吧。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":100}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":200,"pos":1,"voice":"vo_char_2004_00_03","textHome":"交给魔法侦探沙耶香！有问题都来问我吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":200451,"motion":1}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":300,"pos":1,"voice":"vo_char_2004_51_28","textHome":"一说到晚上的海滩……是的！烟花！@快看，我准备了好多！@不放完可不准睡觉哦？"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200451,"motion":201}]},{"autoTurnFirst":3.4,"chara":[{"id":200451,"motion":0}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":100}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_51_29","textHome":"防晒霜也要认真涂才行。@我还是比较注意的。@要是被晒伤可就难办了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":100}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":400,"pos":1,"voice":"vo_char_2004_51_30","textHome":"夏天！大海！打倒魔女！@所以，火力全开的夏天模式沙耶香，@打倒魔女时也不会手下留情的！"}]},{"autoTurnFirst":3.3,"chara":[{"id":200451,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"id":200451,"motion":100}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_31","textHome":"这么热的天，敌人肯定都中……没有中暑啊。@好！那我也拿出干劲把这份炎热赶跑吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":201}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_51_32","textHome":"每个人都穿着泳装呢。@就像来到了泳池一样。@啊，真是大饱眼福！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_042.exp.json","id":200451,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200451,"motion":100}]}],"group_25":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_33","textHome":"是长距离游泳的人！@噢，干劲满满嘛。@那么先到那座岛就是胜利……@预备，开始！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":400}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":4.0,"chara":[{"id":200451,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":201}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_34","textHome":"有人会对着电风扇「啊——」的吧？@看起来真像个小孩子，@虽然我有时也会这么做……"}]},{"autoTurnFirst":1.5,"chara":[{"id":200451,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":200451,"motion":1}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":200451,"motion":100}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":400,"pos":1,"voice":"vo_char_2004_51_35","textHome":"喂，杏子！那边的鸡尾酒刨冰是我的啦！@不许偷吃！你自己不也有嘛！！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":1}]},{"autoTurnFirst":2.3,"chara":[{"id":200451,"motion":300}]},{"autoTurnFirst":3.3,"chara":[{"id":200451,"motion":0}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_36","textHome":"那边的海滩是冲浪专用的。@乘着海浪是种什么样的感觉呢。@我也好想试试啊。"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":200451}]},{"autoTurnFirst":2.2,"chara":[{"id":200451,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":200451}]},{"autoTurnFirst":5.0,"chara":[{"id":200451,"motion":100}]}],"group_29":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":201,"pos":1,"voice":"vo_char_2004_51_37","textHome":"锵锵！怎么样，我的泳装！@因为要和大家来海边，所以新做了一件。@是不是有些太飘飘然了呢，啊哈哈。"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200451,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200451}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_00_04","textHome":"所以，我都说了才不是去约会呢……！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":100}]}],"group_30":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_51_38","textHome":"小圆和小焰的泳装也很漂亮呢。@很可爱又很女孩子气。@不过，不太符合我的性格……"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":200451,"motion":100}]}],"group_31":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":400,"pos":1,"voice":"vo_char_2004_51_39","textHome":"呀～你看到麻美学姐的泳装了吗？@那才是性感又可爱。@好羡慕啊……"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":300}]}],"group_32":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_51_40","textHome":"穿着泳装给那家伙看？怎、怎么可能嘛！@他只不过是青梅竹马而已……为了让他看泳装@就突然把他叫过来是不可能的啦……"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":200451,"motion":201}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200451,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_042.exp.json","id":200451}]}],"group_33":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_51_41","textHome":"怎么啦？对泳装的沙耶香看入迷了吗？@诶，你那种反应的话……我也会害羞的……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":201}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":400}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200451,"motion":300}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":200,"pos":1,"voice":"vo_char_2004_00_42","textHome":"让我来打飞它吧！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_00_43","textHome":"算是告一段落了。"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_44","textHome":"真是千钧一发呀。"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_45","textHome":"我都忍不住夸自己了哦？"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_46","textHome":"太无聊了我都快睡着了！"}]}],"group_39":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_00_63","textHome":"我不会输……我怎么可能会输！"}]},{"autoTurnFirst":3.7,"chara":[{"id":200451,"motion":400}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_05","textHome":"这里有这么多的魔法少女，真是吓了我一跳。"}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":200,"pos":1,"voice":"vo_char_2004_00_64","textHome":"呀啊！"}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_00_65","textHome":"还有还有，还不止这样！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200451,"motion":200}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200451,"motion":200,"pos":1,"voice":"vo_char_2004_00_66","textHome":"看到了吗，我真正的实力！"}]}],"group_43":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":201,"pos":1,"voice":"vo_char_2004_00_02","textHome":"久等啦！正义的魔法少女——美树沙耶香，前@来造访！嗯嗯，因为我很强，所以有什么事@尽管交给我就行了……开玩笑的啦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":201}]}],"group_5":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200451,"motion":400,"pos":1,"voice":"vo_char_2004_00_13","textHome":"噢噢!?我感觉全身充满了魔法的力量……！"}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_00_14","textHome":"嗯，好久没有这么舒服了！爽快爽快！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451}]},{"autoTurnFirst":2.7,"chara":[{"id":200451,"motion":100}]}],"group_7":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1,"pos":1,"voice":"vo_char_2004_00_15","textHome":"谢谢你一直和我在一起。让我总能放下心。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200451}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200451}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200451,"motion":0,"pos":1,"voice":"vo_char_2004_00_16","textHome":"身经百战后，我也算是个合格的魔法少女了，@不过我依然是我。@魔法少女沙耶香，之后也请多指教！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200451,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"id":200451,"motion":200}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200451,"motion":100,"pos":1,"voice":"vo_char_2004_00_17","textHome":"我这个人并没有什么特别的天赋和才能。@但即便如此，我也变得这么强了……@可以稍微骄傲一下吗？"}]},{"autoTurnFirst":5.0,"chara":[{"id":200451,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200451}]}]},"version":3}