{"story":{"group_1":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_01","textHome":"我叫水波玲奈，完毕。什么？没有。@别的也没什么可介绍的了。我知道啦，@自我介绍嘛，我做就是了。年龄15岁，完毕。@哈？还得多说点？那，你先做个示范吧。@我会认真听的，你的自我介绍。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":4.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"id":100900,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_18","textHome":"顺利极了！要是继续保持的话，@咱们小队搞不好就要成为@魔法少女界有名的最强小队了。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_19","textHome":"要是觉得玲奈的极限就到这里了，那可不成。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":1.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_20","textHome":"努力和自信息息相关对吧？@忘了是谁说的，但我会努力的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_21","textHome":"很高兴变强了。@因为这份力量呢，对于玲奈来说……@也是用来守护队友桃子和枫的。"}]},{"autoTurnFirst":6.5,"chara":[{"id":100900,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_14":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_22","textHome":"对自己……应该更加爱护才行。@因为啊，要是说出最讨厌自己这种话来，@那喜欢着玲奈的人们该怎么办呢？"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900}]}],"group_15":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_23","textHome":"总觉得……身为水波玲奈也意外地不错呢。@虽然曾经说着最讨厌自己，@想拥有能变成别人的能力而成为了魔法少女。@但现在不仅仅是力量……@而是连心灵也成长了吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100}]}],"group_16":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_24","textHome":"好慢。玲奈可是五分钟前就等着了。@作为补偿，请我吃豆沙包吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_25","textHome":"早啊……啊？并没有心情不好。……都说过了，玲奈可没有起床气啊。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":1.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":200}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_060.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_26","textHome":"啊~浑身难受……！哈？因为肚子饿了啊！@肚子饿了能不难受吗？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":200}]}],"group_19":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900,"motion":400,"pos":1,"voice":"vo_char_1009_00_27","textHome":"我买到了新的谱面书——@而且居然是~我喜欢的偶像组合的！@偶像们的流行歌曲真是太棒了！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900,"motion":200}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_03","textHome":"不是的……这就是真正的玲奈……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":100900}]}],"group_20":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_28","textHome":"玲奈都要睡觉了。@敢说没什么事的话，打你哦？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":100}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_29","textHome":"那个折一下就能亮的？@虽然我也喜欢那种能变色的，@但如果不是官方的荧光棒的话，@就不能算是应援色了哦。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":100}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_00_30","textHome":"该出发了吧，还没准备好？@玲奈可是万事俱备了。@道歉就算了，再给你五秒钟弄完。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900}]},{"autoTurnFirst":1.9,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"id":100900}]},{"autoTurnFirst":1.7,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":1.6,"chara":[{"id":100900,"motion":200}]}],"group_23":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_31","textHome":"有人挑事的话除了应战还能怎样呢？@要是被想成夹着尾巴逃跑了，@这种事怎么能受得了？"}]},{"autoTurnFirst":2.9,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":200}]}],"group_24":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_32","textHome":"怎么？没必要紧张成那样吧。@你的失误让玲奈来补救就行了，对吧？@玲奈要是失手了，你可要帮忙啊。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_33","textHome":"哼哼哼哼哼~怎样，@是不是很想问发生什么好事了？@我抽到单推的拍立得了哦~"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":1.5,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]}],"group_26":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100900,"motion":100,"pos":1,"voice":"vo_char_1009_00_34","textHome":"豆沙馅当然要磨细的了，@带粒的简直不可理喻。@饮料更不用说了，要奶茶。"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"id":100900}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100900,"motion":0}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900,"motion":0,"pos":1,"voice":"vo_char_1009_00_35","textHome":"超级中意的节目录播呢，就把它刻成DVD，@这样就有种数据不会丢失的感觉吧？"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100900,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100900}]}],"group_28":[{"autoTurnFirst":2.4,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":400,"pos":1,"voice":"vo_char_1009_00_36","textHome":"哇！突然出声吓到我了啦！@……你等着吧，早晚我也要给你来一下。"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100900,"motion":100}]},{"autoTurnFirst":1.9,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100900,"motion":0}]},{"autoTurnFirst":1.6,"chara":[{"id":100900,"motion":200}]}],"group_29":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_37","textHome":"桃子好厉害啊，不管跟谁都能打成一片。@虽然本人好像并没有意识到这一点……@这么自然真的好嘛？"}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100900,"motion":300}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":300,"pos":1,"voice":"vo_char_1009_00_04","textHome":"这样的自己……水波玲奈真是没用……"}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":100}]}],"group_30":[{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_38","textHome":"一起去看演出吧？@打call当然会教你，@还有偶像宅守则之类的……@我都会教你的。"}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100900}]},{"autoTurnFirst":2.3,"chara":[{"id":100900,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"id":100900,"motion":100}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100900}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100900,"motion":1,"pos":1,"voice":"vo_char_1009_00_39","textHome":"又在无关紧要的事情上发脾气了……@玲奈也很想改掉这急性子的毛病！@……那样的话，在团队里也能更顺利……"}]},{"autoTurnFirst":4.5,"chara":[{"id":100900,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100900,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":100900,"motion":100}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100900,"motion":200,"pos":1,"voice":"vo_char_1009_00_40","textHome":"桃子玲奈和枫……？@桃、枫……桃枫玲大三角？@嗯……哪里不对……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn