.1,"chara":[{"eyeClose":0,"id":130102}]},{"autoTurnFirst":2.7,"chara":[{"id":130102,"lipSynch":1,"motion":0},{"id":130100,"lipSynch":0,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":130102,"motion":201}]}],"group_17":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_1301_01_24","textHome":"欢迎。八千代有工作，所以不在家哦。@虽然爸爸有帮我交生活费，@但好像还是不太够的样子……？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130101,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":130101,"motion":301}]}],"group_18":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":130101,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_01_25","textHome":"早上好。@今天的早饭试着做了八千代喜欢的和食。@有煎蛋卷、腌竹荚鱼、味噌汤和纳豆。@哼哼，很健康吧？"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101}]},{"autoTurnFirst":5.2,"chara":[{"id":130101,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101,"motion":100}]}],"group_19":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130101,"lipSynch":1,"motion":301,"pos":1,"voice":"vo_char_1301_01_26","textHome":"啊，天气比想象中还好呢……@接下来去洗洗衣服好像不错……@啊，八千代应该在休息，打电话问问吧。"}]},{"autoTurnFirst":4.0,"chara":[{"id":130101,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":130101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101,"motion":401}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":0,"motion":0,"pos":1,"voice":"vo_char_1301_00_02","textHome":"我们啊，现在要两个人一起去狩猎魔女了。@可以的话你也一起怎么样？@我想一定不会有什么坏处的。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130100,"lipSynch":1,"motion":100,"pos":0,"voice":"vo_char_1301_00_02","textHome":"我们啊，现在要两个人一起去狩猎魔女了。@可以的话你也一起怎么样？@我想一定不会有什么坏处的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":130102,"lipSynch":1,"motion":200},{"id":130100,"lipSynch":0,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]}],"group_20":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_01_27","textHome":"八千代发来的消息……@嗯，要买酱油。@呼……马上要和鹤乃一起回去，@顺便去一下超市吧。"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":130101,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130101}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":130101,"lipSynch":1,"motion":301,"pos":1,"voice":"vo_char_1301_01_28","textHome":"八千代，还醒着吗……是在做什么呢？@啊，是马克杯……时不时地，@会拿出梅露和加奈惠的擦拭一下……"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130101}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":130101,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101,"motion":200}]}],"group_22":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_01_29","textHome":"在三日月别墅度过的每一天都很幸福呢，@但有时会感到不安。@会不会到什么时候就少了人……@对、对不起，说了消极的话……"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130101,"motion":300}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":1,"id":130101}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130101}]},{"autoTurnFirst":1.1,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":130101,"motion":401}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":130101}]}],"group_23":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130101,"lipSynch":1,"motion":301,"pos":1,"voice":"vo_char_1301_01_30","textHome":"现在八千代不在，我一个人……@也要挺身而出和面前的魔女战斗才行。@总是依赖大家，就会失去独立战斗的能力呢。"}]},{"autoTurnFirst":3.9,"chara":[{"eyeClose":1,"id":130101}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":130101}]},{"autoTurnFirst":3.2,"chara":[{"id":130101,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":130101,"motion":200}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":130101,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_1301_01_31","textHome":"无尽镜界的复制品之间，是怎么样交流的呢？@跟我们本人的性格不一样，@有点好奇对话会是什么样子的。"}]},{"autoTurnFirst":3.1,"chara":[{"id":130101,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101}]}],"group_25":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_01_32","textHome":"我们家就算吵起来了也会有人来当裁判，@不会有大问题。@啊，刚说完就吵起来了!?@怎么了——"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":130101,"motion":401}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130101,"motion":400}]}],"group_26":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":130101,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_01_33","textHome":"嗯……记不住历史名词呢……@有没有好的方法啊？@鹤乃今天也没来，去问问八千代吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":130101,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"id":130101,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101}]}],"group_27":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_01_34","textHome":"从大家那里得到的东西，都藏在了宝箱里。@只要看看里面的东西，那时的记忆就会浮现，@就像是小时光机一样。"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":130101,"motion":301}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130101,"motion":100}]}],"group_28":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":130101,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_1301_01_35","textHome":"啊——等一下！菲莉希亚还没有擦头发啊!?@就算八千代不在也不能不弄干啊！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":130101,"motion":200}]}],"group_29":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130101,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_1301_01_36","textHome":"最近八千代的手机里多了很多猫的照片，@好像是受了莎奈的影响。@但说是因为会产生感情，所以绝对不会养。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":130101}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":130101,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":130101,"motion":301}]}],"group_3":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130102,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_1301_00_03","textHome":"也是，大概彩羽会帮我做的。"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":130100,"lipSynch":0,"motion":0,"pos":0,"voice":"vo_char_1301_00_03","textHome":"也是，大概彩羽会帮我做的。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp.json","id":130102}]}],"group_30":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":130101,"lipSynch":1,"motion":401,"pos":1,"voice":"vo_char_1301_01_37","textHome":"这个，来尝一口吧。@我从八千代那里学习的𫚕鱼萝卜的做法。@听说是奶奶手把手教的哦。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":130101,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":130101,"motion":200}]}],"group_31":[{"autoTurnFirst":0.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":130101,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_1301_01_38","textHome":"哼哼，你不觉得八千代有时候@像小孩子一样可爱吗？@看，这张积分卡全部都积满的时候，@她高兴得不得了哦。"}]},{"autoTurnFirst":4.9,"chara":[{"c