{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":200,"pos":1,"voice":"vo_char_1101_00_01","textHome":"看来不会游泳的原因，@还是因为小时候在泳池溺水了啊……@那时候，我在泳池边走着，@然后滑了一下，就唰地掉进水里了……@啊，但是游泳本身我是喜欢的！@只是……没了泳圈就不行了而已……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":110100}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110100}]},{"autoTurnFirst":2.5,"chara":[{"id":110100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":400}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":301}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":110100,"motion":300}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":200,"pos":1,"voice":"vo_char_1101_00_18","textHome":"被菲莉希亚拖着一起游泳感觉真是太厉害了！@这已经不是游泳了，@只是抓紧她都很不容易……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":401}]},{"autoTurnFirst":3.5,"chara":[{"id":110100,"motion":300}]}],"group_11":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_19","textHome":"只要魔力变强就可以不用游泳圈了！@没这种事吧？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":110100,"motion":200}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":400,"pos":1,"voice":"vo_char_1101_00_20","textHome":"感觉不错！@这样是不是也能游得更好呢~"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":200}]}],"group_13":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":301,"pos":1,"voice":"vo_char_1101_00_21","textHome":"只要想游，不管怎么用力……也动不起来，@然后就沉下去了……@是要先学会放松吗？"}]},{"autoTurnFirst":4.5,"chara":[{"id":110100,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":110100}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_22","textHome":"差不多学会换气了的样子。@之前分不清时机，每次都一抬头就呛水，@现在时机感觉已经能抓住了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":110100,"motion":401}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":400}]}],"group_15":[{"autoTurnFirst":0.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_23","textHome":"噗……哈！噗……哈！@嗯，换气就是这个时间吧？@然后是手脚也要动起来……@但是，这才是最大的难点……@但是我会努力的，一定可以学会的！"}]},{"autoTurnFirst":1.0,"chara":[{"id":110100,"motion":400}]},{"autoTurnFirst":0.6,"chara":[{"id":110100,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"id":110100,"motion":400}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110100}]},{"autoTurnFirst":3.7,"chara":[{"id":110100,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":301}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":100}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_24","textHome":"啊，正在给泳圈充气！这样应该够了。@好，随时可以出发……@我会努力踢水的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":400}]}],"group_17":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":401,"pos":1,"voice":"vo_char_1101_00_25","textHome":"鹤乃和菲莉希亚已经在海里游了……@我也努努力去游泳吧！@还是……想想就好……@今天就算了吧……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":300}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_26","textHome":"今天的午饭吃什么呢……@素面怎么样……还是凉面呢……@诶？不是一种东西啊！@宽度是不一样的啊！"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":100}]}],"group_19":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_27","textHome":"夏天的傍晚，有种奇妙的气氛……@就好像热闹的派对散去时那种冷清的感觉。"}]},{"autoTurnFirst":3.6,"chara":[{"id":110100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100}]}],"group_2":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":301,"pos":1,"voice":"vo_char_1101_00_03","textHome":"哈啊……这之后会变成什么样啊……"}]}],"group_20":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":200,"pos":1,"voice":"vo_char_1101_00_28","textHome":"热得难以入眠的夜晚，@先把室温降到容易入睡的程度比较重要。@啊，但是，当心也不要太冷了哦！"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":100}]}],"group_21":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_29","textHome":"虽然好像年年如此，@感觉夏天总是弹指一挥间就过去了……@所以，每一天都好好享受吧！"}]},{"autoTurnFirst":2.2,"chara":[{"id":110100,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":100,"pos":1,"voice":"vo_char_1101_00_30","textHome":"我能带上游泳圈吗？@要是在海里或者泳池里跟魔女战斗，@我就帮不上忙了，只能全拜托你了！"}]},{"autoTurnFirst":5.0,"chara":[{"id":110100,"motion":301}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":200}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":100,"pos":1,"voice":"vo_char_1101_00_31","textHome":"准备得万无一失了……@备用的游泳圈也带了，@万一掉了或者破了，也能立刻换上！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":400}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":401,"pos":1,"voice":"vo_char_1101_00_32","textHome":"啊哇哇……难道只有我还在用游泳圈吗！？@好、好害羞……但是，对不起！@完全没法放手！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110100}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":110100,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110100}]},{"autoTurnFirst":5.0,"chara":[{"id":110100,"motion":400}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_33","textHome":"我特别喜欢看海。@仿佛被涛声逐渐包围的感觉，@让人非常的舒心。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":100}]}],"group_26":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":401,"pos":1,"voice":"vo_char_1101_00_34","textHome":"哇，这款防晒霜是八千代告诉我的，@涂起来感觉跟皮肤特别亲和。@是因为做模特才了解那么多的吗？"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100}]},{"autoTurnFirst":2.5,"chara":[{"id":110100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":100}]}],"group_27":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_35","textHome":"和大家一起去挑选泳装，@虽然犹豫了很久，@最后还是选了一开始看中的那件最可爱的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":200,"pos":1,"voice":"vo_char_1101_00_36","textHome":"确实有所谓「夏天的气息」吧？@说是海和泳池的味道也行，@不过我还是觉得蚊香的气味最合适！@非常有夏天的感觉！"}]},{"autoTurnFirst":3.5,"chara":[{"id":110100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":400}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":400,"pos":1,"voice":"vo_char_1101_00_37","textHome":"八千代游泳的姿势，真的好漂亮啊。@我只能掀起好多水花却游不动，@她嗖地就游出去了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":110100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":110100,"motion":401}]}],"group_3":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":400,"pos":1,"voice":"vo_char_1101_00_04","textHome":"事到如今，我一定要稳住！对吧？"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":200}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":400,"pos":1,"voice":"vo_char_1101_00_38","textHome":"总的来说，游得最快的是鹤乃！@这么说来，她还说游得过摩托艇来着……@但这是真的吗？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":301}]},{"autoTurnFirst":2.5,"chara":[{"id":110100,"motion":200}]}],"group_31":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_39","textHome":"菲莉希亚的泳姿好狂野啊！@压迫力那么强，@前阵子我还把她误认成鲨鱼了！"}]},{"autoTurnFirst":1.7,"chara":[{"id":110100,"motion":401}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":200}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":200,"pos":1,"voice":"vo_char_1101_00_40","textHome":"我在练习游泳的时候感受到了气息……@回头一看……是莎奈在那里！@说是因为担心我，所以就来了。"}]},{"autoTurnFirst":1.5,"chara":[{"id":110100,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":100}]}],"group_33":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_41","textHome":"和大家到海边一起玩，玩累了就回去睡觉……@这样的一天，什么时候能和忧一起度过的话，@就太好了……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110100,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":110100}]},{"autoTurnFirst":2.0,"chara":[{"id":110100,"motion":100}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_42","textHome":"虽然游泳不行……但我会努力的！"}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":400}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":100,"pos":1,"voice":"vo_char_1101_00_43","textHome":"算是……游到终点了……吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":110100}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":300,"pos":1,"voice":"vo_char_1101_00_44","textHome":"游泳真的没什么办法吗……"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":400,"pos":1,"voice":"vo_char_1101_00_45","textHome":"只能踏踏实实地去练了呢！"}]}],"group_38":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_46","textHome":"这感觉……说不定现在就能游起来了！？"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":110100,"motion":400}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_63","textHome":"首先要放松身心……"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":301,"pos":1,"voice":"vo_char_1101_00_05","textHome":"呼……总算是勉强过关……太好了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110100}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":1,"pos":1,"voice":"vo_char_1101_00_64","textHome":"就像练习时那样找到换气的节奏……"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_65","textHome":"就算不得要领也不要慌张……"}]}],"group_42":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_66","textHome":"嗯！我在想象当中游起来了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":400}]}],"group_43":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_02","textHome":"我叫环彩羽！请……诶，这个是?@你发现啦……对，泳圈……@我实在不会游泳，是个旱鸭子……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":110100,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110100,"motion":301}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":110100,"motion":100}]}],"group_5":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_13","textHome":"难道说……我稍微能游一些了吗！？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":110100,"motion":400}]}],"group_6":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_14","textHome":"这是……能够游10米也不沉下去的感觉！"}]},{"autoTurnFirst":4.7,"chara":[{"id":110100,"motion":200}]}],"group_7":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_15","textHome":"哪怕是一点点也好……要往前游下去！"}]},{"autoTurnFirst":3.0,"chara":[{"id":110100,"motion":400}]}],"group_8":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_16","textHome":"八千代告诉我说@「总是用游泳圈的话永远也学不会游泳」@确实是那样没错！@嗯！但还是没法鼓起勇气！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110100,"motion":401}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100,"motion":300}]}],"group_9":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110100,"motion":0,"pos":1,"voice":"vo_char_1101_00_17","textHome":"虽然鹤乃教过我游泳，@但是「跳进水里然后摆手蹬腿就行了！」@这样的说明还是太难了些……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110100,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"id":110100,"motion":401}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":110100,"motion":200}]}]},"version":3}