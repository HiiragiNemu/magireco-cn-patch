{"story":{"group_1":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_01","textHome":"我的愿望让我得到了操纵时间的魔法。在停止@的时间里，进行投掷炸弹之类的攻击……@啊，虽然这样的攻击也会被队友责怪……@不过，我还有其他重要的目的，@我的魔法也是为此存在的……"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_031.exp.json","id":200300,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":200300,"motion":400}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_18","textHome":"巴学姐的战斗方法非常值得学习。稳重而不失@华丽……感觉和我完全相反……"}]},{"autoTurnFirst":2.0,"chara":[{"id":200300,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":200300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":200300,"motion":0}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_19","textHome":"啊……我好像发生了什么变化……"}]},{"autoTurnFirst":6.0,"chara":[{"id":200300,"motion":100}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_20","textHome":"感觉……我的内心平静了下来……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_21","textHome":"因为心脏病的缘故，我之前一直在住院。@在床上只能终日看着天花板……@那段时间的回忆真是非常辛酸……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_22","textHome":"第一天去见泷原上学真是紧张极了……@但是，鹿目同学向我打了招呼。@现在能学校上学也是多亏了鹿目同学。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200300}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":200300,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"id":200300,"motion":0}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_23","textHome":"由于体弱多病，我一直受到别人的白眼。@我总是给周围人添麻烦，一直觉得很尴尬……@我本以为自己一直都会是这个样子……@但是，鹿目同学改变了这一切。"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_031.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":200300,"motion":100}]}],"group_16":[{"autoTurnFirst":4.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_50_24","textHome":"新年快乐！哇，我，有什么奇怪的地方吗？@我很少……穿着盛装出门……"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":200300}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_25","textHome":"早上好……！@今天我要和鹿目同学她们一起打毽球。@为了不迟到所以早起了，但好像起太早了……"}]},{"autoTurnFirst":7.2,"chara":[{"id":200300,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_040.exp.json","id":200300,"motion":0}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_26","textHome":"年糕、杂煮、年节料理……@我过去一直在医院的病床上过年，@现在真是有些不可思议啊……"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":200300}]},{"autoTurnLast":0.01,"chara":[{"eyeClose":0,"id":200300}]},{"autoTurnFirst":4.0,"chara":[{"id":200300,"motion":100}]}],"group_19":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_27","textHome":"冬天，太阳很早就下山了……@出门在外的时候，要注意保暖，@小心不要感冒了呀。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":200300,"motion":100}]}],"group_2":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":300,"pos":1,"tear":1,"voice":"vo_char_2003_00_03","textHome":"怎么会……突然……怎么可能……@鹿目同学……鹿目同学！……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":200300,"motion":100,"tear":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_031.exp.json","id":200300,"motion":400,"tear":1}]}],"group_20":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_50_28","textHome":"就算又过了一年，睡前也要告诉自己。@绝对不可以忘记……@成为魔法少女时立下的誓言……"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":200300}]},{"autoTurnLast":0.01,"chara":[{"eyeClose":0,"id":200300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0}]}],"group_21":[{"autoTurnFirst":8.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":300,"pos":1,"voice":"vo_char_2003_50_29","textHome":"鹿目同学穿着长袖和服的样子，真美啊……@诶，啊，对不起！沉浸在自己的幻想里了……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":200300,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":200300,"motion":1}]}],"group_22":[{"autoTurnFirst":4.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":200,"pos":1,"voice":"vo_char_2003_50_30","textHome":"新年快乐。嗯……又能见到你真是太好了……@今年我也要努力消灭魔女呢！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":200300,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"id":200300,"motion":100}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_50_31","textHome":"到了新年，就算在「镜之魔女」的结界里，@也能看见很多穿着长袖和服的魔法少女……@啊，当然都是复制品了……"}]},{"autoTurnLast":4.0,"chara":[{"id":200300,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200300}]}],"group_24":[{"autoTurnFirst":8.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_32","textHome":"盛装，有着区别平常和特殊日子的作用。@在大战来临前，会让气氛更加严肃。"}]},{"autoTurnFirst":2.5,"chara":[{"id":200300,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200300}]}],"group_25":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_50_33","textHome":"诶！你说穿和服时应该把眼镜摘下来……！？@不、不行！@要是摘下来的话，就没办法冷静下来了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":200300,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":300}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_34","textHome":"说起来，仔细看的话，鹿目同学拿的毽球板，@是丘比形状的呢。"}]},{"autoTurnFirst":5.0,"chara":[{"id":200300,"motion":100}]}],"group_27":[{"autoTurnFirst":7.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_50_35","textHome":"和朋友穿着盛装来庆祝新年，@是我住院的时候完全没想到的事……@这么宝贵的时间，就让我多享受一会儿吧？"}]},{"autoTurnLast":3.5,"chara":[{"eyeClose":0,"id":200300}]},{"autoTurnFirst":6.0,"chara":[{"id":200300,"motion":100}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":300,"pos":1,"voice":"vo_char_2003_50_36","textHome":"这件和服……还合身吗？@鹿目同学说这件很适合我……@真的很适合吗……？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_040.exp.json","id":200300,"motion":400}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_37","textHome":"鹿目同学有着我没有的活力还有阳光，@她总是给我勇气。和愚钝、软弱、任性的我相比，@真是大不一样……"}]},{"autoTurnLast":3.5,"chara":[{"id":200300,"motion":100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":200300,"motion":300}]}],"group_3":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_04","textHome":"先不管这是谁的算计，总之，我必须要@做点什么才行……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_031.exp.json","id":200300,"motion":100}]}],"group_30":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_50_38","textHome":"佐仓同学，她在新年就和往常一样……@不过，正因为她是这样的人，@所以就算是危机的时候，也能和她冷静交流。"}]},{"autoTurnFirst":8.0,"chara":[{"id":200300,"motion":0}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":1,"pos":1,"voice":"vo_char_2003_50_39","textHome":"因为一直在住院，所以我觉得神社里的小摊子@也很新鲜很有趣。不过也有可能是因为@鹿目同学她们陪在我身边吧。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]},{"autoTurnFirst":6.0,"chara":[{"id":200300,"motion":300}]}],"group_32":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_50_40","textHome":"现在，我好想把和鹿目同学的回忆刻在心里。@为了在时间轮回中，不让自己的心灵迷失……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":200300,"motion":100}]},{"autoTurnLast":5.0,"chara":[{"eyeClose":0,"id":200300}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":200300,"motion":300,"pos":1,"voice":"vo_char_2003_50_41","textHome":"不、不要这样子……！@要说脸揉起来像年糕一样有弹性……@那比起我，还是丘比更适合……！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":200300}]},{"autoTurnFirst":3.0,"chara":[{"id":200300,"motion":400}]}],"group_34":[{"autoTurnFirst":0.7,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_42","textHome":"那么，我上场了！"}]},{"autoTurnFirst":3.3,"chara":[{"id":200300,"motion":200}]}],"group_35":[{"autoTurnFirst":0.7,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_43","textHome":"赢了？太好了……！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":400}]}],"group_36":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_44","textHome":"太好了……结束了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":200300}]}],"group_37":[{"autoTurnFirst":0.7,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_45","textHome":"总算是结束了~"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":200}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_46","textHome":"我战斗得还好吗……？"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":400,"pos":1,"voice":"vo_char_2003_00_63","textHome":"哇啊啊啊！诶咻？咚咚……诶咿！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200300,"motion":200}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200300,"motion":200,"pos":1,"voice":"vo_char_2003_00_05","textHome":"之后再考虑发生了什么吧……@现在我得去鹿目同学的身边才行……"}]},{"autoTurnFirst":3.5,"chara":[{"id":200300,"motion":400}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":400,"pos":1,"voice":"vo_char_2003_00_64","textHome":"呼啊啊！要命中呀——！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200300,"motion":200}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_65","textHome":"此时此刻……我要保护鹿目同学！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200300,"motion":200}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_66","textHome":"我绝对不会输的！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200300,"motion":200}]}],"group_43":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":300,"pos":1,"voice":"vo_char_2003_00_02","textHome":"啊，那个……我叫晓美……焰……@啊……嗯……还请多多关照……"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"id":200300,"motion":200,"pos":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"id":200300,"motion":1,"pos":1}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_13","textHome":"不变得更加强大的话……@就保护不了重要的人对吧……"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200300,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200300,"motion":100,"pos":1,"voice":"vo_char_2003_00_14","textHome":"呼~总算是到了这一步呢……太好了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]},{"autoTurnFirst":3.0,"chara":[{"id":200300,"motion":0}]}],"group_7":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_15","textHome":"那个……这样子就能更熟练地使用魔法了吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_16","textHome":"虽然炸弹的攻击非常强力，但也可能会波及到@同伴。时机之类的，很难把握呢……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200300,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_031.exp.json","id":200300,"motion":300}]}],"group_9":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200300,"motion":0,"pos":1,"voice":"vo_char_2003_00_17","textHome":"选枪的时候，还是挑用起来顺手的比较好。@即使带了很多枪，如果用不好的话就没有意义@了。"}]},{"autoTurnFirst":5.0,"chara":[{"id":200300,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200300,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200300,"motion":400}]}]},"version":3}