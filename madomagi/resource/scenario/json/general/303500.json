{"story":{"group_1":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_01","textHome":"我是街上的便当店“千秋屋”家的看板娘，@千秋理子！喜欢的事是算术和打饭！@爸爸妈妈还有老师都经常夸我是个乖孩子！@店里的推荐菜是炸鸡块和健康沙拉便当！@务必要来试吃一下哦！"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":3.9,"chara":[{"id":303500,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"id":303500,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]}],"group_10":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_17","textHome":"在便当店会很辛苦哦。@所以在我给店里帮忙的时候，@也就是一家团聚的时间。@一家人齐心协力哦！"}]},{"autoTurnFirst":1.7,"chara":[{"id":303500,"motion":100}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_11":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_18","textHome":"晚上便当屋需要收拾，陪我在家的人是爸爸！@虽然有些害羞……@现在我们偶尔还会一起（悄悄话）……@这是秘密啦！"}]},{"autoTurnFirst":3.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303500,"motion":300}]},{"autoTurnFirst":2.4,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303500,"motion":400}]}],"group_12":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_19","textHome":"我的彩色叉签能把问题全都解决得更漂亮了！"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]}],"group_13":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_20","textHome":"转一个圈～啪！看，我是不是变了些呢!?"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":303500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]}],"group_14":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_21","textHome":"我想我也一定能和妈妈一样继承好千秋屋。@所以，我必须要成为一个坚强的女孩子！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500}]},{"autoTurnFirst":3.0,"chara":[{"id":303500,"motion":400}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_22","textHome":"一直照顾着我的是领居家姐姐。@我的梦想就是成为@和姐姐一样温柔，笑起来很美的人，@下次就由我来照顾大姐姐的宝宝吧。@我现在已经可以做到了吧？"}]},{"autoTurnFirst":3.0,"chara":[{"id":303500,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":303500,"motion":100}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_16":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_23","textHome":"在我看来，能够独当一面的女人就是我妈妈。@健康又强大，而且又很有人气。@还有一位就是邻居家的姐姐。@温柔又时常微笑，是我最喜欢的人。@她们培养长大的我，也会变成厉害的姐姐哦！"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_17":[{"autoTurnFirst":1.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_24","textHome":"诶？啊，又见面了呢！@啊，没有，我没在哭啦。@我是个坚强的女孩子，@我才不会觉得孤零零呢！"}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303500,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]}],"group_18":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_25","textHome":"早上还是这个最棒了！@出门前的便当！@是千秋屋精心制作出来的，可不能留剩饭哦。"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":200}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_26","textHome":"提起打饭，那就是我出场的时候了！@只不过，我总是给大家盛太多，@有时会惹老师生气……"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":303500,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":303500,"motion":100}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200,"pos":1,"voice":"vo_char_3035_00_02","textHome":"初次见面！我叫千秋理子！@我的优点就是充满活力又听话懂事！@我会尽力加油的，所以今后也请多指教！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_20":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":400,"pos":1,"voice":"vo_char_3035_00_27","textHome":"现在好忙！从傍晚开始，@不论是晚上才干完活回家的爸爸，@还是买东西的妈妈，大家都热热闹闹，@豆吉也汪汪叫个不停！"}]},{"autoTurnFirst":5.8,"chara":[{"id":303500,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_060.exp.json","id":303500,"motion":200}]}],"group_21":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":300,"pos":1,"voice":"vo_char_3035_00_28","textHome":"晚上虽然有些孤单，@但爸爸和妈妈都在努力工作所以也没办法吧。@而且豆吉也会在我旁边安慰我，@所以不要紧的。"}]},{"autoTurnFirst":5.3,"chara":[{"id":303500,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_22":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_29","textHome":"我刚刚在和朋友们玩耍。@虽然我很忙，但我也有很多朋友。@今天我也借了漫画回来哦。"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_23":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":400,"pos":1,"voice":"vo_char_3035_00_30","textHome":"哇，刚刚是魔女的反应吧！？@要是有魔女，大家就会有危险了！@我要赶在给店里帮忙之前解决掉它！"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":303500,"motion":200}]}],"group_24":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_31","textHome":"那个，和魔法少女战斗真的没问题吗？@诶？啊，是大家的冒牌货啊！@那样的话，我就完全放心了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_25":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":300,"pos":1,"voice":"vo_char_3035_00_32","textHome":"我，不太喜欢和人吵架……@但是这里不得不战斗对吧？@嗯……那个……但是……但是……"}]},{"autoTurnFirst":5.8,"chara":[{"id":303500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":303500}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":303500}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":300}]}],"group_26":[{"autoTurnFirst":3.1,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_33","textHome":"嗯～啊呜啊呜啊呜……@看吧，就算是香、香菇，@只要捏住鼻子就没问题了……@因为我是饭店家的看板娘，@所以不可以挑食！"}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":400}]},{"autoTurnFirst":1.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":303500}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":303500,"motion":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":303500}]},{"autoTurnFirst":2.9,"chara":[{"id":303500,"motion":400}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_34","textHome":"就这样，啪！像这样，啪！@这就是把便当装袋的手法。@把手放进去啪的一下撑开来，@这就是技巧啦！"}]},{"autoTurnFirst":1.8,"chara":[{"id":303500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":100}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_35","textHome":"隔壁的五金店，过去住着我最喜欢的大姐姐，@不过她现在已经不在了。@她搬到了很远的地方，@我很少有机会再见到她了。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":303500}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":4.2,"chara":[{"id":303500,"motion":300}]}],"group_29":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":300,"pos":1,"voice":"vo_char_3035_00_36","textHome":"嗯……算术方面我很擅长分数的计算，@不过语文方面我就不擅长了……@这个，你能教我怎么读吗？"}]},{"autoTurnFirst":2.3,"chara":[{"eyeClose":1,"id":303500}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":303500}]},{"autoTurnFirst":2.9,"chara":[{"id":303500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":303500,"motion":100}]}],"group_3":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":300,"pos":1,"voice":"vo_char_3035_00_03","textHome":"因为这是我许下的愿望……@我绝对不可以哭！"}]},{"autoTurnFirst":2.3,"chara":[{"eyeClose":1,"id":303500}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":303500,"motion":200}]}],"group_30":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_37","textHome":"哼哼，这个三角巾是我的宝物！@是隔壁的大姐姐送我的礼物，@我在店里帮忙的时候，就一直带着它哦！"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_31":[{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":400,"pos":1,"voice":"vo_char_3035_00_38","textHome":"啊，竹工房的姐姐是千秋屋的常客哦。@有时，她会来这里买些家常菜。@似乎她还有个双胞胎姐姐，真是令人羡慕啊。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"id":303500,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_32":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_39","textHome":"原来如此啊～拿食物来举例的话……@麻友姐姐就是软绵绵的“棉花糖”！@莉爱姐姐就是……@噼里啪啦的“爆米花”对吧？"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"id":303500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_33":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_40","textHome":"爱香姐姐帅气又威风，@料理也很拿手，还是一位大厨，@是一位非常非常值得尊敬又帅气的人！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_34":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_41","textHome":"这间千秋屋，听说就是爸爸和妈妈邂逅之处。@说不定我的王子，也会是来这里某位客人呢，@诶嘿嘿。"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_35":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_42","textHome":"装袋和退治魔女，都交给我来吧！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200}]}],"group_36":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_43","textHome":"我也是会成长的哦！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_37":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200,"pos":1,"voice":"vo_char_3035_00_44","textHome":"对待客人和退治魔女，笑容都是第一位的！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_38":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":200,"pos":1,"voice":"vo_char_3035_00_45","textHome":"怎么样！？我有没有一点儿姐姐的样子！？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_46","textHome":"千秋屋的看板娘才不会轻易就骄傲呢！"}]},{"autoTurnFirst":2.5,"chara":[{"id":303500,"motion":400}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_04","textHome":"明明不可以哭的……@明明不可以……为什么……@我真是的！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"eyeClose":1,"id":303500,"motion":300,"tear":1}]},{"autoTurnFirst":1.8,"chara":[{"cheek":2,"eyeClose":0,"id":303500,"motion":0,"tear":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_060.exp.json","id":303500,"motion":200,"tear":1}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":100,"pos":1,"voice":"vo_char_3035_00_63","textHome":"一会儿就做好了哦！"}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":400,"pos":1,"voice":"vo_char_3035_00_64","textHome":"缤纷多彩"}]}],"group_42":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303500,"motion":200,"pos":1,"voice":"vo_char_3035_00_65","textHome":"砰砰砰砰砰！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500}]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100,"pos":1,"voice":"vo_char_3035_00_66","textHome":"漂亮地做完啦！"}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_05","textHome":"下次，我一定会成为值得骄傲的姐姐！！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_6":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_13","textHome":"袋子里还没有装满哦。@我各方各面都还会成长！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_7":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":1,"pos":1,"voice":"vo_char_3035_00_14","textHome":"我做得这么出色，@说不定妈妈还会教我采购呢！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500}]}],"group_8":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_15","textHome":"带上便当去公园说会儿话吧。@豆吉也一起来吧汪。"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":200}]}],"group_9":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303500,"motion":0,"pos":1,"voice":"vo_char_3035_00_16","textHome":"便当店家的早晨是非常早的！@醒来的时候，就只能看见妈妈在身边了。@爸爸他早上五点就已经出门采购了！"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303500,"motion":1}]}]},"version":3}