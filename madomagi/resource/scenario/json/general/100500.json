{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_01","textHome":"我的双亲被魔女所杀，街坊们都以为是失踪了@可那是一份虚假的记忆，@是由我缔结契约时所许下的「愿望」形成的。@但是！我会永远记住真实的记忆！@之后我就边当佣兵边杀魔女，今后也会如此！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":300}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_18","textHome":"话说啊，要是想和我干架就尽管来！@看我一个个给你们揍趴下，@让你们晓得啥是超强佣兵！"}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":1.7,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_19","textHome":"哦哦——这感觉！@……毫无疑问是有突破了！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_20","textHome":"嗯，心情不错！还能往上走~！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_21","textHome":"要说让人开心的时候，@那就是没有麻烦的时候。@烦心事儿一概没有！可以随心所欲的时候！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_14":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_22","textHome":"做饭、扫除……这不就是家务活？超麻烦啊！@我完全不爱做这些，会做也不爱做。@啊——不管了不管了！@垃圾再多忍忍就完事了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":400}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_23","textHome":"我想象中最赞的生活嘛，首先是饭来张口，@然后想去哪都有人接送。@总之就是自己什么也不用做！就是这样！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_24","textHome":"好嘞！我等着呢。这边啥都准备好了！@都快坐不住了！走吧，出去逮魔女吧！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_17":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_25","textHome":"……嗯啊？哈……天亮了啊……@我知道了啦，现在就起……@一二……嗯~不行了……再睡一小会……"}]},{"autoTurnFirst":4.5,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"id":100500,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"id":100500,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":300}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_26","textHome":"午饭前想把肚子放空些~@啊，要不你来跟我练练？@没关系没关系！我会手下留情的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_19":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_27","textHome":"依我的经验，@这阵子的魔女都喜欢偷偷摸摸的活动。@到处都找不到啊。要不去那边看看吧——"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":1}]}],"group_2":[{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_03","textHome":"七香那家伙！@从初次见面的时候就觉得与她合不来！"}]},{"autoTurnFirst":4.3,"chara":[{"id":100500,"motion":200}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_28","textHome":"见魔女就打，没魔女就睡！@要问为啥，因为睡觉最舒服啊。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_29","textHome":"佣兵24小时待命！见到魔女随时都可以打！@放马过来吧！"}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":100500,"motion":200}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_30","textHome":"把魔女一个个地打倒！那就是我的工作！@自从做了佣兵，遇到魔女的概率就变高了，@简直就是我的天职嘛。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_23":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_31","textHome":"等好久了！轮到我出动了吧！@嘿嘿，刚才就手痒难耐了。赶紧开始吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_32","textHome":"嗯？不可以一个人吗？@跟人一起啰啰嗦嗦的很麻烦啊……@啊，有了！我一个人全部打倒不就好了！"}]},{"autoTurnFirst":2.7,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}],"group_25":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_33","textHome":"我可喜欢动物了。所以在学校当了饲育委员。@虽然养了兔子啥的……可是一点都不听话！@为啥!?"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]}],"group_26":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_34","textHome":"战斗这种事，犹豫就会败北。@见到敌人也别整什么深思熟虑直接先揍一顿。@而且，有多快整多快。"}]},{"autoTurnFirst":1.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":0}]}],"group_27":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_35","textHome":"这世上烦人的事可太多了，做什么都能撞上。@啊——真是，全都不想管了！"}]},{"autoTurnFirst":3.2,"chara":[{"id":100500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_36","textHome":"最喜欢摸鱼了！要是可以想一直摸下去，@但是逮魔女除外。唯独这件事我是认真的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":200}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_37","textHome":"佣兵这个职业，好像是在漫画上看到的。@就是，想起来的时候就觉得@「来了来了就是它！」这样的感觉。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":400}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_04","textHome":"可恶！被人给骗了！@这不是只有我一个人去战斗了吗！"}]},{"autoTurnFirst":5.0,"chara":[{"id":100500,"motion":300}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_38","textHome":"常盘七香！那个讨厌的家伙！@……但是，确实很强。@就这一点特别让人上头！"}]},{"autoTurnFirst":2.5,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"id":100500,"motion":100}]}],"group_31":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_39","textHome":"那个明日香啊，基本上是个冒失鬼，@但偶尔也能靠得住。@嘛，只是偶尔啦。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":0}]}],"group_32":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_40","textHome":"还是不拘小节地全力战斗最舒服！@最适合我了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]},{"autoTurnFirst":2.0,"chara":[{"id":100500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_33":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_41","textHome":"虽然时不时地会想起爸爸妈妈，@但心里也明白，我已经没有家人了……"}]},{"autoTurnFirst":6.0,"chara":[{"id":100500,"motion":300}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_42","textHome":"哦哟！赶紧战斗吧！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500}]}],"group_35":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_43","textHome":"耶——！是咱赢了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_36":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_44","textHome":"哈！那就给我认输吧！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_45","textHome":"这个结果是当然啦！"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200,"pos":1,"voice":"vo_char_1005_00_46","textHome":"想不到能怎么输！"}]}],"group_39":[{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_63","textHome":"好嘞！就用它了！"}]},{"autoTurnFirst":3.5,"chara":[{"id":100500,"motion":200}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_05","textHome":"我要把魔女通通收拾掉……绝对不会输的！"}]},{"autoTurnFirst":4.0,"chara":[{"id":100500,"motion":200}]}],"group_40":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_64","textHome":"很好！再吃我这招！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_41":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_65","textHome":"看好，用这个把它打得说不出话！"}]},{"autoTurnFirst":4.3,"chara":[{"id":100500,"motion":200}]}],"group_42":[{"autoTurnFirst":0.7,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_66","textHome":"大招！给你打得稀里哗啦！"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_43":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_02","textHome":"听说有人找我！要说到狩猎魔女，@当然是我深月菲莉希亚的事了！@那就赶紧的干活去吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0}]}],"group_5":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_13","textHome":"好！心情特别爽！干啥都杠杠的！"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":200}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_14","textHome":"哦，感觉好像特别顺手？这不是挺好的嘛！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100,"pos":1,"voice":"vo_char_1005_00_15","textHome":"嘿嘿！总觉得变强了。但还可以继续哦！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":0,"pos":1,"voice":"vo_char_1005_00_16","textHome":"虽然成为魔法少女的时日不长，@可我已经身经百战了。基本每天都有战斗。@比起那边的家伙我可以是要更强！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100500,"motion":100}]}],"group_9":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100500,"motion":1,"pos":1,"voice":"vo_char_1005_00_17","textHome":"说起来，听闻有个到处找人决斗的魔法少女，@怎么不来找我啊！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100500,"motion":100}]}]},"version":2}