{"story":{"group_1":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":0,"pos":1,"voice":"vo_char_3002_00_01","textHome":"我是空穗夏希！啦啦队部和棒球部的部员！@当然了，我并不是棒球部的选手，而是经理。@我和棒球部的大家从小学起就认识了……@和最喜欢的大家打成一片，最幸福了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":5.0,"chara":[{"id":300200,"motion":100}]}],"group_10":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":200,"pos":1,"voice":"vo_char_3002_00_18","textHome":"我能抬头挺胸说出来了。@我靠着自己的努力……才来到了这里。@靠自己努力取胜，真的特别开心！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":300200,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_11":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":200,"pos":1,"voice":"vo_char_3002_00_19","textHome":"GO FOR IT！我还能变得更强！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":0,"pos":1,"voice":"vo_char_3002_00_20","textHome":"试着踏出一步……@说不定就能遇见新的幸福了。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200,"motion":100}]}],"group_13":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":100,"pos":1,"voice":"vo_char_3002_00_21","textHome":"Let's Go！夏希！想快点试试@自己变强了多少呢！遇到不利的战斗@也不会胆怯！我会挺起胸膛上场！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_14":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":100,"pos":1,"voice":"vo_char_3002_00_22","textHome":"WE CAN DO IT！@就算是魔法少女的战斗，加油声也有着巨大的@能量，和棒球比赛不是一样嘛？所以，作为@魔法少女的时候，我也会全力为大家加油的！"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp.json","id":300200,"motion":3}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":1,"pos":1,"voice":"vo_char_3002_00_23","textHome":"YES！VICTORY！！@感受到满满的能量了吗？如果魔法少女也有@世界大赛的话，我一定会赢的！我可不是只会@加油的魔法少女，也能作为选手大显身手！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"id":300200,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200,"motion":100}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":1,"pos":1,"voice":"vo_char_3002_00_24","textHome":"你好！等得我好累啊。嘛……等你的这段时间@我做了下发声练习，也不错也不错。"}]},{"autoTurnFirst":4.0,"chara":[{"id":300200,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":300200,"motion":1,"pos":1,"voice":"vo_char_3002_00_25","textHome":"早上好！好啦好啦，今天也要打起精神加油！@没有干劲？那样的话，我来给你应援吧！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300200,"motion":200,"pos":1,"voice":"vo_char_3002_00_26","textHome":"好好吃午饭了吗？要吃有营养的食物才行！@漂亮的投球要从吃饭开始！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_19":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":100,"pos":1,"voice":"vo_char_3002_00_27","textHome":"我也很喜欢看职业棒球赛哦？夜间比赛@真是让人兴奋呢！下次一起去看棒球吧！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":100}]}],"group_2":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":0,"pos":1,"voice":"vo_char_3002_00_03","textHome":"因为梦想已经实现了。所以我不会后悔哦？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]}],"group_20":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":200,"pos":1,"voice":"vo_char_3002_00_28","textHome":"今天的训练到此结束！那～快点睡觉吧！@要是熬得太晚，会影响明天哦？"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":3.0,"chara":[{"id":300200,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":300200,"motion":100,"pos":1,"voice":"vo_char_3002_00_29","textHome":"最近大家有了新的队服。所以呢，@我也试着配合队服，改变一下应援方式吧？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":300200}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300200,"motion":1,"pos":1,"voice":"vo_char_3002_00_30","textHome":"差不多该到训练时间了吧？@偷懒一天可是要用三天补回来的！@今天也要好好努力才行！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":300200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300200,"motion":1}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":300200,"motion":300,"pos":1,"voice":"vo_char_3002_00_31","textHome":"在比赛中留下遗憾，是最糟糕的事了。@棒球是这样……魔法少女的战斗也是吧？@不管什么比赛都只有一次。全力以赴吧！"}]},{