{"story":{"group_1":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_01","textHome":"天乃铃音……没有什么好说的。@我的目的你还是别知道为好。@那样的话……一定会比较幸福。@简而言之，我只是做着我认为正确的事情。@仅此而已。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":100}]}],"group_10":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_18","textHome":"自从椿成为魔女的那一天开始，@我就再也没有覆盖过魔法。@现在的我，保存的就是椿的魔法。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":300}]}],"group_11":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_19","textHome":"谢谢，我变强了。@这也是令人高兴的事呢。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403100}]}],"group_12":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":300,"pos":1,"voice":"vo_char_4031_00_20","textHome":"护身符上的名字，@又多了一个呢。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":403100}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":0,"pos":1,"voice":"vo_char_4031_00_21","textHome":"和双亲一起迷失在结界中时，@那个不知所措的我，@如今已经是如此善战了。@我还能变得更强。"}]},{"autoTurnFirst":3.4,"chara":[{"id":403100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":400,"pos":1,"voice":"vo_char_4031_00_22","textHome":"好强的力量……我已经不会输了。@有了这份力量，那一天的誓言……@破坏魔法少女这种系统的誓言就能实现了……@无论和谁战斗我都不会再输了。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100}]},{"autoTurnFirst":4.0,"chara":[{"id":403100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":403100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":403100}]},{"autoTurnFirst":5.2,"chara":[{"id":403100,"motion":200}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_23","textHome":"我的父母被魔女所杀……@是身为魔法少女的椿领走了我。@我憧憬着温柔又强大的她，@也成为了魔法少女……@现在的我，感觉又向她靠近了一些。"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100}]},{"autoTurnFirst":6.2,"chara":[{"id":403100,"motion":100}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":403100}]}],"group_16":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_24","textHome":"你来啦。你在惊讶什么？@无声无息？嗯嗯，我很擅长隐藏自己的气息。@似乎就连孵化者都察觉不到。"}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100}]}],"group_17":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_25","textHome":"早上好。刚起床吗？@诶，我？我很早之前就起了。@因为小时候就养成了习惯，@每天都会很早起来。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":0}]},{"autoTurnFirst":8.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_26","textHome":"白天……嗯，留我一个人就可以了。@我一直都是一个人吃饭的。@因为那样能让我更加安心……"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100}]},{"autoTurnFirst":3.3,"chara":[{"id":403100,"motion":100}]}],"group_19":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_27","textHome":"看着牵着手回家的母女或是姐妹，@我就想起了过去的事。@以前，我也经常被牵着手回家。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100}]}],"group_2":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_03","textHome":"我、没有做错吧……椿……"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":403100}]}],"group_20":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_28","textHome":"我差不多这时候该出门了，你就好好去睡吧。@去哪里？有点小事，不用在意。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"id":403100,"motion":200}]}],"group_21":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_29","textHome":"闲下来了，我想在神滨市到处走走。@说不定就会有些有用的情报。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":200}]}],"group_22":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_30","textHome":"消灭魔女和消灭魔法少女本质上是一样的……@无论哪种本来都是……算了，没什么。@走吧，去打倒魔女。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":403100,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":403100}]},{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":1}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":0,"pos":1,"voice":"vo_char_4031_00_31","textHome":"我已经习惯了和魔法少女战斗。@一下子就能给予解脱哦。@不会有痛苦，不会有难过……@只需要一瞬间，呐。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":100}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_32","textHome":"这里聚集了好多魔法少女呢……@这样啊……别担心，我不会在这做什么的。"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":403100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":403100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":0,"pos":1,"voice":"vo_char_4031_00_33","textHome":"突然听到铃响，然后被询问了姓名。@一旦回答她，就会被利刃撕裂的，开膛手……@似乎成为了这样的传闻呢。"}]},{"autoTurnFirst":5.0,"chara":[{"id":403100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200}]}],"group_26":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_34","textHome":"接下来我打算到住到报社里去，@每天配送早报……@不，我不觉得辛苦。@总之，我得尽快胜任这份工作。"}]},{"autoTurnFirst":3.0,"chara":[{"id":403100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":403100,"motion":200}]}],"group_27":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_35","textHome":"想看报纸？@我已经看完了，你想看的话就拿去吧。@并不想看吗？难道说，现在纸质报纸很少见？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":403100}]},{"autoTurnFirst":5.7,"chara":[{"id":403100,"motion":1}]}],"group_28":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_36","textHome":"好奇心会害死猫……@世上的事还是别知晓那么多为好。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":403100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":403100,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"id":403100,"motion":200}]}],"group_29":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_37","textHome":"孵化者把感情看作是无用而不合理的东西，@但如果抛弃掉感情，@我们就再也不是我们自己了。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100}]},{"autoTurnFirst":4.5,"chara":[{"id":403100,"motion":100}]}],"group_3":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_04","textHome":"没你的事，@别来妨碍我！"}]}],"group_30":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_38","textHome":"和谁成为同班同学都没有区别。@我也没打算和谁成为朋友。@至今为止我一直都是这么做的……"}]},{"autoTurnFirst":4.8,"chara":[{"id":403100,"motion":300}]}],"group_31":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_39","textHome":"要说算得上宝物的东西……的话。@那就是我系在头发上带有铃铛的护身符吧。@因为这是重要的人留下的东西。"}]},{"autoTurnFirst":5.3,"chara":[{"id":403100,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100}]}],"group_32":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_40","textHome":"只要能阻止魔法少女这一系统……@只要能减少被牵连的人，@就算成为恶人也没问题。@就算是被叫做杀人犯我也不在乎。"}]},{"autoTurnFirst":2.3,"chara":[{"eyeClose":1,"id":403100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":403100}]},{"autoTurnFirst":2.2,"chara":[{"id":403100}]},{"autoTurnFirst":4.0,"chara":[{"id":403100,"motion":400}]}],"group_33":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_41","textHome":"请问，这是你丢掉的东西吧？@不用道谢。没有遗失掉就是最好的了。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":403100,"motion":100}]}],"group_34":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_42","textHome":"告诉我……你的名字？"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_43","textHome":"永别了。"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":0,"pos":1,"voice":"vo_char_4031_00_44","textHome":"我在做我认为正确的事情。"}]}],"group_37":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_45","textHome":"不管多少次都是一样。"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_46","textHome":"你是赢不了我的。"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_63","textHome":"椿……"}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":300,"pos":1,"voice":"vo_char_4031_00_05","textHome":"这座城市@也还在重复着那个循环呢……"}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":400,"pos":1,"voice":"vo_char_4031_00_64","textHome":"把力量借给我吧。"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_65","textHome":"请看着我。"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_66","textHome":"我是不会输的！"}]}],"group_43":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_02","textHome":"还没有自我介绍吧。我是天乃铃音。@和你一样，是一位魔法少女。@你的名字，能告诉我吗？"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"id":403100,"motion":100}]}],"group_5":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_13","textHome":"我似乎，变强了呢……"}]}],"group_6":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":403100,"motion":1,"pos":1,"voice":"vo_char_4031_00_14","textHome":"我一定会用这份力量，@破除所谓魔法少女的架构。"}]},{"autoTurnFirst":2.5,"chara":[{"id":403100,"motion":400}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":403100,"motion":100,"pos":1,"voice":"vo_char_4031_00_15","textHome":"你想知道我的事情？@我觉得你还是别知道为好。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":403100}]}],"group_8":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":200,"pos":1,"voice":"vo_char_4031_00_16","textHome":"我的魔法可以吸收被打倒的魔女的力量。@只不过我能保存的魔法就只能有一种而已。@如果吸收了新的魔法，@就无法使用之前的魔法了。"}]},{"autoTurnFirst":9.5,"chara":[{"id":403100,"motion":1}]}],"group_9":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":403100,"motion":300,"pos":1,"voice":"vo_char_4031_00_17","textHome":"过去，每次覆盖上新魔法的时候，@我都会很期待能获得什么样的力量。@因为那时，我还不知道魔法少女的真相。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":403100,"motion":100}]}]},"version":3}