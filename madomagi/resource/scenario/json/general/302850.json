_030.exp.json","id":302850,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":302850,"motion":100}]}],"group_32":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302850,"motion":100,"pos":1,"voice":"vo_char_3028_50_40"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":302850}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302850,"motion":1}]}],"group_33":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302850,"motion":1,"pos":1,"voice":"vo_char_3028_50_41"}]},{"autoTurnFirst":6.3,"chara":[{"id":302850,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302850,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":302850,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302850,"motion":200}]}],"group_34":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":0,"pos":1,"voice":"vo_char_3028_00_42","textHome":"嘿嘿~！我会把它们收拾干净的！"}]},{"autoTurnFirst":2.0,"chara":[{"id":302800,"motion":100}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":200,"pos":1,"voice":"vo_char_3028_00_43","textHome":"太好了太好了！我做的怎么样~！"}]}],"group_36":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_44","textHome":"呼，干净利落，对吧！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800}]}],"group_37":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_45","textHome":"早就说啦！……我是最强的！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_46","textHome":"轻松拿下了呢！"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_63","textHome":"好的！粗野的招式，要来喽！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":200}]}],"group_4":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":1,"pos":1,"voice":"vo_char_3028_00_05","textHome":"没办法，只好承认了！神滨也有高手在啊！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]}],"group_40":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":1,"pos":1,"voice":"vo_char_3028_00_64","textHome":"我就放手去做，把这家伙解决吧！"}]},{"autoTurnFirst":3.0,"chara":[{"id":302800,"motion":100}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302800,"motion":0,"pos":1,"voice":"vo_char_3028_00_65","textHome":"我的气势，已经攒得满满的了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]}],"group_42":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":302800,"motion":0,"pos":1,"voice":"vo_char_3028_00_66","textHome":"我不会手下留情的……说起来，@根本不能手下留情啊！"}]},{"autoTurnFirst":3.0,"chara":[{"id":302800,"motion":100}]}],"group_43":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_02","textHome":"你——好！我叫三栗菖蒲！请多指教@请多指教！……嗯，该说什么好呢？……嗯——@总而言之，打起精神来吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302800,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":0}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302800,"motion":100,"pos":1,"voice":"vo_char_3028_00_13","textHome":"噢嚯——！力量感觉一下子聚集起来了！"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302800,"motion":200}]}],"group_6":[{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":302800,"motion":200,"pos":1,"voice":"vo_char_3028_00_14","textHome":"很好很好——！太好了！这不是相当不错嘛！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]}],"group_7":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302800,"motion":0,"pos":1,"voice":"vo_char_3028_00_15","textHome":"噢——噢——，我找到了！下次就按照@这样的感觉来吧!?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]}],"group_8":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":0,"pos":1,"voice":"vo_char_3028_00_16","textHome":"在学校的课程里，我最喜欢的就是体育课和@手工课了！我特别喜欢的就是雕刻木头！@一开始我雕了一只兔子，不过做得很烂啦~"}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":1}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":1,"pos":1,"voice":"vo_char_3028_00_17","textHome":"这是我木雕的得意作品，叼着鱼的熊！快看，@这条鱼，你觉得是鲑鱼吧？实际上@是鲭鱼哦~！跟河与海没有关系啦！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":302800,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":302800}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":302800}]},{"autoTurnFirst":3.3,"chara":[{"