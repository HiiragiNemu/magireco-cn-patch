":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_31","textHome":"来场模拟战怎么样？我想要看看最近练习的成@果，要是能陪我来一场的话我会很开心的♪"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405100,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4051_00_32","textHome":"大会正在举行中啊！好像有很多人都参加了，@我们也想要参加♪当然我也会努力的！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":200}]}],"group_26":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4051_00_33","textHome":"方便的话一起聊会儿天吧。我想要和你相处得@更好。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100}]}],"group_27":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_34","textHome":"我的魔法是米德切尔达式。在时空管理局这一@术式很受欢迎……不过在这里我见到了各种@不同的魔法，真是让人吃惊。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405100,"motion":100}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_4051_00_35","textHome":"我的防护服以装甲厚度而出名！微小的攻击根@本无法伤到我，慢慢地就依赖上它了。"}]},{"autoTurnFirst":2.5,"chara":[{"id":405100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100}]}],"group_29":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_36","textHome":"时空管理局，是处理平行次元……还有将遥远@宇宙卷入危险之中的事件的警察组织。我差@不多算是负责帮忙的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":300}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_03","textHome":"为了保护重要的东西……我们的魔法，一定是@为了这个目的！"}]},{"autoTurnFirst":4.0,"chara":[{"id":405100,"motion":100}]}],"group_30":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_37","textHome":"菲特和疾风都是我重要的朋友。虽然只认识了@两年……不过我们之间却很了解。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405100,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4051_00_38","textHome":"我和旭日之心的相遇也是我和魔法的相遇……@从那之后，它一直都是我的老师、我的搭档@。我总是依赖着它。"}]},{"autoTurnFirst":4.0,"chara":[{"id":405100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]}],"group_32":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":405100,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4051_00_39","textHome":"我只要更加努力……就能拯救更多的性命。为@了不让悲伤的故事以悲伤结束，我就必须变@得更强。"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":405100}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":405100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":405100,"motion":200}]}],"group_33":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_40","textHome":"我要变强。虽然这个目标至今也没有改变，但@是我也不想给周围的人带来悲伤。能帮我想@想应该怎么做才好吗。"}]},{"autoTurnFirst":7.5,"chara":[{"c