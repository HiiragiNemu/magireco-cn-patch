{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_01","textHome":"我叫高町奈叶。我小学三年级的时候，在某个@事件的契机下，我认识了魔法。我的搭档「@旭日之心」是拥有智能的法杖。我们会一起@努力，所以战斗方面就交给我们吧！"}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":405100,"motion":300}]},{"autoTurnFirst":5.7,"chara":[{"eyeClose":0,"id":405100,"motion":1}]},{"autoTurnFirst":1.5,"chara":[{"id":405100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_17","textHome":"学习各种魔法和新的战术真是很有趣呢！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]}],"group_11":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_18","textHome":"这还远远不够，我要变得更强……！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405100,"lipSynch":1,"motion":100,"pos":1,"voice":"vo_char_4051_00_19","textHome":"这样，我就能更加努力了!!-是的。"}]},{"autoTurnFirst":1.5,"chara":[{"id":405100,"lipSynch":0}]}],"group_13":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_20","textHome":"为了想守护的东西，为了想帮助的人。我要变@得更强！"}]},{"autoTurnFirst":3.5,"chara":[{"id":405100,"motion":200}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4051_00_21","textHome":"那一天，我从重要的朋友那里得到了旭日之心@还有魔法的力量。为了救助他人于危难，就@要不断磨练自己……"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":405100}]},{"autoTurnFirst":2.0,"chara":[{"id":405100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":405100,"motion":100}]}],"group_15":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_22","textHome":"我会变强的。不管有什么困难……因为我明白@，如果放弃了之后一定会后悔的。所以我决@定了。无论什么时候，我都会直面危险…只@要是我的魔法能触及到的范围，我就会全力@守护。"}]},{"autoTurnFirst":6.0,"chara":[{"id":405100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":405100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":405100,"motion":100}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_23","textHome":"我已经下定决心不会放弃战斗。我发誓要每天@都比昨天更强大。为了对我欢笑的朋友们，@为了我最喜欢的大家……我绝不会气馁！"}]},{"autoTurnFirst":4.0,"chara":[{"id":405100,"motion":300}]},{"autoTurnFirst":5.6,"chara":[{"eyeClose":1,"id":405100}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":405100}]},{"autoTurnFirst":3.0,"chara":[{"id":405100,"motion":100}]}],"group_17":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_24","textHome":"今天也拜托你了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":405100,"motion":100}]}],"group_18":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":405100,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4051_00_25","textHome":"呼啊，早上好。昨天熬了会儿夜……好，努力@起——床。"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":405100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":405100,"motion":100}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":405100,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4051_00_26","textHome":"午餐时间到♪今天午饭吃什么好呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":405100,"motion":1}]}],"group