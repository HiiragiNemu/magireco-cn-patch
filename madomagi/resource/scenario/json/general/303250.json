motion":0,"pos":1,"voice":"vo_char_3032_00_46","textHome":"诶嘿嘿，好开心。"}]},{"autoTurnFirst":3.2,"chara":[{"id":303200,"motion":100}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":303200,"motion":100,"pos":1,"voice":"vo_char_3032_00_63","textHome":"既然被拜托了，我就要做到底！"}]},{"autoTurnFirst":4.5,"chara":[{"id":303200,"motion":200}]}],"group_4":[{"autoTurnFirst":1.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_05","textHome":"我喜欢可靠的人。"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":2,"face":"mtn_ex_011.exp3.json","id":303200,"motion":100}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_64","textHome":"嗯……这边这样……然后那样……"}]}],"group_41":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_65","textHome":"死心吧！到此为止了！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":303200,"motion":200}]}],"group_42":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":303200,"motion":100,"pos":1,"voice":"vo_char_3032_00_66","textHome":"已经了结了！对吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":303200}]}],"group_43":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_02","textHome":"我叫梢麻友。那个，我……虽然有点怕生，@但我并不喜欢自己一个人待着……@我喜欢和别人待在一起。"}]},{"autoTurnFirst":7.4,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":303200,"motion":100}]},{"autoTurnFirst":6.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":303200,"motion":1}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":303200,"motion":1,"pos":1,"voice":"vo_char_3032_00_13","textHome":"嗯……我，变强了吗？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":303200,"motion":100}]}],"group_6":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":200,"pos":1,"voice":"vo_char_3032_00_14","textHome":"我感觉变强了。这样我就能更加努力了。"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":303200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":303200,"motion":100}]}],"group_7":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_15","textHome":"嗯，我们去下个展区吧。"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":303200,"motion":100}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":1,"pos":1,"voice":"vo_char_3032_00_16","textHome":"我的父亲，在我很小的时候就因事故去世了。@现在是我和我的母亲相依为命。"}]},{"autoTurnFirst":6.5,"chara":[{"id":303200,"motion":100}]}],"group_9":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":303200,"motion":0,"pos":1,"voice":"vo_char_3032_00_17","textHome":"有时，我会幻想我的父亲还活着。@好想和他聊聊各种关于美术的话题啊。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":303200,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":0,"id":303200,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":303200,"motion":100}]}]},"version":3}