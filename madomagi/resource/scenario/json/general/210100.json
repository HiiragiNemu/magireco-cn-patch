{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_01","textHome":"我是鹿目圆。虽然之前是普通的初中生，@但现在是承受魔法少女们因果的存在。@我不后悔哦。@因为这是靠着我重要的朋友们才找寻到的，@我无可替代的愿望。"}]},{"autoTurnFirst":1.7,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":8.3,"chara":[{"id":210100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":210100}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":210100}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":1.5,"chara":[{"id":210100,"motion":20}]}],"group_10":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210100,"motion":300,"pos":1,"voice":"vo_char_2101_00_18","textHome":"我是不是有些改变了呢？@有没有变得能更加可靠地引导大家了呢？@要是那样的话，就太好了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":30}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":210100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100}]}],"group_11":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_19","textHome":"这就是我作为因果特异点的力量！"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":40}]}],"group_12":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_20","textHome":"我绝不会对大家坐视不管的，@所以再等我一会儿！"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":20}]}],"group_13":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_21","textHome":"如果有人说心怀希望是错误的，@那么无论多少次我都会去反驳他。@因为，这就是我战斗的理由，@这就是我好不容易才找寻到的愿望。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":2.8,"chara":[{"id":210100,"motion":20}]},{"autoTurnFirst":5.6,"chara":[{"id":210100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":210100}]}],"group_14":[{"autoTurnFirst":12.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_22","textHome":"我看得到所有的过去与未来。@过去可能存在的宇宙，@未来可能诞生的宇宙，全部。@所以，我会保护大家。@我会永远作为消灭魔女的概念而存在。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":210100}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":4.0,"chara":[{"id":210100,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":210100,"motion":20}]}],"group_15":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_23","textHome":"未定"}]}],"group_16":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_24","textHome":"你好！还能和你说上话真让我松了一口气啊。@我作为魔法少女还是个新手，@所以今天也拜托你教我各种各样的事哦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":0.4,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":201}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":20}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_25","textHome":"感觉好久没有感受过这么清爽的早晨了。@啊，今天爸爸好像也在照顾小番茄啊。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":1.3,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100}]}],"group_18":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_26","textHome":"仁美和上条在一起吃午饭真是幸福啊～@他们好不容易才心意相通，@真希望他们能够一直幸福下去。"}]},{"autoTurnFirst":2.6,"chara":[{"id":210100,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":10}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210100,"motion":300,"pos":1,"voice":"vo_char_2101_00_27","textHome":"达也又在一个人画画了。@对不起，我没法成为你的玩伴。@不过，我会好好看着你的……"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":30}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":0}]}],"group_2":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_03","textHome":"这是，我现在看到的世界。"}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210100,"motion":201,"pos":1,"voice":"vo_char_2101_00_28","textHome":"啊，妈妈她又喝多了～@以前我还能帮忙，现在就只剩爸爸一个人了，@真是辛苦啊。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":20}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"id":210100,"motion":30}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":210100}]}],"group_21":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_29","textHome":"无论何时无论何地，我都会陪在大家身边哦。@所以，不管是大家的事情，@还是我自己的事情，我都会很清楚哦。"}]},{"autoTurnFirst":3.7,"chara":[{"id":210100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":10}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_30","textHome":"和大家一起友好相处地组队，@真是一件很棒的事情！@我过去也有过五个人一起战斗的时候哦。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":300}]},{"autoTurnFirst":0.5,"chara":[{"id":210100,"motion":30}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":0.7,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":20}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_31","textHome":"看到了自己都不知道的自己的另一面，@总感觉心里痒痒的。@我竟然对小焰说了“燃起来吧——”@这样的话呢。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":210100,"motion":10}]},{"autoTurnFirst":1.2,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":210100}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":20}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_32","textHome":"魔法少女们聚在一起吵架。@这样的事情必须要阻止。@大家不应该相互争斗。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":1.2,"chara":[{"id":210100,"motion":20}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":210100,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":30}]}],"group_25":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_33","textHome":"总感觉有些兴奋，因为我从来没想到，@我还能像这样和别人一起开心地聊天。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210100,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":30}]}],"group_26":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_34","textHome":"有很多关心着我的人。@爸爸，妈妈，还有小焰。@所以现在，是我为保护他们而努力的时候了！"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":210100}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":210100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":210100,"motion":20}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_35","textHome":"我不是孤单一人哦。@因为大家，一直都和我在一起。"}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":4.0,"chara":[{"id":210100,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210100,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":30}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210100,"motion":300,"pos":1,"voice":"vo_char_2101_00_36","textHome":"过去，我和重要的朋友们道了别。@但是，那只是短暂的分离。@我一直都相信着，我们会有重逢的那一刻。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":30}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":10}]}],"group_29":[{"autoTurnFirst":7.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_37","textHome":"现在我已经很清楚了。@小焰为了拯救我，到底经历了多少苦痛，@遭到了多少伤害……"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":30}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210100,"motion":300,"pos":1,"voice":"vo_char_2101_00_04","textHome":"大家平安无事真是太好了。"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":1,"id":210100}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":30}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_38","textHome":"杏子说，她好不容易才和沙耶香成了朋友……@她们俩果然一直是心意相通的。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":2.7,"chara":[{"id":210100,"motion":20}]},{"autoTurnFirst":1.3,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":210100}]},{"autoTurnFirst":4.0,"chara":[{"id":210100,"motion":10}]}],"group_31":[{"autoTurnFirst":4.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_39","textHome":"不管在哪个世界，麻美学姐还是麻美学姐。@做点心很拿手，正义感也很强，@我有这么一位前辈真是觉得太好了。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":2.5,"chara":[{"id":210100,"motion":20}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"id":210100,"motion":10}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_40","textHome":"沙耶香说过，她没有任何后悔。@听了上条的演奏，@她也找回了自己真正的感情。"}]},{"autoTurnFirst":7.5,"chara":[{"id":210100,"motion":1}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_41","textHome":"已经不用再去怨恨任何人，@也不用再去诅咒任何人了。@在希望变成绝望之前，@大家的因果，都会由我来承受。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":210100,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":210100}]},{"autoTurnFirst":4.0,"chara":[{"id":210100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":20}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":210100,"motion":201,"pos":1,"voice":"vo_char_2101_00_42","textHome":"我来守护大家！"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":20}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_43","textHome":"太好了，大家都没事吧？"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":10}]}],"group_36":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":210100,"motion":201,"pos":1,"voice":"vo_char_2101_00_44","textHome":"我不会放弃希望。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":20}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":1,"pos":1,"voice":"vo_char_2101_00_45","textHome":"再也不用绝望了。"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_46","textHome":"已经可以放心了。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210100,"motion":10}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":200,"pos":1,"voice":"vo_char_2101_00_63","textHome":"所有的魔女……都由我亲手消灭！"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":20}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_05","textHome":"能看到大家对我展现笑容真是件开心的事。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210100,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"id":210100,"motion":10}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":0,"pos":1,"voice":"vo_char_2101_00_64","textHome":"我不会让希望以绝望而结束！"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":201}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":20}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_65","textHome":"实现吧，我的祈求……我的愿望！"}]},{"autoTurnFirst":0.5,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":400}]},{"autoTurnFirst":1.0,"chara":[{"id":210100,"motion":40}]}],"group_42":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210100,"motion":201,"pos":1,"voice":"vo_char_2101_00_66","textHome":"请大家相信！这力量，会让梦与希望实现！！"}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":210100,"motion":10}]}],"group_43":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210100,"motion":300,"pos":1,"voice":"vo_char_2101_00_02","textHome":"吓我一跳。那个，你真的看得见我吗？@我，还以为再也没法和任何人说话了……@啊，我叫鹿目圆！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210100,"motion":0}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":210100,"motion":400}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210100,"motion":100,"pos":1,"voice":"vo_char_2101_00_13","textHome":"我要努力去一点点适应战斗才行呢。"}]},{"autoTurnFirst":2.5,"chara":[{"id":210100,"motion":10}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":210100}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.j