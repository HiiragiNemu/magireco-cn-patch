{"story":{"group_1":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_01","textHome":"新年快乐~！诶嘿嘿……我今天抽签……@抽到大吉了呢！所以我心情特别好！@我想把这份快乐分享给大家，@祈愿大家都能有个美好的新年……！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":210000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":210000}]}],"group_10":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_18","textHome":"好厉害……灵魂宝石发出了前所未有的光芒！@用这份力量，一起把新年变成最棒的一年吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_19","textHome":"我现在，一定能够帮到别人了……！"}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":0,"pos":1,"voice":"vo_char_2100_00_20","textHome":"新的一年，也会带来新的心情呢……！"}]},{"autoTurnFirst":3.5,"chara":[{"id":210000,"motion":100}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_21","textHome":"和服，真的好难穿啊……@虽然我很喜欢这根像缎带一样可爱的带子，@但是我一个人绝对系不上……！"}]},{"autoTurnFirst":4.8,"chara":[{"id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":210000,"motion":201}]}],"group_14":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_22","textHome":"我，作了新年的第一个梦。@梦里我和麻美学姐、沙耶香、杏子@还有小焰一起吃蛋糕。@过年吃蛋糕……有些奇怪吧……？"}]},{"autoTurnFirst":7.0,"chara":[{"eyeClose":1,"id":210000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":210000,"motion":100}]}],"group_15":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":0,"pos":1,"voice":"vo_char_2100_00_23","textHome":"我从今往后也会继续战斗。@因为我的愿望是发自内心的。@只要不放弃，就一定能实现愿望，@我想要大家都相信这一点。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":210000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]}],"group_16":[{"autoTurnFirst":2.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_24","textHome":"我在等你哦~！@哼哼……我要再次向你新年问候哦！@过去的一年中受到了你的诸多照顾！@新的一年，也请你多多关照呢！"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":3.8,"chara":[{"id":210000,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_17":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":201,"pos":1,"voice":"vo_char_2100_00_25","textHome":"早上好~！诶嘿嘿……@今天我要穿着盛装和大家出门！@因为很期待，所以我醒得比平时都早！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_26","textHome":"我最喜欢年节菜了！@不单是喜欢吃，跟妈妈和达也一起帮爸爸，@大家一起来做也很快乐呢~！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":210000}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":4.0,"chara":[{"id":210000,"motion":300}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_27","textHome":"晚上，仁美叫我去她家做客。@如果有魔女来捣乱的话，@我就要赶紧消灭掉才行……！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":210000,"motion":201}]}],"group_2":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_03","textHome":"打扮完就好想快点出门啊。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_20":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":400,"pos":1,"voice":"vo_char_2100_00_28","textHome":"糟糕！今天该睡觉了，明天得早起才行……！@我记得签上面写着，@「早起就可以心想事成」……！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":210000}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]}],"group_21":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_29","textHome":"我在街上看到了和子老师。@她好像在嘀咕着「所以才说，@比自己小的男人是……」什么的……@新年刚开始，发生了什么吗？"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":210000,"motion":100}]}],"group_22":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_30","textHome":"呼啊……到了寒假，就不禁慵懒起来了呢……@不行不行！魔法少女新年在家睡觉什么的，@绝对不行！"}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":201}]}],"group_23":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":0,"pos":1,"voice":"vo_char_2100_00_31","textHome":"叫镜之魔女的话，会不会也喜欢镜饼呢……@在结界里奉上镜饼的话，说不定会放过……@应该不会吧……"}]},{"autoTurnFirst":3.5,"chara":[{"id":210000,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":210000}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":300}]}],"group_24":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_32","textHome":"呜……像是班级间的比赛一样，好紧张……@为了不成为大家的累赘，我得努力才行！"}]},{"autoTurnFirst":2.5,"chara":[{"id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":201}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_33","textHome":"虽然这件和服我很喜欢，也很可爱，@但实际上穿起来走路有点不方便。@我必须小心一点，不能在新年开头就摔倒啊！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":210000}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":210000,"motion":201}]}],"group_26":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_34","textHome":"嗯，年糕小豆汤很棒，煮年糕也很好吃啊……@明天我就代替爸爸来准备料理吧。@可以的话，一起吃怎么样？"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":0,"pos":1,"voice":"vo_char_2100_00_35","textHome":"你看过新年的日出吗？@从黑暗中慢慢放出光芒，十分的神秘呢！@我是和家人们一起看的，真是令人感动啊！"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":210000,"motion":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":5.0,"chara":[{"id":210000,"motion":100}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_36","textHome":"听我说呀！我收到了好多人给我的贺年卡哦！@其中有不少人，我还没来得及给他们寄呢。@得赶紧回复才行……诶嘿嘿。"}]},{"autoTurnFirst":3.0,"chara":[{"id":210000,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":210000,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_37","textHome":"今年，要是能和达也一起玩双六棋就好了……@去年我们也一起玩了，但好像有点难。"}]},{"autoTurnFirst":2.0,"chara":[{"id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":210000}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_04","textHome":"着装，真的好难啊……"}]}],"group_30":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_38","textHome":"要是之前练习过羽毛球就好了……@发球、扣球、截击球什么的，@也是对毽球能起到帮助……的吧！？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_39","textHome":"和大家一起庆祝新年，是平凡而幸福的对吧？@我觉得守护这样的幸福，@就是魔法少女的重要使命。"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":210000,"motion":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":210000}]},{"autoTurnFirst":6.0,"chara":[{"id":210000,"motion":201}]}],"group_32":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_40","textHome":"对了，方便的话一起去买东西吧！？@附近的商店开始新年促销了。@我好想买个福袋啊……"}]},{"autoTurnFirst":3.5,"chara":[{"id":210000,"motion":1}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000}]}],"group_33":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_41","textHome":"诶嘿嘿嘿……那样夸我的话，我会害羞的。@一直都穿着盛装也可以吧……！？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":2,"face":"mtn_ex_040.exp.json","id":210000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_041.exp.json","id":210000,"motion":300}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_42","textHome":"还想着回家吃年节菜的……！"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_43","textHome":"甜甜的~年糕小豆汤在等着我呢……！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_44","textHome":"快点回去吃年糕喽！"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_45","textHome":"新年的兆头不错呀！"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_46","textHome":"大家一起庆祝吧！"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":201,"pos":1,"voice":"vo_char_2100_00_63","textHome":"要比平常更加华丽哦！"}]}],"group_4":[{"autoTurnFirst":2.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_05","textHome":"要是大家都能过个幸福的年就好了呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":201,"pos":1,"voice":"vo_char_2100_00_64","textHome":"呀！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_65","textHome":"将这份心情，传递给新年的日出吧……！"}]}],"group_42":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210000,"motion":200,"pos":1,"voice":"vo_char_2100_00_66","textHome":"给大家带去……美好的新年！"}]}],"group_43":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_02","textHome":"我是鹿目圆。嘿嘿嘿……@接下来要和小焰她们……一起去新年参拜！@所以今天，我特意穿了这身衣服哦！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":201}]}],"group_5":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":300,"pos":1,"voice":"vo_char_2100_00_13","textHome":"快看……！灵魂宝石也比平常更闪耀了！"}]}],"group_6":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":210000,"motion":400,"pos":1,"voice":"vo_char_2100_00_14","textHome":"好厉害……我变得和之前不一样了。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_15","textHome":"谢谢你一直陪着我……今后也请多指教呢！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000}]}],"group_8":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210000,"motion":1,"pos":1,"voice":"vo_char_2100_00_16","textHome":"让我再说一次，新年快乐~！@诶嘿嘿~……因为抽到了大吉特别开心，@所以我想一直这么说啦！"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":210000,"motion":201}]}],"group_9":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210000,"motion":100,"pos":1,"voice":"vo_char_2100_00_17","textHome":"听我说嘛听我说嘛！@我被邀请到朋友家喝茶时，茶叶竖了起来！@好兆头源源不断，真是让人开心呢！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000,"motion":201}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":210000,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":210000}]}]},"version":3}