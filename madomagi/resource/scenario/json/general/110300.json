{"skipTransitionList":[],"story":{"group_1":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_01","textHome":"有时是从未迟到缺席，@追求着12年全勤奖的热血少女；@有时是努力上菜的中餐店看板娘。@然而，她的真实身份……@竟然是螯合游乐园的管理者，传闻鹤乃。@来吧，大家和我一起悠闲懒散地度日吧。"}]},{"autoTurnFirst":6.5,"chara":[{"id":110300,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"id":110300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":110300,"motion":101}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":200}]}],"group_10":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_18","textHome":"因为是开业前，@工作人员们一起进行迎客的练习真是费力呢。@虽然可能我也练习一下比较好，@但好麻烦，还是睡吧。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":100}]}],"group_11":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_19","textHome":"不怀好意的入场者请赶紧离场哦！"}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":201}]}],"group_12":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":1,"pos":1,"voice":"vo_char_1103_00_20","textHome":"嗯，感觉稍微和传闻更加亲近了。"}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_111.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_21","textHome":"这样正好。大家都会守护我，@可以什么都不用想了。@但是，陷入危机的时候，@我就要作为管理员出手了。"}]},{"autoTurnFirst":5.5,"chara":[{"id":110300,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":101}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110300,"motion":101,"pos":1,"voice":"vo_char_1103_00_22","textHome":"感受到了，在大家身上流动的传闻的魔力。@也就是说，我更加融入这个传闻了吧。@换句话说，螯合游乐园就是我本身。@绝不允许别人否定。"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110300}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":110300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":110300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":110300,"motion":101}]}],"group_15":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_23","textHome":"偶尔会想起来，令人怀念的线香气味，@稍稍让人倒胃口的油烟味。@好不容易能悠闲地过了，@但想到这些，心里又充满了力量。"}]},{"autoTurnFirst":2.4,"chara":[{"eyeClose":1,"id":110300,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"id":110300,"motion":200}]}],"group_16":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":200,"pos":1,"voice":"vo_char_1103_00_24","textHome":"哦，欢迎来到螯合游乐园！@我是和你越来越熟的管理员由比鹤乃。@今天也和我一起懒洋洋地度过吧。"}]},{"autoTurnFirst":2.5,"chara":[{"id":110300,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":101}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":100}]}],"group_17":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_25","textHome":"早晨的演出准备正忙，今天还在彩排中。@我则是去美食广场慢慢喝味噌汤而已。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":101}]},{"autoTurnFirst":2.0,"chara":[{"id":110300,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":110300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300}]}],"group_18":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_26","textHome":"到了中午螯合游行就开始了。@这是为了消除工作人员的烦恼的治愈活动哦。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":101}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_27","textHome":"这个时间段万万岁该忙起来了。@虽然对不起爸爸，但我再想帮忙，@也不能回去了……"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":110300,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_133.exp.json","id":110300}]}],"group_2":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_03","textHome":"只要在这里，就不用努力也能幸福了呢。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":100}]}],"group_20":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_28","textHome":"奇怪，每次到了深夜都不困。@有点怀念八千代喊我早点睡觉的样子了。"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":0}]}],"group_21":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_29","textHome":"希望螯合游乐园早日开张。@真期待大家来这里尽情游玩放松，@然后一直留在这里。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"id":110300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":101}]}],"group_22":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_30","textHome":"螯合游乐园外面好像有魔女出现了。@但不着急不着急，@让别的魔法少女来猎取也好嘛。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]}],"group_23":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_31","textHome":"要是对镜之魔女有兴趣，那就尽管去看看吧。@但这里是螯合游乐园哦？@那么有精神可是违反传闻的哦？"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":1}]},{"autoTurnFirst":7.2,"chara":[{"cheek":0,"face":"mtn_ex_133.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":110300,"motion":100}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_32","textHome":"大家竟然能那样血气旺盛地战斗呢……@要是有什么不能退缩的理由倒也能理解，@只是会很累呢。"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":100}]}],"group_25":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110300,"motion":300,"pos":1,"voice":"vo_char_1103_00_33","textHome":"嗯……虽然是游乐园，@但还是想要更多的懒散要素啊。@像是懒人沙发啦，漫画啦，@还有自动喂零食机之类的。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":101}]},{"autoTurnFirst":2.0,"chara":[{"id":110300,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":110300,"motion":100}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_150.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_34","textHome":"嗯？啊，抱歉，太过舒适然后就发呆了。"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_111.exp.json","id":110300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0}]}],"group_27":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_35","textHome":"无需烦恼，无需努力的话，还能干什么呢？@嗯……要是师父她们也过来一起住就好了。"}]},{"autoTurnFirst":2.1,"chara":[{"id":110300,"motion":100}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":101}]}],"group_28":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110300,"motion":400,"pos":1,"voice":"vo_char_1103_00_36","textHome":"哇，趁人在长椅上午睡的时候袭击@简直是无法无天了。@各位职员，这里有坏人！"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":110300,"motion":101}]}],"group_29":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_37","textHome":"身为管理员，是能看出@各位螯合职员的样貌区别的。@比如说那边的职员，胡子有点卷对吧？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":101}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"id":110300,"motion":101}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_133.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_04","textHome":"我不回去了……@玛吉斯给了我能够安心的地方……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_133.exp.json","id":110300,"motion":300}]}],"group_30":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110300,"motion":400,"pos":1,"voice":"vo_char_1103_00_38","textHome":"啊，不能打开！@大摩天轮里装满了人们的烦恼，很危险的！"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110300,"motion":200}]}],"group_31":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_39","textHome":"看到这游乐园的样子时，我就明白了。@一年前的那个时候，我也很安心呢。"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_133.exp.json","id":110300,"motion":100}]}],"group_32":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_40","textHome":"成就伟业和为大家的幸福许愿都很重要！@但是最重要的还是自身的安宁！@像这样委身其中是最好的。"}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":101}]},{"autoTurnFirst":2.5,"chara":[{"id":110300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":100}]}],"group_33":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_41","textHome":"嘶……嘶……嗯嗯……@欢迎光临，师父……"}]},{"autoTurnFirst":2.0,"chara":[{"id":110300,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":110300,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":0}]}],"group_34":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":101,"pos":1,"voice":"vo_char_1103_00_42","textHome":"我会作为螯合游乐园的管理员保护它！"}]},{"autoTurnFirst":3.0,"chara":[{"id":110300,"motion":200}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_43","textHome":"这样大家就该退场啦！"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_44","textHome":"只是委身于现状而已——"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_45","textHome":"嘿，别倒下，现在开始是休闲时间。"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_46","textHome":"因为这是让我安心的地方。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110300,"motion":200,"pos":1,"voice":"vo_char_1103_00_63","textHome":"我的魔力上覆盖着传闻之力。"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_05","textHome":"为什么是火锅呢？@自己也不太明白。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":110300,"motion":201,"pos":1,"voice":"vo_char_1103_00_64","textHome":"燃烧燃烧，熊熊燃烧！"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_65","textHome":"那么，禁止你的出入！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_66","textHome":"嗯，之后就可以放松了。"}]}],"group_43":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_02","textHome":"风风火火、吵吵嚷嚷，大家喜欢什么样的？@还是懒懒散散最好啊。@那就来螯合游乐园玩吧！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_150.exp.json","id":110300,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp.json","id":110300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp.json","id":110300,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp.json","id":110300,"motion":201}]}],"group_5":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_13","textHome":"其实不想努力的，但要维持强大呢。"}]},{"autoTurnFirst":3.5,"chara":[{"id":110300,"motion":101}]}],"group_6":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_14","textHome":"比想象的要努力过头了！@现在是休息时间。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":101}]}],"group_7":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_15","textHome":"可以呀，去那边懒洋洋地说吧。"}]}],"group_8":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":0,"pos":1,"voice":"vo_char_1103_00_16","textHome":"说到游乐场，那必须是喷气过山车啊。@还有旋转木马也不容错过哦。"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":110300,"motion":201}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":100}]}],"group_9":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":110300,"motion":100,"pos":1,"voice":"vo_char_1103_00_17","textHome":"光是高兴可不行呀。@既然是以悠闲懒散作为标语的螯合游乐园，@那一定要有能晒太阳的地方才行。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_033.exp.json","id":110300,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110300,"motion":101}]}]},"version":3}