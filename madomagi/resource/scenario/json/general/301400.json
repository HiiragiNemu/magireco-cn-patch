{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_01","textHome":"我一见到别人就会紧张……而且我也不知道@怎么样和别人相处，所以没法冷静下来……@第一次和丽良还有未都相遇的时候也是如此。@只不过，那个时候不一样的是，@我有想要和她们两个人成为朋友的想法。"}]},{"autoTurnFirst":11.5,"chara":[{"id":301400,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":100}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_18","textHome":"因为不知道对话在不在一个频道上……@所以，经常我打完招呼，气氛就变得奇怪了，@再然后就这样分别了……哈啊～好尴尬……"}]},{"autoTurnFirst":6.0,"chara":[{"id":301400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":1,"id":301400,"motion":300}]}],"group_11":[{"autoTurnFirst":0.8,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_19","textHome":"太好了……这样子我就更擅长战斗了……嗯！"}]},{"autoTurnFirst":0.0,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":5.0,"chara":[{"id":301400,"motion":400}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_20","textHome":"感觉又登上了一个阶梯……@我，似乎还能再向上迈进！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":100}]}],"group_13":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_21","textHome":"我从小开始，就不擅长和人交流……@总之，我喜欢独自一人，就算在家也是……"}]},{"autoTurnFirst":4.0,"chara":[{"id":301400,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301400}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_22","textHome":"丽良和未都，和我至今遇见的所有人都不同。@从初次见面起，她们就一直注视我，包容我。@所以，我也很想和她们说更多话。"}]},{"autoTurnFirst":7.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":5.5,"chara":[{"id":301400,"motion":100}]}],"group_15":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_23","textHome":"我的父母对待我也很仔细。@只是，也许是他们怕不小心伤到我，@所以我感觉到了和他们的距离感。@能一口气突破这种感觉的，只有丽良和未都。"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":301400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":5.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":1}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_24","textHome":"啊……你好……嗯……总之，请多关照……@抱歉……那个……我，怎么说好呢……@见到人会害怕……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400}]},{"autoTurnFirst":3.0,"chara":[{"id":301400,"motion":400}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"eyeClose":1,"id":301400,"motion":300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":5.0,"chara":[{"id":301400}]}],"group_17":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_25","textHome":"说实话……我早上起不来……@不过，丽良和未都早上很精神，@所以我也跟着能清醒过来……@差不多就是这样的感觉吧？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"id":301400,"motion":1}]}],"group_18":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_26","textHome":"上课的时候，我也会经常一不留神就发呆。@但是，我发呆时的表情反而看起来会很认真，@所以不会被发现……"}]},{"autoTurnFirst":5.0,"chara":[{"id":301400,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301400}]}],"group_19":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_27","textHome":"我经常会和丽良还有未都一起放学回家。@只不过，有时未都会说@「回家时只准走有影子的地方」之类的，@然后我们就像这样回家了……"}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":301400,"motion":100}]}],"group_2":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_03","textHome":"我真是不行啊……@为什么怎么样都说不出话呢……"}]},{"autoTurnFirst":2.5,"chara":[{"id":301400,"motion":1}]}],"group_20":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":100,"pos":1,"voice":"vo_char_3014_00_28","textHome":"晚上一不留神就熬夜了。@一旦看起书或者漫画，就很容易停不下来……@不过，真的很有趣……！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":1,"id":301400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":4.0,"chara":[{"id":301400,"motion":1}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_29","textHome":"什么都不做就这么让时间流逝可能很浪费……@不过，我倒是很喜欢这样的感觉。"}]},{"autoTurnFirst":5.5,"chara":[{"id":301400,"motion":100}]}],"group_22":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_30","textHome":"和魔女战斗就是魔法少女的宿命……@我很清楚这样的事情。@所以，接下来就是认真对待宿命的时候了！"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":301400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":301400,"motion":400}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_31","textHome":"这里似乎有些不寻常……@只要稍微有些大意，就会立刻遭到算计……@我有着这样的感觉！"}]},{"autoTurnFirst":5.0,"chara":[{"id":301400,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":301400,"motion":200}]}],"group_24":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301400,"motion":200,"pos":1,"voice":"vo_char_3014_00_32","textHome":"现在吗？嗯……我当然很紧张……@因为……居然有这么多的魔法少女……@所以，我从刚刚开始就一直看着上面……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":301400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":5.0,"chara":[{"id":301400}]}],"group_25":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_33","textHome":"和丽良一起做着点心，@和未都玩着她想出来的游戏，@有她们两个在的时候，@我的生活就变得很充实。"}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":301400,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":301400}]}],"group_26":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_34","textHome":"就算对我说「冷静一点」，我也做不到……@脑子里总会想着「和我在一起会不会很无聊」@之类的……"}]},{"autoTurnFirst":4.0,"chara":[{"id":301400,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301400}]}],"group_27":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_35","textHome":"我在家的时候经常会看书……@不过最近，我也开始锻炼肌肉了。@这个还真是很容易沉迷进去呢……！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":301400,"motion":100}]}],"group_28":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_36","textHome":"在外面我会很紧张，在家我就会经常发呆。@什么都不想……就像这样……啊！@不好意思，真的发呆了……"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301400,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301400}]}],"group_29":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_37","textHome":"准备好白纸和铅笔。然后，就在上面画点。@光是这样事情就足够让我沉浸进去了。"}]},{"autoTurnFirst":4.3,"chara":[{"id":301400,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"id":301400,"motion":100}]}],"group_3":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_04","textHome":"有没有打开心门的诀窍呢？@要是有的话就告诉我吧……"}]}],"group_30":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_38","textHome":"我试过一个人玩接龙游戏。@不过，因为结束不了就放弃了……@嗯，嘛，虽然这个结果我早就知道了……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300}]},{"autoTurnFirst":1.1,"chara":[{"eyeClose":1,"id":301400}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":4.0,"chara":[{"id":301400,"motion":1}]}],"group_31":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_39","textHome":"在房间里一个人静静待着的时候，@窗外会传来各种的声音。@然后靠声音来想象各种发生的事情也很有趣！"}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":3.0,"chara":[{"id":301400,"motion":400}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":100,"pos":1,"voice":"vo_char_3014_00_40","textHome":"在和人搭话的时候，应该说些什么好呢……@「呀啊」之类的吗？啊，不、不是吗！？@哈啊～真是搞不懂啊……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":1}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301400,"motion":400}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301400,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":301400}]}],"group_33":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":200,"pos":1,"voice":"vo_char_3014_00_41","textHome":"向着太阳前进吧！……跳吧！@嗯……哈！你听到了吗！？@这是，这是电视剧「Skip教师故事」@的台词……"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301400,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":301400}]},{"autoTurnFirst":2.3,"chara":[{"id":301400,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":301400}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_42","textHome":"我……我必须这么做！"}]},{"autoTurnFirst":3.0,"chara":[{"id":301400,"motion":1}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":300,"pos":1,"voice":"vo_char_3014_00_43","textHome":"太好了……胜利了……"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301400}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_44","textHome":"接下来也要继续才行……！"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":400,"pos":1,"voice":"vo_char_3014_00_45","textHome":"下次……也要努力……！"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":200,"pos":1,"voice":"vo_char_3014_00_46","textHome":"只需要相信……然后前进就够了！"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_63","textHome":"首先要提高……一点……"}]}],"group_4":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":200,"pos":1,"voice":"vo_char_3014_00_05","textHome":"就算只有一点我也要改变自己！@虽然很艰辛……"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":100}]}],"group_40":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_64","textHome":"把想象……变为形状！"}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_65","textHome":"就想大脑中描绘的那样……！"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":400,"pos":1,"voice":"vo_char_3014_00_66","textHome":"一口气……去吧！"}]}],"group_43":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_02","textHome":"啊，那个……我叫桑水……清佳……@初次见面……请多指教……嗯……那个……@那么……就是这样……你好……"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":0}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"id":301400,"motion":0}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301400,"motion":400,"pos":1,"voice":"vo_char_3014_00_13","textHome":"哇！这个感觉……是我变强了！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301400,"motion":100}]}],"group_6":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_14","textHome":"虽然只是感觉……我，似乎……变得很强了！"}]},{"autoTurnFirst":3.5,"chara":[{"id":301400,"motion":100}]}],"group_7":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_15","textHome":"从过去到未来，时间在不断流动……@所以我也必须前进！"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":301400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301400,"motion":400}]}],"group_8":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":0,"pos":1,"voice":"vo_char_3014_00_16","textHome":"我，就算在街上看见了熟人，@我也会不禁转身往回走……@光是看见熟人的脸就已经紧张得不行了……"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":301400,"motion":300}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":301400,"motion":1,"pos":1,"voice":"vo_char_3014_00_17","textHome":"在突然见到别人的时候，@我也不知道该说些什么……@所以别人看我的时候，@我的表情看起来就会很惊讶……"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301400,"motion":100}]}]},"version":3}