nFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_63","textHome":"我要拯救这一切。"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_05","textHome":"不管发生什么……我都要前进……"}]},{"autoTurnFirst":3.0,"chara":[{"id":402100,"motion":201}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_64","textHome":"心坚无难事。"}]},{"autoTurnFirst":2.0,"chara":[{"id":402100,"motion":200}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_65","textHome":"光辉万丈！"}]}],"group_42":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402100,"motion":201,"pos":1,"voice":"vo_char_4021_00_66","textHome":"这下就结束了。"}]}],"group_43":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_02","textHome":"初次见面，我叫塔鲁特。@啊，塔鲁特是天使大人赐给我的名字，@亲密的人都是这么叫我的。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402100,"motion":100,"pos":1}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402100}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_13","textHome":"这样子，我对魔力的控制又得心应手了一些。"}]},{"autoTurnFirst":4.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100,"motion":100}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402100,"motion":100,"pos":1,"voice":"vo_char_4021_00_14","textHome":"这样，我就能完美地控制魔力了！"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_15","textHome":"回想起来……已经……是很久远的事情了。"}]}],"group_8":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402100,"motion":0,"pos":1,"voice":"vo_char_4021_00_16","textHome":"栋雷米……那里就是我的故乡。@要说在我成为魔法少女之前的愿望，@那就是希望家人和村庄的人们能够免于灾祸，@幸福地生活。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402100,"motion":1}]},{"autoTurnFirst":6.1,"chara":[{"id":402100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"face":"mtn_ex_011.exp.json","id":402100}]}],"group_9":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402100,"motion":1,"pos":1,"voice":"vo_char_4021_00_17","textHome":"凯瑟琳用命救了我，我才成为了魔法少女。@我已经……不想再有人@和我遭受同样的痛苦了……"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":402100,"motion":300}]}]},"version":3}