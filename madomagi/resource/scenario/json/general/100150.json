{"story":{"group_1":[{"autoTurnFirst":2.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_01","textHome":"我叫环彩羽。因为刚来神滨市不久……@对神滨市了解的不是很透彻，@若是彼此间互有不熟悉的，希望能多多交流。@啊！话说……我的兴趣是做料理。@可以的话……我做晚饭给你吃好不好呀？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":3.9,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":1}]},{"autoTurnFirst":2.9,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":2.8,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100}]},{"autoTurnFirst":3.0,"chara":[{"id":100100,"motion":100}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_00_18","textHome":"即使如今已经不是了，有朝一日@我也想向小忧坦白……曾经怯懦的自己。@因为我相信……小忧的话，@无论是怎样的我，都会温柔接纳的吧。"}]},{"autoTurnFirst":7.1,"chara":[{"id":100100,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":2.1,"chara":[{"id":100100,"motion":100}]}],"group_11":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_19","textHome":"为了找回自己重要的东西……@我一定会一次又一次地变强！"}]},{"autoTurnFirst":2.3,"chara":[{"id":100100,"motion":1}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_20","textHome":"接受弱小的自己……@从这里开始慢慢进步就好了吧……"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":100}]}],"group_13":[{"autoTurnFirst":1.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_21","textHome":"开始一点点……慢慢改变了吗……？@即便厌恶过去的自己……也不能当作不存在……@应该接纳它，然后超越它……"}]},{"autoTurnFirst":3.3,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":3.1,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"id":100100,"motion":300}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100}]},{"autoTurnFirst":1.9,"chara":[{"id":100100,"motion":0}]}],"group_14":[{"autoTurnFirst":4.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_22","textHome":"和大家相遇之后，我终于明白了。@正因是重要的人，才不能隐藏自己的本心……@正因为重要，才必须传达出自己真实的心意。@因为对喜欢的人，是不应该说谎的……"}]},{"autoTurnFirst":5.3,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":1.8,"chara":[{"id":100100,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}]}],"group_15":[{"autoTurnFirst":6.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_23","textHome":"我不会再蒙混过关，也不会再欺骗自己了。@从自我保护的那层厚壳中飞出来后……@发现外面的世界好明亮，感觉浑身都轻松了。@我终于……成为了自己想要成为的人。"}]},{"autoTurnFirst":2.7,"chara":[{"id":100100,"motion":300}]},{"autoTurnFirst":3.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}]},{"autoTurnFirst":3.3,"chara":[{"id":100100,"motion":0}]},{"autoTurnFirst":5.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":200}]},{"autoTurnFirst":2.2,"chara":[{"id":100100,"motion":100}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_50_24","textHome":"呼…虽然今天的风很冷，但反而让人期待呢。@白色圣诞节要来了。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100,"motion":100}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_50_25","textHome":"早上好，最近冷得都离不开兔子抱枕了。@但今天有圣诞节前夜，只好早起了。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":200}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_50_26","textHome":"今天大家要聚会所以很忙！@八千代打算自己制作多少东西呢……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":200}]}],"group_19":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_50_27","textHome":"东西买好了，稍微散步一会儿再回去吧？@听说城市里的彩灯非常的漂亮呢。"}]},{"autoTurnFirst":2.3,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100}]}],"group_2":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_03","textHome":"小忧她无论何时……@都有办法让大家露出笑容呢……"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":100}]}],"group_20":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_28","textHome":"因为是愉快的一天，更要注意睡眠才行。@而且不好好睡觉的话，圣诞老人就不来了哦。"}]},{"autoTurnFirst":3.3,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_29","textHome":"因为是寒假，大家都像这样聚在家里，@感觉房间都变温暖了。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100}]}],"group_22":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_022.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_50_30","textHome":"无论大人还是小孩，大家都期待着这一天。@可不能让魔女来捣乱！走吧！"}]},{"autoTurnFirst":1.0,"chara":[{"id":100100,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":100100,"motion":400}]}],"group_23":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_31","textHome":"八千代说，如果太闹腾的话，是会被@魔女蛊惑的。鹤乃她不会有事吧……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100100,"motion":301}]}],"group_24":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_50_32","textHome":"这不是大家聚在一起欢度圣诞节的气氛吧……@哎，这一天要是能安安稳稳地度过该有多好。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}]}],"group_25":[{"autoTurnFirst":8.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_33","textHome":"今年的圣诞节，总觉得会成为至今为止@最幸福的一次。是因为@有八千代她们在的原因吧……？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":100100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_34","textHome":"呼气变成了白雾呢。想起来小时候因为这个@而感到很惊讶，还被爸爸妈妈笑话了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":100100,"motion":200}]}],"group_27":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_50_35","textHome":"小忧她还是只能在医院过圣诞节。@要是将来有一天可以和她一起过就好了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":301}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_50_36","textHome":"说“我们是圣诞老人”也就意味着“我们已经@不是小孩子了”吧？总觉得@好像长得太高了？哈哈。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":100100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":100100}]}],"group_29":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_37","textHome":"天气冷起来之后，终于到了连出门都很困难的@状况了。菲莉希亚也是一直……@啊，菲莉希亚……作业完全都没动!?"}]},{"autoTurnFirst":3.0,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100100}]},{"autoTurnFirst":3.0,"chara":[{"id":100100,"motion":401}]}],"group_3":[{"autoTurnFirst":2.9,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_04","textHome":"连我都开始说教别人了……@自己都有点难以置信……"}]},{"autoTurnFirst":2.6,"chara":[{"id":100100,"motion":200}]}],"group_30":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_38","textHome":"之前在八千代家留宿的时候，大家就在一起@聚会过了。这棵圣诞树也是@从那时开始一直用到现在。"}]},{"autoTurnFirst":2.5,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":200}]}],"group_31":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_50_39","textHome":"说起来，莎奈是做装饰最努力的啊。@连菲莉希亚的份也做好了。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":100}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_50_40","textHome":"圣诞节对恋人们来说是很重要的一天吧。@在漫画和连续剧里看过……@不过我不是很懂啦。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":100100,"motion":200}]}],"group_33":[{"autoTurnFirst":2.5,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":400,"pos":1,"voice":"vo_char_1001_50_41","textHome":"不、不要一直盯着看好吗……@以前从没这样穿过，感觉好害羞……"}]},{"autoTurnFirst":3.5,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100100,"motion":300}]}],"group_34":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_42","textHome":"一定……没问题……！"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"id":100100}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_43","textHome":"还好没放弃……！"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_44","textHome":"没问题的……我相信！"}]}],"group_37":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_45","textHome":"姐姐赢了哦！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":100100,"motion":100}]}],"group_38":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_46","textHome":"是不是变成了厉害的姐姐了呢？"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"id":100100,"motion":100}]}],"group_39":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_63","textHome":"通往希望……未来……之路！！"}]},{"autoTurnFirst":1.7,"chara":[{"id":100100,"motion":400}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_05","textHome":"果然……这两人不在的话感觉就少了些什么。@两位……欢迎回来。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":100100,"motion":100}]}],"group_40":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_64","textHome":"愿这一箭……化为通向未来的道路！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":300}]}],"group_41":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_65","textHome":"思念着想要守护之人的心情……@现在成为我的力量！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100,"motion":1}]}],"group_42":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_66","textHome":"结束吧……不会再让任何人悲伤了！"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"id":100100,"motion":400}]}],"group_43":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_02","textHome":"我叫环彩羽。如果有什么我能帮上忙的，@请尽管开口。……虽然……@听起来好像有点大言不惭……"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":100100,"motion":301}]}],"group_5":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":1,"pos":1,"voice":"vo_char_1001_00_13","textHome":"每当变得更强的时候，@我的心就会怦怦跳地期待起更光明的未来。"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100,"motion":300}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100100,"motion":300,"pos":1,"voice":"vo_char_1001_00_14","textHome":"竟然能达到这样的程度……我……@是不是可以再自信一点呢……？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100,"motion":1}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_15","textHome":"嗯……哈……总感觉心情舒畅了许多……@没问题，我能行。"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":100100}]},{"autoTurnFirst":3.1,"chara":[{"id":100100,"motion":300}]},{"autoTurnFirst":2.6,"chara":[{"id":100100,"motion":1}]}],"group_8":[{"autoTurnFirst":0.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":0,"pos":1,"voice":"vo_char_1001_00_16","textHome":"小忧是世界第一的妹妹哦……所以我也希望，@有朝一日能让小忧自豪地说，@我是她「世界第一的姐姐」。@我会一点一点慢慢改变的！"}]},{"autoTurnFirst":2.8,"chara":[{"id":100100,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_021.exp.json","id":100100,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":100100}]},{"autoTurnFirst":3.0,"chara":[{"id":100100,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":100100,"motion":300}]}],"group_9":[{"autoTurnFirst":7.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100100,"motion":200,"pos":1,"voice":"vo_char_1001_00_17","textHome":"我和小忧能相互展现出真实的笑容的时候……@那就是我们两个真正再会的时候吧。"}]},{"autoTurnFirst":2.7,"chara":[{"id":100100,"motion":0}]},{"autoTurnFirst":3.6,"chara":[{"id":100100,"motion":300}]}]},"version":3}