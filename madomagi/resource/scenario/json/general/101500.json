{"story":{"group_1":[{"autoTurnFirst":2.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_01","textHome":"我叫环忧，其实才刚刚成为魔法少女。@还有，因为一直住院，有很多事情不太懂。@可能会多麻烦你，希望你不要介意。@啊，其实我的姐姐也是魔法少女来着，@下次介绍给你哦。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":5.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":101500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_10":[{"autoTurnFirst":3.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_17","textHome":"虽然我看上去很开朗阳光，@但住院的时候还是哭了很多次……@但是，不要告诉姐姐哦。@总感觉她也会伤心的……"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":101500}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":100}]}],"group_11":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_18","textHome":"虽然只是些许，但我感受到了。@姐姐在学校，好像也有很多难事。@但我不说，这件事就藏在我心里吧。"}]},{"autoTurnFirst":5.0,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_19","textHome":"收到大家的力量……@我会把它合为一体发射出去！"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":101500}]}],"group_13":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_20","textHome":"先不说魔法少女，得先适应外面的生活才行。@"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]}],"group_14":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_21","textHome":"右左右，绿灯！嗯，我在学习交通规则！@但是，还是有点吓人。@城市里有好多车辆会朝人撞过来啊。"}]},{"autoTurnFirst":0.7,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":1.7,"chara":[{"id":101500,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":300}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_22","textHome":"现在的目标是，帮上大家的忙。@不要吵架，好好相处，一起歌唱与欢笑。@虽说这话有点太理想了，但我真的想做到！@关于这一点，我就和姐姐一样的顽固了。"}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":6.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]}],"group_16":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_23","textHome":"认识了许多人，了解到人与人之间的差别。@人们要同心协力是一件非常困难的事情……@但是，就算明知如此，也不能放弃。@只要抱持希望，人与人就能携起手来。"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101500}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":101500,"motion":200}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]}],"group_17":[{"autoTurnFirst":5.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_24","textHome":"哇，好开心，还记得我啊。但是不要紧吗？@我可能会拖累你的……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":101500}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":300}]}],"group_18":[{"autoTurnFirst":7.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_25","textHome":"打开窗户，就能听到啾啾鸟鸣，@探出头来，能呼吸到清新的空气。@呼呼，真是心情舒畅的早晨！"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":1.2,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_19":[{"autoTurnFirst":1.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_26","textHome":"章鱼香肠、水煮西兰花加上土豆沙拉。@这是我学着姐姐的样子做的，怎么样？@看起来就很好吃吧？"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]},{"autoTurnFirst":1.8,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":101500,"motion":100}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_02","textHome":"我叫环忧。诶……谢谢你选中我！我很开心！@为了大家的笑脸，我会努力战斗的！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":3.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":101500,"motion":100}]}],"group_20":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_27","textHome":"最喜欢傍晚到入夜这段时间，@感觉就像是一家团圆的时间。@今天也能和大家一起吃饭，@然后看电视，真让人期待。"}]},{"autoTurnFirst":3.5,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_21":[{"autoTurnFirst":3.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_031.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_28","textHome":"呜呜……好黑……灯花？音梦？@啊，已经不在医院了……@姐姐还醒着吗……？"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":6.0,"chara":[{"id":101500,"motion":300}]}],"group_22":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_29","textHome":"不行不行……！@一不留神就唱起歌来了，要控制才行……@前阵子才被别人笑了，@搞不好会被当作奇怪的人，要忍住……"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":101500}]}],"group_23":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_30","textHome":"虽然已经可以独自讨伐魔女了，@但其实还是会害怕……@但并不是害怕魔女，而是害怕会迷路……"}]},{"autoTurnFirst":2.5,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":101500}]}],"group_24":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_31","textHome":"不要不要……！@镜之府邸就是像鬼屋一样的地方吧！？@诶？结界吗？那样的话还行……吧？"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":8.0,"chara":[{"id":101500,"motion":300}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_32","textHome":"唉，不是打架的时候啊！@先好好沟通才行，你说对吧？"}]},{"autoTurnFirst":2.5,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]}],"group_26":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_33","textHome":"我其实也很会画画哦？@音梦和灯花想故事，我负责画画。@啊，肖像我也会画哦！？"}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]},{"autoTurnFirst":4.0,"chara":[{"id":101500,"motion":200}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_34","textHome":"我最喜欢体育课啦。@那时候虽然也有教书的人，@但是一点都没有运动，@现在来说特别新奇！"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_35","textHome":"最近拍了些照片传到社交媒体上了。@你看，夕阳下的猫，还有花！@啊，但是不会上传自己的照片啦，不安全。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":300}]},{"autoTurnFirst":1.5,"chara":[{"id":101500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":101500}]}],"group_29":[{"autoTurnFirst":8.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_36","textHome":"以前啊，院内的老师们找来附近的大学生，@开了合唱团。我可喜欢合唱了，超开心！"}]},{"autoTurnFirst":1.8,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_3":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_03","textHome":"我能做到什么呢？@我又想成为什么样的人呢……"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":101500}]}],"group_30":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_37","textHome":"灯花和音梦以前都很倔，老是吵起来。@现在相处得这么好，我很开心。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":101500}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_31":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_38","textHome":"诶嘿，现在在和家里人开群通话呢。@告诉了爸爸妈妈我体育课拿了第一的事，@他们可惊讶了。"}]},{"autoTurnFirst":4.0,"chara":[{"id":101500,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"id":101500,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_32":[{"autoTurnFirst":2.3,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":101500,"motion":300,"pos":1,"tear":1,"voice":"vo_char_1015_00_39","textHome":"呜……为了生病的我，@姐姐居然研究了这么多料理配方……@这本笔记里，真是装满了思念啊……"}]},{"autoTurnFirst":7.7,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":9.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":101500,"motion":0,"tear":1}]}],"group_33":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_40","textHome":"每分每秒，我的世界都在延展……@所以我不后悔哦。@真想不到我也有能这样去感受世界的时候。"}]},{"autoTurnFirst":3.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":101500}]},{"autoTurnFirst":7.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]}],"group_34":[{"autoTurnFirst":3.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_41","textHome":"我啊，已经有喜欢的人了。那就是……姐姐！@还有灯花和音梦！@哼哼，我最喜欢大家了！"}]},{"autoTurnFirst":2.0,"chara":[{"id":101500,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":101500}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":101500,"motion":200}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_42","textHome":"全部吸收掉哦！"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_43","textHome":"姐姐，我也能打败敌人了！"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_44","textHome":"嗯，能力状态稳定！"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_45","textHome":"谢谢你，燕子！"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_46","textHome":"是不是能帮上忙了呢？"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_04","textHome":"太好啦。@这样三日月别墅的大家就都能友好相处啦。"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500}]}],"group_40":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1015_00_63","textHome":"大家，借与我力量！"}]}],"group_41":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_64","textHome":"变成照亮未来的光吧！"}]}],"group_42":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1015_00_65","textHome":"穿透天空。"}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":101500,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1015_00_66","textHome":"Luce Speranza！"}]}],"group_5":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":101500,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1015_00_05","textHome":"这就是我的未来。@从今天开始就要认真努力。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":101500,"motion":0}]}],"group_6":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":101500,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1015_00_13","textHome":"虽然看上去没变……但其实有变化了。@感觉身体里暖洋洋的。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":101500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":101500}]}],"group_7":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":101500,"motion":300,"pos":1,"