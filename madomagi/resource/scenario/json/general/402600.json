{"story":{"group_1":[{"autoTurnFirst":4.25,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_4026_00_01","textHome":"初次见面。我是爱丽莎·瑟尔斯加，@神圣罗马帝国皇妃芭芭拉的女儿！@诶，有什么好惊讶的吗？@不管对方是谁，都要自豪地报出自己的名号。@这是我的母亲大人教导我的！"}]},{"autoTurnFirst":4.0,"chara":[{"id":402600,"motion":200}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402600,"motion":0}]},{"autoTurnFirst":5.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402600,"motion":1}]}],"group_10":[{"autoTurnFirst":9.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_4026_00_17","textHome":"初次见面就轻易相信我的直率。@无视一切挑衅的谦虚……@这都是塔鲁特有，而我没有的品质。"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":402600,"motion":300}]}],"group_11":[{"autoTurnFirst":7.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_4026_00_18","textHome":"……我曾经被宫廷流放，@利用魔法的力量才得以回归。@对我的态度从没变过的，只有沃尔爷爷。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402600,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402600,"motion":0}]}],"group_12":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402600,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4026_00_19","textHome":"我的武器似乎也跟上了我的成长！"}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402600,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_4026_00_20","textHome":"可以说，奔赴战场的经验，@终于在今天开花了吗？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402600}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4026_00_21","textHome":"我将凭借这份力量，劈开未来的道路！@我不相信什么预言。@我无法忍受至今为止的战斗@就因这种玩意儿被一笔勾销！"}]},{"autoTurnFirst":2.0,"chara":[{"id":402600,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":402600}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"id":402600,"motion":200}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402600,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4026_00_22","textHome":"我的母亲·皇妃芭芭拉的愿望@正是欧洲的安宁……@我会尽我全力，支援塔鲁特，完成使命的。@赌上我，与我神圣罗马帝国龙骑士团的荣耀！"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402600}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":2.5,"chara":[{"id":402600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600}]},{"autoTurnFirst":6.0,"chara":[{"id":402600,"motion":200}]}],"group_16":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4026_00_23","textHome":"我从未想过会有一天到达这样的高度。@即便如此，此身化作魔女之日也终将会到来。@明知如此也要前进，@正是因为有着想要活着实现的愿望。"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600,"motion":300}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":1,"id":402600}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":4.0,"chara":[{"id":402600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402600,"motion":200}]}],"group_17":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4026_00_24","textHome":"啊，贵安？……嗯，有什么奇怪的吗？@我只是像在皇宫里一样，@优雅地打了个招呼而已。"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402600,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402600,"motion":100}]}],"group_18":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402600,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4026_00_25","textHome":"嗯？什么啊？@哈！？已经早上了！？@等、等一下！@我现在就换衣服过去！"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402600,"motion":400}]},{"autoTurnFirst":5.5,"chara":[{"id":402600,"motion":200}]}],"group_19":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_26","textHome":"到了用餐时间呢。请不要有所顾虑。@我作为龙骑士团的一员也在战场上生存过，@粗糙的饮食也早已习惯。"}]},{"autoTurnFirst":7.0,"chara":[{"id":402600,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402600,"motion":100}]}],"group_2":[{"autoTurnFirst":8.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"tear":0,"voice":"vo_char_4026_00_02","textHome":"我是神圣罗马帝国皇帝西吉斯蒙德的伟大皇妃@芭芭拉·瑟尔斯加的女儿。@龙骑士团的一员爱丽莎·瑟尔斯加！@请多关照！"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":402600}]},{"autoTurnFirst":0.6,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":1.6,"chara":[{"id":402600,"motion":200}]},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402600}]}],"group_20":[{"autoTurnFirst":4.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":200,"pos":1,"voice":"vo_char_4026_00_27","textHome":"干什么呀，沃尔爷爷！我正在洗澡呢……@哎呀？原来是你啊。@既然叫我的话，肯定有什么特别重要的事吧？"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402600,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402600,"motion":1}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":402600}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":0,"id":402600}]}],"group_21":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_28","textHome":"为了备战，差不多该去睡了。@因为我的身体是神圣罗马帝国皇帝陛下，@还有母亲而存在的。"}]},{"autoTurnFirst":3.5,"chara":[{"id":402600,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402600}]}],"group_22":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4026_00_29","textHome":"就像被塔鲁特吸引了一样，@从各地而来的魔法少女集结起来了……@这也是因为，这是一场@将决定欧洲的未来的战斗！"}]},{"autoTurnFirst":3.0,"chara":[{"id":402600,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":402600,"motion":200}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4026_00_30","textHome":"好了好了！休息已经结束了！！@没有忘记这里是战场吧？@外面开始变得躁动不安了。@赶紧准备吧。"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402600}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":402600,"motion":200}]}],"group_24":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_31","textHome":"就算是魔法少女的样子，@也不改变对方是敌人的事实。@就让我向这龙型徽章起誓，@把它们全部消灭吧！"}]},{"autoTurnFirst":2.5,"chara":[{"id":402600,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":402600,"motion":200}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402600,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4026_00_32","textHome":"什么，你居然催促起我来……！@嗯，是要去和其他魔法少女们较量对吧？@不必多说了！"}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":402600,"motion":1}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_020.exp.json","id":402600,"motion":200}]}],"group_26":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"voice":"vo_char_4026_00_33","textHome":"不用叫我“爱丽莎大人”，@就叫我“爱丽莎”就行了。@不必拘谨。我是不会在乎这些的。"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600,"motion":200}]}],"group_27":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_34","textHome":"嗯？我的武器？噢嚯嚯嚯！@这是使用炼金术的锻造而成的五管火枪。@是佩蕾……咳咳，@是某个炼金术师交给我的魔法之枪。"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402600,"motion":100}]},{"autoTurnFirst":5.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":402600,"motion":200}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402600}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":402600,"motion":0}]},{"autoTurnFirst":0.6,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600,"motion":1}]}],"group_28":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_35","textHome":"去确认一下“圣女”的实力，@要是那份力量是真的的话，那就去协助她……@这就是母亲交予我们龙骑士团的使命。"}]},{"autoTurnFirst":6.5,"chara":[{"id":402600,"motion":300}]}],"group_29":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":300,"pos":1,"voice":"vo_char_4026_00_36","textHome":"我在成为魔法少女，@是因为遇见了炼金术师佩蕾奈尔和丘卜……@我真想骂自己当初怎么就轻信了他们！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":402600,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"id":402600,"motion":200}]}],"group_3":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402600,"lipSynch":1,"motion":1,"pos":1,"tear":0,"voice":"vo_char_4026_00_03","textHome":"哼！真无聊呢。"}]}],"group_30":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_37","textHome":"生于意大利的莉兹，@总是称呼我叫「公主·爱丽莎」……@或者是爱丽莎王女。@我倒是希望她能对我不要这么见外。"}]},{"autoTurnFirst":2.8,"chara":[{"id":402600,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402600,"motion":1}]}],"group_31":[{"autoTurnFirst":5.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_38","textHome":"梅丽莎……初次交手竟然就把我丢飞了出去！@下次如果还有机会比试的话，@我一定要把她打得落花流水！"}]},{"autoTurnFirst":2.0,"chara":[{"id":402600,"motion":400}]},{"autoTurnFirst":3.3,"chara":[{"id":402600,"motion":1}]},{"autoTurnFirst":0.8,"chara":[{"eyeClose":1,"id":402600,"motion":200}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":0,"id":402600}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_39","textHome":"我并不是王女，@只是皇妃芭芭拉的私生女……@我为了自己的存在被认可，@所以一直奔波于战场中。"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":402600,"motion":300}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402600}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":402600}]},{"autoTurnFirst":3.0,"chara":[{"id":402600,"motion":0}]}],"group_33":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402600,"lipSynch":1,"motion":0,"pos":1,"voice":"vo_char_4026_00_40","textHome":"塔鲁特不管什么时候，@都在为了他人而不断战斗。@坚韧，崇高，所以大家都很敬仰她。"}]},{"autoTurnFirst":4.0,"chara":[{"id":402600,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402600,"motion":1}]}],"group_34":[{"autoTurnFirst":5.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402600,"lipSynch":1,"motion":400,"pos":1,"voice":"vo_char_4026_00_41","textHome":"什么……你说丘卜是天使大人！？@那家伙算哪门子的天使嘛！@这种跟化了的奶油蛋糕一样的东西！！"}]},{"autoT