{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_01","textHome":"虽然还有很多不明白的事情，但在麻美学姐的@教导下，我也想靠自己的努力，成为能帮上@大家的魔法少女……啊，光是想可不行！@我在努力！啊，对了！之前，麻美学姐还@夸奖了我呢！诶嘿嘿......"}]},{"autoTurnFirst":6.5,"chara":[{"id":200151,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_051.exp.json","id":200151,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"face":"mtn_ex_041.exp.json","id":200151}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_10":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_18","textHome":"沙耶香和杏子也成为了朋友了哦。虽然她们两个@总是吵架，但关系很好呢！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"face":"mtn_ex_041.exp.json","id":200151}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]}],"group_11":[{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_19","textHome":"现在的我怎么样？有什么奇怪的地方吗……？"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200151}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_20","textHome":"怎么回事呢……感觉眼前都变明亮了……"}]},{"autoTurnFirst":5.0,"chara":[{"id":200151,"motion":200}]}],"group_13":[{"autoTurnFirst":8.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_21","textHome":"我们家是妈妈在外工作，爸爸在家料理家务。@所以爸爸是家庭主夫。@不过，大家关系很好哦！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_011.exp.json","id":200151,"motion":100}]}],"group_14":[{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_22","textHome":"家人、朋友或是魔法少女同伴们，@大家都是我所珍视的人。@所以，有什么事我都要帮助他们。@如果这些都是魔女的罪行，@那我就得更加努力才行呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151}]},{"autoTurnFirst":0.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200151,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200151}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200151,"motion":200}]}],"group_15":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_23","textHome":"虽然只是假设……如果有一天遇到了很强的@魔女，我还能够战斗下去吗……但是，不管@对方多强，我也不会放弃保护大家的使命。@希望一定是存在的，对吧……"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200151}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200151,"motion":300}]},{"autoTurnFirst":7.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200151,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]}],"group_16":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_51_24","textHome":"来了来了！我在等你哦！今天也尽情玩耍吧！@夏天的海边有很多有趣的事情哦！"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":200151,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_51_25","textHome":"早上好，睡得香吗？@我有些太兴奋了，都没怎么睡着。@昨晚一直在想玩什么、吃什么味的@刨冰这样杂七杂八的事情。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_041.exp.json","id":200151,"motion":300}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_51_26","textHome":"提到白天的海之家那就是炒面了，对吧！@哼哼，为什么呢？因为特别的好吃。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":201}]}],"group_19":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1,"pos":1,"voice":"vo_char_2001_51_27","textHome":"我喜欢从学校回来之后，@在开着空调的屋里吃冰淇淋～@感觉特别的幸福。"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151}]},{"autoTurnFirst":4.8,"chara":[{"id":200151,"motion":300}]}],"group_2":[{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_03","textHome":"为了不拖累麻美学姐，我要变得更强才行！"}]}],"group_20":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":201,"pos":1,"voice":"vo_char_2001_51_28","textHome":"晚上是烟花大会！@沙耶香准备了好多烟花，各式各样都有。@该从哪一种开始呢？"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":200151,"motion":1}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_21":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":201,"pos":1,"voice":"vo_char_2001_51_29","textHome":"给你运动饮料。@为了不被暑气侵袭，@要好好补充水分和盐分才行。@要是身体状况不好的话，也就没法享受了嘛。"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":100}]}],"group_22":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":200151,"motion":400,"pos":1,"voice":"vo_char_2001_51_30","textHome":"哇！魔女的气息！@为了不让魔女打扰大家享受夏天，@要快点收拾掉它。"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"id":200151,"motion":201}]}],"group_23":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_51_31","textHome":"是夏天的暑气形成的海市蜃楼……@不对，是镜子里的我们吧。@不管是什么，都不能掉以轻心！"}]},{"autoTurnFirst":3.2,"chara":[{"id":200151,"motion":100}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":201}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1,"pos":1,"voice":"vo_char_2001_51_32","textHome":"既然在夏天聚集了这么多魔法少女的话，@就用夏天的方式战斗吧？游泳比赛之类的！@诶，不行吗？"}]},{"autoTurnFirst":3.0,"chara":[{"id":200151,"motion":201}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_51_33","textHome":"虽然是因为对游泳没什么自信才带的游泳圈，@但像这样浮在水上也很舒服呢。@我去向大家推荐一下吧。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100}]}],"group_26":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":1,"pos":1,"voice":"vo_char_2001_51_34","textHome":"呜，走不稳了……西瓜，不在这里吗？@呜……脚也不听使唤了……呀！好冷！@诶嘿嘿，不小心走到海水上了。"}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":200151}]},{"autoTurnFirst":1.6,"chara":[{"id":200151,"motion":0}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":200151}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200151,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_041.exp.json","id":200151,"motion":300}]}],"group_27":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_51_35","textHome":"快看快看，这里有小螃蟹……啊！躲起来了。@嗯？这里的小虾也好可爱！@沙滩边也很有趣啊。"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_051.exp.json","id":200151,"motion":400}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":1}]}],"group_28":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_51_36","textHome":"我想试试桃子味的刨冰！@和大家一起换着吃也很开心呢。@张嘴，啊——嗯……@诶嘿嘿，稍微有些害羞呢。"}]},{"autoTurnFirst":4.1,"chara":[{"id":200151,"motion":100}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":201}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"id":200151,"motion":1}]}],"group_29":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_51_37","textHome":"这件泳装怎么样？@是不是有些太花哨了……@不过妈妈觉得这样比较好……诶嘿嘿。"}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_04","textHome":"能做出这样的事的，只有魔女吧……!?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"face":"mtn_ex_040.exp.json","id":200151}]}],"group_30":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_51_38","textHome":"小焰的泳装超级可爱对吧！@发饰上的花，还有背后的缎带都很可爱！"}]},{"autoTurnFirst":3.8,"chara":[{"id":200151,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":201}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_51_39","textHome":"杏子的泳装也很不错啊。@明年，我也想穿和杏子一样的泳装。@嗯，不知道会合适吗？"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":200151,"motion":1}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_51_40","textHome":"明年，想和大家一起去挑泳装。@一起讨论决定哪件合适，哪件更加可爱的话，@一定会很有趣。"}]},{"autoTurnFirst":4.7,"chara":[{"id":200151,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":200151,"motion":300}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_060.exp.json","id":200151,"motion":400,"pos":1,"voice":"vo_char_2001_51_41","textHome":"烫！好烫～沙滩好烫啊！@我把沙滩凉鞋放在海之家了～@呜……还是回去拿上吧。"}]},{"autoTurnFirst":2.0,"chara":[{"id":200151,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":200151,"motion":200}]}],"group_34":[{"autoTurnFirst":4.2,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_42","textHome":"我必须要保护大家……！"}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_43","textHome":"太好了……像是赢了呢！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]}],"group_36":[{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_00_44","textHome":"太棒了~！好厉害！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151}]}],"group_37":[{"autoTurnFirst":1.1,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_45","textHome":"嗯嗯！感觉不错呢！"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]}],"group_38":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_041.exp.json","id":200151,"motion":300,"pos":1,"voice":"vo_char_2001_00_46","textHome":"哈~，总算是结束了……！"}]},{"autoTurnFirst":4.0}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_63","textHome":"我有想要守护的东西！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200151}]}],"group_4":[{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_05","textHome":"虽然已经结束了，但还是平静不下来呢~"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":-1,"face":"mtn_ex_030.exp.json","id":200151,"motion":300}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_64","textHome":"我一定会消灭掉你！"}]}],"group_41":[{"autoTurnFirst":2.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_65","textHome":"这一箭，带上我的意念……贯穿它！"}]},{"autoTurnFirst":3.0,"chara":[{"id":200151,"motion":400}]}],"group_42":[{"autoTurnFirst":1.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_66","textHome":"为了大家的笑容……！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"face":"mtn_ex_020.exp.json","id":200151}]}],"group_43":[{"autoTurnFirst":3.5,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":1,"pos":1,"voice":"vo_char_2001_00_02","textHome":"我叫鹿目圆。就叫我小圆吧！@虽然才成为魔法少女不久，但我会加油的！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":0}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_00_13","textHome":"稍微变强了一点吧？……嗯，感觉到了！"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":200151,"motion":200,"pos":1,"voice":"vo_char_2001_00_14","textHome":"这样就能帮助更多的人了！"}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_00_15","textHome":"麻美学姐说，我的魔力还能变得更强！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151}]}],"group_8":[{"autoTurnFirst":3.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":200151,"motion":0,"pos":1,"voice":"vo_char_2001_00_16","textHome":"因为以前没有用过弓箭，一开始用的时候还很@不习惯。现在已经没问题了！用得很顺手呢！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":-1,"face":"mtn_ex_041.exp.json","id":200151}]},{"autoTurnFirst":5.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151,"motion":100}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":200151,"motion":100,"pos":1,"voice":"vo_char_2001_00_17","textHome":"小焰的时间停止魔法很厉害哦！@我也好想试试啊。对着静止的对手@就可以一个劲射箭了呢。"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":200151,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":2,"face":"mtn_ex_011.exp.json","id":200151}]}]},"version":3}