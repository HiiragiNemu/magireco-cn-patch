{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_01","textHome":"啊，稍等！我妆就快化完了……OK！@来啦来啦！我是木崎衣美里，想要心动的感觉！@不管什么都可以！就是说，不论何时何地，@我都想要心动的感觉！@发现有意思的事情，就来告诉我呀～！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":3.5,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":0.5,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_18","textHome":"我能做到了呢……那个……高尔夫……@就是用一球……对，一杆进洞！很难对吧？@但是，现在的我一发就行啦！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":1,"id":300600,"motion":100}]},{"autoTurnFirst":1.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_11":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_19","textHome":"哦，这不是来了嘛？我已经超越极限了！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_12":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_20","textHome":"等等！我的脑中咣地一下，完全醒悟了——！"}]},{"autoTurnFirst":0.5,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_13":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300600,"motion":400,"pos":1,"voice":"vo_char_3006_00_21","textHome":"天啊！我的头脑现在超级灵活！……42。@看吧！怎么样！？诶？这是什么？@是6*7的答案啦！平常才没法脱口而出呢！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_14":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_22","textHome":"嗯～我的头脑好像越来越好了！啊，我发现了@惊人的事情，想听吗？嗯……「如果不花钱，@钱就不会变少，那么马上就能变成有钱人了」@……很厉害吧！？必胜法则呀！？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300600,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"id":300600,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600,"motion":100}]}],"group_15":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":300,"pos":1,"voice":"vo_char_3006_00_23","textHome":"现在头脑已经极致灵光了，我要喊啦……@UFO！我对宇宙很有兴趣！所以让我试试！@开始喽～宇宙中的外星人，听得到吗？@现在，有空吗？一起去哪里玩吧？"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":5.8,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600,"motion":100}]}],"group_16":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_24","textHome":"你好呀！有精神吗？我超有精神的！@一飞冲天的气势哦！@今天也想要找到令人心动的事情！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":100,"pos":1,"voice":"vo_char_3006_00_25","textHome":"早上好！我，早上状态超好的！@醒来就是电光火石，蓄势待发！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_18":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_26","textHome":"肚子好饿——！好嘞，便当……@啊，刚刚已经吃光了！@呜哇——糟糕，好饿啊——！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":400}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300600}]},{"autoTurnFirst":5.0,"chara":[{"id":300600,"motion":300}]}],"group_19":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_27","textHome":"我说我说——我们去吃东西吧？@吃什么，甜点啦～甜点。@蛋糕？不对……是蜜豆！我的最爱！"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_2":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_03","textHome":"魔法少女真是辛苦啊～@但好像很有趣呢！"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":2.3,"chara":[{"id":300600,"motion":200}]}],"group_20":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_28","textHome":"晚上睡觉很浪费对吧？每天都熬到眼皮打架，@实在不行了再倒下睡觉。那样子最棒了！"}]},{"autoTurnFirst":4.5,"chara":[{"id":300600,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_21":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_29","textHome":"是谁规定的一天24小时？完全不够用嘛！@要是能靠气势延长一下就好了……"}]},{"autoTurnFirst":3.0,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":1}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_30","textHome":"耶耶耶！我等好久了——！快走快走——！@我一定要找到令人心动的东西！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_23":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_31","textHome":"没问题没问题！……虽然没什么自信！@啊哈哈！嗯，就交给我吧！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.1,"chara":[{"id":300600,"motion":0}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_32","textHome":"看起来很有趣嘛！大家一起战斗，@气势就该到最最最最高！这样才对吧！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_33","textHome":"（认真）嗯嗯……哇……果然没错……@我今天的妆，很漂亮对吧？嘿嘿——！"}]},{"autoTurnFirst":3.0,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_26":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_34","textHome":"嗯，我知道魔法少女是很危险的！@但是，没有办法吧，做都做了嘛！"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":2.0,"chara":[{"id":300600,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":100}]}],"group_27":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_35","textHome":"经常被人说我太轻率了……@不，才不是那样！我只是做决定很快而已！"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300600}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":300600}]}],"group_28":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_36","textHome":"哇——！我看到了一个好可爱的女孩子！@呜哇——天啊——！只要一想起来……@就感觉不得了啊！我，最喜欢可爱的人了！"}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":100}]}],"group_29":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_37","textHome":"那个那个！我想知道，你是狗派、还是猫派？@我啊，是猫狗派！两个都喜欢！@我还是熊猫派！其实我还是美洲鬣蜥派呢！"}]},{"autoTurnFirst":1.5,"chara":[{"id":300600,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":0}]}],"group_3":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_04","textHome":"怎么会变成这样。@算了，也行吧……"}]}],"group_30":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_38","textHome":"总之我没办法闲下来！要是不做点什么的话，@我就会坐立不安。所以一起来玩吧！来嘛！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":300600,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":200}]}],"group_31":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_39","textHome":"别看我这样，我也很喜欢钓鱼的。@小时候就和男孩子一起去钓过鱼，@下次就让你见识一下我的鬼钓之术吧！"}]},{"autoTurnFirst":4.5,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_32":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_40","textHome":"我经常会去捕虫哦。我最喜欢的就是蚂蚱了。@不是蝗虫哦。蚂蚱啦，它的腿，很帅不是吗？"}]},{"autoTurnFirst":3.5,"chara":[{"id":300600,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"id":300600,"motion":200}]}],"group_33":[{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_41","textHome":"好想离那个人再近一点，我憧憬的那个人……@但是我已经走远了……@嘛，会寂寞也是没办法的事啊！"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_42","textHome":"速战速决！"}]}],"group_35":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600,"motion":100,"pos":1,"voice":"vo_char_3006_00_43","textHome":"耶！胜利～！"}]}],"group_36":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_44","textHome":"只是热身而已！"}]}],"group_37":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":100,"pos":1,"voice":"vo_char_3006_00_45","textHome":"感觉不错～♪"}]}],"group_38":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_46","textHome":"我可是恶魔级别的哦！"}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_63","textHome":"啊哈哈～！接招吧！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_4":[{"autoTurnFirst":3.1,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_05","textHome":"莉爱她闪闪发亮的呢！@真让我心动不已！"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_40":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_64","textHome":"快看快看！我灵敏的身姿！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_41":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":100,"pos":1,"voice":"vo_char_3006_00_65","textHome":"慢慢有感觉了！那么！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_42":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_66","textHome":"就让你尝尝，这份心动的感觉吧！"}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_43":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_02","textHome":"我？木崎衣美里！@总之有我在的话总会有办法的！@虽然我也不太明白！啊哈哈！@初次见面！请多指教！"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":100}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"id":300600,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":300600,"motion":100}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_13","textHome":"我，有没有变可爱啊！？@怎么样怎么样——！？"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_6":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_14","textHome":"我是不是变得更有魅力了呢？@这还没到我的极限呢！"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_7":[{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":0,"pos":1,"voice":"vo_char_3006_00_15","textHome":"我啊，已经达到凌驾于@魔法少女之上的境界了呢——！"}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":200}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_8":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600,"motion":1,"pos":1,"voice":"vo_char_3006_00_16","textHome":"我有时也会去……棒球训练场。所以呀，@现在的我差不多就是挥棒即本垒打的状态！"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":300600,"motion":200}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":300600,"motion":0}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":0.5,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]}],"group_9":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":300600,"motion":200,"pos":1,"voice":"vo_char_3006_00_17","textHome":"啊——我现在超得心应手！嗯！如果打@保龄球的话……就能打出狸猫了呢。@诶？不对？啊，是火鸡啊！对对！"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":300600}]},{"autoTurnFirst":2.5,"chara":[{"id":300600,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":300600}]},{"autoTurnFirst":1.5,"chara":[{"id":300600,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":300600}]},{"autoTurnFirst":2.0,"ch