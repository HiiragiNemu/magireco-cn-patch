{"story":{"group_1":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_01","textHome":"要说自己的话题，真是麻烦死了耶。@话说回来，如果你去看看美术杂志，@就会知道阿莉娜是天才艺术家了。@所以，就自己先去看看再来问行吧。@私人的事情就放在以后，理解了吗？"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800}]}],"group_10":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_18","textHome":"阿莉娜心跳加速了。@因为马上有杰作要诞生了。@看看就明白了吧？这高度……"}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":100}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_19","textHome":"啊……有什么东西熟透了，@就在阿莉娜身体里……"}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_20","textHome":"入门就是培养基础，和绘画是一样的。"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_21","textHome":"感觉又上了一层楼……@哼，就好像第一次找到了@自己想表现的style一样的感觉。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":100}]}],"group_14":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100800,"motion":400,"pos":1,"voice":"vo_char_1008_00_22","textHome":"什么，这是……没见过……@阿莉娜没见过的……真是刺激爆了！@哈……太强了，就好像发现了新大陆……@怎么办，兴奋极了……"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"face":"mtn_ex_010.exp.json","id":100800}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":100800,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":100}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_23","textHome":"这兴奋的感觉，就好像变得无所不能一样。@仿佛连牺牲一切展现毁灭之美也能表现出来。@啊……大家会来看吗……阿莉娜的最终作品。"}]},{"autoTurnFirst":6.5,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":200}]}],"group_16":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_24","textHome":"哈……又来了？真觉得你来得太频繁了……@嘛，阿莉娜反正是自由自在的，不用理会。@好，说完了。"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"id":100800,"motion":0}]}],"group_17":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_25","textHome":"什么……天已经亮了吗……阿莉娜可不管。@呜……水呢……阿莉娜早上不能没水喝……@快，bring me……"}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":200}]}],"group_18":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_26","textHome":"昨晚一直在肝画，白天就要午睡。@所以，go away，去那边。@要是打扰我的话，就等着吃苦头吧。"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":200}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_27","textHome":"去活动室一看，那fool girl又在。@大概又要请我看没意思的漫画了……@哈……这家伙早点进步就好了……"}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":200}]}],"group_2":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_03","textHome":"阿莉娜的作品，本应该更加优秀才对……"}]}],"group_20":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_28","textHome":"有空看阿莉娜画画，是很闲吧。@不如早点睡了好……@哼哼，难道是有什么事忍着？"}]},{"autoTurnFirst":3.3,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_29","textHome":"必须要完成最高杰作的阿莉娜，一直都很忙。@可没时间跟你磨叽。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":400}]}],"group_22":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_30","textHome":"这反应是，可爱迷人又美丽的魔女。@是消灭掉、养起来还是喂掉，@等见面之后再想吧～"}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_013.exp.json","id":100800}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_31","textHome":"要是别的魔法少女敢来碍阿莉娜的事，@那为了实现目标除了抹消掉就别无他法了。@那，该做出个什么样的作品好呢？"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":100}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_32","textHome":"人数众多的战斗，阿莉娜可没有兴趣。@倒是阿莉娜一个人不在的话，@应该不会被发现吧……"}]},{"autoTurnFirst":5.5,"chara":[{"id":100800,"motion":0}]}],"group_25":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_33","textHome":"嘿，知道阿莉娜的死者复生系列吗？@虽然说觉得它引起不适的人很多，@但能欣赏的人一定能从中感受到生命吧。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":6.0,"chara":[{"id":100800,"motion":100}]}],"group_26":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_34","textHome":"阿莉娜对食物的质量没什么要求。@只要能吃下肚就可以了，@反正专心画画的时候也是食不知味。"}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":100}]}],"group_27":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_35","textHome":"绘画、陶艺、手工、装置，@成为阿莉娜创作的根基的，@大概是在自家画廊里所受到的@各位名家的启发吧。"}]},{"autoTurnFirst":8.5,"chara":[{"id":100800,"motion":100}]}],"group_28":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_36","textHome":"盯——你看我，所以我也看你，@但是一点意思也没有。@感觉根本不够刺激啊。"}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300}]}],"group_29":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_37","textHome":"对，美冬的身体是最棒的！@作为女性而言曲线和柔韧性都无比精巧，@让我对着画上100小时的素描也没问题。"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":5.0,"chara":[{"id":100800,"motion":100}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_04","textHome":"只能创作出阿莉娜最终的作品了……"}]}],"group_30":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_38","textHome":"利害关系……@三位玛吉斯之间的联系也不过如此吧。@所以另外两位的goal，阿莉娜根本不感兴趣。"}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":3.7,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":400}]}],"group_31":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_39","textHome":"哈？谁说不升学了？@阿莉娜可是打算上大学的。@因为想从旁观察一下大学里的人生百态呢。"}]},{"autoTurnFirst":4.5,"chara":[{"id":100800,"motion":200}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_40","textHome":"迎合他人needs而创作@和阿莉娜的信条是相违的。@不如说，阿莉娜是把别人@卷入自己的路线里的风格。"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100}]}],"group_33":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_41","textHome":"烦死了。就不会看场面这一点，@跟我家那fool girl真是一模一样。@叫什么……御园花凛来着。"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":300}]},{"autoTurnFirst":1.0,"chara":[{"id":100800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":200}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_42","textHome":"来开派对吧♪"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_43","textHome":"呼，开始兴奋了。"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_44","textHome":"哈……阿莉娜差不多看腻了。"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_45","textHome":"这种事真是令人上瘾呢。"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_46","textHome":"连变成阿莉娜的作品的价值都没有。"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_63","textHome":"喂，让阿莉娜满足吧！"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_05","textHome":"啊——哈哈哈哈……哈，真让人兴奋。"}]},{"autoTurnFirst":3.0,"chara":[{"id":100800,"motion":200}]}],"group_40":[{"autoTurnFirst":5.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_64","textHome":"就在我眼前，啊……慢慢被压碎吧……"}]}],"group_41":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_014.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_65","textHome":"呵呵呵，哈，啊哈哈！"}]}],"group_42":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_66","textHome":"超级兴奋，刺激极了……"}]}],"group_43":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":200,"pos":1,"voice":"vo_char_1008_00_02","textHome":"就阿莉娜看来，跟你交流起来还有点意思。@但是距离靠得太近的话是不行的，@在这个前提下请多关照。OK？"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":100800,"motion":400}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":100}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_13","textHome":"啊……呵呵，不错的感觉涌上来了。"}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":100800}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":100800}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":200}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":100,"pos":1,"voice":"vo_char_1008_00_14","textHome":"该去下一个目标了，@要是感到满足的话就end了。"}]}],"group_7":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_15","textHome":"哼……就那么想了解阿莉娜吗？"}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":200}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":100800,"motion":300,"pos":1,"voice":"vo_char_1008_00_16","textHome":"这种feeling，@就像初次遭遇魔女时的感觉……@让人兴致满满。"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp.json","id":100800}]},{"autoTurnFirst":4.0,"chara":[{"id":100800,"motion":100}]}],"group_9":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":100800,"motion":0,"pos":1,"voice":"vo_char_1008_00_17","textHome":"和魔女的接触，颠覆了阿莉娜的人生。@但那也不是坏事，倒不如说是件好事。"}]},{"autoTurnFirst":3.5,"chara":[{"id":100800,"motion":100}]},{"autoTurnFirst":2.5,"chara":[{"face":"mtn_ex_013.exp.json","id":100800}]}]},"version":3}