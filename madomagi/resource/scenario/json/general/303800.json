{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_01","textHome":"我是历史研究部的古町美仓。有关历史的事情@不论什么我都喜欢，特别是神滨的乡土史和@民俗史。啊，我说的是不是民族，而是民俗@。我不想把自己限制在狭义来讲的历史学中@中进行活动，所以没有把部名取为“史学研@究部”"}]},{"autoTurnFirst":2.8,"chara":[{"id":303800,"motion":300}]},{"autoTurnFirst":4.7,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":303800,"motion":0}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":3.0,"chara":[{"id":303800,"motion":100}]}],"group_10":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_17","textHome":"做历史的研究的时候，可以忘掉其他任何事情@一头栽进去。相应的，我也自觉对身边的事@情有些疏忽了"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_18","textHome":"我和吉良还有三穗野走上不同的路的那天，大@概终将会到来…真希望在历史研究部度过的@这段开心的日子能再持续一会儿呀"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":300}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":303800}]}],"group_12":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":300,"pos":1,"voice":"vo_char_3038_00_19","textHome":"试着去理解之后发现其实很简单呢…比起之前@，应该能更好地战斗了"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":2.0,"chara":[{"id":303800,"motion":200}]}],"group_13":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":303800,"motion":101,"pos":1,"voice":"vo_char_3038_00_20","textHome":"之前没做不到的事情，现在能做到了…这就是@所谓的成长呢"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":303800}]}],"group_14":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_21","textHome":"变强对我来说是很开心的哦。变强的话，就能@生存下去，继续研究喜欢的历史，也说不定@能守护吉良和三穗野"}]},{"autoTurnFirst":4.7,"chara":[{"id":303800,"motion":100}]},{"autoTurnFirst":4.3,"chara":[{"id":303800,"motion":200}]}],"group_15":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_22","textHome":"作为魔法少女的成长，也是有好处的。能找到@被埋没的文献，遇到一手史料，让历史的真@实在现代复苏…我好像，拥有这样的魔法的@力量呢"}]},{"autoTurnFirst":5.2,"chara":[{"id":303800,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":303800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":5.2,"chara":[{"id":303800,"motion":100}]}],"group_16":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":400,"pos":1,"voice":"vo_char_3038_00_23","textHome":"这或许，是超越我自身的力量…想必一定有用@这份力量青史留名的魔法少女吧。但是我果@然，比起历史的主角，还是更想做见证历史@的存在啊。"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":2.5,"chara":[{"id":303800,"motion":200}]}],"group_17":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_24","textHome":"今天也请多关照了。话说回来，你也差不多该@想要加入历史研究部了吧？还在犹豫的话，@也欢迎体验入部哦"}]},{"autoTurnFirst":5.5,"chara":[{"id":303800,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"id":303800,"motion":101}]}],"group_18":[{"autoTurnFirst":8.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_25","textHome":"早上好，看起来你醒了呢。正如你所见，我刚@才在阅读文献。因为在意后续，很自然就早@起了。"}]},{"autoTurnFirst":1.7,"chara":[{"id":303800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303800}]}],"group_19":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_26","textHome":"嗯…啊，已经到饭点了？抱歉，我读的太着迷@了…。这是整理了神滨的乡土史的一册书，@里面有着很有意思的记述。你要读读看吗？"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800}]},{"autoTurnFirst":3.5,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":5.9,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":100}]},{"autoTurnFirst":1.6,"chara":[{"id":303800,"motion":200}]}],"group_2":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_02","textHome":"初次见面，我是古町美仓。是历史研究部的部@长…啊，稍等一下！那个！你手里拿着的那@个茶碗让我看看！这是！…只是普通的特产@而已呢"}]},{"autoTurnFirst":1.9,"chara":[{"id":303800,"motion":101}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303800}]},{"autoTurnFirst":2.0,"chara":[{"id":303800,"motion":400}]},{"autoTurnFirst":2.3,"chara":[{"id":303800,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":100,"pos":1,"voice":"vo_char_3038_00_27","textHome":"嗯，社团活动结束之后，接下来就是魔法少女@活动了呢…我家的门限很早，这段时间非常@紧"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303800,"motion":200}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":303800,"motion":300}]}],"group_21":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_28","textHome":"你问我刚才在干什么吗？我在做课堂的预习。@姑且，我还是打算走推荐保送的，所以历史@以外的学习也想好好保证"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800}]},{"autoTurnFirst":3.5,"chara":[{"id":303800,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":303800,"motion":101}]}],"group_22":[{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_29","textHome":"明天要怎么办呢…想去乡土资料馆，巡游墓地@也不错…毕竟说不定能找到意料之外的，名@人之墓之类的呢"}]},{"autoTurnFirst":2.2,"chara":[{"id":303800,"motion":101}]},{"autoTurnFirst":1.3,"chara":[{"eyeClose":1,"id":303800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":2.0,"chara":[{"id":303800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303800,"motion":200}]}],"group_23":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":300,"pos":1,"voice":"vo_char_3038_00_30","textHome":"虽然我还不是很习惯讨伐魔女，一起加油吧。@毕竟作为魔法少女，只有这个是没法偷懒的@呢"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":200}]}],"group_24":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":100,"pos":1,"voice":"vo_char_3038_00_31","textHome":"住在镜子张成的结界的深处的，镜之魔女，吗@…我对魔女虽然不太有兴趣，但对那个洋房@或许有点兴趣。你不觉得造型非常有意思吗@？"}]},{"autoTurnFirst":5.5,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":1}]}],"group_25":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_32","textHome":"大家聚集在一块活动身体，除了体育祭之外没@这种经验呢…从小学的时候开始我就完全是@文化系的。不过，我也会尽我所能加油试试@的"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":303800,"motion":200}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_33","textHome":"我家在神滨市的东边，所以是和吉良一起跨境@上学的。不过父母是出身于神滨的，所以也@没有踏上未知的土地的感觉"}]},{"autoTurnFirst":2.5,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":303800,"motion":100}]}],"group_27":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_34","textHome":"嗯——，果然还是这个路线吗…？我现在在写@论文。我被拜托向一个认识的博物馆研究员@办的杂志投稿…"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":303800}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"id":303800,"motion":100}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_35","textHome":"你问我总是读古代文献会不会腻吗？从没有感@到过不喜欢呢。因为历史的探究，是我毕生@的工作"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"id":303800,"motion":200}]}],"group_29":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":400,"pos":1,"voice":"vo_char_3038_00_36","textHome":"啊，稍等。跟父母打个电话才行。父母虽然允@许我自由行动，但也有过保护的地方…"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":303800}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":400,"pos":1,"soulGem":0,"voice":"vo_char_3038_00_03","textHome":"欸…这个神祠，说不定是…！"}]},{"autoTurnFirst":2.0,"chara":[{"id":303800,"motion":200}]}],"group_30":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_37","textHome":"要学习历史的话，果然大学是最好的地方吧…@乡土史方面则有不少在野的研究者，不必过@分追求升学"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":303800,"motion":100}]}],"group_31":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":200,"pos":1,"voice":"vo_char_3038_00_38","textHome":"我觉得三穗野有朝一日会成为电影监督的哦。@她行动力很强，而且别看她那样，和人交往@时也非常重视细节，总有一天会站在中心驱@动他人的"}]},{"autoTurnFirst":3.8,"chara":[{"id":303800,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"id":303800,"motion":0}]}],"group_32":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_39","textHome":"吉良对他人不太有兴趣，所以我们之间相处不@必有奇怪的顾虑。保持适当的距离感在一起@，会感到轻松呢。吉良也觉得这样很好就是"}]},{"autoTurnFirst":3.8,"chara":[{"id":303800,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"id":303800,"motion":300}]}],"group_33":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303800,"motion":101,"pos":1,"voice":"vo_char_3038_00_40","textHome":"父母的过保护，是从我小时候被卷入一场犯罪@事件开始的。那也是我对历史开始着迷的时@期…现在回想起来，应该是当时想要忘掉那@个事件"}]},{"autoTurnFirst":3.2,"chara":[{"id":303800,"motion":0}]},{"autoTurnFirst":1.5,"chara":[{"id":303800,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":303800}]}],"group_34":[{"autoTurnFirst":2.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_41","textHome":"欸，做什么!?这么认真的…等、脸好近啊！@哇…!?…………欸？眼镜歪了？请不要这@样，真是白让我惊吓了一场"}]},{"autoTurnFirst":2.2,"chara":[{"id":303800,"motion":400}]},{"autoTurnFirst":1.3,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303800}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":0,"id":303800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":303800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":303800}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"id":303800,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":303800}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_42","textHome":"人类，会反复地陷入斗争…"}]}],"group_36":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_43","textHome":"…吸取了教训了吗？"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303800,"motion":200,"pos":1,"voice":"vo_char_3038_00_44","textHome":"胜者决定未来"}]}],"group_38":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":200,"pos":1,"voice":"vo_char_3038_00_45","textHome":"继续探究吗"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":100,"pos":1,"voice":"vo_char_3038_00_46","textHome":"不学历史之人的末路呢"}]}],"group_4":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"soulGem":0,"voice":"vo_char_3038_00_04","textHome":"这是…非常珍贵的一手史料！"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":303800}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_05","textHome":"请多关照，“历史研究部”"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303800}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_13","textHome":"这样子魔力就会增加呢…有意思"}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_14","textHome":"不差的感觉，头脑更清晰了…！"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":303800,"motion":100}]}],"group_8":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":0,"pos":1,"voice":"vo_char_3038_00_15","textHome":"一直以来非常感谢…不是的，我只是觉得偶尔@也该表达一下感谢"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303800,"motion":300}]}],"group_9":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":303800,"motion":1,"pos":1,"voice":"vo_char_3038_00_16","textHome":"我一直都只想做一个观察者。而不是主角。所@以追求保持客观的做学问的世界对我来说最@为舒适"}]},{"autoTurnFirst":3.7,"chara":[{"id":303800,"motion":101}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":303800}]}]},"version":3}